rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Portal público: cualquier visitante puede crear tickets (sin login).
    // No pueden leer, editar ni borrar — solo enviar.
    match /tickets_publicos/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // El resto del CRM requiere autenticación (anónima o real).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
