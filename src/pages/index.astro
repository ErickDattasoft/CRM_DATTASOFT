    const realizado = document.getElementById("form-tk-realizado")?.value.trim() || "";
    const notasInternas = document.getElementById("form-tk-notas-internas")?.value.trim() || "";

    if (!contacto || !asunto || !descripcion) {
      alert("Por favor rellena los campos obligatorios: Contacto, Asunto, Descripción.");
      return;
    }

    if (sistema === "__otro__") {
      const sistemaOtro = (document.getElementById("form-tk-sistema-otro") as HTMLInputElement | null)?.value.trim() || "";
      if (!sistemaOtro) {
        alert("Especifica el nombre del sistema.");
        return;
      }
      sistema = sistemaOtro;
      if (!configTickets.sistemas) configTickets.sistemas = [];
      if (!configTickets.sistemas.some(s => s.toLowerCase() === sistema.toLowerCase())) {
        configTickets.sistemas.push(sistema);
        if (crmLocalOnly) guardarLocal("crm_config_tickets", configTickets);
        else guardarConfigTickets(configTickets).catch(() => {});
      }
    }

    if (idx === "") {
      const num = tickets.length > 0 ? Math.max(...tickets.map(t => t.numero)) + 1 : 1001;
      tickets.push({
        numero: num, asunto, empresa, contacto, contactoCorreo, tipo, sistema, estado, prioridad, grupo, agente,
        descripcion, notasInternas, cc, cco, referido, solicitado, canalizado, realizado,
        adjuntos: [...adjuntosTicketActual],
        fechaCreacion: new Date().toISOString(),
        fechaActualizacion: new Date().toISOString(),
        notas: []
      });
      logBitacora(`Ticket #${num} creado: "${asunto}" — ${empresa || contacto}`, "🎫");

      const enviarCorreo = document.getElementById("chk-enviar-correo")?.checked;
      const mailTo = contactoCorreo || contactos.find(c => c.nombre === contacto)?.correo || "";
      if (enviarCorreo && mailTo) {
        const mailCC = [parseEmailList(configTickets.correoSoporte)[0] || "", cc].filter(Boolean).join(",");
        const mailSubject = `[Ticket #${num}] ${asunto}`;
        const htmlTicket = `
          <h2 style="color:#4f46e5; font-family:sans-serif;">[Ticket #${num}] ${asunto}</h2>
          <table style="border-collapse:collapse; width:100%; font-family:sans-serif; font-size:14px;">
            <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6; width:130px;">Empresa</td><td style="padding:6px 12px;">${empresa}</td></tr>
            <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6;">Contacto</td><td style="padding:6px 12px;">${contacto}</td></tr>
            <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6;">Tipo</td><td style="padding:6px 12px;">${tipo}</td></tr>
            <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6;">Prioridad</td><td style="padding:6px 12px;">${prioridad}</td></tr>
            <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6;">Estado</td><td style="padding:6px 12px;">${estado}</td></tr>
          </table>
          <h3 style="margin-top:16px; font-family:sans-serif;">Descripción</h3>
          <div style="background:#f9fafb; padding:12px; border-radius:6px; font-family:sans-serif; white-space:pre-wrap;">${descripcion.replace(/<[^>]*>/g, "")}</div>
          <hr style="margin-top:24px; border:none; border-top:1px solid #e5e7eb;">
          <p style="font-size:12px; color:#6b7280; font-family:sans-serif;">DATTASOFT BY INFOXPERT — Sistema de Tickets</p>
        `;
        const sent = await enviarEmailConProveedor({ to: mailTo, subject: mailSubject, html: htmlTicket, replyTo: mailCC || "" });
        if (sent?.ok) { toast(`✉️ Notificación enviada a ${mailTo}`); logBitacora(`✉️ Correo enviado a ${mailTo} — Ticket #${num}`, "📧"); }
        else toast(`⚠️ No se pudo enviar: ${sent?.error || "error desconocido"}`, "error");
      } else if (enviarCorreo && !mailTo) {
        toast("⚠️ El contacto no tiene correo registrado", "warning");
      }
    } else {
      const t = tickets[parseInt(idx)];
      const adjuntosExistentes = t.adjuntos || [];
      Object.assign(t, { asunto, empresa, contacto, contactoCorreo, tipo, sistema, estado, prioridad, grupo, agente,
        descripcion, notasInternas, cc, cco, referido, solicitado, canalizado, realizado,
        adjuntos: [...adjuntosExistentes, ...adjuntosTicketActual],
        fechaActualizacion: new Date().toISOString() });
      logBitacora(`Ticket #${t.numero} "${t.asunto}" actualizado a ${estado}${prioridad ? ` · ${prioridad}` : ""}`, "✏️");
    }

    guardarLocal("crm_tickets", tickets);
    if (crmLocalOnly) {
      toast("💾 Ticket guardado (Local)");
      cerrarFormTicket();
      renderTickets();
      renderDashboard();
      return;
    }
    mostrarEstado("💾 Guardando ticket...");
    const ok = await guardarTickets(tickets);
    if (ok) { toast("💾 Ticket guardado"); ocultarEstado(); }
    else { mostrarEstado("⚠️ Guardado localmente (sin conexión)", 3000); }
    cerrarFormTicket();
    renderTickets();
    renderDashboard();
  });

