  const BACKUP_KEY = "crm_ultimo_backup";

  async function descargarBackupCompleto() {
    const backup = {
      version: "2.0",
      app: "CRM DATTASOFT",
      fecha: new Date().toISOString(),
      datos: {
        clientes,
        contactos,
        tickets,
        versionesMercado,
        cartasTecnicas,
        plantillaMensaje,
        configTickets,
        bitacora: bitacoraLog,
        usuarios: safeParseLocal("crm_usuarios", []),
        knowledge_base: kbDocs.length ? kbDocs : safeParseLocal("crm_kb", []),
        papelera,
        acercaDe,
        eventos
      }
    };
    const json = JSON.stringify(backup, null, 2);
    const filename = `crm-backup-${new Date().toISOString().slice(0, 10)}.json`;

    if ("showSaveFilePicker" in window) {
      try {
        const fh = await (window as any).showSaveFilePicker({
          suggestedName: filename,
          types: [{ description: "Backup CRM JSON", accept: { "application/json": [".json"] } }]
        });
        const writable = await fh.createWritable();
        await writable.write(json);
        await writable.close();
      } catch (e: any) {
        if (e?.name === "AbortError") return; // usuario canceló
        // Fallback si falla la API
        const blob = new Blob([json], { type: "application/json" });
        const a = document.createElement("a");
        a.href = URL.createObjectURL(blob); a.download = filename; a.click();
        URL.revokeObjectURL(a.href);
      }
    } else {
      // Fallback para Firefox / Safari / móvil
      const blob = new Blob([json], { type: "application/json" });
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob); a.download = filename; a.click();
      URL.revokeObjectURL(a.href);
    }

    localStorage.setItem(BACKUP_KEY, new Date().toISOString());
    actualizarUIBackup();
    toast("✅ Backup completo guardado");
    logBitacora("Backup completo guardado", "🛡️");
  }

  function actualizarUIBackup() {
    const ultimo = localStorage.getItem(BACKUP_KEY);
    const elUltimo = document.getElementById("backup-ultimo");
    const elFecha = document.getElementById("backup-ultimo-fecha");
    const elAlerta = document.getElementById("backup-alerta");
    const elAlertaMsg = document.getElementById("backup-alerta-msg");
    if (!ultimo) {
      if (elAlerta) { elAlerta.style.display = "block"; if (elAlertaMsg) elAlertaMsg.textContent = "Nunca se ha hecho un backup"; }
      return;
    }
    const dias = Math.floor((Date.now() - new Date(ultimo).getTime()) / 86400000);
    if (elUltimo) { elUltimo.style.display = "block"; }
    if (elFecha) { elFecha.textContent = new Date(ultimo).toLocaleDateString("es-MX", { day:"2-digit", month:"short", year:"numeric", hour:"2-digit", minute:"2-digit" }); }
    if (elAlerta) {
      if (dias >= 7) {
        elAlerta.style.display = "block";
        if (elAlertaMsg) elAlertaMsg.textContent = `Han pasado ${dias} días desde el último backup`;
      } else {
        elAlerta.style.display = "none";
      }
    }
  }

  function checkBackupAlerta() {
    const ultimo = localStorage.getItem(BACKUP_KEY);
    if (!ultimo) return;
