        <div class="dash-charts-grid" style="margin-top:16px;">
          <!-- Tickets por mes -->
          <div class="dash-chart-card">
            <div class="dash-chart-title">📊 Tickets por Mes <span style="font-size:0.7rem;font-weight:400;color:var(--text-muted);">(últimos 6 meses)</span></div>
            <canvas id="chart-tickets-mes" height="160"></canvas>
          </div>
          <!-- Distribución por estado -->
          <div class="dash-chart-card">
            <div class="dash-chart-title">🍩 Tickets por Estado</div>
            <div style="display:flex;align-items:center;justify-content:center;height:200px;">
              <canvas id="chart-estados" style="max-height:200px;max-width:280px;"></canvas>
              <div id="chart-estados-vacio" class="dash-empty-mini" style="display:none;">Sin tickets aún</div>
            </div>
          </div>
          <!-- Licencias por vencer en 90 días -->
          <div class="dash-chart-card">
            <div class="dash-chart-title">📅 Licencias por Vencer <span style="font-size:0.7rem;font-weight:400;color:var(--text-muted);">(próximos 90 días)</span></div>
            <div id="dash-licencias-prox"><div class="dash-empty-mini">Sin licencias próximas a vencer</div></div>
          </div>
          <!-- Tickets sin resolver >5 días -->
          <div class="dash-chart-card">
            <div class="dash-chart-title">⏰ Tickets Abiertos &gt;5 Días</div>
            <div id="dash-tickets-viejos"><div class="dash-empty-mini">No hay tickets abiertos con más de 5 días</div></div>
          </div>
        </div>

        <!-- === CALENDARIO DE EVENTOS Y TAREAS === -->
        <div class="card dash-tareas-card" style="margin-top:16px;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;flex-wrap:wrap;gap:8px;">
            <div class="card-title" style="margin-bottom:0;">📅 Calendario</div>
            <div style="display:flex;gap:6px;align-items:center;">
              <button class="btn btn-ghost btn-xs" id="cal-prev">‹</button>
              <span id="cal-mes-label" style="font-size:0.85rem;font-weight:700;color:var(--text-bright);min-width:130px;text-align:center;"></span>
              <button class="btn btn-ghost btn-xs" id="cal-next">›</button>
            </div>
          </div>
          <div id="dash-calendario"></div>
          <div style="display:flex;gap:14px;margin-top:10px;flex-wrap:wrap;">
            <span style="font-size:0.72rem;color:var(--text-muted);display:flex;align-items:center;gap:5px;"><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#6366f1;"></span>Evento</span>
            <span style="font-size:0.72rem;color:var(--text-muted);display:flex;align-items:center;gap:5px;"><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#f59e0b;"></span>Tarea</span>
            <span style="font-size:0.72rem;color:var(--text-muted);display:flex;align-items:center;gap:5px;"><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#ef4444;"></span>Tarea vencida</span>
          </div>
        </div>

        <!-- === TAREAS PENDIENTES === -->
        <div class="card dash-tareas-card" style="margin-top:16px;" id="dash-card-tareas">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
            <div class="card-title" style="margin-bottom:0;">📌 Tareas Pendientes</div>
            <button class="btn btn-primary btn-xs" id="btnNuevaTareaDash">➕ Nueva Tarea</button>
          </div>
          <div id="dash-tareas-lista"><div class="dash-empty-mini">No hay tareas pendientes</div></div>
        </div>
      </div>

      <!-- ============================== -->
      <!-- SECTION: VERSIONES SISTEMAS   -->
      <!-- ============================== -->
      <div class="section" id="section-versiones">
        <div class="controls-bar" style="margin-bottom:0;">
          <div class="controls-left">
            <h2 style="font-size:1.1rem; font-weight:800; color:var(--text-bright); font-family:var(--font-heading);">🚀 Versiones Oficiales CONTPAQi</h2>
          </div>
          <div class="controls-right">
            <button class="btn btn-ghost btn-sm" id="btnGenerarReporteVersiones" title="Reporte de empresas con sistemas o licencias desactualizadas">📋 Generar reporte</button>
          </div>
        </div>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-top:16px; align-items:start;">
          <div class="card">
            <div class="card-title" style="font-size:0.88rem;">📊 Versiones del Mercado</div>
            <p style="font-size:0.78rem; color:var(--text-muted); margin-bottom:14px;">Registra las versiones oficiales más recientes. El CRM las comparará con las versiones instaladas en cada empresa.</p>
            <div class="market-grid">
              {listaSistemasOpciones.map(sistema => (
                <div class="market-row">
                  <label>{sistema}</label>
                  <div class="market-row-inputs">
                    <input type="text" class="input-version-oficial" data-sistema={sistema} placeholder="Ej: 18.1.0">
                    <span class="version-status status-empty" data-sistema-status={sistema}>Sin versión</span>
                  </div>
                  <input type="text" class="input-carta-tecnica" data-sistema={sistema} placeholder="🔗 Link Carta Técnica" style="font-size:0.72rem; margin-top:2px;">
                </div>
              ))}
            </div>
            <button class="btn btn-success btn-block btn-sm" id="btnGuardarVersiones" style="margin-top:14px;">💾 Guardar Versiones</button>
          </div>

          <div class="card">
            <div class="card-title" style="font-size:0.88rem;">📝 Plantilla de Notificación</div>
            <div class="comodin-list" style="margin-bottom:10px; font-size:0.8rem;">
              • <strong>[contacto]</strong> → Nombre del contacto<br>
              • <strong>[empresa]</strong> → Razón Social<br>
              • <strong>[sistemas_pendientes]</strong> → Lista de sistemas desactualizados
            </div>
            <textarea id="txtPlantillaMensaje" rows="10" style="font-size:0.82rem; resize:vertical;"></textarea>
          </div>
        </div>
      </div>

      <!-- ============================== -->
      <!-- SECTION: EMPRESAS              -->
      <!-- ============================== -->
      <div class="section" id="section-empresas">
        <div>
            <div class="controls-bar">
              <div class="controls-left">
                <div class="search-bar">
                  <input type="text" id="txtBuscar" placeholder="Buscar empresa o contacto...">
                </div>
                <select id="selectFiltroSistema" style="max-width:180px;">
                  <option value="">🎯 Todos los Sistemas</option>
                  {listaSistemasOpciones.map(sistema => <option value={sistema}>{sistema}</option>)}
                </select>
                <button class="btn btn-warning btn-sm" id="btnFiltroFavoritos">☆ Favoritos</button>
                <button class="btn btn-ghost btn-sm" id="btnFiltrosGuardados" title="Filtros Guardados">🔖 Filtros</button>
              </div>
              <div class="controls-right">
                <button class="btn btn-ghost btn-sm" id="btnImportCSVEmpresas">📥 Importar CSV</button>
                <button class="btn btn-ghost btn-sm" id="btnImportXLSEmpresas">📥 Importar Excel</button>
                <input type="file" id="input-import-xls" accept=".xlsx,.xls" style="display:none">
                <button class="btn btn-ghost btn-sm" id="btnExportCSVEmpresas">📤 Exportar CSV</button>
                <button class="btn btn-whatsapp btn-sm" id="btnWspMasivo">📢 WhatsApp (<span class="lblCountSel">0</span>)</button>
                <button class="btn btn-email btn-sm" id="btnMailMasivo">✉️ Email (<span class="lblCountSel">0</span>)</button>
                <button class="btn btn-primary btn-sm" id="btnNuevoEmpresa">➕ Registrar Empresa</button>
              </div>
            </div>

            <!-- Panel Filtros Guardados (oculto) -->
            <div class="filtros-panel hidden" id="panel-filtros-guardados">
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
                <div style="font-size:0.85rem;font-weight:700;color:var(--brand-primary);">🔖 Filtros Guardados</div>
                <button class="btn btn-ghost btn-xs" id="btnCerrarFiltrosPanel">✕ Cerrar</button>
              </div>
              <div id="lista-filtros-guardados" style="margin-bottom:12px;"></div>
              <div style="border-top:1px dashed rgba(255,255,255,0.08);padding-top:12px;">
                <div style="font-size:0.78rem;font-weight:600;color:var(--text-muted);margin-bottom:8px;">💾 Guardar filtro actual como:</div>
                <div style="display:flex;gap:8px;">
                  <input id="filtro-nuevo-nombre" placeholder="Ej: Clientes CONTPAQi Nóminas..." style="font-size:0.82rem;flex:1;">
                  <button class="btn btn-success btn-sm" id="btnGuardarFiltroActual">💾 Guardar</button>
                </div>
                <div style="font-size:0.7rem;color:var(--text-muted);margin-top:6px;">Se guardará: sistema seleccionado + texto buscado + vencimiento en X días (si aplica)</div>
              </div>
            </div>

            <!-- Formulario Empresa (oculto) -->
            <div class="card hidden" id="formulario-empresa" style="border-color: rgba(99,102,241,0.3);">
              <div class="card-title" id="form-emp-titulo">➕ Registrar Empresa</div>
              <input type="hidden" id="edit-emp-index">
              <div class="form-grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px;margin-bottom:14px;">
                <div class="form-group"><label>Empresa <span class="required">*</span></label><input id="form-empresa" required style="text-transform:uppercase;" oninput="this.value=this.value.toUpperCase()"></div>
                <div class="form-group"><label>RFC</label><input id="form-empresa-rfc" placeholder="Ej: XAXX010101000"></div>
              </div>
              <!-- Sección inline de contactos -->
              <div style="border:1px solid rgba(99,102,241,0.25);border-radius:var(--radius-md);padding:12px 14px;margin-bottom:12px;background:rgba(99,102,241,0.04);">
                <div style="font-size:0.8rem;font-weight:700;color:#a5b4fc;margin-bottom:10px;">📇 Contactos de esta empresa</div>
                <div id="form-emp-ct-lista" style="margin-bottom:10px;"></div>
                <!-- Mini-form agregar contacto -->
                <div style="border-top:1px dashed rgba(255,255,255,0.08);padding-top:10px;">
                  <div style="font-size:0.72rem;color:var(--text-muted);margin-bottom:6px;font-weight:600;">➕ Agregar contacto</div>
                  <div style="display:grid;grid-template-columns:2fr 1.5fr 2fr auto;gap:6px;align-items:end;">
                    <div><label style="font-size:0.7rem;color:var(--text-muted);">Nombre *</label><input id="form-ct-inline-nombre" placeholder="Ej: Juan García" style="font-size:0.82rem;"></div>
                    <div><label style="font-size:0.7rem;color:var(--text-muted);">📱 Celular</label><input id="form-ct-inline-tel" placeholder="Ej: 9991234567" style="font-size:0.82rem;"></div>
                    <div><label style="font-size:0.7rem;color:var(--text-muted);">✉️ Correo</label><input id="form-ct-inline-correo" placeholder="Ej: juan@empresa.mx" style="font-size:0.82rem;"></div>
                    <button type="button" class="btn btn-success btn-sm" id="btnAddCtInline" style="height:36px;padding:0 12px;white-space:nowrap;">+ Agregar</button>
                  </div>
                </div>
              </div>
              <div id="form-emp-campos-extra-section" style="border-top:1px dashed rgba(255,255,255,0.06); margin-top:10px; padding-top:12px;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                  <h4 style="font-size:0.85rem; color:var(--brand-secondary); font-family:var(--font-heading);">⚙️ Campos Extra</h4>
                  <button type="button" class="btn btn-ghost btn-xs" id="btnAgregarCampoExtra">➕ Añadir campo</button>
                </div>
                <div id="contenedorCamposExtras" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:10px;"></div>
              </div>
              <div class="form-actions">
                <button class="btn btn-primary" id="btnGuardarEmpresa">💾 Guardar Empresa</button>
                <button class="btn btn-secondary" id="btnCancelarEmpresa">Cancelar</button>
              </div>
            </div>

            <!-- Tarjeta separada: Versiones de Sistemas Instalados -->
            <div class="card hidden" id="formulario-empresa-versiones">
              <div class="card-title">💻 Versiones y Vencimientos de Licencias
                <span style="font-size:0.68rem; font-weight:400; color:var(--text-muted); margin-left:8px;">(se guardan con los datos de empresa · deja vacío si no aplica)</span>
              </div>
              <div class="sys-grid">
                {listaSistemasOpciones.map(sistema => (
                  <div style="background:var(--bg-input); border:1px solid var(--border-color); border-radius:var(--radius-md); padding:10px 10px 8px; display:flex; flex-direction:column; gap:5px;">
                    <div style="font-size:0.72rem; font-weight:700; color:var(--brand-secondary); text-transform:uppercase; letter-spacing:0.03em;">{sistema}</div>
                    <input id={`sys-${sistema.replace(/\s+/g, '_')}`} class="sistema-version-input" data-sistema={sistema} placeholder="Versión (ej: 18.1.0)" style="padding:8px 10px; font-size:0.88rem; font-weight:600; letter-spacing:0.02em;">
                    <div style="display:flex; align-items:center; gap:5px; margin-top:1px;">
                      <span style="font-size:0.6rem; color:#fbbf24; white-space:nowrap; flex-shrink:0;">📅 Vence:</span>
                      <input id={`venc-${sistema.replace(/\s+/g, '_')}`} class="sistema-vencimiento-input" data-sistema={sistema} type="date" style="padding:3px 6px; font-size:0.72rem; color:#fbbf24; border-color:rgba(245,158,11,0.3); flex:1;">
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div id="aviso-sin-versiones" style="display:none; align-items:center; gap:10px; background:rgba(245,158,11,0.1); border:1px solid rgba(245,158,11,0.3); border-radius:8px; padding:10px 14px; margin-bottom:10px; font-size:0.82rem; color:#fbbf24;">
              ⚠️ <strong>Sin versiones oficiales.</strong>&nbsp; Ve a <strong>Versiones Oficiales</strong> (panel izquierdo) y captura la versión actual de cada sistema CONTPAQi (ej: <code style="background:rgba(0,0,0,0.2); padding:1px 5px; border-radius:4px;">18.1.0</code>) para ver los colores de actualización.
            </div>

            <div class="table-wrap" id="table-wrap-empresas">
              <table id="tabla-empresas" style="table-layout:fixed;">
                <thead>
                  <tr>
                    <th style="width:40px; min-width:40px; text-align:center;"><input type="checkbox" id="chkSeleccionarTodo" style="cursor:pointer;"></th>
                    <th class="th-sortable" id="th-sort-emp" style="min-width:130px; width:180px;">Empresa <span class="sort-arrow active" id="sort-arrow-emp">↑</span><div class="col-resize-handle"></div></th>
                    <th style="min-width:160px; width:200px;">Contacto principal<div class="col-resize-handle"></div></th>
                    <th style="min-width:160px; width:200px;">Contacto alternativo<div class="col-resize-handle"></div></th>
                    <th style="min-width:110px; width:130px;">RFC<div class="col-resize-handle"></div></th>
                    <th style="text-align:center; min-width:100px; width:110px;">Acciones</th>
                  </tr>
                </thead>
                <tbody id="tabla-empresas-body"></tbody>
              </table>
            </div>
          </div>
        </div>

      <!-- ============================== -->
      <!-- SECTION: CONTACTOS             -->
      <!-- ============================== -->
      <div class="section" id="section-contactos">
        <div class="controls-bar">
          <div class="controls-left">
            <div class="search-bar">
              <input type="text" id="txtBuscarContacto" placeholder="Buscar contacto...">
            </div>
          </div>
          <div class="controls-right">
            <button class="btn btn-ghost btn-sm" id="btnImportCSVContactos">📥 Importar CSV</button>
            <button class="btn btn-ghost btn-sm" id="btnExportCSVContactos">📤 Exportar CSV</button>
            <button class="btn btn-primary btn-sm" id="btnNuevoContacto">➕ Agregar Contacto</button>
          </div>
        </div>

        <!-- Formulario Contacto (oculto) -->
        <div class="card hidden" id="formulario-contacto" style="border-color: rgba(236,72,153,0.3);">
          <div class="card-title" id="form-ct-titulo">➕ Agregar Contacto</div>
          <input type="hidden" id="edit-ct-index">
          <!-- Empresa (campo principal — como Freshdesk) -->
          <div class="form-group" style="margin-bottom:14px;">
            <label>🏢 Empresa <span class="required">*</span> <span style="font-size:0.7rem;font-weight:400;color:var(--text-muted);">— busca o crea una nueva</span></label>
            <div style="display:flex; gap:8px; align-items:flex-start;">
              <div class="autocomplete-wrap" style="flex:1;">
                <input id="form-ct-empresa-buscar" placeholder="Escribe el nombre de la empresa..." autocomplete="off" style="font-weight:600;">
                <input type="hidden" id="form-ct-empresa">
                <div class="autocomplete-list hidden" id="ct-empresa-autocomplete"></div>
              </div>
              <button type="button" id="btnNuevaEmpresaRapida" class="btn btn-secondary btn-sm" style="white-space:nowrap; margin-top:2px;" title="Crear empresa nueva">🏢 Nueva</button>
            </div>
          </div>
          <!-- Datos del contacto -->
          <div class="form-grid">
            <div class="form-group"><label>Nombre <span class="required">*</span></label><input id="form-ct-nombre" required placeholder="Nombre completo del contacto"></div>
            <div class="form-group"><label>✉️ Correo</label><input id="form-ct-correo" type="email" placeholder="contacto@empresa.mx"></div>
            <div class="form-group"><label>📱 Celular <span style="font-size:0.7rem;font-weight:400;color:var(--text-muted);">(WhatsApp)</span></label><input id="form-ct-tel1" placeholder="Ej: 9991234567"></div>
            <div class="form-group"><label>☎️ Tel. Oficina</label><input id="form-ct-tel2" placeholder="Ej: 9991234567"></div>
          </div>
          <div class="form-actions">
            <button class="btn btn-primary" id="btnGuardarContacto">💾 Guardar Contacto</button>
            <button class="btn btn-secondary" id="btnCancelarContacto">Cancelar</button>
          </div>
        </div>

        <!-- Mini-modal nueva empresa rápida -->
        <div id="modal-empresa-rapida" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:10000; align-items:center; justify-content:center;">
          <div style="background:#1a1e2e; border:1px solid rgba(99,102,241,0.4); border-radius:12px; padding:24px; width:380px; max-width:90vw; box-shadow:0 20px 60px rgba(0,0,0,0.6);">
            <div style="font-size:1rem; font-weight:700; color:#f1f5f9; margin-bottom:6px;">🏢 Nueva Empresa</div>
            <div style="font-size:0.75rem;color:var(--text-muted);margin-bottom:14px;">El correo y teléfono vendrán del contacto que estás registrando.</div>
            <div class="form-group" style="margin-bottom:12px;"><label>Nombre de la Empresa <span class="required">*</span></label><input id="quick-emp-nombre" placeholder="Nombre de la empresa" style="text-transform:uppercase;" oninput="this.value=this.value.toUpperCase()"></div>
            <div class="form-group" style="margin-bottom:16px;"><label>RFC <span style="font-size:0.7rem;font-weight:400;color:var(--text-muted);">(opcional)</span></label><input id="quick-emp-rfc" placeholder="Ej: XAXX010101000"></div>
            <div style="display:flex; gap:8px; justify-content:flex-end;">
              <button class="btn btn-secondary btn-sm" id="btnCancelarEmpresaRapida">Cancelar</button>
              <button class="btn btn-primary btn-sm" id="btnGuardarEmpresaRapida">💾 Crear y Asociar</button>
            </div>
          </div>
        </div>

        <div class="table-wrap" id="table-wrap-contactos">
          <table id="tabla-contactos" style="table-layout: fixed;">
            <thead>
              <tr>
                <th class="th-sortable" id="th-sort-ct" style="width:170px; min-width:130px;">Nombre <span class="sort-arrow active" id="sort-arrow-ct">↑</span><div class="col-resize-handle"></div></th>
                <th style="width:200px; min-width:140px;">🏢 Empresa<div class="col-resize-handle"></div></th>
                <th style="width:200px; min-width:130px;">✉️ Correo<div class="col-resize-handle"></div></th>
                <th style="width:130px; min-width:90px;">📱 Celular<div class="col-resize-handle"></div></th>
                <th style="width:130px; min-width:90px;">☎️ Tel. Oficina<div class="col-resize-handle"></div></th>
                <th style="width:110px; min-width:100px; text-align:center;">Acciones</th>
              </tr>
            </thead>
            <tbody id="tabla-contactos-body"></tbody>
          </table>
        </div>
      </div>

      <!-- ============================== -->
      <!-- SECTION: COTIZACIONES          -->
      <!-- ============================== -->
      <div class="section" id="section-cotizaciones">
        <div class="stats-grid">
          <div class="stat-card stat-total">
            <span class="stat-value" id="cot-count-total">0</span>
            <span class="stat-label">Total Cotizaciones</span>
          </div>
          <div class="stat-card stat-open">
            <span class="stat-value" id="cot-count-activas">0</span>
            <span class="stat-label">Activas</span>
          </div>
          <div class="stat-card stat-resolved">
            <span class="stat-value" id="cot-count-aceptadas">0</span>
            <span class="stat-label">Aceptadas</span>
          </div>
          <div class="stat-card stat-closed">
            <span class="stat-value" id="cot-count-vencidas">0</span>
            <span class="stat-label">Vencidas</span>
          </div>
        </div>

        <div class="controls-bar">
          <div class="controls-left">
            <div class="search-bar">
              <input type="text" id="txtBuscarCotizacion" placeholder="Buscar por empresa o número...">
            </div>
            <select id="selectFiltroEstadoCot" style="max-width:160px;">
              <option value="">🎯 Todos</option>
              <option value="borrador">Borrador</option>
              <option value="enviada">Enviada</option>
              <option value="aceptada">Aceptada</option>
              <option value="rechazada">Rechazada</option>
              <option value="vencida">Vencida</option>
            </select>
          </div>
          <div class="controls-right">
            <button class="btn btn-primary btn-sm" id="btnNuevaCotizacion">➕ Nueva Cotización</button>
          </div>
        </div>

        <!-- Formulario Cotización (oculto) -->
        <div class="card hidden" id="formulario-cotizacion" style="border-color: rgba(99,102,241,0.3);">
          <div class="card-title" id="form-cot-titulo">➕ Nueva Cotización</div>
          <input type="hidden" id="edit-cot-id">

          <!-- Card 1: Emisor -->
          <div class="card" style="margin-bottom:16px;">
            <div class="card-title">🧑‍💼 Emisor</div>
