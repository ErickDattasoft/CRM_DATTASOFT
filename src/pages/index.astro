            ${i.correo ? `<div style="font-size:0.78rem;color:var(--text-muted);">✉️ ${escapeHtml(i.correo)}</div>` : ""}
            ${i.telefono ? `<div style="font-size:0.78rem;color:var(--text-muted);">📞 ${escapeHtml(i.telefono)}</div>` : ""}
            ${i.fuente ? `<div style="font-size:0.72rem;color:var(--brand-primary);margin-top:4px;">📌 ${escapeHtml(i.fuente)}</div>` : ""}
