<script>
import { firebaseEnabled, authListo, sesionEsAnonima, cargarDatosCRM, suscribirCRM, guardarClientes, guardarConfiguracion, guardarPlantilla, guardarTickets, guardarContactos, guardarConfigTickets, cargarTicketsPublicos, eliminarTicketPublico, guardarUsuarios, guardarEventosFB, guardarBitacora, guardarPapelera, guardarAcercaDe, guardarConfigCorreo, guardarConfigN8n, agregarEntradaBitacora, suscribirKB, crearDocKB, actualizarDocKB, actualizarSourcePathKB, eliminarDocKB, guardarKBAcceso, guardarLogo, guardarInteracciones, guardarTareas, guardarFiltrosGuardados, guardarAlertasVencimiento, guardarInscripcionEvento, obtenerInscripcionesEvento, guardarConfigPublica, activarCuentaSegura, iniciarSesionSegura, otorgarAccesoStaff, quitarAccesoStaff, solicitarAcceso, crearSolicitudAcceso, obtenerSolicitudesAcceso, eliminarSolicitudAcceso, cargarConfigPublica, obtenerSiguienteFolioCotizacion, agregarCotizacion, guardarCotizaciones, guardarConfigCotizaciones } from "../data/firebase.js";

// ── Modal confirmación (reemplaza confirm() — funciona en móvil) ──
function confirmar(msg: string, icon = "⚠️"): Promise<boolean> {
  return new Promise(resolve => {
    const overlay = document.getElementById("confirm-modal-overlay");
    const msgEl   = document.getElementById("confirm-modal-msg");
    const iconEl  = document.getElementById("confirm-modal-icon");
    const okBtn   = document.getElementById("confirm-modal-ok");
    const cancelBtn = document.getElementById("confirm-modal-cancel");
    if (!overlay || !msgEl || !okBtn || !cancelBtn) { resolve(confirm(msg)); return; }
    if (iconEl) iconEl.textContent = icon;
    msgEl.textContent = msg;
    overlay.classList.add("open");
    const close = (result: boolean) => {
      overlay.classList.remove("open");
      okBtn.removeEventListener("click", onOk);
      cancelBtn.removeEventListener("click", onCancel);
      overlay.removeEventListener("click", onOutside);
      resolve(result);
    };
    const onOk      = () => close(true);
    const onCancel  = () => close(false);
    const onOutside = (e: Event) => { if (e.target === overlay) close(false); };
    okBtn.addEventListener("click", onOk);
    cancelBtn.addEventListener("click", onCancel);
    overlay.addEventListener("click", onOutside);
  });
}

// ── Multi-user Auth ───────────────────────────────────────────
async function sha256(str: string): Promise<string> {
  const buf = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(str));
  return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, "0")).join("");
}

const SESSION_KEY = "crm_session";
const USUARIOS_KEY = "crm_usuarios";
const PASS_DEFECTO = "Datta2026";
const LOGIN_ATTEMPTS_KEY = "crm_login_attempts";
const MAX_INTENTOS_LOGIN = 5;
const BLOQUEO_LOGIN_MINUTOS = 15;
// Dominio público real del CRM — los links que se comparten (registro a eventos, etc.)
// siempre deben apuntar aquí, nunca a location.origin (que en desarrollo sería localhost).
const URL_PRODUCCION = "https://crm-dattasoft.pages.dev";

interface Usuario { id: string; nombre: string; rol: "admin" | "normal"; passHash: string; activo: boolean; authEmail?: string; seccionesPermitidas?: string[]; }

// Secciones que un admin puede restringir por usuario "normal" desde Configuración → Usuarios.
// Dashboard siempre es visible (es el home). Bitácora ya es admin-only por rol (regla aparte,
// no se toca aquí). SOPORTE (Knowledge Base) ya tiene su propio control de acceso por persona
// gestionado por el propietario (kbAcceso) — mezclarlo aquí crearía dos candados independientes.
const SECCIONES_CONFIGURABLES = [
  { id: "empresas", label: "🏢 Empresas" },
  { id: "contactos", label: "📇 Contactos" },
  { id: "cotizaciones", label: "📋 Cotizaciones" },
  { id: "tickets", label: "🎫 Tickets" },
  { id: "eventos", label: "📅 Eventos" },
  { id: "versiones", label: "🚀 Versiones" },
  { id: "configuracion", label: "⚙️ Configuración" },
  { id: "manual", label: "📖 Manual de Uso" },
];

function getUsuarioActual(): { nombre: string; rol: string } | null {
  try { const s = sessionStorage.getItem(SESSION_KEY); return s ? JSON.parse(s) : null; } catch { return null; }
}
function getUsuarios(): Usuario[] {
  try { return JSON.parse(localStorage.getItem(USUARIOS_KEY) || "[]"); } catch { return []; }
}
function saveUsuariosLocal(u: Usuario[]) { localStorage.setItem(USUARIOS_KEY, JSON.stringify(u)); }

// Deduplica nombres ignorando mayúsculas/minúsculas, conservando la primera forma vista
function dedupeNombres(nombres: string[]): string[] {
  const vistos = new Map<string, string>();
  nombres.forEach(n => {
    if (!n) return;
    const key = n.toLowerCase();
    if (!vistos.has(key)) vistos.set(key, n);
  });
  return [...vistos.values()];
}

// Lista de agentes para tickets: agentes configurados + usuarios reales del sistema (excluye INVITADO)
function getListaAgentes(): string[] {
  const base = (typeof configTickets !== "undefined" && configTickets.agentes) || [];
  const usuariosNombres = getUsuarios().filter(u => u.activo && u.nombre !== "INVITADO").map(u => u.nombre);
  return dedupeNombres([...base, ...usuariosNombres]).sort();
}

async function seedUsuariosDefault(): Promise<Usuario[]> {
  const h = await sha256(PASS_DEFECTO);
  const defaults: Usuario[] = [
    { id: "u1", nombre: "ERICK",    rol: "admin",  passHash: h, activo: true },
    { id: "u2", nombre: "ARTURO",   rol: "admin",  passHash: h, activo: true },
    { id: "u3", nombre: "GABY",     rol: "normal", passHash: h, activo: true },
    { id: "u4", nombre: "GELMI",    rol: "normal", passHash: h, activo: true },
    { id: "u5", nombre: "INVITADO", rol: "normal", passHash: h, activo: true },
  ];
  saveUsuariosLocal(defaults);
  return defaults;
}

let selectedUser: Usuario | null = null;

// ── Protección contra intentos de contraseña ──
// Se guarda por id de usuario en localStorage (no es dato de negocio, es un contador de UI
// de este navegador — no hace falta Firestore para esto).
interface IntentoLogin { fallos: number; bloqueadoHasta: number | null }
function getIntentosLogin(): Record<string, IntentoLogin> {
  try { return JSON.parse(localStorage.getItem(LOGIN_ATTEMPTS_KEY) || "{}"); } catch { return {}; }
}
function saveIntentosLogin(data: Record<string, IntentoLogin>) {
  localStorage.setItem(LOGIN_ATTEMPTS_KEY, JSON.stringify(data));
}
function minutosRestantesBloqueo(usuarioId: string): number {
  const info = getIntentosLogin()[usuarioId];
  if (!info?.bloqueadoHasta) return 0;
  const restanteMs = info.bloqueadoHasta - Date.now();
  return restanteMs > 0 ? Math.ceil(restanteMs / 60000) : 0;
}
function registrarIntentoFallido(usuarioId: string) {
  const data = getIntentosLogin();
  const info = data[usuarioId] || { fallos: 0, bloqueadoHasta: null };
  info.fallos += 1;
  if (info.fallos >= MAX_INTENTOS_LOGIN) {
    info.bloqueadoHasta = Date.now() + BLOQUEO_LOGIN_MINUTOS * 60000;
    info.fallos = 0;
  }
  data[usuarioId] = info;
  saveIntentosLogin(data);
}
function resetIntentosLogin(usuarioId: string) {
  const data = getIntentosLogin();
  if (data[usuarioId]) { delete data[usuarioId]; saveIntentosLogin(data); }
}
function mostrarAvisoBloqueo(usuarioId: string): boolean {
  const lockEl = document.getElementById("login-lockout-warning");
  const btn = document.getElementById("login-btn") as HTMLButtonElement | null;
  const restante = minutosRestantesBloqueo(usuarioId);
  if (restante > 0) {
    if (lockEl) { lockEl.textContent = `🔒 Demasiados intentos. Espera ${restante} minuto${restante === 1 ? "" : "s"}.`; lockEl.classList.add("visible"); }
    if (btn) btn.disabled = true;
    return true;
  }
  if (lockEl) { lockEl.textContent = ""; lockEl.classList.remove("visible"); }
  if (btn) btn.disabled = false;
  return false;
}

async function initLoginUI() {
  let usuarios = getUsuarios();
  if (!usuarios.length) usuarios = await seedUsuariosDefault();
  const activos = usuarios.filter(u => u.activo);
  const grid = document.getElementById("login-user-grid");
  if (!grid) return;
  grid.innerHTML = activos.map(u => `
    <button class="login-user-btn ${u.rol === "admin" ? "login-user-admin" : ""}" data-id="${u.id}">
      <span class="login-user-avatar">${u.nombre[0]}</span>
      <span class="login-user-name">${u.nombre}</span>
      ${u.rol === "admin" ? '<span class="login-user-role">Admin</span>' : ""}
    </button>`).join("");
  grid.querySelectorAll<HTMLButtonElement>(".login-user-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      // Leer usuarios frescos de localStorage (Firebase pudo haberlos actualizado ya)
      const usuariosFrescos = getUsuarios();
      selectedUser = (usuariosFrescos.length ? usuariosFrescos : activos).find(u => u.id === btn.dataset.id) || null;
      if (!selectedUser) return;
      document.getElementById("login-step-user")!.style.display = "none";
      // Usuarios aprobados por el flujo de "Solicitar acceso" nunca tuvieron una contraseña del
      // login viejo (passHash vacío) — mandarlos directo al login seguro, prellenado con su
      // correo, en vez de un campo de contraseña que jamás podría funcionar para ellos.
      if (!selectedUser.passHash && selectedUser.authEmail) {
        document.getElementById("login-step-securo")!.style.display = "block";
        const correoInp = document.getElementById("login-securo-correo") as HTMLInputElement;
        if (correoInp) correoInp.value = selectedUser.authEmail;
        const passInp = document.getElementById("login-securo-pass") as HTMLInputElement;
        if (passInp) { passInp.value = ""; passInp.focus(); }
        return;
      }
      document.getElementById("login-step-pass")!.style.display = "block";
      document.getElementById("login-selected-name")!.textContent = `👤 ${selectedUser.nombre}`;
      const inp = document.getElementById("login-pass-input") as HTMLInputElement;
      if (inp) { inp.value = ""; inp.focus(); }
      mostrarAvisoBloqueo(selectedUser.id);
    });
  });
}

async function intentarLogin() {
  if (!selectedUser) return;
  if (mostrarAvisoBloqueo(selectedUser.id)) return;
  const inp = document.getElementById("login-pass-input") as HTMLInputElement;
  const errEl = document.getElementById("login-error");
  const pass = inp?.value;
  if (!pass) { if (errEl) errEl.textContent = "Ingresa tu contraseña."; return; }
  const hash = await sha256(pass);
  // Re-leer usuario desde localStorage para obtener el hash más reciente (Firebase pudo haberlo actualizado)
  const usuariosActuales = getUsuarios();
  const usuarioActualizado = usuariosActuales.find(u => u.id === selectedUser!.id);
  const hashEsperado = usuarioActualizado?.passHash ?? selectedUser.passHash;
  if (hash !== hashEsperado) {
    registrarIntentoFallido(selectedUser.id);
    if (mostrarAvisoBloqueo(selectedUser.id)) {
      if (errEl) errEl.textContent = "";
    } else if (errEl) {
      errEl.textContent = "Contraseña incorrecta.";
    }
    if (inp) { inp.value = ""; inp.focus(); }
    return;
  }
  resetIntentosLogin(selectedUser.id);
  if (usuarioActualizado) selectedUser = usuarioActualizado;
  sessionStorage.setItem(SESSION_KEY, JSON.stringify({ nombre: selectedUser.nombre, rol: selectedUser.rol }));
  document.getElementById("login-overlay")?.classList.add("hidden");
  if (errEl) errEl.textContent = "";
  // Notificar al IIFE (scope distinto) para que aplique permisos y registre en bitácora
  document.dispatchEvent(new CustomEvent("crm:login", { detail: { nombre: selectedUser.nombre, rol: selectedUser.rol } }));
  iniciarControlInactividad();
}

async function verificarSesion() {
  if (sessionStorage.getItem(SESSION_KEY)) {
    document.getElementById("login-overlay")?.classList.add("hidden");
    iniciarControlInactividad();
  } else {
    await initLoginUI();
  }
  const motivoCierre = sessionStorage.getItem("crm_logout_motivo");
  if (motivoCierre) {
    sessionStorage.removeItem("crm_logout_motivo");
    setTimeout(() => toast(motivoCierre, "warning"), 300);
  }
}

document.getElementById("login-btn")?.addEventListener("click", intentarLogin);
document.getElementById("login-pass-input")?.addEventListener("keydown", e => {
  if ((e as KeyboardEvent).key === "Enter") intentarLogin();
  const warnEl = document.getElementById("login-capslock-warning");
  if (warnEl) warnEl.classList.toggle("visible", (e as KeyboardEvent).getModifierState?.("CapsLock"));
