  // Verificar licencias por vencer al iniciar (por sistema por empresa)
  function checkLicenciasPorVencer() {
    const hoy = new Date(); hoy.setHours(0,0,0,0);
    const vencidas = [];
    const proximas = [];
    clientes.forEach(c => {
      if (!c.VENCIMIENTOS) return;
      Object.entries(c.VENCIMIENTOS).forEach(([sistema, fecha]) => {
        if (!fecha) return;
        const dias = Math.ceil((new Date(fecha + "T00:00:00") - hoy) / 86400000);
        const label = `${c.EMPRESA} – ${sistema}`;
        if (dias < 0) vencidas.push(label);
        else if (dias <= 30) proximas.push(`${label} (${dias}d)`);
      });
    });
    if (vencidas.length > 0)
      setTimeout(() => toast(`🔴 Licencias VENCIDAS: ${vencidas.join(" · ")}`, "error"), 1500);
    if (proximas.length > 0)
      setTimeout(() => toast(`⚠️ Por vencer ≤30d: ${proximas.join(" · ")}`, "warning"), 2800);
  }

