    if (!tareasEmp.length) { lista.innerHTML = '<div class="timeline-empty">Sin tareas para esta empresa.</div>'; return; }
    const hoy = new Date(); hoy.setHours(0,0,0,0);
    lista.innerHTML = tareasEmp.map(t => {
      const fv = t.fechaVencimiento ? new Date(t.fechaVencimiento + "T00:00:00") : null;
      const dias = fv ? Math.ceil((fv.getTime() - hoy.getTime()) / 86400000) : null;
      const cls = dias === null ? "proxima" : dias < 0 ? "vencida" : dias === 0 ? "hoy" : "proxima";
      const fechaCls = dias === null ? "" : dias < 0 ? "tarea-fecha-vencida" : dias === 0 ? "tarea-fecha-hoy" : "tarea-fecha-proxima";
      const fechaTxt = fv ? (dias < 0 ? `⚠️ Venció ${fv.toLocaleDateString("es-MX")}` : dias === 0 ? "🔔 Vence hoy" : `📅 ${fv.toLocaleDateString("es-MX")}`) : "";
