async function intentarLoginSeguro() {
  const correoInp = document.getElementById("login-securo-correo") as HTMLInputElement;
  const passInp = document.getElementById("login-securo-pass") as HTMLInputElement;
  const errEl = document.getElementById("login-securo-error");
  const correo = correoInp?.value.trim().toLowerCase();
  const pass = passInp?.value;
  if (!correo || !pass) { if (errEl) errEl.textContent = "Ingresa correo y contraseña."; return; }

  const btn = document.getElementById("login-securo-btn") as HTMLButtonElement;
  btn.disabled = true; btn.textContent = "Ingresando...";
  const res = await iniciarSesionSegura(correo, pass);
  btn.disabled = false; btn.textContent = "Ingresar →";

  if (!res.ok) {
    if (errEl) errEl.textContent = res.mensaje || "No se pudo iniciar sesión.";
    passInp.value = ""; passInp.focus();
    return;
  }

  // La cuenta de Firebase ya inició sesión — ahora hay que resolver a qué usuario del CRM
  // corresponde (por el correo guardado en usuarios[].authEmail). Se busca primero en la caché
  // local, pero en un dispositivo nuevo (sin caché) eso vendría vacío aunque el login sí haya
  // sido correcto — por eso, si no aparece ahí, se consulta Firestore directo antes de rendirse.
  let usuariosActuales = getUsuarios();
  let usuarioCRM = usuariosActuales.find((u: any) => (u.authEmail || "").toLowerCase() === correo);
  if (!usuarioCRM && firebaseEnabled) {
    try {
      const datos = await cargarDatosCRM();
      if (datos?.usuarios?.length) {
        usuariosActuales = datos.usuarios;
        saveUsuariosLocal(usuariosActuales);
        usuarioCRM = usuariosActuales.find((u: any) => (u.authEmail || "").toLowerCase() === correo);
      }
    } catch { /* se maneja abajo con el mensaje de "no vinculada" */ }
  }
  if (!usuarioCRM) {
    if (errEl) errEl.textContent = "Esta cuenta segura no está vinculada a ningún usuario del CRM. Avísale a un administrador.";
    return;
  }
  if (!usuarioCRM.activo) {
    if (errEl) errEl.textContent = "Tu usuario está desactivado. Avísale a un administrador.";
    return;
  }

  sessionStorage.setItem(SESSION_KEY, JSON.stringify({ nombre: usuarioCRM.nombre, rol: usuarioCRM.rol }));
  document.getElementById("login-overlay")?.classList.add("hidden");
  if (errEl) errEl.textContent = "";
  document.dispatchEvent(new CustomEvent("crm:login", { detail: { nombre: usuarioCRM.nombre, rol: usuarioCRM.rol } }));
  iniciarControlInactividad();
}
