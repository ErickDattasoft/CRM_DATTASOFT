  #confirm-modal-icon { font-size: 2rem; margin-bottom: 10px; }
  #confirm-modal-msg { font-size: 0.95rem; font-weight: 600; color: var(--text-main, #e2e8f0); margin-bottom: 20px; line-height: 1.4; }
