  function crearTicketDesdeCotizacion() {
    const id = editCotId?.value;
    const cot = cotizaciones.find(c => c.id === id);
    if (!cot) return;
    navegarA("tickets");
    cotizacionOrigenParaTicket = cot.id;
    cerrarFormTicket();
    const tituloTk = document.getElementById("form-tk-titulo");
    if (tituloTk) tituloTk.textContent = "➕ Crear Ticket de Soporte";
    initTicketFormDropdowns();
    (document.getElementById("form-tk-empresa") as HTMLInputElement).value = cot.empresaNombre || "";
    (document.getElementById("form-tk-contacto") as HTMLInputElement).value = cot.empresaContacto || "";
    (document.getElementById("form-tk-correo-contacto") as HTMLInputElement).value = cot.empresaCorreo || "";
    (document.getElementById("form-tk-asunto") as HTMLInputElement).value = `Seguimiento a cotización ${cot.numero}`;
    formTk?.classList.remove("hidden");
    formTk?.scrollIntoView({ behavior: "smooth" });
  }
  document.getElementById("btnCrearTicketDesdeCot")?.addEventListener("click", crearTicketDesdeCotizacion);

  document.getElementById("btnVerTicketDeCotizacion")?.addEventListener("click", () => {
    const id = editCotId?.value;
    const cot = cotizaciones.find(c => c.id === id);
    if (!cot?.ticketNumero) return;
    const idx = tickets.findIndex(t => t.numero === cot.ticketNumero);
    if (idx === -1) { toast("⚠️ El ticket vinculado ya no existe", "error"); return; }
    navegarA("tickets");
    mostrarDetalleTicket(idx);
  });

  // ----- PDF -----
  function cargarLogoPDF() {
    try { return localStorage.getItem("crm_logo") || null; } catch { return null; }
  }

  function formatoImagenDesdeDataURI(dataUri: string) {
    if (dataUri.includes("image/jpeg") || dataUri.includes("image/jpg")) return "JPEG";
    if (dataUri.includes("image/webp")) return "WEBP";
    return "PNG";
  }

  function generarPDFCotizacion(cot: any) {
    const { jsPDF } = (window as any).jspdf;
    const doc = new jsPDF({ unit: "mm", format: "letter" });
    const morado: [number, number, number] = [99, 102, 241];
    const grisTexto: [number, number, number] = [71, 85, 105];
    let y = 15;

    const logo = cargarLogoPDF();
    if (logo) {
      try { doc.addImage(logo, formatoImagenDesdeDataURI(logo), 14, y, 30, 16, undefined, "FAST"); } catch (e) { console.warn("[PDF] No se pudo insertar el logo:", e); }
    }

    doc.setFont("helvetica", "bold");
    doc.setFontSize(20);
    doc.setTextColor(...morado);
    doc.text("COTIZACIÓN", 200, y + 8, { align: "right" });
    doc.setFontSize(12);
    doc.setTextColor(...grisTexto);
    doc.text(cot.numero || "", 200, y + 15, { align: "right" });

    y += 26;
    doc.setDrawColor(...morado);
    doc.setLineWidth(0.6);
    doc.line(14, y, 200, y);
    y += 8;

    doc.setFontSize(9);
    doc.setFont("helvetica", "bold");
    doc.setTextColor(...morado);
    doc.text("EMISOR", 14, y);
    doc.text("RECEPTOR", 110, y);
    y += 5;
    doc.setFont("helvetica", "normal");
    doc.setTextColor(30, 30, 30);
    const emisorLineas = [cot.emisorNombre, cot.emisorCargo, cot.emisorTel, cot.emisorCorreo].filter(Boolean);
    const receptorLineas = [cot.empresaNombre, cot.empresaRFC ? `RFC: ${cot.empresaRFC}` : "", cot.empresaContacto, cot.empresaCorreo].filter(Boolean);
    const maxLineas = Math.max(emisorLineas.length, receptorLineas.length);
    for (let i = 0; i < maxLineas; i++) {
      if (emisorLineas[i]) doc.text(String(emisorLineas[i]), 14, y + i * 5, { maxWidth: 88 });
      if (receptorLineas[i]) doc.text(String(receptorLineas[i]), 110, y + i * 5, { maxWidth: 88 });
    }
    y += maxLineas * 5 + 6;

    doc.setFontSize(9);
    doc.setTextColor(...grisTexto);
    doc.text(`Fecha de emisión: ${cot.fechaCreacion ? new Date(cot.fechaCreacion).toLocaleDateString("es-MX") : "—"}`, 14, y);
    doc.text(`Vigencia: ${cot.fechaVigencia ? new Date(cot.fechaVigencia).toLocaleDateString("es-MX") : "—"}`, 110, y);
    y += 8;

    const filasConDescuento: number[] = [];
    const conceptos = cot.conceptos || [];
    const body = conceptos.map((c: any, i: number) => {
      if (Number(c.descuento) > 0) filasConDescuento.push(i);
      const precioTxt = Number(c.descuento) > 0
        ? `${formatMoney(c.precioUnitario)}\n${formatMoney(c.precioUnitario * (1 - c.descuento / 100))}`
        : formatMoney(c.precioUnitario);
      return [
        c.descripcion || "",
        String(c.cantidad ?? 0),
        precioTxt,
        `${c.descuento || 0}%`,
        c.tieneIVA !== false ? "Sí" : "No",
        formatMoney(subtotalLineaConcepto(c)),
      ];
    });

    (doc as any).autoTable({
      startY: y,
      head: [["Descripción", "Cant.", "P. Unit.", "Dto.%", "IVA", "Subtotal"]],
      body,
      theme: "grid",
      headStyles: { fillColor: morado, textColor: 255, fontStyle: "bold" },
      styles: { fontSize: 8.5, cellPadding: 2.2, valign: "middle" },
      columnStyles: { 0: { cellWidth: 70 }, 1: { halign: "center", cellWidth: 15 }, 2: { halign: "right", cellWidth: 28 }, 3: { halign: "center", cellWidth: 16 }, 4: { halign: "center", cellWidth: 12 }, 5: { halign: "right", cellWidth: 25 } },
      didDrawCell: (data: any) => {
        if (data.section !== "body" || data.column.index !== 2) return;
        if (!filasConDescuento.includes(data.row.index)) return;
        const cell = data.cell;
        const original = conceptos[data.row.index];
        const texto = formatMoney(original.precioUnitario);
        const anchoTexto = doc.getTextWidth(texto);
        const xFin = cell.x + cell.width - 2.2;
        const xIni = xFin - anchoTexto;
        const yLinea = cell.y + 4.3;
        doc.setDrawColor(150, 150, 150);
        doc.setLineWidth(0.25);
        doc.line(xIni, yLinea, xFin, yLinea);
      },
    });

    let yFinal = (doc as any).lastAutoTable.finalY + 8;
    const totales = calcularTotalesCotizacion(cot.conceptos);
    doc.setFontSize(9.5);
    doc.setFont("helvetica", "normal");
    doc.setTextColor(...grisTexto);
    doc.text("Subtotal:", 150, yFinal, { align: "right" });
    doc.text(formatMoney(totales.subtotalGeneral), 200, yFinal, { align: "right" });
    yFinal += 6;
    doc.text("IVA (16%):", 150, yFinal, { align: "right" });
    doc.text(formatMoney(totales.totalIVA), 200, yFinal, { align: "right" });
    yFinal += 7;
    doc.setFont("helvetica", "bold");
    doc.setFontSize(13);
    doc.setTextColor(...morado);
    doc.text("TOTAL:", 150, yFinal, { align: "right" });
    doc.text(formatMoney(totales.total), 200, yFinal, { align: "right" });
    yFinal += 12;

    if (cot.notas) {
      const notasLineas = doc.splitTextToSize(cot.notas, 178);
      const cajaAlto = notasLineas.length * 4.5 + 8;
      if (yFinal + cajaAlto > 260) { doc.addPage(); yFinal = 20; }
      doc.setDrawColor(220, 220, 220);
      doc.setFillColor(248, 250, 252);
      doc.rect(14, yFinal, 186, cajaAlto, "FD");
      doc.setFont("helvetica", "bold");
      doc.setFontSize(8.5);
      doc.setTextColor(...grisTexto);
      doc.text("Notas y condiciones:", 18, yFinal + 6);
      doc.setFont("helvetica", "normal");
      doc.setTextColor(60, 60, 60);
      doc.text(notasLineas, 18, yFinal + 11);
    }

    const paginas = doc.getNumberOfPages();
    for (let p = 1; p <= paginas; p++) {
      doc.setPage(p);
      doc.setFontSize(7.5);
      doc.setTextColor(150, 150, 150);
      doc.text(
        `Cotización válida hasta ${cot.fechaVigencia ? new Date(cot.fechaVigencia).toLocaleDateString("es-MX") : "—"} — ${cot.emisorCorreo || ""} — ${cot.emisorTel || ""}`,
        105, 285, { align: "center" }
      );
    }

    return doc;
  }

  function nombreArchivoPDFCotizacion(cot: any) {
    const empresaSlug = (cot.empresaNombre || "cliente").replace(/[^a-zA-Z0-9]+/g, "_").replace(/^_+|_+$/g, "");
    return `${cot.numero || "COT"}_${empresaSlug}.pdf`;
  }

  function descargarPDFCotizacion(cot: any) {
    if (!cot) return;
    const doc = generarPDFCotizacion(cot);
    doc.save(nombreArchivoPDFCotizacion(cot));
  }

  function obtenerPDFCotizacionBase64(cot: any) {
    const doc = generarPDFCotizacion(cot);
    const datauri = doc.output("datauristring");
    return datauri.split(",")[1];
  }

  // ----- Envío por correo -----
  const modalEnviarCot = document.getElementById("modal-enviar-cotizacion");

  function abrirModalEnviarCotizacion(cot: any) {
    if (!cot) return;
    (document.getElementById("modal-cot-mail-id") as HTMLInputElement).value = cot.id;
    (document.getElementById("modal-cot-mail-para") as HTMLInputElement).value = cot.empresaCorreo || "";
    (document.getElementById("modal-cot-mail-asunto") as HTMLInputElement).value = `Cotización ${cot.numero} — DATTASOFT`;
    (document.getElementById("modal-cot-mail-cuerpo") as HTMLTextAreaElement).value =
      `Hola${cot.empresaContacto ? " " + cot.empresaContacto : ""},\n\nAdjuntamos la cotización ${cot.numero} solicitada. Queda vigente hasta el ${cot.fechaVigencia ? new Date(cot.fechaVigencia).toLocaleDateString("es-MX") : "—"}.\n\nQuedamos atentos a tus comentarios.\n\nSaludos,\n${cot.emisorNombre || "Equipo DATTASOFT"}`;
    if (modalEnviarCot) (modalEnviarCot as HTMLElement).style.display = "flex";
  }

  document.getElementById("btnCerrarModalEnviarCot")?.addEventListener("click", () => {
    if (modalEnviarCot) (modalEnviarCot as HTMLElement).style.display = "none";
  });

  document.getElementById("btnEnviarCotizacionCorreo")?.addEventListener("click", async () => {
    const id = (document.getElementById("modal-cot-mail-id") as HTMLInputElement).value;
    const cot = cotizaciones.find(c => c.id === id);
    if (!cot) return;
    const para = (document.getElementById("modal-cot-mail-para") as HTMLInputElement).value.trim();
    if (!para || !para.includes("@")) { toast("⚠️ Ingresa un correo válido"); return; }
    const asunto = (document.getElementById("modal-cot-mail-asunto") as HTMLInputElement).value.trim();
    const cuerpo = (document.getElementById("modal-cot-mail-cuerpo") as HTMLTextAreaElement).value;
    const btn = document.getElementById("btnEnviarCotizacionCorreo") as HTMLButtonElement | null;
    if (btn) { btn.disabled = true; btn.textContent = "Enviando..."; }
    try {
      const pdfBase64 = obtenerPDFCotizacionBase64(cot);
      const res = await enviarEmailConProveedor({
        to: para,
        subject: asunto,
        html: `<div style="font-family:sans-serif; white-space:pre-wrap; line-height:1.6;">${escapeHtml(cuerpo)}</div>`,
        attachment: [{ content: pdfBase64, name: nombreArchivoPDFCotizacion(cot) }],
      });
      if (res.ok) {
        cot.estado = "enviada";
        if (crmLocalOnly) guardarLocal("crm_cotizaciones", cotizaciones); else await guardarCotizaciones(cotizaciones);
        logBitacora(`Cotización ${cot.numero} enviada a ${para}`, "✉️");
        guardarLocal("crm_cotizaciones", cotizaciones);
        if (modalEnviarCot) (modalEnviarCot as HTMLElement).style.display = "none";
        renderCotizaciones();
        renderDashboard();
      }
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = "✉️ Enviar"; }
    }
  });

  // ============================================================
  // TICKETS PÚBLICOS (Portal de Clientes)
  // ============================================================
  let ticketsPublicos = [];

  let _ticketsPubPrevCount = 0;
  async function cargarYMostrarTicketsPub() {
    if (!firebaseEnabled) return;
    try {
      ticketsPublicos = await cargarTicketsPublicos();
    } catch(e) { ticketsPublicos = []; }
    const card = document.getElementById("card-tickets-publicos");
    const countEl = document.getElementById("count-tickets-pub");
    if (card) card.style.display = ticketsPublicos.length > 0 ? "block" : "none";
    if (countEl) countEl.textContent = ticketsPublicos.length;
    // Notificación del navegador cuando llegan tickets nuevos
    if (ticketsPublicos.length > _ticketsPubPrevCount && _ticketsPubPrevCount >= 0) {
      const nuevos = ticketsPublicos.length - _ticketsPubPrevCount;
      if ("Notification" in window && Notification.permission === "granted") {
        new Notification("🎫 Ticket nuevo del Portal", {
          body: `${nuevos} solicitud(es) de clientes esperan ser revisadas`,
          icon: "/favicon.ico",
          tag: "ticket-pub"
        });
      }
    }
    _ticketsPubPrevCount = ticketsPublicos.length;
  }

  // Abre el formulario real de "Nueva Empresa" (o "Nuevo Contacto") precargado con los datos
  // del ticket público, pero SIN guardar nada — el usuario revisa/edita/completa (RFC, etc.)
  // y guarda con el botón normal del formulario. No se crea nada de forma silenciosa.
  function abrirNuevaEmpresaDesdeTicketPub(tp) {
    const modal = document.getElementById("modal-tickets-pub");
    if (modal) modal.style.display = "none";
    navegarA("empresas");
    (document.getElementById("btnNuevoEmpresa") as HTMLButtonElement)?.click();
    (document.getElementById("form-empresa") as HTMLInputElement).value = tp.empresa || "";
    if (tp.contacto) {
      formContactosTemp.push({ nombre: tp.contacto, telefono1: tp.telefono || "", correo: tp.contactoCorreo || "", telefono2: "", empresa: "" });
      renderFormContactos();
    }
    const titulo = document.getElementById("form-emp-titulo");
    if (titulo) titulo.textContent = "➕ Registrar Empresa (datos del ticket del portal — revisa antes de guardar)";
    document.getElementById("formulario-empresa")?.scrollIntoView({ behavior: "smooth" });
  }

  function abrirNuevoContactoDesdeTicketPub(tp) {
    const modal = document.getElementById("modal-tickets-pub");
    if (modal) modal.style.display = "none";
    navegarA("contactos");
    (document.getElementById("btnNuevoContacto") as HTMLButtonElement)?.click();
    (document.getElementById("form-ct-nombre") as HTMLInputElement).value = tp.contacto || "";
    (document.getElementById("form-ct-correo") as HTMLInputElement).value = tp.contactoCorreo || "";
    (document.getElementById("form-ct-tel1") as HTMLInputElement).value = tp.telefono || "";
    setEmpresaContacto(tp.empresa || "");
    const titulo = document.getElementById("form-ct-titulo");
    if (titulo) titulo.textContent = "➕ Agregar Contacto (datos del ticket del portal — revisa antes de guardar)";
    document.getElementById("formulario-contacto")?.scrollIntoView({ behavior: "smooth" });
  }

  function renderTicketsPub() {
    const cont = document.getElementById("lista-tickets-pub");
    if (!cont) return;
    if (!ticketsPublicos.length) {
      cont.innerHTML = '<div style="text-align:center; color:var(--text-muted); padding:24px;">No hay tickets públicos pendientes.</div>';
      return;
    }
    cont.innerHTML = "";
    ticketsPublicos.forEach((t, i) => {
      const div = document.createElement("div");
      div.style.cssText = "background:var(--bg-input); border:1px solid var(--border-color); border-radius:var(--radius-md); padding:14px 16px;";
      // ¿La empresa/contacto del ticket ya existen en la base de datos? Si no, se ofrece un
      // botón que abre el formulario correspondiente PRELLENADO con los datos del ticket —
      // sin guardar nada solo — para que se pueda revisar/editar/completar (RFC, etc.) antes
      // de darle al botón real de Guardar del formulario.
      const empExistente = t.empresa ? clientes.find((c: any) => (c.EMPRESA || "").toLowerCase() === t.empresa.toLowerCase()) : null;
      const ctExistente = (t.contacto && (empExistente || t.empresa))
        ? contactos.find((c: any) => (c.nombre || "").toLowerCase() === t.contacto.toLowerCase() && (c.empresa || "").toLowerCase() === (t.empresa || "").toLowerCase())
        : null;
      let bloqueAltaCliente = "";
      if (!empExistente && t.empresa) {
        bloqueAltaCliente = `<button type="button" class="btn btn-ghost btn-xs btn-alta-empresa-pub" data-i="${i}" style="margin-top:8px;">🏢 Agregar empresa${t.contacto ? " y contacto" : ""} a la base de datos…</button>`;
      } else if (!ctExistente && t.contacto && t.empresa) {
        bloqueAltaCliente = `<button type="button" class="btn btn-ghost btn-xs btn-alta-contacto-pub" data-i="${i}" style="margin-top:8px;">👤 Agregar contacto a ${escapeHtml(t.empresa)}…</button>`;
      }
      div.innerHTML = `
        <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:10px; flex-wrap:wrap;">
          <div style="flex:1; min-width:200px;">
            <div style="font-weight:700; color:var(--text-bright); margin-bottom:4px;">${escapeHtml(t.asunto) || "Sin asunto"}</div>
            <div style="font-size:0.78rem; color:var(--text-muted);">
              👤 ${escapeHtml(t.contacto) || "—"} · 🏢 ${escapeHtml(t.empresa) || "—"} · ✉️ ${escapeHtml(t.contactoCorreo) || "—"}
              ${t.telefono ? ` · 📞 ${escapeHtml(t.telefono)}` : ""}
              ${t.sistema ? ` · 💻 ${escapeHtml(t.sistema)}` : ""}
              ${t.tipo ? ` · 🏷️ ${escapeHtml(t.tipo)}` : ""}
            </div>
            <div style="font-size:0.78rem; color:var(--text-muted); margin-top:4px;">⚡ Prioridad: <strong>${escapeHtml(t.prioridad) || "Media"}</strong> · 📅 ${t.fechaCreacion ? new Date(t.fechaCreacion).toLocaleString('es-MX') : "—"}</div>
            <div style="margin-top:8px; font-size:0.82rem; background:var(--bg-card); padding:10px 12px; border-radius:var(--radius-sm); border-left:3px solid var(--brand-warning); color:var(--text-main);">${escapeHtml(t.descripcion).replace(/\n/g,"<br>")}</div>
            ${(t.adjuntos && t.adjuntos.length > 0) ? `<div style="display:flex; flex-wrap:wrap; gap:6px; margin-top:8px;">${t.adjuntos.map((a: any) => `<a href="${a.data}" target="_blank" title="${escapeHtml(a.nombre)}"><img src="${a.data}" style="width:60px; height:60px; object-fit:cover; border-radius:6px; border:1px solid var(--border-color); cursor:pointer;"></a>`).join("")}</div>` : ""}
            ${bloqueAltaCliente}
          </div>
          <div style="display:flex; flex-direction:column; gap:6px; flex-shrink:0;">
            <button class="btn btn-success btn-xs btn-aceptar-pub" data-i="${i}" style="white-space:nowrap;">✅ Aceptar ticket</button>
            <button class="btn btn-danger btn-xs btn-rechazar-pub" data-i="${i}" style="white-space:nowrap;">🗑️ Rechazar</button>
          </div>
        </div>`;
      div.querySelector(".btn-aceptar-pub").addEventListener("click", async (e) => {
        const idx = parseInt(e.target.dataset.i);
        const tp = ticketsPublicos[idx];
        const num = tickets.length > 0 ? Math.max(...tickets.map(x => x.numero)) + 1 : 1001;
        const nuevoTicketPub = {
          numero: num,
          asunto: tp.asunto || "Sin asunto",
          empresa: tp.empresa || "",
          contacto: tp.contacto || "",
          contactoCorreo: tp.contactoCorreo || "",
          tipo: tp.tipo || "General",
          sistema: tp.sistema || "No aplica",
          estado: "Abierto",
          prioridad: tp.prioridad || "Media",
          grupo: "", agente: "",
          descripcion: (tp.descripcion || "").replace(/\n/g, "<br>"),
          solicitado: "", canalizado: "",
          adjuntos: tp.adjuntos || [],
          actividad: [],
          fechaCreacion: tp.fechaCreacion || new Date().toISOString(),
          fechaActualizacion: new Date().toISOString()
        };
        tickets.push(nuevoTicketPub);
        registrarActividadTicket(nuevoTicketPub, `Ticket aceptado desde el portal público (folio original: ${tp.folioPub || "—"})`);
        // El portal público (ticket-publico.astro) no tiene acceso a agenda/datos (ahí viven las
        // API keys de WhatsApp) por las reglas de Firestore, así que el evento se dispara aquí,
        // al aceptarlo dentro del CRM — es el primer punto donde config.n8n está disponible.
        dispararN8n("ticket_creado_cliente", datosEventoTicket(nuevoTicketPub));

        guardarLocal("crm_tickets", tickets);
        if (!crmLocalOnly) await guardarTickets(tickets);
        if (tp._fbId) await eliminarTicketPublico(tp._fbId).catch(() => {});
        ticketsPublicos.splice(idx, 1);
        logBitacora(`Ticket público aceptado como #${num}: "${tp.asunto}"`, "🌐");
        toast(`✅ Ticket #${num} creado desde portal público`);
        await cargarYMostrarTicketsPub();
        renderTicketsPub();
        renderTickets();
        renderDashboard();
      });
      div.querySelector(".btn-rechazar-pub").addEventListener("click", async (e) => {
        const idx = parseInt(e.target.dataset.i);
        const tp = ticketsPublicos[idx];
        if (!await confirmar(`¿Rechazar el ticket "${tp.asunto}"? Se eliminará del portal.`, "🗑️")) return;
        if (tp._fbId) await eliminarTicketPublico(tp._fbId).catch(() => {});
        ticketsPublicos.splice(idx, 1);
        logBitacora(`Ticket público rechazado: "${tp.asunto}"`, "🗑️");
        toast("🗑️ Ticket rechazado");
        await cargarYMostrarTicketsPub();
        renderTicketsPub();
      });
      div.querySelector(".btn-alta-empresa-pub")?.addEventListener("click", (e) => {
        const idx = parseInt((e.target as HTMLElement).dataset.i);
        abrirNuevaEmpresaDesdeTicketPub(ticketsPublicos[idx]);
      });
      div.querySelector(".btn-alta-contacto-pub")?.addEventListener("click", (e) => {
        const idx = parseInt((e.target as HTMLElement).dataset.i);
        abrirNuevoContactoDesdeTicketPub(ticketsPublicos[idx]);
      });
      cont.appendChild(div);
    });
  }

  document.getElementById("btnRevisarTicketsPub")?.addEventListener("click", () => {
    renderTicketsPub();
    const m = document.getElementById("modal-tickets-pub");
    if (m) m.style.display = "flex";
  });
  document.getElementById("btnCerrarTicketsPub")?.addEventListener("click", () => {
    const m = document.getElementById("modal-tickets-pub");
    if (m) m.style.display = "none";
  });
  document.getElementById("modal-tickets-pub")?.addEventListener("click", e => {
    if (e.target === document.getElementById("modal-tickets-pub")) document.getElementById("modal-tickets-pub").style.display = "none";
  });

  // ============================================================
  // EVENTOS
  // ============================================================
  let eventos = JSON.parse(localStorage.getItem("crm_eventos") || "[]");
  let eventoActivoId = null;

  function guardarEventos() {
    localStorage.setItem("crm_eventos", JSON.stringify(eventos));
    if (!crmLocalOnly && firebaseEnabled) { guardarEventosFB(eventos); sincronizarConfigPublica(); }
  }

  function getEventoActivo() { return eventos.find(e => e.id === eventoActivoId) || null; }

  function calcularStatsEvento(ev) {
    const todos = [...(ev.empresas || []), ...(ev.extras || [])];
    return {
      invitados: todos.filter(x => x.invitado).length,
      asistira: todos.filter(x => x.respuesta === "ASISTIRA").length,
      no: todos.filter(x => x.respuesta === "NO_ASISTIRA").length,
      noloc: todos.filter(x => x.respuesta === "NO_LOCALIZADO").length,
      pendiente: todos.filter(x => !x.respuesta || x.respuesta === "PENDIENTE").length,
    };
  }

  function renderSelectEventos() {
    const sel = document.getElementById("selectEventoActivo");
    if (!sel) return;
    const prev = sel.value;
    sel.innerHTML = '<option value="">— Selecciona un evento —</option>';
    eventos.forEach(ev => {
      const opt = document.createElement("option");
      opt.value = ev.id;
      opt.textContent = `${ev.nombre}${ev.fecha ? " · " + new Date(ev.fecha + "T00:00:00").toLocaleDateString("es-MX", { day:"2-digit", month:"short", year:"numeric" }) : ""}`;
      sel.appendChild(opt);
    });
    if (prev && eventos.find(e => e.id === prev)) sel.value = prev;
    else sel.value = "";
  }

  function mostrarPanelEvento(ev) {
    document.getElementById("ev-empty").style.display = "none";
    document.getElementById("panel-evento").style.display = "block";
    document.getElementById("btnEliminarEvento").style.display = "inline-flex";
    document.getElementById("btnLinkRegistroEvento").style.display = "inline-flex";
    document.getElementById("btnVerInscripciones").style.display = "inline-flex";
    // Contar inscritos async
    obtenerInscripcionesEvento(ev.id).then(list => {
      const badge = document.getElementById("badge-inscritos");
      if (badge) badge.textContent = list.length;
    }).catch(() => {});

    document.getElementById("ev-nombre-display").textContent = ev.nombre || "—";
    const sistEl = document.getElementById("ev-sistema-display");
    sistEl.textContent = ev.sistema ? `📦 ${ev.sistema}` : "";
    const fechaEl = document.getElementById("ev-fecha-display");
    fechaEl.textContent = ev.fecha ? `📅 ${new Date(ev.fecha + "T00:00:00").toLocaleDateString("es-MX", { weekday:"long", day:"2-digit", month:"long", year:"numeric" })}${ev.hora ? " · " + ev.hora : ""}` : "";
    const linkEl = document.getElementById("ev-link-display");
    if (ev.link) { linkEl.href = ev.link; linkEl.style.display = "inline"; }
    else linkEl.style.display = "none";
    const notasEl = document.getElementById("ev-notas-display");
    if (ev.notas) { notasEl.textContent = ev.notas; notasEl.style.display = "block"; }
    else notasEl.style.display = "none";

    const s = calcularStatsEvento(ev);
    document.getElementById("ev-stat-invitados").textContent = s.invitados;
    document.getElementById("ev-stat-asistira").textContent = s.asistira;
    document.getElementById("ev-stat-no").textContent = s.no;
    document.getElementById("ev-stat-noloc").textContent = s.noloc;
    document.getElementById("ev-stat-pendiente").textContent = s.pendiente;

    renderTablaEmpresasEvento(ev);
    renderTablaExtrasEvento(ev);
  }

  function ocultarPanelEvento() {
    document.getElementById("panel-evento").style.display = "none";
    document.getElementById("btnEliminarEvento").style.display = "none";
    document.getElementById("btnLinkRegistroEvento").style.display = "none";
    document.getElementById("btnVerInscripciones").style.display = "none";
    const hayEventos = eventos.length > 0;
    document.getElementById("ev-empty").style.display = hayEventos ? "none" : "block";
  }

  document.getElementById("btnCerrarInscritos")?.addEventListener("click", () => {
    document.getElementById("modal-inscritos").style.display = "none";
  });
  document.getElementById("modal-inscritos")?.addEventListener("click", e => {
    if (e.target === document.getElementById("modal-inscritos")) document.getElementById("modal-inscritos").style.display = "none";
  });

  function getHistorialEmpresaEventos(nombreEmpresa, excludeId) {
    const historial = [];
    eventos.forEach(ev => {
      if (ev.id === excludeId) return;
      const found = (ev.empresas || []).find(e => e.nombre === nombreEmpresa);
      if (found && found.invitado) {
        historial.push({ nombre: ev.nombre, fecha: ev.fecha, tema: ev.tema || ev.sistema || "", respuesta: found.respuesta });
      }
    });
    return historial;
  }

  function renderTablaEmpresasEvento(ev) {
    const tbody = document.getElementById("ev-tabla-empresas");
    if (!tbody) return;
    const empresas = ev.empresas || [];
    if (!empresas.length) {
      tbody.innerHTML = '<tr><td colspan="7" style="text-align:center; color:var(--text-muted); padding:20px; font-style:italic;">Sin empresas. Usa el buscador para agregar.</td></tr>';
      return;
    }
    tbody.innerHTML = "";
    empresas.forEach((emp, i) => {
      const tr = document.createElement("tr");
      const respOpts = ["PENDIENTE", "ASISTIRA", "NO_ASISTIRA", "NO_LOCALIZADO"];
      const respLabels = { PENDIENTE: "Pendiente", ASISTIRA: "✅ Asistirá", NO_ASISTIRA: "❌ No Asistirá", NO_LOCALIZADO: "📵 No Localizado" };
      const selOpts = respOpts.map(r => `<option value="${r}" ${emp.respuesta === r ? "selected" : ""}>${respLabels[r]}</option>`).join("");
      const historial = getHistorialEmpresaEventos(emp.nombre, ev.id);
      const asistidos = historial.filter(h => h.respuesta === "ASISTIRA");
      const historialTip = historial.length
        ? historial.map(h => `${h.respuesta === "ASISTIRA" ? "✅" : h.respuesta === "NO_ASISTIRA" ? "❌" : "📵"} ${h.nombre}${h.fecha ? " ("+h.fecha+")" : ""}${h.tema ? " — "+h.tema : ""}`).join("\n")
        : "";
      const historialBadge = historial.length
        ? `<span title="${historialTip}" style="cursor:help; font-size:0.68rem; padding:2px 6px; border-radius:999px; background:${asistidos.length ? "rgba(16,185,129,0.15)" : "rgba(100,116,139,0.15)"}; color:${asistidos.length ? "#34d399" : "#94a3b8"}; white-space:nowrap;">📋 ${historial.length} evento${historial.length>1?"s":""}${asistidos.length ? " · ✅"+asistidos.length : ""}</span>`
        : `<span style="font-size:0.65rem; color:var(--text-muted);">—</span>`;
      const INV_POR_OPTS = ["ERICK","ARTURO","GELMI","GABY","Otro"];
      const invPorVal = INV_POR_OPTS.includes(emp.invitadoPor) ? emp.invitadoPor : (emp.invitadoPor && emp.invitadoPor !== "" ? "Otro" : "");
      const invPorManual = invPorVal === "Otro" ? (emp.invitadoPorManual || emp.invitadoPor || "") : (emp.invitadoPorManual || "");
      const invPorSelOpts = ['<option value="">—</option>', ...INV_POR_OPTS.map(n => `<option value="${n}" ${invPorVal === n ? "selected" : ""}>${n}</option>`)].join("");
      tr.innerHTML = `
        <td style="font-weight:600; font-size:0.85rem;">${emp.nombre}<br><span style="font-size:0.68rem; font-weight:400;">${historialBadge}</span></td>
        <td><input class="ev-emp-sistema" data-idx="${i}" value="${emp.sistema || ""}" placeholder="Sistema/área" style="font-size:0.78rem; padding:4px 8px; width:100%;"></td>
