  function renderNotasTicket(t) {
    const cont = document.getElementById("det-tk-notas");
    if (!cont) return;
    cont.innerHTML = "";
    const notas = t.notas || [];
    if (notas.length === 0) {
      cont.innerHTML = '<div style="text-align:center; color:var(--text-light); font-size:0.8rem; padding:14px;">Sin notas de seguimiento.</div>';
      return;
    }
    notas.forEach(n => {
      const div = document.createElement("div");
      div.className = "note-item";
      div.innerHTML = `
        <div class="note-meta">
          <strong>👤 ${n.autor || "Soporte"}</strong>
          <span>📅 ${new Date(n.fecha).toLocaleString()}</span>
        </div>
        <div style="line-height:1.5; white-space:pre-wrap;">${n.texto}</div>
      `;
      cont.appendChild(div);
    });
    cont.scrollTop = cont.scrollHeight;
  }

  document.getElementById("btnCerrarDetalle")?.addEventListener("click", () => {
    if (modalDetalle) modalDetalle.style.display = "none";
    ticketDetalleIdx = null;
    document.getElementById("txtNuevaNotaTicket").value = "";
  });

  document.getElementById("btnAgregarNotaTicket")?.addEventListener("click", async () => {
    if (ticketDetalleIdx === null) return;
    const txt = document.getElementById("txtNuevaNotaTicket").value.trim();
    const nuevoEstado = document.getElementById("selectCambiarEstadoDetalle")?.value;
    const t = tickets[ticketDetalleIdx];

    if (!txt && nuevoEstado === t.estado) {
      alert("Escribe una nota o cambia el estado.");
      return;
    }

    if (txt) {
      if (!t.notas) t.notas = [];
      t.notas.push({ autor: "Soporte", fecha: new Date().toISOString(), texto: txt });
      document.getElementById("txtNuevaNotaTicket").value = "";
    }

    if (nuevoEstado && nuevoEstado !== t.estado) {
      if (!t.notas) t.notas = [];
      t.notas.push({ autor: "Sistema", fecha: new Date().toISOString(), texto: `Estado cambiado: "${t.estado}" → "${nuevoEstado}"` });
      t.estado = nuevoEstado;
      document.getElementById("det-tk-estado-badge").textContent = nuevoEstado;
      document.getElementById("det-tk-estado-badge").className = `badge badge-${nuevoEstado.toLowerCase()}`;
    }

    t.fechaActualizacion = new Date().toISOString();
    guardarLocal("crm_tickets", tickets);
    if (crmLocalOnly) {
      toast("💬 Nota agregada (Local)");
      renderNotasTicket(t);
      renderTickets();
      renderDashboard();
      return;
    }
    mostrarEstado("💬 Posteando...");
    const ok = await guardarTickets(tickets);
    if (ok) { toast("💬 Nota agregada"); ocultarEstado(); }
    else { mostrarEstado("⚠️ Guardado localmente (sin conexión)", 2000); }
    renderNotasTicket(t);
    renderTickets();
    renderDashboard();
  });

