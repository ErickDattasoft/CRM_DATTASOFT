        // partiendo de "todas marcadas", para que el resto no se desmarque solo.
        let actuales = Array.isArray(u.seccionesPermitidas) ? [...u.seccionesPermitidas] : SECCIONES_CONFIGURABLES.map(s => s.id);
        actuales = chk.checked ? [...new Set([...actuales, seccion])] : actuales.filter(s => s !== seccion);
