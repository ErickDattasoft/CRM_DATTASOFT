const INACTIVIDAD_LIMITE_MS = 8 * 60 * 60 * 1000; // 8 horas
let _inactividadTimer: ReturnType<typeof setTimeout> | null = null;
function cerrarSesionPorInactividad() {
  sessionStorage.setItem("crm_logout_motivo", "Sesión cerrada por inactividad.");
  sessionStorage.removeItem(SESSION_KEY);
  location.reload();
}
function resetTimerInactividad() {
  if (_inactividadTimer) clearTimeout(_inactividadTimer);
  _inactividadTimer = setTimeout(cerrarSesionPorInactividad, INACTIVIDAD_LIMITE_MS);
}
function iniciarControlInactividad() {
  resetTimerInactividad();
  ["mousemove", "mousedown", "click", "keydown", "scroll", "touchstart"].forEach(evt => {
    document.addEventListener(evt, resetTimerInactividad, { passive: true });
  });
}
function detenerControlInactividad() {
  if (_inactividadTimer) clearTimeout(_inactividadTimer);
  _inactividadTimer = null;
  ["mousemove", "mousedown", "click", "keydown", "scroll", "touchstart"].forEach(evt => {
    document.removeEventListener(evt, resetTimerInactividad);
  });
}

