    populateSelectOptions("form-tk-prioridad", configTickets.prioridades, ticket?.prioridad || "Media");
    populateSelectOptions("form-tk-grupo", configTickets.grupos, ticket?.grupo || configTickets.grupos[0]);
    populateSelectOptions("form-tk-agente", ["", ...configTickets.agentes], ticket?.agente || "");

