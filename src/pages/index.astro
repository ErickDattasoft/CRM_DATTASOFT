    font-family: inherit; outline: none; margin-bottom: 10px; text-align: center;
  }
  #login-securo-correo:focus, #login-securo-pass:focus,
  #login-sol-nombre:focus, #login-sol-correo:focus, #login-sol-pass1:focus, #login-sol-pass2:focus { border-color: #6366f1; }
  #login-error, #login-securo-error, #login-sol-error { font-size: 0.8rem; color: #f87171; min-height: 20px; margin-bottom: 8px; }
