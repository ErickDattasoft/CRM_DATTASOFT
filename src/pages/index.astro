  function processCSV(file) {
    const reader = new FileReader();
    reader.onload = e => {
      const text = e.target.result;
      const lines = text.split(/\r?\n/).filter(l => l.trim());
      if (lines.length < 2) return alert("CSV vacío.");

      const delimiter = lines[0].includes(";") ? ";" : ",";
      const headers = lines[0].replace(/^\uFEFF/, "").split(delimiter).map(h => h.trim().replace(/^"|"$/g, "")).map(h => h.toUpperCase());
      const rows = [];
      for (let i = 1; i < lines.length; i++) {
        const vals = lines[i].split(",").map(v => v.trim().replace(/^"|"$/g, ""));
        const obj = {};
        headers.forEach((h, j) => { obj[h] = vals[j] || ""; });
        rows.push(obj);
      }

      csvParsedData = rows;
      document.getElementById("import-csv-count").textContent = rows.length;

      // Render preview
      const thead = document.getElementById("import-csv-thead");
      const tbody = document.getElementById("import-csv-tbody");
      thead.innerHTML = `<tr>${headers.map(h => `<th>${h}</th>`).join("")}</tr>`;
      tbody.innerHTML = "";
      rows.slice(0, 10).forEach(row => {
        const tr = document.createElement("tr");
        tr.innerHTML = headers.map(h => `<td>${row[h] || ""}</td>`).join("");
        tbody.appendChild(tr);
      });
      document.getElementById("import-csv-preview")?.classList.remove("hidden");
    };
    // Leer primero como binario para detectar encoding Windows-1252 (Excel) vs UTF-8
    const sniff = new FileReader();
    sniff.onload = ev => {
      const bytes = new Uint8Array(ev.target.result.slice(0, 4));
      // BOM UTF-8: EF BB BF — si está presente, es UTF-8 seguro
      const enc = (bytes[0] === 0xEF && bytes[1] === 0xBB && bytes[2] === 0xBF)
        ? 'UTF-8' : 'windows-1252';
      reader.readAsText(file, enc);
    };
    sniff.readAsArrayBuffer(file);
  }

