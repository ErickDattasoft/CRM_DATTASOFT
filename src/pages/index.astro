    obtenerInscripcionesEvento(ev.id).then(list => {
      const badge = document.getElementById("badge-inscritos");
      if (badge) badge.textContent = list.length;
    }).catch(() => {});

    document.getElementById("ev-nombre-display").textContent = ev.nombre || "—";
