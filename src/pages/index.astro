  .login-user-name { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.04em; }
  .login-user-role { font-size: 0.6rem; color: #818cf8; font-weight: 600; background: rgba(99,102,241,0.15); padding: 1px 5px; border-radius: 3px; }
  #login-selected-name { font-size:0.95rem; font-weight:700; color:#e2e8f0; margin-bottom:14px; }

