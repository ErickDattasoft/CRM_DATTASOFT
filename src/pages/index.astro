async function intentarSolicitarAcceso() {
  const nombreInp = document.getElementById("login-sol-nombre") as HTMLInputElement;
  const correoInp = document.getElementById("login-sol-correo") as HTMLInputElement;
  const pass1Inp = document.getElementById("login-sol-pass1") as HTMLInputElement;
  const pass2Inp = document.getElementById("login-sol-pass2") as HTMLInputElement;
  const errEl = document.getElementById("login-sol-error");
  const nombre = nombreInp?.value.trim();
  const correo = correoInp?.value.trim().toLowerCase();
  const pass1 = pass1Inp?.value;
  const pass2 = pass2Inp?.value;

  if (errEl) errEl.textContent = "";
  if (!nombre) { if (errEl) errEl.textContent = "Ingresa tu nombre."; return; }
  if (!correo || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(correo)) { if (errEl) errEl.textContent = "Ingresa un correo válido."; return; }
  if (pass1.length < 6) { if (errEl) errEl.textContent = "La contraseña debe tener al menos 6 caracteres."; return; }
  if (pass1 !== pass2) { if (errEl) errEl.textContent = "Las contraseñas no coinciden."; return; }

  const btn = document.getElementById("login-sol-btn") as HTMLButtonElement;
  btn.disabled = true; btn.textContent = "Enviando...";
  const res = await solicitarAcceso(correo, pass1);
  btn.disabled = false; btn.textContent = "Solicitar acceso →";

  if (!res.ok) {
    if (errEl) errEl.textContent = res.mensaje || "No se pudo enviar la solicitud.";
    return;
  }

  // Guardar la solicitud pendiente en su propia colección (no en agenda/datos): quien recién
  // pide acceso todavía no tiene permiso de leer/escribir ahí — necesitaría el acceso que
  // justo está pidiendo.
  try {
    await crearSolicitudAcceso(nombre, correo);
  } catch (e) { console.error("[Solicitud de acceso] No se pudo guardar:", e); }

  // Avisar a soporte por correo — se usa el documento público porque en este punto no hay
  // sesión de CRM ni configTickets cargado en memoria.
  try {
    const pub = await cargarConfigPublica();
    const destino = pub?.correoSoporte;
    if (destino) {
      await fetch("/send-email", {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          to: destino,
          subject: `🆕 Solicitud de acceso al CRM — ${nombre}`,
          html: `<div style="font-family:sans-serif;"><p><strong>${nombre}</strong> (${correo}) solicitó acceso al CRM.</p><p>Entra a Configuración → Usuarios → Solicitudes pendientes para aprobar o rechazar.</p></div>`
        })
      });
    }
  } catch (e) { console.error("[Solicitud de acceso] No se pudo enviar el correo de aviso:", e); }

  document.getElementById("login-step-solicitar")!.innerHTML = `
    <div class="login-sub" style="line-height:1.6;">✅ Solicitud enviada.<br><br>Un administrador debe aprobarla antes de que puedas entrar. Te avisan cuando esté lista.</div>
    <button id="login-sol-listo-btn" style="width:100%; margin-top:10px;">Entendido</button>
  `;
  document.getElementById("login-sol-listo-btn")?.addEventListener("click", () => location.reload());
}
