    cursor: pointer; transition: var(--transition-base);
  }
  .sidebar-logout-btn:hover { background: rgba(239,68,68,0.1); border-color: rgba(239,68,68,0.4); }
  .sidebar.collapsed .sidebar-logout-btn .logout-label { display: none; }

  /* ===== BASE DE CONOCIMIENTO (KB) ===== */
  #section-knowledge { display: none; flex-direction: column; gap: 0; height: 100%; overflow-y: auto; }
  #section-knowledge.active { display: flex; }

  /* ── CALENDARIO ────────────────────────────────────────── */
  .cal-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:2px; }
  .cal-head { text-align:center; font-size:0.68rem; font-weight:800; color:var(--text-muted); text-transform:uppercase; padding:4px 0; letter-spacing:.04em; }
  .cal-dia  { min-height:52px; border-radius:8px; padding:4px 5px; font-size:0.72rem; background:var(--bg-input); cursor:default; transition:background .15s; }
  .cal-dia:hover { background:rgba(99,102,241,0.1); }
  .cal-dia-num { font-weight:700; color:var(--text-muted); font-size:0.7rem; margin-bottom:3px; }
  .cal-dia-hoy .cal-dia-num { color:#6366f1; background:rgba(99,102,241,0.15); border-radius:50%; width:20px;height:20px;display:flex;align-items:center;justify-content:center; }
  .cal-dia-otro { opacity:0.3; }
  .cal-dot { display:block; border-radius:3px; padding:1px 4px; margin-bottom:1px; font-size:0.62rem; font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
