  // Envía a n8n el payload de programar/cancelar/reprogramar el recordatorio de un ticket
  // (formato propio, distinto del genérico dispararN8n — ver sección 10 del pedido original).
  async function enviarRecordatorioN8n(accion, t) {
    const url = configN8n.webhookUrl;
    if (!url) return;
    const regla = (configN8n.reglas || []).find(r => r.id === "ticket_recordatorio");
    if (!regla || !regla.activo) return;
    const ids = t.recordatorioDestinatariosIds || [];
    const destinatarios = (configN8n.destinatarios || [])
      .filter(d => d.activo && ids.includes(d.id))
      .map(d => ({ nombre: d.nombre, telefono: d.telefono, apiKey: d.apiKey }));
    if (accion !== "cancelar" && !destinatarios.length) return;
    const payload = {
      evento: "ticket_recordatorio",
      accion,
      ticket: {
        id: String(t.numero), numero: t.numero, empresa: t.empresa || "", asunto: t.asunto,
        agenteAsignado: t.agenteAsignado || "", fechaProgramada: t.fechaProgramada || "",
        horaProgramada: t.horaProgramada || "",
        fechaHoraISO: t.fechaProgramada ? new Date(`${t.fechaProgramada}T${t.horaProgramada || "00:00"}`).toISOString() : "",
      },
      destinatarios,
    };
    try {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 5000);
      await fetch(url, {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload), signal: controller.signal,
      }).catch(() => {});
      clearTimeout(timeoutId);
    } catch (err) { console.warn("[n8n] Error al enviar recordatorio", err); }
  }

  document.getElementById("btnGuardarTicket")?.addEventListener("click", async () => {
    const idx = editTkIdx.value;
    const contacto = document.getElementById("form-tk-contacto").value.trim();
    const contactoCorreo = document.getElementById("form-tk-correo-contacto").value.trim();
    const empresa = document.getElementById("form-tk-empresa").value.trim();
    const asunto = document.getElementById("form-tk-asunto").value.trim();
    const tipo = document.getElementById("form-tk-tipo").value;
    let sistema = document.getElementById("form-tk-sistema").value;
    const estado = document.getElementById("form-tk-estado").value;
    const facturado = document.getElementById("form-tk-facturado")?.value || "NO FACTURADO";
    const prioridad = document.getElementById("form-tk-prioridad").value;
    const grupo = document.getElementById("form-tk-grupo").value;
    const agente = document.getElementById("form-tk-agente").value;
    const descripcion = document.getElementById("form-tk-descripcion").innerHTML.trim();
    const cc = document.getElementById("form-tk-cc").value.trim();
    const cco = document.getElementById("form-tk-cco").value.trim();
    const solicitado = document.getElementById("form-tk-solicitado")?.value.trim() || "";
    const canalizado = document.getElementById("form-tk-canalizado")?.value.trim() || "";
    const notasInternas = document.getElementById("form-tk-notas-internas")?.value.trim() || "";
    const fechaProgramada = (document.getElementById("form-tk-fecha-programada") as HTMLInputElement)?.value || "";
    const horaProgramada = fechaProgramada ? ((document.getElementById("form-tk-hora-programada") as HTMLInputElement)?.value || "09:00") : "";
    const agenteAsignado = (document.getElementById("form-tk-agente-asignado") as HTMLSelectElement)?.value || "";
    const recordatorioActivo = (document.getElementById("chk-recordatorio-wsp") as HTMLInputElement)?.checked || false;
    const recordatorioDestinatariosIds = (fechaProgramada && recordatorioActivo)
      ? Array.from(document.querySelectorAll<HTMLInputElement>(".chk-recordatorio-dest:checked")).map(el => el.value)
      : [];

    if (!contacto || !asunto || !descripcion) {
      alert("Por favor rellena los campos obligatorios: Contacto, Asunto, Descripción.");
      return;
    }

    if (sistema === "__otro__") {
      const sistemaOtro = (document.getElementById("form-tk-sistema-otro") as HTMLInputElement | null)?.value.trim() || "";
      if (!sistemaOtro) {
        alert("Especifica el nombre del sistema.");
        return;
      }
      sistema = sistemaOtro;
      if (!configTickets.sistemas) configTickets.sistemas = [];
      if (!configTickets.sistemas.some(s => s.toLowerCase() === sistema.toLowerCase())) {
        configTickets.sistemas.push(sistema);
        if (crmLocalOnly) guardarLocal("crm_config_tickets", configTickets);
        else guardarConfigTickets({ sistemas: configTickets.sistemas }).catch(() => {});
      }
    }

    if (idx === "") {
      const num = tickets.length > 0 ? Math.max(...tickets.map(t => t.numero)) + 1 : 1001;
      const nuevoTicket = {
        numero: num, asunto, empresa, contacto, contactoCorreo, tipo, sistema, estado, facturado, prioridad, grupo, agente,
        descripcion, notasInternas, cc, cco, solicitado, canalizado,
        fechaProgramada, horaProgramada, agenteAsignado, recordatorioDestinatariosIds,
        adjuntos: [...adjuntosTicketActual],
        fechaCreacion: new Date().toISOString(),
        fechaActualizacion: new Date().toISOString(),
        notas: [],
        actividad: []
      };
      tickets.push(nuevoTicket);
      registrarActividadTicket(nuevoTicket, `Ticket creado${agente ? ` y asignado a ${agente}` : ""}`);
      logBitacora(`Ticket #${num} creado: "${asunto}" — ${empresa || contacto}`, "🎫");
      dispararN8n("ticket_creado_equipo", datosEventoTicket(nuevoTicket));

      // Puente Cotización → Ticket: si este ticket nació de "🎫 Crear ticket desde esta cotización",
      // se guarda el vínculo cruzado (nunca cambia el estado del ticket, ver plan: solo nace normal).
      if (cotizacionOrigenParaTicket !== null) {
        const cotOrigen = cotizaciones.find(c => c.id === cotizacionOrigenParaTicket);
        if (cotOrigen) {
          nuevoTicket.cotizacionId = cotOrigen.id;
          nuevoTicket.cotizacionNumero = cotOrigen.numero;
          cotOrigen.ticketNumero = nuevoTicket.numero;
          logBitacora(`Ticket #${nuevoTicket.numero} vinculado a cotización ${cotOrigen.numero}`, "🧾");
          if (crmLocalOnly) guardarLocal("crm_cotizaciones", cotizaciones); else await guardarCotizaciones(cotizaciones);
        }
        cotizacionOrigenParaTicket = null;
      }
      await procesarCierreTicket(nuevoTicket, "");
      await procesarFacturacion(nuevoTicket, "", "");
      if (fechaProgramada && recordatorioDestinatariosIds.length) await enviarRecordatorioN8n("programar", nuevoTicket);

      const enviarCorreo = document.getElementById("chk-enviar-correo")?.checked;
      if (enviarCorreo) await enviarNotificacionTicket(nuevoTicket);
    } else {
      const t = tickets.find(tk => tk.numero === parseInt(idx));
      if (!t) {
        toast("⚠️ Este ticket ya no existe (fue eliminado en otro dispositivo)", "error");
        cerrarFormTicket();
        renderTickets();
        return;
      }
      const adjuntosExistentes = t.adjuntos || [];
      const estadoAnterior = t.estado, agenteAnterior = t.agente, prioridadAnterior = t.prioridad;
      const notasInternasAnterior = t.notasInternas || "";
      const facturadoAnterior = t.facturado || "NO FACTURADO";
      const fechaProgAnterior = t.fechaProgramada || "", horaProgAnterior = t.horaProgramada || "";
      const recordatorioIdsAnterior = t.recordatorioDestinatariosIds || [];
      Object.assign(t, { asunto, empresa, contacto, contactoCorreo, tipo, sistema, estado, facturado, prioridad, grupo, agente,
        descripcion, notasInternas, cc, cco, solicitado, canalizado,
        fechaProgramada, horaProgramada, agenteAsignado, recordatorioDestinatariosIds,
        adjuntos: [...adjuntosExistentes, ...adjuntosTicketActual],
        fechaActualizacion: new Date().toISOString() });
      if (estado !== estadoAnterior) registrarActividadTicket(t, `Estado cambiado: "${estadoAnterior}" → "${estado}"`);
      if (agente !== agenteAnterior) registrarActividadTicket(t, `Asignado cambiado: "${agenteAnterior || "sin asignar"}" → "${agente || "sin asignar"}"`);
      if (prioridad !== prioridadAnterior) registrarActividadTicket(t, `Prioridad cambiada: "${prioridadAnterior}" → "${prioridad}"`);
      if (facturado !== facturadoAnterior) registrarActividadTicket(t, `Facturación cambiada: "${facturadoAnterior}" → "${facturado}"`);
      logBitacora(`Ticket #${t.numero} "${t.asunto}" actualizado a ${estado}${prioridad ? ` · ${prioridad}` : ""}`, "✏️");
      if (facturado !== facturadoAnterior) logBitacora(`Ticket #${t.numero}: facturación cambiada a "${facturado}"`, "🧾");
      if (estado !== estadoAnterior) dispararN8n("ticket_estado_cambiado", datosEventoTicket(t));
      if (notasInternas !== notasInternasAnterior && notasInternas.trim()) dispararN8n("ticket_nota_interna", datosEventoTicket(t));
      await procesarCierreTicket(t, estadoAnterior);
      await procesarFacturacion(t, estadoAnterior, facturadoAnterior);

      const habiaRecordatorio = !!(fechaProgAnterior && recordatorioIdsAnterior.length);
      const hayRecordatorioAhora = !!(fechaProgramada && recordatorioDestinatariosIds.length);
      if (hayRecordatorioAhora && !habiaRecordatorio) await enviarRecordatorioN8n("programar", t);
      else if (!hayRecordatorioAhora && habiaRecordatorio) await enviarRecordatorioN8n("cancelar", t);
      else if (hayRecordatorioAhora && habiaRecordatorio && (fechaProgramada !== fechaProgAnterior || horaProgramada !== horaProgAnterior))
        await enviarRecordatorioN8n("reprogramar", t);
    }

    guardarLocal("crm_tickets", tickets);
    if (crmLocalOnly) {
      toast("💾 Ticket guardado (Local)");
      cerrarFormTicket();
      renderTickets();
      renderDashboard();
      return;
    }
    mostrarEstado("💾 Guardando ticket...");
    const ok = await guardarTickets(tickets);
    if (ok) { toast("💾 Ticket guardado"); ocultarEstado(); }
    else { mostrarEstado("⚠️ Guardado localmente (sin conexión)", 3000); }
    cerrarFormTicket();
    renderTickets();
    renderDashboard();
  });

  function prepararEdicionTicket(e) {
    const idx = parseInt(e.target.closest("button").dataset.idx);
    const t = tickets[idx];
    cerrarFormTicket();
    document.getElementById("form-tk-titulo").textContent = "✏️ Editar Ticket";
    // Se guarda el folio (t.numero), no la posición en el arreglo — ver comentario junto a
    // ticketDetalleNumero más abajo para la misma razón.
    editTkIdx.value = String(t.numero);
    document.getElementById("form-tk-contacto").value = t.contacto || "";
    document.getElementById("form-tk-correo-contacto").value = t.contactoCorreo || "";
    document.getElementById("form-tk-empresa").value = t.empresa || "";
    document.getElementById("form-tk-asunto").value = t.asunto;
    document.getElementById("form-tk-descripcion").innerHTML = sanitizeDescripcionHtml(t.descripcion);
    document.getElementById("form-tk-cc").value = t.cc || "";
    document.getElementById("form-tk-cco").value = t.cco || "";
    const fSol = document.getElementById("form-tk-solicitado"); if (fSol) fSol.value = t.solicitado || "";
    const fCan = document.getElementById("form-tk-canalizado"); if (fCan) fCan.value = t.canalizado || "";
    const fNI = document.getElementById("form-tk-notas-internas"); if (fNI) fNI.value = t.notasInternas || "";
    initTicketFormDropdowns(t);
    formTk?.classList.remove("hidden");
    formTk?.scrollIntoView({ behavior: "smooth" });
  }

  async function eliminarTicket(e) {
    const idx = parseInt(e.target.closest("button").dataset.idx);
    if (!await confirmar("¿Mover este ticket a la papelera?", "🗑️")) return;
    const [t] = tickets.splice(idx, 1);
    t.fechaEliminado = new Date().toISOString();
    papelera.unshift(t);
    logBitacora(`Ticket #${t.numero} "${t.asunto}" movido a papelera`, "🗑️");
    actualizarBadgePapelera();
    if (firebaseEnabled) { guardarPapelera(papelera).catch(() => {}); }
    if (crmLocalOnly) {
      toast("🗑️ Ticket en papelera (Local)");
      renderTickets();
      renderDashboard();
      return;
    }
    await guardarTickets(tickets);
    toast("🗑️ Ticket movido a papelera");
    renderTickets();
    renderDashboard();
  }

  // Ticket Detail Modal
  // Se guarda el folio (t.numero), no la posición en el arreglo: si mientras el modal está
  // abierto otro dispositivo crea/edita/mueve tickets, tickets[idx] podría ya no ser el mismo
  // ticket que se está viendo — buscar por folio es estable sin importar el orden del arreglo.
  let ticketDetalleNumero: number | null = null;
  // Puente Ticket↔Cotización: recuerdan el origen mientras el usuario completa el formulario del
  // otro lado, para poder guardar el vínculo cruzado en cuanto guarde. Se limpian tras usarse.
  let cotizandoDesdeTicketNumero: number | null = null;
  let cotizacionOrigenParaTicket: string | null = null;
  function ticketPorNumero(numero: number | null) { return tickets.find(t => t.numero === numero) || null; }
  const modalDetalle = document.getElementById("modal-detalle-ticket");

  function registrarActividadTicket(t, texto) {
    if (!t.actividad) t.actividad = [];
    const u = getUsuarioActual();
    t.actividad.push({ fecha: new Date().toISOString(), usuario: u?.nombre || "Sistema", texto });
  }

  function renderActividadTicket(t) {
    const cont = document.getElementById("det-tk-actividad");
    const count = document.getElementById("det-tk-actividad-count");
    if (!cont) return;
    const act = (t.actividad || []).slice().sort((a, b) => new Date(b.fecha).getTime() - new Date(a.fecha).getTime());
    if (count) count.textContent = String(act.length);
    if (!act.length) {
      cont.innerHTML = '<div style="text-align:center; color:var(--text-light); font-size:0.78rem; padding:8px;">Sin actividad registrada.</div>';
      return;
    }
    cont.innerHTML = act.map(a => `
      <div style="font-size:0.78rem; line-height:1.5; border-left:2px solid var(--brand-primary); padding-left:8px;">
        <strong>👤 ${escapeHtml(a.usuario) || "Sistema"}</strong> · <span style="color:var(--text-muted);">${new Date(a.fecha).toLocaleString("es-MX")}</span><br>
        ${escapeHtml(a.texto)}
      </div>
    `).join("");
  }

  function abrirDetalleTicket(e) {
    const idx = parseInt(e.target.closest("button").dataset.idx);
    mostrarDetalleTicket(idx);
  }

  function mostrarDetalleTicket(idx) {
    const t = tickets[idx];
    if (!t) return;
    ticketDetalleNumero = t.numero;

    document.getElementById("det-tk-num").textContent = `Folio #${t.numero}`;
    document.getElementById("det-tk-asunto").textContent = t.asunto;
    document.getElementById("det-tk-empresa").textContent = t.empresa || "—";
    document.getElementById("det-tk-contacto").textContent = t.contacto || "—";
    document.getElementById("det-tk-grupo").textContent = t.grupo || "—";
    document.getElementById("det-tk-agente").textContent = t.agente || "—";
    document.getElementById("det-tk-sistema").textContent = (t.sistema && t.sistema !== "No aplica") ? t.sistema : "No aplica";
    (document.getElementById("det-tk-solicitado") as HTMLInputElement).value = t.solicitado || "";
    (document.getElementById("det-tk-canalizado") as HTMLInputElement).value = t.canalizado || "";
    document.getElementById("det-tk-descripcion").innerHTML = sanitizeDescripcionHtml(t.descripcion);
    const detNI = document.getElementById("det-tk-notas-internas") as HTMLTextAreaElement;
    if (detNI) detNI.value = t.notasInternas || "";
    renderAdjuntosDetalle(t);

    const bPrior = document.getElementById("det-tk-prioridad-badge");
    bPrior.textContent = t.prioridad;
    bPrior.className = `badge badge-${slugBadge(t.prioridad || "media")}`;

    const bEst = document.getElementById("det-tk-estado-badge");
    bEst.textContent = t.estado;
    bEst.className = `badge badge-${slugBadge(t.estado || "abierto")}`;

    const bTipo = document.getElementById("det-tk-tipo-badge");
    bTipo.textContent = t.tipo || "General";

    const cotVinculada = t.cotizacionId ? cotizaciones.find(c => c.id === t.cotizacionId) : null;
    const btnVerCot = document.getElementById("btnVerCotizacionDeTicket");
    if (cotVinculada) {
      document.getElementById("det-tk-cotizacion-numero").textContent = cotVinculada.numero;
      btnVerCot?.classList.remove("hidden");
    } else {
      btnVerCot?.classList.add("hidden");
    }
    document.getElementById("btnCotizarTicket")?.classList.toggle("hidden", !!cotVinculada && cotVinculada.estado !== "rechazada");

    populateSelectOptions("selectCambiarEstadoDetalle", configTickets.estados, t.estado);
    populateSelectOptions("det-tk-facturado", configTickets.facturacion, t.facturado || "NO FACTURADO");
    renderActividadTicket(t);

    if (modalDetalle) modalDetalle.style.display = "flex";
  }

  function cerrarDetalleTicket() {
    if (modalDetalle) modalDetalle.style.display = "none";
    ticketDetalleNumero = null;
  }

  document.getElementById("btnCerrarDetalle")?.addEventListener("click", cerrarDetalleTicket);
  modalDetalle?.addEventListener("click", (e) => {
    if (e.target === modalDetalle) cerrarDetalleTicket();
  });

  // Abre una ventana con una versión imprimible del ticket y llama a window.print() — el propio
  // diálogo de impresión del navegador ya ofrece "Guardar como PDF" como destino, sin necesidad
  // de generar el PDF nosotros mismos.
  function imprimirTicket(t, incluirLogo = true) {
    const win = window.open("", "_blank", "width=800,height=900");
    if (!win) {
      toast("⚠️ El navegador bloqueó la ventana de impresión — permite pop-ups para este sitio", "warning");
      return;
    }
    const logoBase64 = incluirLogo ? (localStorage.getItem("crm_logo") || "") : "";
    const html = `<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Ticket #${t.numero} — ${escapeHtml(t.asunto || "")}</title>
<style>
  body { font-family: Arial, Helvetica, sans-serif; color: #1f2937; padding: 32px; max-width: 720px; margin: 0 auto; }
  .encabezado { display: flex; align-items: center; gap: 14px; margin-bottom: 2px; }
  .encabezado img { height: 48px; max-width: 180px; object-fit: contain; }
  h1 { font-size: 1.3rem; color: #4f46e5; margin: 0; }
  .sub { color: #6b7280; font-size: 0.85rem; margin-bottom: 20px; }
  table { border-collapse: collapse; width: 100%; margin-bottom: 20px; }
  td { padding: 7px 12px; font-size: 0.9rem; border-bottom: 1px solid #e5e7eb; }
  td.k { font-weight: bold; background: #f3f4f6; width: 150px; }
  h2 { font-size: 1rem; margin: 18px 0 8px; color: #111827; }
  .desc { background: #f9fafb; padding: 14px; border-radius: 6px; font-size: 0.9rem; line-height: 1.5; }
  footer { margin-top: 28px; padding-top: 12px; border-top: 1px solid #e5e7eb; font-size: 0.75rem; color: #9ca3af; }
  @media print { body { padding: 0; } }
</style>
</head>
<body>
  <div class="encabezado">
    ${logoBase64 ? `<img src="${logoBase64}" alt="Logo">` : ""}
    <h1>Ticket #${t.numero}</h1>
  </div>
  <div class="sub">${escapeHtml(t.asunto || "")}</div>
  <table>
    <tr><td class="k">Empresa</td><td>${escapeHtml(t.empresa || "—")}</td></tr>
    <tr><td class="k">Contacto</td><td>${escapeHtml(t.contacto || "—")}</td></tr>
    <tr><td class="k">Tipo</td><td>${escapeHtml(t.tipo || "—")}</td></tr>
    <tr><td class="k">Prioridad</td><td>${escapeHtml(t.prioridad || "—")}</td></tr>
    <tr><td class="k">Estado</td><td>${escapeHtml(t.estado || "—")}</td></tr>
    <tr><td class="k">Agente</td><td>${escapeHtml(t.agente || "—")}</td></tr>
    <tr><td class="k">Fecha de creación</td><td>${t.fechaCreacion ? new Date(t.fechaCreacion).toLocaleString("es-MX") : "—"}</td></tr>
  </table>
  <h2>Descripción</h2>
  <div class="desc">${descripcionTicketAHtml(t.descripcion)}</div>
  <footer>DATTASOFT BY INFOXPERT — Sistema de Tickets · Impreso el ${new Date().toLocaleString("es-MX")}</footer>
</body>
</html>`;
    win.document.write(html);
    win.document.close();
    win.onload = () => { win.focus(); win.print(); };
  }

  const chkImprimirLogo = document.getElementById("chkImprimirLogo") as HTMLInputElement | null;
  if (chkImprimirLogo) {
    chkImprimirLogo.checked = localStorage.getItem("crm_imprimir_logo") !== "false";
    chkImprimirLogo.addEventListener("change", () => {
      localStorage.setItem("crm_imprimir_logo", String(chkImprimirLogo.checked));
    });
  }

  document.getElementById("btnImprimirTicket")?.addEventListener("click", () => {
    if (ticketDetalleNumero === null) return;
    const t = ticketPorNumero(ticketDetalleNumero);
    if (!t) { toast("⚠️ Este ticket ya no existe (fue eliminado)", "error"); return; }
    imprimirTicket(t, chkImprimirLogo ? chkImprimirLogo.checked : true);
    logBitacora(`Ticket #${t.numero} impreso / exportado a PDF`, "🖨️");
  });

  // ----- Puente a Cotizaciones -----
  // Igual que el puente inverso (Cotización → Ticket): nunca crea la cotización sola, solo
  // prellena el formulario y recuerda el ticket de origen para guardar el vínculo al guardar.
  document.getElementById("btnCotizarTicket")?.addEventListener("click", () => {
    if (ticketDetalleNumero === null) return;
    const t = ticketPorNumero(ticketDetalleNumero);
    if (!t) { toast("⚠️ Este ticket ya no existe (fue eliminado)", "error"); return; }
    cerrarDetalleTicket();
    navegarA("cotizaciones");
    cotizandoDesdeTicketNumero = t.numero;
    abrirNuevaCotizacion(t.asunto);
    setEmpresaCotizacion(t.empresa || "");
    (document.getElementById("form-cot-contacto") as HTMLInputElement).value = t.contacto || "";
    (document.getElementById("form-cot-correo") as HTMLInputElement).value = t.contactoCorreo || "";
  });

  document.getElementById("btnVerCotizacionDeTicket")?.addEventListener("click", () => {
    if (ticketDetalleNumero === null) return;
    const t = ticketPorNumero(ticketDetalleNumero);
    if (!t?.cotizacionId) return;
    cerrarDetalleTicket();
    abrirCotizacionPorId(t.cotizacionId);
  });

  document.getElementById("btnReenviarCorreoTicket")?.addEventListener("click", async (e) => {
    if (ticketDetalleNumero === null) return;
    const t = ticketPorNumero(ticketDetalleNumero);
    if (!t) { toast("⚠️ Este ticket ya no existe (fue eliminado)", "error"); cerrarDetalleTicket(); return; }
    const btn = e.currentTarget as HTMLButtonElement;
    btn.disabled = true;
    const textoOriginal = btn.textContent;
    btn.textContent = "Enviando...";
    try {
      await enviarNotificacionTicket(t);
    } finally {
      btn.disabled = false;
      btn.textContent = textoOriginal;
    }
  });

  document.getElementById("btnAgregarNotaTicket")?.addEventListener("click", async () => {
    if (ticketDetalleNumero === null) return;
    const t = ticketPorNumero(ticketDetalleNumero);
    if (!t) { toast("⚠️ Este ticket ya no existe (fue eliminado)", "error"); cerrarDetalleTicket(); return; }
    const nuevoEstado = document.getElementById("selectCambiarEstadoDetalle")?.value;

    const nuevoSolicitado = (document.getElementById("det-tk-solicitado") as HTMLInputElement)?.value.trim() || "";
    const nuevoCanalizado = (document.getElementById("det-tk-canalizado") as HTMLInputElement)?.value.trim() || "";
    const camposGestionCambiaron = nuevoSolicitado !== (t.solicitado || "") || nuevoCanalizado !== (t.canalizado || "");

    const nuevoNotasInternas = (document.getElementById("det-tk-notas-internas") as HTMLTextAreaElement)?.value.trim() || "";
    const notasInternasCambiaron = nuevoNotasInternas !== (t.notasInternas || "");

    const nuevoFacturado = (document.getElementById("det-tk-facturado") as HTMLSelectElement)?.value || (t.facturado || "NO FACTURADO");
    const facturadoCambio = nuevoFacturado !== (t.facturado || "NO FACTURADO");

    if (nuevoEstado === t.estado && !camposGestionCambiaron && !notasInternasCambiaron && !facturadoCambio) {
      alert("Cambia el estado, la facturación, o modifica algún campo de Solicitado/Canalizado/Notas Internas.");
      return;
    }

    const estadoAnterior = t.estado;
    const facturadoAnterior = t.facturado || "NO FACTURADO";
    if (nuevoEstado && nuevoEstado !== t.estado) {
      registrarActividadTicket(t, `Estado cambiado: "${estadoAnterior}" → "${nuevoEstado}"`);
      logBitacora(`Ticket #${t.numero} cambió de estado: "${estadoAnterior}" → "${nuevoEstado}"`, "🔄");
      t.estado = nuevoEstado;
      document.getElementById("det-tk-estado-badge").textContent = nuevoEstado;
      document.getElementById("det-tk-estado-badge").className = `badge badge-${slugBadge(nuevoEstado)}`;
    }
    if (facturadoCambio) {
      registrarActividadTicket(t, `Facturación cambiada: "${facturadoAnterior}" → "${nuevoFacturado}"`);
      logBitacora(`Ticket #${t.numero}: facturación cambiada a "${nuevoFacturado}"`, "🧾");
      t.facturado = nuevoFacturado;
    }

    if (camposGestionCambiaron) logBitacora(`Ticket #${t.numero}: datos de gestión actualizados (Solicitado/Canalizado)`, "✏️");
    if (notasInternasCambiaron) logBitacora(`Ticket #${t.numero}: notas internas actualizadas`, "🔒");

    t.solicitado = nuevoSolicitado;
    t.canalizado = nuevoCanalizado;
    t.notasInternas = nuevoNotasInternas;

    t.fechaActualizacion = new Date().toISOString();
    if (nuevoEstado && nuevoEstado !== estadoAnterior) dispararN8n("ticket_estado_cambiado", datosEventoTicket(t));
    if (notasInternasCambiaron && nuevoNotasInternas) dispararN8n("ticket_nota_interna", datosEventoTicket(t));
    await procesarCierreTicket(t, estadoAnterior);
    await procesarFacturacion(t, estadoAnterior, facturadoAnterior);
    guardarLocal("crm_tickets", tickets);
    if (crmLocalOnly) {
      toast("💬 Cambios guardados (Local)");
      renderActividadTicket(t);
      renderTickets();
      renderDashboard();
      return;
    }
    mostrarEstado("💾 Guardando...");
    const ok = await guardarTickets(tickets);
    if (ok) { toast("💬 Cambios guardados"); ocultarEstado(); }
    else { mostrarEstado("⚠️ Guardado localmente (sin conexión)", 2000); }
    renderActividadTicket(t);
    renderTickets();
    renderDashboard();
  });

  // Ticket filters
  document.getElementById("txtBuscarTicket")?.addEventListener("input", renderTickets);
  document.getElementById("selectFiltroEstado")?.addEventListener("change", renderTickets);
  document.getElementById("selectFiltroPrioridad")?.addEventListener("change", renderTickets);
  document.getElementById("selectFiltroTipo")?.addEventListener("change", renderTickets);
  document.getElementById("selectFiltroAgente")?.addEventListener("change", renderTickets);
  document.getElementById("selectFiltroFacturado")?.addEventListener("change", renderTickets);

  // ============================================================
  // ZOHO MAILTO
  // ============================================================
  function abrirZohoMail({ to = "", subject = "", body = "" } = {}) {
    window.open("https://mail.zoho.com/zm/#compose", "_blank");
    if (to) {
      navigator.clipboard.writeText(to).then(() => {
        toast(`✉️ Zoho abierto · Correo copiado: ${to} — pégalo en el campo "Para:"`, "info");
      }).catch(() => {
        toast(`✉️ Zoho abierto · Destinatario: ${to}`, "info");
      });
    }
    logBitacora(`Correo Zoho abierto para: ${to || "(sin destino)"}`, "✉️");
  }

  // Hook en botón de email empresa → Zoho si está configurado
  document.addEventListener("click", e => {
    const btn = e.target.closest(".btn-mail-emp-zoho");
    if (!btn) return;
    const idx = parseInt(btn.dataset.idx);
    const c = clientes[idx];
    if (!c) return;
    const pendientes = getSistemasPendientes(c);
    const bodyMsg = pendientes.length > 0 ? generarMensaje(c) || "" : "";
    abrirZohoMail({ to: getInfoContacto(c).correo || "", subject: "Actualización de Sistemas CONTPAQi", body: bodyMsg });
  });

  // ============================================================
  // CONFIGURACIÓN
  // ============================================================
  function updateMailProviderSelectionState() {
    document.querySelectorAll('.cfg-mail-provider').forEach(label => {
      const input = label.querySelector('input[name="cfg-mail-provider"]');
      if (!input) return;
      label.classList.toggle('selected', input.checked);
    });
  }

  function updateMailProviderHelp() {
    const fromInput = document.getElementById("cfg-correo-soporte")?.value.trim() || "";
    const from = parseEmailList(fromInput || configTickets.correoSoporte)[0] || "";
    const helpEl = document.getElementById("mail-provider-help");
    if (!helpEl) return;
    helpEl.className = "provider-status";
    if (!from) {
      helpEl.textContent = "⚠️ Ingresa el correo remitente para activar el envío automático.";
      helpEl.classList.add("warn");
      return;
    }
    helpEl.textContent = `✅ Brevo listo. Correos se enviarán desde ${from}.`;
    helpEl.classList.add("ok");
  }

  function renderConfig() {
    actualizarUIBackup();
    document.getElementById("cfg-correo-soporte").value = configTickets.correoSoporte || "";
    const resumenSemanalUltimoEl = document.getElementById("cfg-resumen-semanal-ultimo");
    if (resumenSemanalUltimoEl) {
      resumenSemanalUltimoEl.textContent = configTickets.resumenSemanalUltimoEnvio
        ? `Último envío: ${configTickets.resumenSemanalUltimoEnvio}`
        : "Aún no se ha enviado ningún resumen.";
    }
    renderConfigSLA();
    renderConfigCotizaciones();

    // Cargar proveedor de correo guardado
    const providerRadio = document.querySelector(`input[name="cfg-mail-provider"][value="${configCorreo.provider || "brevo"}"]`);
    if (providerRadio) providerRadio.checked = true;
    const apiKeyInput = document.getElementById("cfg-mail-apikey");
    if (apiKeyInput) apiKeyInput.value = configCorreo.apiKey || "";

    const localOnlyCheckbox = document.getElementById("cfg-local-only");
    if (localOnlyCheckbox) {
      localOnlyCheckbox.checked = crmLocalOnly;
    }

    const fields = ["tipo", "estado", "prioridad", "grupo", "agente", "sistema", "facturado"];
    fields.forEach(field => {
      const listEl = document.getElementById(`cfg-list-${field}`);
      if (!listEl) return;
      listEl.innerHTML = "";
      const key = field === "estado" ? "estados" : field === "prioridad" ? "prioridades" : field === "facturado" ? "facturacion" : `${field}s`;

      (configTickets[key] || []).forEach((item, idx) => {
        const div = document.createElement("div");
        div.className = "config-item";
        div.innerHTML = `
          <input value="${item}" data-field="${key}" data-idx="${idx}" style="color:var(--text-bright); background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.12);">
          <button class="btn btn-danger btn-xs cfg-del-item" data-field="${key}" data-idx="${idx}">🗑️</button>
        `;
        listEl.appendChild(div);
      });
    });

    if (localOnlyCheckbox) {
      localOnlyCheckbox.onchange = () => {
        crmLocalOnly = localOnlyCheckbox.checked;
        localStorage.setItem("crm_local_only", String(crmLocalOnly));
        if (crmLocalOnly) {
          cargarDesdeLocalStorage("📡 Modo Local activo. Cambiando a local storage...");
        } else {
          mostrarEstado("🔄 Intentando reconectar a Firebase...");
          inicializarApp();
        }
      };
    }

    document.querySelectorAll('input[name="cfg-mail-provider"]').forEach(input => {
      input.onchange = () => {
        updateMailProviderHelp();
        updateMailProviderSelectionState();
      };
    });
    if (apiKeyInput) {
      apiKeyInput.oninput = updateMailProviderHelp;
    }
    const correoSoporteInput = document.getElementById("cfg-correo-soporte") as HTMLInputElement | null;
    if (correoSoporteInput) correoSoporteInput.oninput = updateMailProviderHelp;

    // Botón de prueba de correo
    const btnTestEmail = document.getElementById("btn-test-email");
    if (btnTestEmail) btnTestEmail.onclick = async () => {
      const dest = document.getElementById("cfg-test-email")?.value.trim();
      const resultEl = document.getElementById("cfg-test-email-result");
      if (!dest || !dest.includes("@")) {
        resultEl.textContent = "⚠️ Ingresa un correo válido";
        resultEl.style.color = "#f59e0b";
        resultEl.style.display = "inline";
        return;
      }
      resultEl.textContent = "Enviando...";
      resultEl.style.color = "var(--text-muted)";
      resultEl.style.display = "inline";
      const res = await enviarEmailConProveedor({
        to: dest,
        subject: "✅ Prueba de correo — DATTASOFT CRM",
        html: `<div style="font-family:sans-serif;padding:20px;"><h2 style="color:#6366f1;">DATTASOFT CRM</h2><p>Este es un correo de prueba enviado desde el CRM.</p><p style="color:#64748b;font-size:0.85em;">Si recibes este mensaje, el envío de correos está funcionando correctamente.</p></div>`
      });
      if (res?.ok) {
        resultEl.textContent = `✅ Enviado correctamente a ${dest}`;
        resultEl.style.color = "#34d399";
      } else {
        resultEl.textContent = `❌ Error: ${res?.error || "fallo desconocido"}`;
        resultEl.style.color = "#f87171";
      }
    };

    updateMailProviderSelectionState();
    updateMailProviderHelp();

    // Add button events
    document.querySelectorAll("[data-cfg-add]").forEach(btn => {
      btn.onclick = () => {
        const field = btn.dataset.cfgAdd;
        const key = field === "estado" ? "estados" : field === "prioridad" ? "prioridades" : field === "facturado" ? "facturacion" : `${field}s`;
        const val = prompt(`Nuevo ${field}:`);
        if (val && val.trim()) {
          if (!configTickets[key]) configTickets[key] = [];
          configTickets[key].push(val.trim());
          renderConfig();
        }
      };
    });

    // Delete events
    document.querySelectorAll(".cfg-del-item").forEach(btn => {
      btn.onclick = async () => {
        const field = btn.dataset.field;
        const idx = parseInt(btn.dataset.idx);
        if (await confirmar(`¿Eliminar "${configTickets[field][idx]}"?`, "🗑️")) {
          configTickets[field].splice(idx, 1);
          renderConfig();
        }
      };
    });
  }

  document.getElementById("btnGuardarConfig")?.addEventListener("click", async () => {
    // Read edited values from inputs
    document.querySelectorAll(".config-item input").forEach(inp => {
      const field = inp.dataset.field;
      const idx = parseInt(inp.dataset.idx);
      if (configTickets[field] && configTickets[field][idx] !== undefined) {
        configTickets[field][idx] = inp.value.trim();
      }
    });
    configTickets.correoSoporte = document.getElementById("cfg-correo-soporte").value.trim();

    const selectedProvider = document.querySelector('input[name="cfg-mail-provider"]:checked')?.value || "";
    const apiKeyVal = document.getElementById("cfg-mail-apikey")?.value.trim() || "";
    if (selectedProvider || apiKeyVal) {
      configCorreo = { provider: selectedProvider || configCorreo.provider, apiKey: apiKeyVal || configCorreo.apiKey };
      if (firebaseEnabled) guardarConfigCorreo(configCorreo).catch(() => {});
    }

const localOnlyCheckbox = document.getElementById("cfg-local-only");
      if (localOnlyCheckbox) {
        crmLocalOnly = localOnlyCheckbox.checked;
      localStorage.setItem("crm_local_only", String(crmLocalOnly));
    }

    if (crmLocalOnly) {
      guardarLocal("crm_config_tickets", configTickets);
      toast("💾 Configuración guardada (Local)");
      updateMailProviderHelp();
      return;
    }
    mostrarEstado("💾 Guardando configuración...");
    // Antes de guardar, se trae la versión más fresca de Firestore y se fusiona (unión) con las
    // listas de esta pestaña: mismo problema que tenía Bitácora — esta pestaña pudo quedarse con
    // una copia vieja de Tipos/Estados/Facturación/etc. mientras otra sesión agregaba algo, y
    // guardar el arreglo completo desde esa copia vieja borraría silenciosamente lo ajeno. Aquí
    // solo se agregan los valores que falten (nunca se quita nada de lo que ya está en pantalla),
    // así que si otra pestaña borró algo sin refrescar, podría "reaparecer" — trade-off aceptado
    // para evitar la pérdida de datos real que sí estaba pasando.
    const camposListaConfig = ["tipos", "estados", "prioridades", "grupos", "agentes", "sistemas", "facturacion"];
    try {
      const datosFrescos = await cargarDatosCRM();
      const listasFrescas = datosFrescos?.configTickets || {};
      camposListaConfig.forEach(key => {
        const remoto = listasFrescas[key];
        if (!remoto || !remoto.length) return;
        const local = configTickets[key] || [];
        const extra = remoto.filter(v => !local.includes(v));
        if (extra.length) configTickets[key] = [...local, ...extra];
      });
    } catch { /* si falla la lectura fresca, se guarda con lo que ya había en memoria */ }
    const ok = await guardarConfigTickets({
      tipos: configTickets.tipos,
      estados: configTickets.estados,
      prioridades: configTickets.prioridades,
      grupos: configTickets.grupos,
      agentes: configTickets.agentes,
      sistemas: configTickets.sistemas,
      facturacion: configTickets.facturacion,
      correoSoporte: configTickets.correoSoporte
    });
    if (ok) { toast("💾 Configuración guardada"); ocultarEstado(); sincronizarConfigPublica(); renderConfig(); }
    else { guardarLocal("crm_config_tickets", configTickets); mostrarEstado("⚠️ Guardado localmente", 3000); }
  });

  document.getElementById("btn-guardar-correo-soporte")?.addEventListener("click", async () => {
    configTickets.correoSoporte = document.getElementById("cfg-correo-soporte").value.trim();
    updateMailProviderHelp();
    if (crmLocalOnly) {
      guardarLocal("crm_config_tickets", configTickets);
      toast("💾 Correo de soporte guardado (Local)");
      return;
    }
    const ok = await guardarConfigTickets({ correoSoporte: configTickets.correoSoporte });
    if (ok) { toast("💾 Correo de soporte guardado"); sincronizarConfigPublica(); }
    else { guardarLocal("crm_config_tickets", configTickets); toast("⚠️ Sin conexión — guardado solo localmente", "warning"); }
  });

  // SLA config load
  function renderConfigSLA() {
    const sla = configTickets.sla || { Urgente: 4, Alta: 8, Media: 24, Baja: 72 };
    const el = id => document.getElementById(id);
    if (el("sla-urgente")) el("sla-urgente").value = sla.Urgente ?? 4;
    if (el("sla-alta"))    el("sla-alta").value    = sla.Alta    ?? 8;
    if (el("sla-media"))   el("sla-media").value   = sla.Media   ?? 24;
    if (el("sla-baja"))    el("sla-baja").value    = sla.Baja    ?? 72;
  }
  document.getElementById("btnGuardarSLA")?.addEventListener("click", async () => {
    configTickets.sla = {
      Urgente: parseInt((document.getElementById("sla-urgente") as HTMLInputElement).value) || 4,
      Alta:    parseInt((document.getElementById("sla-alta")    as HTMLInputElement).value) || 8,
      Media:   parseInt((document.getElementById("sla-media")   as HTMLInputElement).value) || 24,
      Baja:    parseInt((document.getElementById("sla-baja")    as HTMLInputElement).value) || 72,
    };
    const ok = await guardarConfigTickets({ sla: configTickets.sla });
    if (ok) { toast("⏱️ SLA guardado"); renderTickets(); }
    else toast("⚠️ Error al guardar SLA", "error");
  });

  // Configuración de Cotizaciones: términos por defecto + catálogo de conceptos rápidos.
  // El catálogo usa .config-item-cat (nunca .config-item) para no caer en el guardado genérico
  // de listas de 1 campo (Tipos/Estados/etc.) — ver comentario en el CSS de .config-item-cat.
  function renderConfigCotizaciones() {
    const terminosEl = document.getElementById("cfg-cotizacion-terminos") as HTMLTextAreaElement | null;
    if (terminosEl) terminosEl.value = configCotizaciones.terminos || "";
    renderCatalogoConceptos();
  }

  function renderCatalogoConceptos() {
    const listEl = document.getElementById("cfg-list-catalogo-cotizaciones");
    if (!listEl) return;
    listEl.innerHTML = "";
    (configCotizaciones.catalogo || []).forEach((item: any, idx: number) => {
      const div = document.createElement("div");
      div.className = "config-item-cat";
      div.innerHTML = `
        <input class="cat-field-nombre" placeholder="Nombre del concepto" value="${escapeHtml(item.nombre || "")}" data-cat-idx="${idx}" data-cat-field="nombre">
        <input class="cat-field-precio" type="number" min="0" step="0.01" placeholder="Precio" value="${item.precioUnitario ?? 0}" data-cat-idx="${idx}" data-cat-field="precioUnitario">
        <input class="cat-field-dto" type="number" min="0" max="100" step="1" placeholder="Dto. %" value="${item.descuentoPorDefecto ?? 0}" data-cat-idx="${idx}" data-cat-field="descuentoPorDefecto">
        <button class="btn btn-danger btn-xs btn-del-cat-item" data-cat-idx="${idx}">🗑️</button>
      `;
      listEl.appendChild(div);
    });
  }

  document.getElementById("btnAddConceptoCatalogo")?.addEventListener("click", () => {
    configCotizaciones.catalogo = configCotizaciones.catalogo || [];
    configCotizaciones.catalogo.push({ nombre: "", precioUnitario: 0, descuentoPorDefecto: 0 });
    renderCatalogoConceptos();
  });

  document.getElementById("cfg-list-catalogo-cotizaciones")?.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest(".btn-del-cat-item") as HTMLElement | null;
    if (!btn) return;
    const idx = parseInt(btn.dataset.catIdx || "");
    configCotizaciones.catalogo.splice(idx, 1);
    renderCatalogoConceptos();
  });

  document.getElementById("btnGuardarConfigCotizaciones")?.addEventListener("click", async () => {
    const terminosEl = document.getElementById("cfg-cotizacion-terminos") as HTMLTextAreaElement | null;
    configCotizaciones.terminos = terminosEl?.value || "";
    const catalogo: any[] = [];
    document.querySelectorAll("#cfg-list-catalogo-cotizaciones .config-item-cat").forEach(div => {
      const nombre = (div.querySelector('[data-cat-field="nombre"]') as HTMLInputElement)?.value.trim() || "";
      const precioUnitario = parseFloat((div.querySelector('[data-cat-field="precioUnitario"]') as HTMLInputElement)?.value || "0") || 0;
      const descuentoPorDefecto = parseFloat((div.querySelector('[data-cat-field="descuentoPorDefecto"]') as HTMLInputElement)?.value || "0") || 0;
      if (nombre) catalogo.push({ nombre, precioUnitario, descuentoPorDefecto });
    });
    configCotizaciones.catalogo = catalogo;
    guardarLocal("crm_config_cotizaciones", configCotizaciones);
    const ok = firebaseEnabled && !crmLocalOnly ? await guardarConfigCotizaciones(configCotizaciones) : true;
    if (ok) toast("🧾 Configuración de Cotizaciones guardada");
    else toast("⚠️ Error al guardar (se guardó localmente)", "error");
    renderCatalogoConceptos();
  });

  async function renderSolicitudesAccesoPanel() {
    const uActual = getUsuarioActual();
    const panel = document.getElementById("cfg-solicitudes-panel");
    if (!panel) return;
    if (!uActual || uActual.rol !== "admin") { panel.style.display = "none"; return; }
    const cont = document.getElementById("cfg-solicitudes-list");
    if (!cont) return;
    const solicitudes = await obtenerSolicitudesAcceso();
    if (!solicitudes.length) { panel.style.display = "none"; return; }
    panel.style.display = "";
    cont.innerHTML = solicitudes.map((s: any) => `
      <div style="display:flex; align-items:center; gap:10px; background:rgba(99,102,241,0.06); border:1px solid rgba(99,102,241,0.2); border-radius:var(--radius-md); padding:10px 14px;">
        <div style="flex:1; min-width:0;">
          <div style="font-weight:700; color:var(--text-bright); font-size:0.88rem;">${escapeHtml(s.nombre)}</div>
          <div style="font-size:0.75rem; color:var(--text-muted);">${escapeHtml(s.correo)}</div>
        </div>
        <button class="btn btn-success btn-xs btn-aprobar-solicitud" data-id="${s._id}" data-nombre="${escapeHtml(s.nombre)}" data-correo="${escapeHtml(s.correo)}" style="white-space:nowrap;">✅ Aprobar</button>
        <button class="btn btn-danger btn-xs btn-rechazar-solicitud" data-id="${s._id}" data-nombre="${escapeHtml(s.nombre)}" style="white-space:nowrap;">❌ Rechazar</button>
      </div>`).join("");

    cont.querySelectorAll<HTMLButtonElement>(".btn-aprobar-solicitud").forEach(btn => {
      btn.addEventListener("click", async () => {
        const { id, nombre, correo } = btn.dataset as any;
        if (!await confirmar(`¿Aprobar el acceso de "${nombre}" (${correo})?`, "✅")) return;
        const usuariosAct = getUsuarios();
        if (usuariosAct.some((u: any) => u.nombre.toLowerCase() === nombre.toLowerCase())) {
          toast(`⚠️ Ya existe un usuario llamado "${nombre}" — cámbiale el nombre antes de aprobar, o edítalo manualmente.`, "error");
          return;
        }
        const esAdmin = await confirmar(`¿Le das permisos de administrador a "${nombre}"? (Cancelar = usuario normal)`, "🛡️");
        usuariosAct.push({ id: `u${Date.now()}`, nombre, rol: esAdmin ? "admin" : "normal", passHash: "", activo: true, authEmail: correo });
        saveUsuariosLocal(usuariosAct);
        await guardarUsuarios(usuariosAct);
        await otorgarAccesoStaff(correo);
        await eliminarSolicitudAcceso(id);
        toast(`✅ "${nombre}" aprobado — ya puede entrar con su cuenta segura`);
        logBitacora(`Solicitud de acceso aprobada: ${nombre} (${correo})`, "✅");
        renderSolicitudesAccesoPanel();
        renderUsuariosPanel();
      });
    });
    cont.querySelectorAll<HTMLButtonElement>(".btn-rechazar-solicitud").forEach(btn => {
      btn.addEventListener("click", async () => {
        const { id, nombre } = btn.dataset as any;
        if (!await confirmar(`¿Rechazar la solicitud de "${nombre}"?`, "❌")) return;
        await eliminarSolicitudAcceso(id);
        toast(`🗑️ Solicitud de "${nombre}" rechazada`);
        logBitacora(`Solicitud de acceso rechazada: ${nombre}`, "❌");
        renderSolicitudesAccesoPanel();
      });
    });
  }

  function renderUsuariosPanel() {
    const uActual = getUsuarioActual();
    const panel = document.getElementById("cfg-usuarios-panel");
    if (!panel) return;
    if (!uActual || uActual.rol !== "admin") { panel.style.display = "none"; return; }
    panel.style.display = "";
    renderSolicitudesAccesoPanel();
    const usuarios = getUsuarios();
    const cont = document.getElementById("cfg-usuarios-list");
    if (!cont) return;
    cont.innerHTML = usuarios.map((u, i) => `
      <div style="background:var(--bg-input); border:1px solid var(--border-color); border-radius:var(--radius-md); padding:10px 14px; opacity:${u.activo ? 1 : 0.5};">
        <div style="display:flex; align-items:center; gap:10px;">
          <div style="width:32px; height:32px; border-radius:50%; background:${u.rol==="admin"?"rgba(99,102,241,0.2)":"rgba(255,255,255,0.06)"}; display:flex; align-items:center; justify-content:center; font-weight:800; color:${u.rol==="admin"?"#818cf8":"var(--text-main)"}; font-size:0.85rem; flex-shrink:0;">${u.nombre[0]}</div>
          <div style="flex:1; min-width:0;">
            <div style="font-weight:700; color:var(--text-bright); font-size:0.88rem;">${u.nombre} <span style="font-size:0.68rem; padding:1px 6px; border-radius:3px; background:${u.rol==="admin"?"rgba(99,102,241,0.12)":"rgba(255,255,255,0.06)"}; color:${u.rol==="admin"?"#818cf8":"var(--text-muted)"};">${u.rol==="admin"?"Admin":"Normal"}</span></div>
            <div style="font-size:0.7rem; color:${u.activo?"#34d399":"#f87171"};">${u.activo?"● Activo":"● Inactivo"}</div>
            <div style="font-size:0.68rem; color:${u.authEmail?"#34d399":"#fbbf24"}; margin-top:1px;">${u.authEmail?`🔒 Cuenta segura: ${escapeHtml(u.authEmail)}`:"🔓 Sin activar cuenta segura"}</div>
          </div>
          ${!u.authEmail ? `<button class="btn btn-ghost btn-xs btn-activar-cuenta-segura" data-i="${i}" title="Activar cuenta segura para ${escapeHtml(u.nombre)}" style="color:#818cf8; white-space:nowrap;">🔒 Activar segura</button>` : ""}
          <button class="btn btn-ghost btn-xs btn-reset-pass" data-i="${i}" title="Restablecer contraseña" style="white-space:nowrap;">🔑 Reset</button>
          <button class="btn btn-ghost btn-xs btn-toggle-rol" data-i="${i}" title="${u.rol==="admin"?"Quitar permisos de administrador":"Dar permisos de administrador"}" style="color:${u.rol==="admin"?"#fbbf24":"#818cf8"}; white-space:nowrap;">${u.rol==="admin"?"⬇️ Quitar admin":"⬆️ Hacer admin"}</button>
          <button class="btn btn-ghost btn-xs btn-toggle-user" data-i="${i}" style="color:${u.activo?"#f87171":"#34d399"}; white-space:nowrap;">${u.activo?"🚫 Off":"✅ On"}</button>
        </div>
        ${u.rol !== "admin" ? `
        <div style="margin-top:10px; padding-top:10px; border-top:1px dashed rgba(255,255,255,0.08); display:flex; flex-wrap:wrap; gap:10px;">
          <span style="font-size:0.68rem; color:var(--text-muted); width:100%;">👁️ Secciones visibles para ${escapeHtml(u.nombre)} (todas marcadas = sin restricción):</span>
          ${SECCIONES_CONFIGURABLES.map(s => `
            <label style="display:flex; align-items:center; gap:4px; font-size:0.75rem; color:var(--text-main); cursor:pointer;">
              <input type="checkbox" class="chk-seccion-usuario" data-i="${i}" data-seccion="${s.id}" ${(!Array.isArray(u.seccionesPermitidas) || u.seccionesPermitidas.includes(s.id)) ? "checked" : ""} style="width:auto; cursor:pointer;">
              ${s.label}
            </label>`).join("")}
        </div>` : ""}
      </div>`).join("");
    cont.querySelectorAll<HTMLButtonElement>(".btn-activar-cuenta-segura").forEach(btn => {
      btn.addEventListener("click", () => {
        const i = parseInt(btn.dataset.i!);
        abrirModalCuentaSegura(usuarios[i].nombre);
      });
    });
    cont.querySelectorAll<HTMLButtonElement>(".btn-reset-pass").forEach(btn => {
      btn.addEventListener("click", async () => {
        const i = parseInt(btn.dataset.i!);
        const u = usuarios[i];
        const nueva = prompt(`Nueva contraseña para ${u.nombre}:\n(vacío = "${PASS_DEFECTO}")`);
        if (nueva === null) return;
        const passNueva = nueva.trim() || PASS_DEFECTO;
        if (passNueva.length < 4) { toast("⚠️ Mínimo 4 caracteres", "error"); return; }
        usuarios[i].passHash = await sha256(passNueva);
        saveUsuariosLocal(usuarios);
        if (!crmLocalOnly) guardarUsuarios(usuarios).catch(() => {});
        toast(`🔑 Contraseña de ${u.nombre} restablecida`);
        logBitacora(`Contraseña restablecida: ${u.nombre}`, "🔑");
      });
    });
    cont.querySelectorAll<HTMLButtonElement>(".btn-toggle-rol").forEach(btn => {
      btn.addEventListener("click", async () => {
        const i = parseInt(btn.dataset.i!);
        const u = usuarios[i];
        if (u.rol === "admin") {
          const adminsActivos = usuarios.filter(x => x.rol === "admin" && x.activo);
          if (adminsActivos.length <= 1) { toast("⚠️ No puedes quitar el único administrador activo", "error"); return; }
          if (u.nombre === uActual.nombre) { toast("⚠️ No puedes quitarte tus propios permisos de administrador", "error"); return; }
          if (!await confirmar(`¿Quitar permisos de administrador a ${u.nombre}?`, "🛡️")) return;
          usuarios[i].rol = "normal";
        } else {
          if (!await confirmar(`¿Dar permisos de administrador a ${u.nombre}?`, "🛡️")) return;
          usuarios[i].rol = "admin";
        }
        saveUsuariosLocal(usuarios);
        if (!crmLocalOnly) guardarUsuarios(usuarios).catch(() => {});
        toast(`${usuarios[i].rol === "admin" ? "⬆️ Ahora es admin" : "⬇️ Ya no es admin"}: ${u.nombre}`);
