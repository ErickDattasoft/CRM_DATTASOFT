    empresas: { title: "Empresas", sub: "Gestión de empresas, sistemas instalados y vencimientos de licencias" },
    contactos: { title: "Contactos", sub: "Directorio de contactos asociados a empresas" },
    tickets: { title: "Soporte — Tickets", sub: "Sistema de tickets de soporte técnico" },
    configuracion: { title: "Configuración", sub: "Ajustes del sistema de tickets y campos" },
    bitacora: { title: "Bitácora de Acciones", sub: "Registro de actividades del CRM" },
    eventos: { title: "Eventos", sub: "Gestión de eventos, invitados y asistencia" },
    knowledge: { title: "SOPORTE", sub: "Búsqueda de soluciones, datos de empresas y scripts de soporte" },
    manual: { title: "📖 Manual de Uso", sub: "Guía visual para usar el CRM — funciones de cada módulo y botón" }
  };

  function navegarA(sectionId, filtroEstado = "") {
    // Si hay un formulario de edición abierto (empresa, contacto o ticket), se cancela
    // automáticamente al navegar a otro apartado — no hace falta dar clic en "Cancelar".
    cerrarFormEmpresa();
    cerrarFormContacto();
    cerrarFormTicket();

    navItems.forEach(n => n.classList.toggle("active", n.dataset.section === sectionId));
    sections.forEach(s => s.classList.toggle("active", s.id === `section-${sectionId}`));
    const meta = sectionMeta[sectionId] || {};
    if (topbarTitle) topbarTitle.textContent = meta.title || "";
    if (topbarSub) topbarSub.textContent = meta.sub || "";

    if (sectionId === "dashboard") renderDashboard();
    if (sectionId === "versiones") initMarketForms();
    if (sectionId === "empresas") renderEmpresas();
    if (sectionId === "contactos") renderContactos();
    if (sectionId === "tickets") {
      const sel = document.getElementById("selectFiltroEstado");
      if (sel) sel.value = filtroEstado; // "" resetea el filtro, valor específico lo aplica
      renderTickets();
    }
    if (sectionId === "configuracion") renderConfig();
    if (sectionId === "bitacora") {
      const uNav = getUsuarioActual();
      if (!uNav || uNav.rol !== "admin") { navegarA("dashboard"); return; }
      renderBitacora();
    }
    if (sectionId === "configuracion") renderUsuariosPanel();
    if (sectionId === "eventos") renderSeccionEventos();
    if (sectionId === "knowledge") initKB();
  }

  // Click en stat-cards del dashboard
  document.querySelectorAll(".stat-card[data-nav]").forEach(card => {
    card.addEventListener("click", () => {
      const nav = card.dataset.nav;
      const filtroEstado = card.dataset.filterEstado || "";
      navegarA(nav, filtroEstado);
    });
  });

  navItems.forEach(n => n.addEventListener("click", () => navegarA(n.dataset.section)));

