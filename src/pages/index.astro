      div.querySelector(".btn-aceptar-pub").addEventListener("click", async (e) => {
        const idx = parseInt(e.target.dataset.i);
        const tp = ticketsPublicos[idx];
        const num = tickets.length > 0 ? Math.max(...tickets.map(x => x.numero)) + 1 : 1001;
        tickets.push({
          numero: num,
          asunto: tp.asunto || "Sin asunto",
          empresa: tp.empresa || "",
          contacto: tp.contacto || "",
          contactoCorreo: tp.contactoCorreo || "",
          tipo: tp.tipo || "General",
          sistema: tp.sistema || "No aplica",
          estado: "Abierto",
          prioridad: tp.prioridad || "Media",
          grupo: "", agente: "",
          descripcion: (tp.descripcion || "").replace(/\n/g, "<br>"),
          referido: "Portal Público", solicitado: "", canalizado: "", realizado: "",
          adjuntos: tp.adjuntos || [],
          notas: [{ autor: "Sistema", fecha: new Date().toISOString(), texto: `Ticket importado del portal público. Folio original: ${tp.folioPub || "—"}` }],
