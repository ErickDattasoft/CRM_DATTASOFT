  document.getElementById("btn-ver-puntos")?.addEventListener("click", () => {
    window.open(`https://github.com/${GH_OWNER}/${GH_REPO}/tags`, "_blank");
  });

  document.getElementById("btn-crear-punto")?.addEventListener("click", () => {
    const pat = localStorage.getItem(GH_PAT_KEY) || "";
    if (!pat) { toast("⚠️ Primero guarda tu GitHub Token en Configuración", "warning"); return; }
    document.getElementById("modal-gh-punto")!.style.display = "flex";
    const hoy = new Date();
    const sugerido = `v${hoy.getFullYear()}.${String(hoy.getMonth()+1).padStart(2,"0")}.${String(hoy.getDate()).padStart(2,"0")}`;
    (document.getElementById("gh-punto-nombre") as HTMLInputElement).value = sugerido;
    (document.getElementById("gh-punto-desc") as HTMLInputElement).value = "";
    document.getElementById("gh-punto-status")!.style.display = "none";
    (document.getElementById("gh-punto-nombre") as HTMLInputElement).focus();
  });

  document.getElementById("btn-gh-punto-cancelar")?.addEventListener("click", () => {
    document.getElementById("modal-gh-punto")!.style.display = "none";
  });

  document.getElementById("btn-gh-punto-crear")?.addEventListener("click", async () => {
    const pat  = localStorage.getItem(GH_PAT_KEY) || "";
    const name = (document.getElementById("gh-punto-nombre") as HTMLInputElement).value.trim().replace(/\s+/g, "-");
    const desc = (document.getElementById("gh-punto-desc") as HTMLInputElement).value.trim() || `Punto de restauración ${name}`;
    const status = document.getElementById("gh-punto-status2")!;
    const btn = document.getElementById("btn-gh-punto-crear") as HTMLButtonElement;

    if (!name) { toast("⚠️ El nombre no puede estar vacío", "warning"); return; }

    btn.disabled = true;
    btn.textContent = "Creando...";
    status.style.display = "inline";
    status.style.color = "var(--text-muted)";
    status.textContent = "⏳ Obteniendo commit actual...";

    try {
      // 1. Obtener SHA del HEAD de main
      const refRes = await fetch(`https://api.github.com/repos/${GH_OWNER}/${GH_REPO}/git/ref/heads/main`, {
        headers: { Authorization: `Bearer ${pat}`, Accept: "application/vnd.github+json" }
      });
      if (!refRes.ok) throw new Error(refRes.status === 401 ? "Token inválido o sin permiso" : `Error ${refRes.status}`);
      const refData = await refRes.json();
      const sha = refData.object.sha;

      status.textContent = "⏳ Creando tag anotado...";

      // 2. Crear el objeto tag (anotado)
      const tagRes = await fetch(`https://api.github.com/repos/${GH_OWNER}/${GH_REPO}/git/tags`, {
        method: "POST",
        headers: { Authorization: `Bearer ${pat}`, Accept: "application/vnd.github+json", "Content-Type": "application/json" },
        body: JSON.stringify({ tag: name, message: desc, object: sha, type: "commit",
          tagger: { name: "CRM DATTASOFT", email: "crm@dattasoft.mx", date: new Date().toISOString() }
        })
      });
      if (!tagRes.ok) {
        const err = await tagRes.json();
        throw new Error(err.message || `Error ${tagRes.status}`);
      }
      const tagData = await tagRes.json();

      // 3. Crear la referencia del tag
      const refPostRes = await fetch(`https://api.github.com/repos/${GH_OWNER}/${GH_REPO}/git/refs`, {
        method: "POST",
        headers: { Authorization: `Bearer ${pat}`, Accept: "application/vnd.github+json", "Content-Type": "application/json" },
        body: JSON.stringify({ ref: `refs/tags/${name}`, sha: tagData.sha })
      });
      if (!refPostRes.ok) {
        const err = await refPostRes.json();
        throw new Error(err.message || `Error ${refPostRes.status}`);
      }

      status.style.color = "#34d399";
      status.textContent = `✓ Punto "${name}" creado en GitHub`;
      btn.textContent = "✓ Creado";
      setTimeout(() => {
        document.getElementById("modal-gh-punto")!.style.display = "none";
        toast(`🔖 Punto de restauración "${name}" guardado`, "success");
        btn.disabled = false;
        btn.textContent = "🔖 Crear";
      }, 1500);
    } catch (err: any) {
      status.style.color = "#f87171";
      status.textContent = `✗ ${err.message}`;
      btn.disabled = false;
      btn.textContent = "🔖 Crear";
    }
  });

