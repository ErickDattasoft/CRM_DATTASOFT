  #confirm-modal-cancel { background: rgba(255,255,255,0.07); color: var(--text-main, #e2e8f0); }
  #confirm-modal-ok { background: #ef4444; color: #fff; }
  #login-overlay {
    position: fixed; inset: 0; background: #0b0e16;
