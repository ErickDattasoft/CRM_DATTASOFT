  function cerrarFormContacto() {
    formCt?.classList.add("hidden");
    editCtIdx.value = "";
    ["form-ct-nombre", "form-ct-correo", "form-ct-tel1", "form-ct-tel2", "form-ct-empresa", "form-ct-empresa-buscar"].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.value = "";
    });
  }

  // Autocomplete empresa en formulario de contacto
  const ctEmpBuscar = document.getElementById("form-ct-empresa-buscar");
  const ctEmpHidden = document.getElementById("form-ct-empresa");
  const ctEmpList   = document.getElementById("ct-empresa-autocomplete");
  attachAutocompleteKeyboardNav(ctEmpBuscar, ctEmpList);

  function setEmpresaContacto(nombre) {
    if (ctEmpBuscar) ctEmpBuscar.value = nombre;
    if (ctEmpHidden) ctEmpHidden.value = nombre;
    ctEmpList?.classList.add("hidden");
  }

  ctEmpBuscar?.addEventListener("input", function() {
    const val = this.value.toLowerCase().trim();
    if (ctEmpHidden) ctEmpHidden.value = this.value.trim();
    if (!val) { ctEmpList?.classList.add("hidden"); return; }
    const matches = clientes.filter(c => (c.EMPRESA || "").toLowerCase().includes(val)).slice(0, 12);
    if (!matches.length) { ctEmpList?.classList.add("hidden"); return; }
    ctEmpList.innerHTML = "";
    matches.forEach(c => {
      const div = document.createElement("div");
      div.className = "autocomplete-item";
      div.innerHTML = `<span style="font-weight:600; color:#f1f5f9;">🏢 ${c.EMPRESA}</span>`;
      div.addEventListener("click", () => setEmpresaContacto(c.EMPRESA));
      ctEmpList.appendChild(div);
    });
    ctEmpList?.classList.remove("hidden");
  });

  document.addEventListener("click", e => {
    if (!e.target.closest("#form-ct-empresa-buscar") && !e.target.closest("#ct-empresa-autocomplete")) {
      ctEmpList?.classList.add("hidden");
    }
  });

  // Modal nueva empresa rápida
  document.getElementById("btnNuevaEmpresaRapida")?.addEventListener("click", () => {
    document.getElementById("quick-emp-nombre").value = ctEmpBuscar?.value || "";
    document.getElementById("quick-emp-correo").value = "";
    document.getElementById("quick-emp-tel").value = "";
    document.getElementById("modal-empresa-rapida").style.display = "flex";
  });
  document.getElementById("btnCancelarEmpresaRapida")?.addEventListener("click", () => {
    document.getElementById("modal-empresa-rapida").style.display = "none";
  });
  document.getElementById("btnGuardarEmpresaRapida")?.addEventListener("click", async () => {
    const nombre = (document.getElementById("quick-emp-nombre") as HTMLInputElement).value.trim().toUpperCase();
    if (!nombre) { toast("⚠️ El nombre de la empresa es obligatorio"); return; }
    if (clientes.find((c: any) => c.EMPRESA === nombre)) {
      setEmpresaContacto(nombre);
      document.getElementById("modal-empresa-rapida").style.display = "none";
      toast(`ℹ️ La empresa "${nombre}" ya existe — asociada`);
      return;
    }
    const nueva = {
