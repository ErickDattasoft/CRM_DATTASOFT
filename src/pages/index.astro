  }

  function kbGuardarLocal(data: Omit<KBDoc, "_id">, id?: string) {
    const now = { toDate: () => new Date(), seconds: Date.now() / 1000 };
    if (id) {
      const idx = kbDocs.findIndex(d => d._id === id);
      if (idx >= 0) kbDocs[idx] = { ...kbDocs[idx], ...data, updated_at: now };
    } else {
      const newDoc: KBDoc = { _id: "kb_" + Date.now(), ...data, created_at: now, updated_at: now };
      kbDocs.unshift(newDoc);
      kbSelId = newDoc._id;
    }
    localStorage.setItem("crm_kb", JSON.stringify(kbDocs));
    kbRenderList();
    if (kbSelId) kbAbrirDoc(kbSelId);
  }

  async function kbGuardar() {
    const title    = (document.getElementById("kb-form-title") as HTMLInputElement).value.trim();
    const category = (document.getElementById("kb-form-cat") as HTMLSelectElement).value as KBDoc["category"];
    const file_type= (document.getElementById("kb-form-type") as HTMLSelectElement).value as KBDoc["file_type"];
    const content  = (document.getElementById("kb-form-content") as HTMLTextAreaElement).value;
    const tagsRaw  = (document.getElementById("kb-form-tags") as HTMLInputElement).value;
    const tags     = tagsRaw.split(",").map(t => t.trim()).filter(Boolean);
    if (!title) { (document.getElementById("kb-form-title") as HTMLInputElement).focus(); toast("⚠️ El título es obligatorio", "warning"); return; }

    const saveBtn = document.getElementById("kb-form-save") as HTMLButtonElement;
    saveBtn.disabled = true; saveBtn.textContent = "Guardando...";

    const data = { title, category, file_type, content, tags };
    if (firebaseEnabled) {
      if (kbEditId) {
        await actualizarDocKB(kbEditId, data);
        if (kbSelId === kbEditId) setTimeout(() => kbAbrirDoc(kbEditId!), 200);
      } else {
        const newId = await crearDocKB(data);
        if (newId) kbSelId = newId;
      }
    } else {
      kbGuardarLocal(data, kbEditId || undefined);
    }
    saveBtn.disabled = false; saveBtn.textContent = "💾 Guardar documento";
    kbCerrarModal();
    toast("✅ Documento guardado");
  }

  async function kbRecuperarEnFirestore(localDocs: KBDoc[]) {
    toast("🔄 Recuperando KB en Firestore...", "info");
    let ok = 0, err = 0;
    for (const d of localDocs) {
      try {
        await crearDocKB({ title: d.title, category: d.category, file_type: d.file_type, content: d.content, tags: d.tags || [] });
        ok++;
      } catch { err++; }
    }
    toast(`✅ ${ok} documentos recuperados en Firestore${err ? ` · ${err} errores` : ""}`, err ? "warning" : "success");
  }

  async function kbEliminar(id: string) {
    if (!confirm("¿Eliminar este documento? Esta acción no se puede deshacer.")) return;
    if (firebaseEnabled) {
      await eliminarDocKB(id);
    } else {
      kbDocs = kbDocs.filter(d => d._id !== id);
      localStorage.setItem("crm_kb", JSON.stringify(kbDocs));
      kbRenderList();
    }
    if (kbSelId === id) {
      kbSelId = null;
      const emptyEl = document.getElementById("kb-viewer-empty");
      const viewEl  = document.getElementById("kb-doc-view");
      if (emptyEl) emptyEl.style.display = "";
      if (viewEl)  viewEl.style.display = "none";
    }
    toast("🗑️ Documento eliminado");
  }

  async function kbCargarArchivo(file: File, forcedCategory?: KBDoc["category"]): Promise<string | null> {
    const text = await file.text();
    const title = file.name.replace(/\.(md|ps1|bat|txt)$/i, "");
    const file_type = kbGuessType(file.name);
    const category  = forcedCategory || kbGuessCat(file.name);
    const tags: string[] = [];
    const data = { title, category, file_type, content: text, tags };
    if (firebaseEnabled) {
      return await crearDocKB(data);
    } else {
      kbGuardarLocal(data);
      return "local_" + Date.now();
    }
  }

  async function kbSubidaMasiva(files: FileList | File[], forcedCategory?: KBDoc["category"]) {
    const lista = Array.from(files).filter(f => /\.(md|ps1|bat|sql|txt)$/i.test(f.name));
    if (!lista.length) { toast("⚠️ No se encontraron archivos .md .ps1 .bat", "warning"); return; }

    const progressEl  = document.getElementById("kb-upload-progress");
    const statusEl    = document.getElementById("kb-upload-status");
    const counterEl   = document.getElementById("kb-upload-counter");
    const barEl       = document.getElementById("kb-upload-bar");
    const errorsEl    = document.getElementById("kb-upload-errors");
    if (progressEl) progressEl.style.display = "block";
    if (errorsEl) errorsEl.textContent = "";
    if (barEl) barEl.style.width = "0%";

    const total = lista.length;
    let done = 0, errors = 0;
    const errNames: string[] = [];

    const updateProgress = () => {
      const pct = Math.round((done / total) * 100);
      if (barEl) barEl.style.width = pct + "%";
      if (counterEl) counterEl.textContent = `${done} / ${total}`;
      if (statusEl) statusEl.textContent = done < total ? `Subiendo... (${pct}%)` : errors ? `✅ Listo con ${errors} error(es)` : "✅ Todos subidos";
    };

    // Subida en lotes de 8 simultáneos
    const BATCH = 8;
    for (let i = 0; i < lista.length; i += BATCH) {
      const lote = lista.slice(i, i + BATCH);
      const resultados = await Promise.allSettled(lote.map(f => kbCargarArchivo(f, forcedCategory)));
      resultados.forEach((r, idx) => {
        done++;
        if (r.status === "rejected" || (r.status === "fulfilled" && !r.value)) {
          errors++;
          errNames.push(lote[idx].name);
        }
      });
      updateProgress();
    }

    if (errNames.length && errorsEl)
      errorsEl.textContent = `❌ Fallaron: ${errNames.slice(0,5).join(", ")}${errNames.length > 5 ? ` y ${errNames.length-5} más` : ""}`;

    setTimeout(() => { if (progressEl) progressEl.style.display = "none"; }, 3500);
    toast(`✅ ${done - errors} subidos${errors ? ` · ${errors} errores` : ""}`);
  }

  async function kbIndexar(files: FileList | File[]) {
    const lista = Array.from(files).filter(f => /\.(md|ps1|bat|sql|txt)$/i.test(f.name));
    if (!lista.length) { toast("⚠️ No se encontraron archivos válidos", "warning"); return; }

    const progressEl = document.getElementById("kb-upload-progress");
    const statusEl   = document.getElementById("kb-upload-status");
    const counterEl  = document.getElementById("kb-upload-counter");
    const barEl      = document.getElementById("kb-upload-bar");
    const errorsEl   = document.getElementById("kb-upload-errors");
    if (progressEl) progressEl.style.display = "block";
    if (errorsEl)   errorsEl.textContent = "";
    if (barEl)      barEl.style.width = "0%";

    const total = lista.length;
    let done = 0, actualizados = 0, nuevos = 0, errores = 0;

    const updateProgress = () => {
      const pct = Math.round((done / total) * 100);
      if (barEl)    barEl.style.width = pct + "%";
      if (counterEl) counterEl.textContent = `${done} / ${total}`;
      if (statusEl)  statusEl.textContent = done < total
        ? `Indexando... (${pct}%)`
        : `✅ ${actualizados} actualizados · ${nuevos} nuevos${errores ? ` · ${errores} errores` : ""}`;
    };

    const BATCH = 8;
    for (let i = 0; i < lista.length; i += BATCH) {
      const lote = lista.slice(i, i + BATCH);
      await Promise.allSettled(lote.map(async (f) => {
        try {
          const text    = await f.text();
          const title   = f.name.replace(/\.(md|ps1|bat|sql|txt)$/i, "");
          const existing = kbDocs.find(d => kbNorm(d.title) === kbNorm(title));
          if (existing) {
            await actualizarDocKB(existing._id, { content: text });
            actualizados++;
          } else {
            await crearDocKB({
              title,
              category: kbGuessCat(f.name),
              file_type: kbGuessType(f.name),
              content: text,
              tags: []
            });
            nuevos++;
          }
        } catch { errores++; }
        done++;
        updateProgress();
      }));
    }
    setTimeout(() => { if (progressEl) progressEl.style.display = "none"; }, 4000);
    toast(`🔄 Indexado: ${actualizados} actualizados · ${nuevos} nuevos`);
  }

  function kbSetupEvents() {
    // Búsqueda
    document.getElementById("kb-search-input")?.addEventListener("input", kbRenderList);

    // Toggle frase exacta
    document.getElementById("kb-exact-btn")?.addEventListener("click", () => {
      kbExact = !kbExact;
      document.getElementById("kb-exact-btn")?.classList.toggle("active", kbExact);
      kbRenderList();
    });

    // Pestañas de categoría
    document.querySelectorAll<HTMLButtonElement>(".kb-tab").forEach(btn => {
      btn.addEventListener("click", () => {
        kbCat = btn.dataset.kbCat!;
        document.querySelectorAll(".kb-tab").forEach(t => t.classList.remove("kb-tab-active"));
        btn.classList.add("kb-tab-active");

        // Cerrar visor si el doc activo no pertenece a esta categoría
        if (kbSelId && kbCat !== "all") {
          const docActivo = kbDocs.find(d => d._id === kbSelId);
          if (docActivo && docActivo.category !== kbCat) {
            kbSelId = null;
            const emptyEl = document.getElementById("kb-viewer-empty");
            const viewEl  = document.getElementById("kb-doc-view");
            if (emptyEl) emptyEl.style.display = "flex";
            if (viewEl)  viewEl.style.display  = "none";
          }
        }

        kbRenderList();
      });
    });

    // Click y doble clic delegados en el contenedor (sobreviven re-renders)
    const docList = document.getElementById("kb-doc-list");
    docList?.addEventListener("click", (e) => {
      const tagChip = (e.target as HTMLElement).closest<HTMLElement>(".kb-tag-chip");
      if (tagChip) {
        kbTagFilter = kbTagFilter === tagChip.dataset.tag ? null : tagChip.dataset.tag!;
        kbRenderList();
        return;
      }
      const item = (e.target as HTMLElement).closest<HTMLElement>(".kb-doc-item");
      if (item?.dataset.kid) kbAbrirDoc(item.dataset.kid);
    });
    docList?.addEventListener("dblclick", (e) => {
      if ((e.target as HTMLElement).closest(".kb-tag-chip")) return;
      const item = (e.target as HTMLElement).closest<HTMLElement>(".kb-doc-item");
      if (item?.dataset.kid) kbAbrirModal(item.dataset.kid);
    });

    // Orden alfabético
    document.getElementById("kb-sort-az")?.addEventListener("click", () => {
      kbSort = "asc";
      document.getElementById("kb-sort-az")?.classList.add("active");
      document.getElementById("kb-sort-za")?.classList.remove("active");
      kbRenderList();
    });
    document.getElementById("kb-sort-za")?.addEventListener("click", () => {
      kbSort = "desc";
      document.getElementById("kb-sort-za")?.classList.add("active");
      document.getElementById("kb-sort-az")?.classList.remove("active");
      kbRenderList();
    });

    // Nuevo documento
    document.getElementById("kb-btn-nuevo")?.addEventListener("click", () => kbAbrirModal());
    document.getElementById("kb-btn-export")?.addEventListener("click", () => {
      if (!kbDocs.length) { toast("⚠️ No hay documentos para exportar", "warning"); return; }
      const backup = { fecha: new Date().toISOString(), total: kbDocs.length, documentos: kbDocs };
      const blob = new Blob([JSON.stringify(backup, null, 2)], { type: "application/json" });
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = `kb-backup-${new Date().toISOString().slice(0,10)}.json`;
      a.click();
      URL.revokeObjectURL(a.href);
      toast(`✅ Backup exportado: ${kbDocs.length} documentos`);
    });

    // Modal: cerrar
    document.getElementById("kb-modal-close")?.addEventListener("click", kbCerrarModal);
    document.getElementById("kb-form-cancel")?.addEventListener("click", kbCerrarModal);
    document.getElementById("kb-modal")?.addEventListener("click", (e) => { if (e.target === document.getElementById("kb-modal")) kbCerrarModal(); });

    // Modal: guardar
    document.getElementById("kb-form-save")?.addEventListener("click", kbGuardar);

    // Escape cierra modal KB
    document.addEventListener("keydown", (e) => {
      const modal = document.getElementById("kb-modal");
      if ((e as KeyboardEvent).key === "Escape" && modal?.style.display !== "none") kbCerrarModal();
    });

    // Copiar contenido
    document.getElementById("kb-btn-copy")?.addEventListener("click", () => {
      const doc = kbDocs.find(d => d._id === kbSelId);
      if (!doc) return;
      navigator.clipboard.writeText(doc.content).then(() => toast("📋 Contenido copiado al portapapeles"));
    });

    // Descargar como archivo
    document.getElementById("kb-btn-download")?.addEventListener("click", () => {
      const doc = kbDocs.find(d => d._id === kbSelId);
      if (!doc) return;
      const ext = doc.file_type === "md" ? "md" : doc.file_type === "ps1" ? "ps1" : doc.file_type === "sql" ? "sql" : "bat";
      const mime = ext === "md" ? "text/markdown" : "text/plain";
      const blob = new Blob([doc.content], { type: mime });
      const url  = URL.createObjectURL(blob);
      const a    = document.createElement("a");
      a.href     = url;
      a.download = `${doc.title}.${ext}`;
      a.click();
      URL.revokeObjectURL(url);
      toast(`⬇ Descargando ${doc.title}.${ext}`);
    });

    // Editar
    document.getElementById("kb-btn-edit")?.addEventListener("click", () => { if (kbSelId) kbAbrirModal(kbSelId); });

    // Eliminar
    document.getElementById("kb-btn-del")?.addEventListener("click", () => { if (kbSelId) kbEliminar(kbSelId); });

    // Menú desplegable de carga
    const uploadBtn  = document.getElementById("kb-upload-btn");
    const uploadMenu = document.getElementById("kb-upload-menu");
    uploadBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = uploadMenu?.style.display === "none";
      if (uploadMenu) uploadMenu.style.display = open ? "block" : "none";
    });
    document.addEventListener("click", () => { if (uploadMenu) uploadMenu.style.display = "none"; });
    uploadMenu?.addEventListener("click", (e) => e.stopPropagation());

    // Upload: archivos individuales o múltiples
    document.getElementById("kb-upload-input")?.addEventListener("change", async (e) => {
      const files = (e.target as HTMLInputElement).files;
      if (uploadMenu) uploadMenu.style.display = "none";
      if (!files?.length) return;
      await kbSubidaMasiva(files);
      (e.target as HTMLInputElement).value = "";
    });

    // Upload: carpeta completa — muestra confirmación de categoría
    let pendingFolderFiles: FileList | null = null;
    document.getElementById("kb-upload-folder")?.addEventListener("change", (e) => {
      const files = (e.target as HTMLInputElement).files;
      if (uploadMenu) uploadMenu.style.display = "none";
      if (!files?.length) return;
      pendingFolderFiles = files;

      // Detectar nombre de carpeta y preseleccionar categoría
      const firstPath = (files[0] as any).webkitRelativePath as string || "";
      const folderName = firstPath.split("/")[0] || "Carpeta";
      const fn = folderName.toLowerCase();
      const catGuess: KBDoc["category"] =
        /empresa|client|company/.test(fn) ? "empresa" :
        /script|ps1|bat|cmd|auto|sql|quer/.test(fn) ? "script" : "solucion";

      const validFiles = Array.from(files).filter(f => /\.(md|ps1|bat|txt)$/i.test(f.name));
      const confirmEl = document.getElementById("kb-folder-confirm");
      const nameEl    = document.getElementById("kb-folder-name");
      const countEl   = document.getElementById("kb-folder-count");
      const catEl     = document.getElementById("kb-folder-cat") as HTMLSelectElement;
      if (nameEl)  nameEl.textContent  = folderName;
      if (countEl) countEl.textContent = `${validFiles.length} archivos`;
      if (catEl)   catEl.value         = catGuess;
      if (confirmEl) confirmEl.style.display = "block";
    });

    document.getElementById("kb-folder-ok")?.addEventListener("click", async () => {
      const catEl = document.getElementById("kb-folder-cat") as HTMLSelectElement;
      const cat   = (catEl?.value || "solucion") as KBDoc["category"];
      const confirmEl = document.getElementById("kb-folder-confirm");
      if (confirmEl) confirmEl.style.display = "none";
      if (!pendingFolderFiles) return;
      const files = pendingFolderFiles;
      pendingFolderFiles = null;
      await kbSubidaMasiva(files, cat);
      const folderInput = document.getElementById("kb-upload-folder") as HTMLInputElement;
      if (folderInput) folderInput.value = "";
    });

    document.getElementById("kb-folder-cancel")?.addEventListener("click", () => {
      const confirmEl = document.getElementById("kb-folder-confirm");
      if (confirmEl) confirmEl.style.display = "none";
      pendingFolderFiles = null;
      const folderInput = document.getElementById("kb-upload-folder") as HTMLInputElement;
      if (folderInput) folderInput.value = "";
    });

    // Indexar: actualizar existentes por nombre, crear nuevos
    document.getElementById("kb-index-input")?.addEventListener("change", async (e) => {
      const files = (e.target as HTMLInputElement).files;
      if (uploadMenu) uploadMenu.style.display = "none";
      if (!files?.length) return;
      await kbIndexar(files);
      (e.target as HTMLInputElement).value = "";
    });

    // Resizer del panel lista ↔ visor
    const resizerEl = document.getElementById("kb-resizer");
    let kbResizing = false, kbResizeStartX = 0, kbResizeStartW = 290;
    resizerEl?.addEventListener("mousedown", (e) => {
      kbResizing = true;
      kbResizeStartX = e.clientX;
      kbResizeStartW = parseInt(
        getComputedStyle(document.documentElement).getPropertyValue("--kb-list-w") || "290"
      ) || 290;
      resizerEl.classList.add("kb-resizing");
      document.body.style.cursor = "col-resize";
      document.body.style.userSelect = "none";
    });
    document.addEventListener("mousemove", (e) => {
      if (!kbResizing) return;
      const w = Math.max(160, Math.min(820, kbResizeStartW + e.clientX - kbResizeStartX));
      document.documentElement.style.setProperty("--kb-list-w", w + "px");
    });
    document.addEventListener("mouseup", () => {
      if (!kbResizing) return;
      kbResizing = false;
      resizerEl?.classList.remove("kb-resizing");
      document.body.style.cursor = "";
      document.body.style.userSelect = "";
    });

    // Drag & drop sobre el panel principal (kb-split)
    const kbSplit = document.getElementById("kb-split");
    let dragCounter = 0;
    kbSplit?.addEventListener("dragenter", (e) => {
      e.preventDefault();
      dragCounter++;
      kbSplit.classList.add("kb-dragging");
    });
    kbSplit?.addEventListener("dragleave", () => {
      dragCounter--;
      if (dragCounter <= 0) { dragCounter = 0; kbSplit.classList.remove("kb-dragging"); }
    });
    kbSplit?.addEventListener("dragover", (e) => e.preventDefault());
    kbSplit?.addEventListener("drop", async (e) => {
      e.preventDefault();
      dragCounter = 0;
      kbSplit.classList.remove("kb-dragging");
      const files = (e as DragEvent).dataTransfer?.files;
      if (files?.length) await kbSubidaMasiva(files);
    });

    // Dropzone en modal
    const dropzone = document.getElementById("kb-dropzone");
    const dropInput = document.getElementById("kb-drop-input") as HTMLInputElement;
    dropzone?.addEventListener("click", () => dropInput?.click());
    dropzone?.addEventListener("dragover", (e) => { e.preventDefault(); dropzone.classList.add("kb-drag"); });
    dropzone?.addEventListener("dragleave", () => dropzone.classList.remove("kb-drag"));
    dropzone?.addEventListener("drop", async (e) => {
      e.preventDefault(); dropzone.classList.remove("kb-drag");
      const file = (e as DragEvent).dataTransfer?.files[0];
      if (!file) return;
      const text = await file.text();
      (document.getElementById("kb-form-title") as HTMLInputElement).value = file.name.replace(/\.(md|ps1|bat|txt)$/i, "");
      (document.getElementById("kb-form-type") as HTMLSelectElement).value = kbGuessType(file.name);
      (document.getElementById("kb-form-cat") as HTMLSelectElement).value  = kbGuessCat(file.name);
      (document.getElementById("kb-form-content") as HTMLTextAreaElement).value = text;
    });
    dropInput?.addEventListener("change", async () => {
      const file = dropInput.files?.[0];
      if (!file) return;
      const text = await file.text();
      (document.getElementById("kb-form-title") as HTMLInputElement).value = file.name.replace(/\.(md|ps1|bat|txt)$/i, "");
      (document.getElementById("kb-form-type") as HTMLSelectElement).value = kbGuessType(file.name);
      (document.getElementById("kb-form-cat") as HTMLSelectElement).value  = kbGuessCat(file.name);
      (document.getElementById("kb-form-content") as HTMLTextAreaElement).value = text;
    });
  }

  function kbRenderAccesoPanel() {
    const panel = document.getElementById("kb-acceso-user-list");
    if (!panel) return;
    const usuarios = getUsuarios().filter(u => u.activo);
    panel.innerHTML = usuarios.map(u => {
      const checked = kbAcceso.includes(u.nombre) ? "checked" : "";
      const isOwner = u.nombre === "ERICK";
      return `<label class="kb-acceso-user">
        <input type="checkbox" data-uname="${u.nombre}" ${checked} ${isOwner ? "disabled" : ""}>
        <span class="kb-acceso-user-name">${u.nombre}</span>
        <span class="kb-acceso-user-rol">${isOwner ? "Propietario" : u.rol}</span>
      </label>`;
    }).join("");
    panel.querySelectorAll<HTMLInputElement>("input[type=checkbox]:not([disabled])").forEach(cb => {
      cb.addEventListener("change", async () => {
        const name = cb.dataset.uname!;
        kbAcceso = cb.checked
          ? [...new Set([...kbAcceso, name])]
          : kbAcceso.filter(n => n !== name);
        localStorage.setItem("crm_kb_acceso", JSON.stringify(kbAcceso));
        if (firebaseEnabled) await guardarKBAcceso(kbAcceso);
        toast(`${cb.checked ? "✅" : "🚫"} Acceso ${cb.checked ? "otorgado a" : "removido de"} ${name}`);
      });
    });
  }

