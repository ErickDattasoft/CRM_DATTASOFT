  // Cerrar modales al click fuera
  ["modal-acerca-de", "modal-papelera", "modal-exportar-excel"].forEach(id => {
    const m = document.getElementById(id);
    m?.addEventListener("click", e => { if (e.target === m) m.style.display = "none"; });
  });

  // ============================================================
  // BASE DE CONOCIMIENTO (KB) — solo ERICK
  // ============================================================
  interface KBDoc {
    _id: string;
    title: string;
    category: "empresa" | "solucion" | "script";
    content: string;
    file_type: "md" | "ps1" | "bat" | "sql";
    tags: string[];
    sourcePath?: string;
    created_at?: any;
    updated_at?: any;
  }

  let kbDocs: KBDoc[] = [];
  let kbExportDirHandle: any = null; // FileSystemDirectoryHandle para escritura directa
  let kbSelId: string | null = null;
  let kbSelId2: string | null = null;
  let kbCat = "all";
  let kbExact = false;
  let kbSort: "asc" | "desc" = "asc";
  let kbTagFilter: string | null = null;
  let kbEditId: string | null = null;
  let kbUnsubscribe: (() => void) | null = null;
  let kbInited = false;
  let kbSplitMode = false;
  let kbActivePanel = 1;
  let kbHistorial: string[] = (() => {
    try { return JSON.parse(localStorage.getItem("crm_kb_historial") || "[]"); } catch { return []; }
  })();
  let kbAcceso: string[] = (() => {
    try { return JSON.parse(localStorage.getItem("crm_kb_acceso") || '["ERICK"]'); } catch { return ["ERICK"]; }
  })();

  function kbNorm(s: string): string {
    return (s || "").normalize("NFD").replace(/[̀-ͯ]/g, "").toLowerCase();
  }
  function kbEsc(s: string): string {
    return (s || "").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }
  function kbFmtDate(ts: any): string {
    if (!ts) return "";
    let d: Date;
    if (ts.toDate) d = ts.toDate();
    else if (ts.seconds) d = new Date(ts.seconds * 1000);
    else d = new Date(ts);
    if (isNaN(d.getTime())) return "";
    return d.toLocaleDateString("es-MX", { day: "2-digit", month: "short" });
  }
  function kbFmtType(type: string): { ext: string; cls: string } {
    if (type === "ps1") return { ext: ".ps1", cls: "kb-b-ps1" };
    if (type === "bat") return { ext: ".bat", cls: "kb-b-bat" };
    if (type === "sql") return { ext: ".sql", cls: "kb-b-sql" };
    return { ext: ".md", cls: "kb-b-md" };
  }
  function kbFmtCat(cat: string): { label: string; cls: string } {
    if (cat === "empresa")  return { label: "🏢 Empresa",  cls: "kb-b-cat-empresa" };
    if (cat === "script")   return { label: "⚡ Script",   cls: "kb-b-cat-script" };
    return { label: "🛠 Solución", cls: "kb-b-cat-solucion" };
  }

  function kbGuessType(filename: string): "md" | "ps1" | "bat" | "sql" {
    const ext = filename.split(".").pop()?.toLowerCase() || "";
    if (ext === "ps1") return "ps1";
    if (ext === "bat") return "bat";
    if (ext === "sql") return "sql";
    return "md";
  }
  function kbGuessCat(filename: string): "empresa" | "solucion" | "script" {
    const n = filename.toLowerCase();
    if (n.includes("empresa") || n.includes("client")) return "empresa";
    if (n.includes("script") || n.includes(".ps1") || n.includes(".bat") || n.includes("sql") || n.includes("quer")) return "script";
    return "solucion";
  }

  function kbTagIcon(tag: string): string {
    const t = (tag || "").toLowerCase();
    if (t.includes("error") || t.includes("falla") || t.includes("problema")) return "🔴";
    if (t.includes("sql") || t.includes("base de dato") || t.includes(" bd")) return "🗄️";
    if (t.includes("windows") || t.includes("win-") || t.startsWith("win")) return "🪟";
    if (t.includes("red") || t.includes("network") || t.includes("internet") || t.includes("wifi")) return "🌐";
    if (t.includes("contab")) return "📊";
    if (t.includes("nomin") || t.includes("nómin")) return "💰";
    if (t.includes("banco")) return "🏦";
    if (t.includes("factura") || t.includes("cfdi") || t.includes("xml")) return "🧾";
    if (t.includes("script") || t.includes("ps1") || t.includes("bat") || t.includes("auto")) return "⚡";
    if (t.includes("backup") || t.includes("respaldo")) return "💾";
    if (t.includes("instal")) return "📦";
    if (t.includes("licencia") || t.includes("clave")) return "🔑";
    if (t.includes("correo") || t.includes("email") || t.includes("mail")) return "📧";
    if (t.includes("actuali") || t.includes("update") || t.includes("version")) return "🔄";
    if (t.includes("impuest") || t.includes("sat") || t.includes("fiscal")) return "🏛️";
    if (t.includes("servidor") || t.includes("server")) return "🖥️";
    if (t.includes("usuario") || t.includes("acceso") || t.includes("pass")) return "👤";
    return "🏷️";
  }

  function kbSaveSearch(q: string) {
    q = q.trim();
    if (!q || q.length < 2) return;
    kbHistorial = [q, ...kbHistorial.filter(h => h !== q)].slice(0, 10);
    localStorage.setItem("crm_kb_historial", JSON.stringify(kbHistorial));
  }

  function kbRenderHistorial() {
    const el = document.getElementById("kb-search-history");
    if (!el) return;
    if (!kbHistorial.length) {
      el.innerHTML = `<div class="kb-hist-item" style="color:var(--text-light); cursor:default; justify-content:center; font-style:italic;">Sin búsquedas recientes — escribe y presiona Enter para guardar</div>`;
      el.classList.add("open");
      return;
    }
    el.innerHTML = kbHistorial.map((h, i) =>
      `<div class="kb-hist-item" data-q="${kbEsc(h)}">
        <span style="color:var(--text-muted); font-size:0.85rem;">🕐</span>
        <span style="flex:1;">${kbEsc(h)}</span>
        <span class="kb-hist-del" data-idx="${i}" title="Eliminar">✕</span>
      </div>`
    ).join("") + `<div class="kb-hist-footer"><span class="kb-hist-clear-all">🗑 Limpiar historial</span></div>`;
    el.classList.add("open");
  }

  function kbUpdateTagCloud() {
    const el = document.getElementById("kb-tag-cloud");
    if (!el) return;
    const docs = kbCat === "all" ? kbDocs : kbDocs.filter(d => d.category === kbCat);
    const allTags = [...new Set(docs.flatMap(d => d.tags || []).filter(Boolean))]
      .sort((a, b) => kbNorm(a).localeCompare(kbNorm(b)));
    el.style.display = "flex";
    if (!allTags.length) {
      el.innerHTML = `<span class="kb-tag-cloud-label">🏷 Tags:</span><span style="font-size:0.72rem;color:var(--text-muted);font-style:italic;">Sin etiquetas — agrégalas al crear o editar un documento.</span>`;
      return;
    }
    const clearBtn = kbTagFilter
      ? `<span class="kb-tag-chip" data-tag="" style="cursor:pointer;opacity:0.6;">✕ Quitar filtro</span>`
      : "";
    el.innerHTML = `<span class="kb-tag-cloud-label">🏷 Tags:</span>` + allTags.map(t =>
      `<span class="kb-tag-chip ${kbTagFilter && kbNorm(t) === kbNorm(kbTagFilter) ? "kb-tag-active" : ""}" data-tag="${kbEsc(t)}" style="cursor:pointer;">${kbTagIcon(t)} ${kbEsc(t)}</span>`
    ).join("") + clearBtn;
  }

