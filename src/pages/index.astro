  .btn-demo-warning  { background: rgba(245,158,11,.12);  border-color: rgba(245,158,11,.4);  color: #fbbf24; }
  .btn-demo-ghost    { background: rgba(148,163,184,.08); border-color: rgba(148,163,184,.3); color: var(--text-main); }
  .btn-demo-green    { background: rgba(21,128,61,.15);   border-color: rgba(21,128,61,.5);   color: #4ade80; }
  .manual-tip {
    display: flex; gap: 10px; align-items: flex-start;
    background: rgba(99,102,241,0.07); border: 1px solid rgba(99,102,241,0.2);
    border-radius: 10px; padding: 12px 14px; margin-top: 12px; font-size: 0.82rem;
    color: var(--text-main); line-height: 1.55;
  }
  .manual-tip-icon { font-size: 1rem; flex-shrink: 0; margin-top: 1px; }
  .manual-aviso {
    display: flex; gap: 10px; align-items: flex-start;
    background: rgba(245,158,11,0.07); border: 1px solid rgba(245,158,11,0.25);
    border-radius: 10px; padding: 12px 14px; margin-top: 12px; font-size: 0.82rem;
    color: var(--text-main); line-height: 1.55;
  }
  .manual-tabla { width: 100%; border-collapse: collapse; font-size: 0.82rem; margin-top: 10px; }
  .manual-tabla th { background: rgba(99,102,241,0.1); color: var(--text-bright); padding: 8px 12px; text-align: left; font-size: 0.75rem; text-transform: uppercase; letter-spacing: .05em; }
  .manual-tabla td { padding: 9px 12px; border-bottom: 1px solid var(--border-color); color: var(--text-main); vertical-align: middle; }
  .manual-tabla tr:last-child td { border-bottom: none; }
  .manual-badge { display: inline-block; border-radius: 20px; padding: 2px 10px; font-size: 0.72rem; font-weight: 700; }
  .manual-indice { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }
  .manual-indice a { background: var(--bg-input); border: 1px solid var(--border-color); border-radius: 20px; padding: 5px 14px; font-size: 0.8rem; color: var(--text-main); text-decoration: none; transition: background .15s; }
  .manual-indice a:hover { background: rgba(99,102,241,0.15); color: #a5b4fc; border-color: rgba(99,102,241,.4); }
  .kb-toolbar { display: flex; gap: 10px; align-items: center; margin-bottom: 14px; flex-wrap: wrap; }
  .kb-search-wrap {
    flex: 1; min-width: 240px; display: flex; align-items: center;
    background: var(--bg-input); border: 1px solid var(--border-color);
    border-radius: var(--radius-md); padding: 0 12px; gap: 8px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .kb-search-wrap:focus-within { border-color: var(--brand-primary); box-shadow: 0 0 0 3px var(--brand-primary-glow); }
  .kb-search-icon { color: var(--text-muted); flex-shrink: 0; font-size: 0.95rem; }
  .kb-search-wrap input {
    border: none !important; background: transparent !important; box-shadow: none !important;
    flex: 1; padding: 10px 0; font-size: 0.88rem; color: var(--text-main) !important;
  }
  .kb-search-wrap input::placeholder { color: var(--text-light); }
  .kb-toggle-btn {
    font-size: 0.7rem; font-weight: 600; padding: 4px 10px; border-radius: var(--radius-full);
    border: 1px solid var(--border-color); background: transparent; color: var(--text-muted);
    cursor: pointer; transition: all 0.15s; white-space: nowrap; letter-spacing: 0.02em;
  }
  .kb-toggle-btn.active { background: var(--brand-primary); border-color: var(--brand-primary); color: #fff; }
  .kb-toggle-btn:hover:not(.active) { border-color: var(--brand-primary); color: var(--brand-primary-hover); }
  .kb-tabs { display: flex; gap: 2px; margin-bottom: 12px; border-bottom: 1px solid var(--border-color); overflow-x: auto; flex-shrink: 0; scrollbar-width: none; }
  .kb-tabs::-webkit-scrollbar { display: none; }
  .kb-tab {
    padding: 8px 16px; font-size: 0.8rem; font-weight: 600; border: none; background: transparent;
    color: var(--text-muted); cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px;
    transition: all 0.15s; border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    display: flex; align-items: center; gap: 5px; font-family: var(--font-heading);
  }
  .kb-tab:hover { color: var(--text-main); background: rgba(255,255,255,0.03); }
  .kb-tab.kb-tab-active { color: var(--brand-primary-hover); border-bottom-color: var(--brand-primary); background: rgba(99,102,241,0.06); }
  .kb-cnt {
    background: rgba(99,102,241,0.15); color: var(--brand-primary-hover); border-radius: var(--radius-full);
    padding: 1px 7px; font-size: 0.66rem; font-weight: 700; min-width: 18px; text-align: center;
  }
  .kb-split { display: grid; grid-template-columns: var(--kb-list-w, 290px) 14px 1fr; gap: 0; flex: 1; min-height: 0; overflow: hidden; }
  #kb-resizer { cursor: col-resize; background: transparent; transition: background 0.15s; position: relative; }
  #kb-resizer::after { content: ''; position: absolute; top: 0; bottom: 0; left: 50%; transform: translateX(-50%); width: 4px; border-radius: 2px; background: transparent; transition: background 0.15s; }
  #kb-resizer:hover::after, #kb-resizer.kb-resizing::after { background: var(--brand-primary); }
  .kb-list {
    background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-lg);
    overflow-y: auto; display: flex; flex-direction: column; padding: 6px; gap: 2px;
  }
  .kb-list-empty { padding: 28px 14px; text-align: center; color: var(--text-light); font-size: 0.8rem; line-height: 1.5; }
  .kb-list.kb-drop-over { border-color: var(--brand-primary); background: rgba(99,102,241,0.06); }
  .kb-drop-hint { pointer-events:none; position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; background:rgba(15,17,23,0.85); border-radius:var(--radius-lg); border:2px dashed var(--brand-primary); font-size:1rem; color:var(--brand-primary-hover); font-weight:700; gap:8px; z-index:10; opacity:0; transition:opacity 0.15s; }
  .kb-split.kb-dragging .kb-drop-hint { opacity:1; }
  .kb-doc-item {
    padding: 10px 12px; border-radius: var(--radius-md); cursor: pointer;
    transition: all 0.15s; border: 1px solid transparent; user-select: none;
  }
  .kb-doc-item:hover { background: var(--bg-card-hover); border-color: var(--border-color); }
  .kb-doc-item.kb-sel, .kb-doc-item.kb-sel:hover { background: rgba(99,102,241,0.18) !important; border-color: rgba(99,102,241,0.5) !important; border-left: 3px solid #6366f1 !important; padding-left: 9px; }
  .kb-item-title { font-size: 0.82rem; font-weight: 600; color: var(--text-main); line-height: 1.35; margin-bottom: 5px; word-break: break-word; }
  .kb-item-foot { display: flex; align-items: center; gap: 5px; flex-wrap: wrap; }
  .kb-badge { font-size: 0.6rem; font-weight: 700; padding: 2px 6px; border-radius: 3px; text-transform: uppercase; letter-spacing: 0.04em; }
  .kb-b-md { background: rgba(16,185,129,0.12); color: #34d399; }
  .kb-b-ps1 { background: rgba(99,102,241,0.12); color: #818cf8; }
  .kb-b-bat { background: rgba(245,158,11,0.12); color: #fbbf24; }
  .kb-b-sql { background: rgba(20,184,166,0.12); color: #2dd4bf; }
  .kb-b-cat-empresa { background: rgba(14,165,233,0.1); color: #38bdf8; }
  .kb-b-cat-solucion { background: rgba(16,185,129,0.1); color: #34d399; }
  .kb-b-cat-script { background: rgba(168,85,247,0.1); color: #c084fc; }
  .kb-b-cat-sql { background: rgba(20,184,166,0.1); color: #2dd4bf; }
  .kb-item-date { font-size: 0.66rem; color: var(--text-light); margin-left: auto; }
  .kb-viewer {
    background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-lg);
    display: flex; flex-direction: column; overflow: hidden; min-height: 0;
  }
  .kb-viewer-empty {
    flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 40px; text-align: center; gap: 10px;
  }
  .kb-ve-icon { font-size: 3.5rem; opacity: 0.4; }
  .kb-ve-title { font-size: 1rem; font-weight: 700; color: var(--text-muted); font-family: var(--font-heading); }
  .kb-ve-sub { font-size: 0.78rem; color: var(--text-light); }
  .kb-doc-header {
    display: flex; justify-content: space-between; align-items: flex-start; gap: 12px;
    padding: 16px 20px; border-bottom: 1px solid var(--border-color);
    flex-shrink: 0; background: rgba(255,255,255,0.015);
  }
  .kb-doc-title-wrap { flex: 1; min-width: 0; }
  .kb-doc-h { font-size: 1.05rem; font-weight: 800; color: var(--text-bright); font-family: var(--font-heading); line-height: 1.3; word-break: break-word; }
  .kb-doc-submeta { font-size: 0.72rem; color: var(--text-muted); margin-top: 4px; display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
  .kb-doc-actions { display: flex; gap: 6px; flex-shrink: 0; align-items: center; }
  .kb-content-wrap { flex: 1; overflow-y: auto; padding: 20px 24px; }
  /* Markdown */
  .kb-md { font-size: 0.87rem; color: var(--text-main); line-height: 1.7; }
  .kb-md h1 { font-size: 1.25rem; font-weight: 800; color: var(--text-bright); margin: 0 0 14px; font-family: var(--font-heading); }
  .kb-md h2 { font-size: 1rem; font-weight: 700; color: var(--brand-primary-hover); margin: 22px 0 8px; padding-bottom: 6px; border-bottom: 1px solid rgba(99,102,241,0.2); font-family: var(--font-heading); }
  .kb-md h3 { font-size: 0.88rem; font-weight: 700; color: var(--text-main); margin: 14px 0 6px; }
  .kb-md h4 { font-size: 0.8rem; font-weight: 700; color: var(--text-muted); margin: 10px 0 4px; text-transform: uppercase; letter-spacing: 0.04em; }
  .kb-md p { margin: 0 0 10px; }
  .kb-md ul, .kb-md ol { padding-left: 20px; margin: 0 0 10px; }
  .kb-md li { margin-bottom: 4px; }
  .kb-md code { background: rgba(99,102,241,0.1); color: #818cf8; padding: 1px 6px; border-radius: 4px; font-size: 0.82rem; font-family: 'Courier New', monospace; }
  .kb-md pre { background: #0a0c14; border: 1px solid rgba(255,255,255,0.07); border-radius: var(--radius-md); padding: 14px 16px; margin: 10px 0 14px; overflow-x: auto; }
  .kb-md pre code { background: transparent; color: #c9d1d9; padding: 0; font-size: 0.81rem; }
  .kb-md blockquote { border-left: 3px solid var(--brand-primary); padding: 8px 14px; background: rgba(99,102,241,0.06); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; margin: 10px 0; color: var(--text-muted); }
  .kb-md hr { border: none; border-top: 1px solid var(--border-color); margin: 18px 0; }
  .kb-md a { color: var(--brand-secondary); }
  .kb-md strong { color: var(--text-bright); font-weight: 700; }
  .kb-md table { width: 100%; border-collapse: collapse; margin: 10px 0 14px; font-size: 0.82rem; }
  .kb-md th { background: var(--bg-table-header); padding: 8px 10px; text-align: left; font-weight: 700; color: var(--text-muted); border: 1px solid var(--border-color); }
  .kb-md td { padding: 7px 10px; border: 1px solid var(--border-color); color: var(--text-main); }
  .kb-md tr:hover td { background: var(--bg-table-row-hover); }
  /* Script viewer */
  .kb-script { background: #0a0c14; border: 1px solid rgba(255,255,255,0.07); border-radius: var(--radius-md); padding: 16px; font-family: 'Courier New', monospace; font-size: 0.82rem; color: #c9d1d9; white-space: pre-wrap; word-break: break-word; line-height: 1.6; }
  /* Highlight búsqueda */
  mark.kb-hl { background: rgba(251,191,36,0.28); color: var(--text-bright); border-radius: 2px; padding: 0 1px; font-style: normal; }
  mark.kb-hl-content { background: rgba(16,185,129,0.25); color: #34d399; border-radius: 2px; padding: 0 1px; font-style: normal; }
  .kb-fmt-btn { background: transparent; border: 1px solid transparent; border-radius: 4px; color: var(--text-muted); cursor: pointer; font-size: 0.75rem; padding: 3px 7px; transition: all 0.12s; }
  .kb-fmt-btn:hover { background: rgba(99,102,241,0.1); border-color: rgba(99,102,241,0.2); color: var(--text-main); }
  #kb-pizarra-texto:empty::before { content: attr(data-placeholder); color: var(--text-light); pointer-events: none; }
  #kb-pizarra-texto h3 { font-size: 0.95rem; font-weight: 700; margin: 6px 0 2px; color: var(--text-bright); }
  #kb-pizarra-texto ul, #kb-pizarra-texto ol { padding-left: 20px; margin: 4px 0; }
  #kb-pizarra-texto li { margin: 2px 0; }
  /* Modal KB */
  .kb-modal-overlay { position: fixed; inset: 0; z-index: 3000; background: rgba(0,0,0,0.72); display: flex; align-items: center; justify-content: center; padding: 20px; backdrop-filter: blur(4px); }
  .kb-modal-box { background: var(--bg-card); border: 1px solid var(--border-color); border-radius: var(--radius-xl); width: 100%; max-width: 800px; max-height: 92vh; display: flex; flex-direction: column; box-shadow: var(--shadow-xl); }
  .kb-modal-header { padding: 18px 22px 14px; border-bottom: 1px solid var(--border-color); display: flex; justify-content: space-between; align-items: center; flex-shrink: 0; }
  .kb-modal-title { font-size: 1rem; font-weight: 800; color: var(--text-bright); font-family: var(--font-heading); }
  .kb-modal-body { padding: 18px 22px; overflow-y: auto; flex: 1; display: flex; flex-direction: column; gap: 14px; }
  .kb-modal-footer { padding: 14px 22px 18px; border-top: 1px solid var(--border-color); display: flex; justify-content: flex-end; gap: 8px; flex-shrink: 0; }
  .kb-modal-body .form-group { margin: 0; }
  .kb-modal-body textarea { font-family: 'Courier New', monospace; font-size: 0.82rem; resize: vertical; min-height: 220px; }
  .kb-dropzone {
    border: 2px dashed rgba(99,102,241,0.3); border-radius: var(--radius-md); padding: 18px;
    text-align: center; cursor: pointer; transition: all 0.2s; color: var(--text-muted); font-size: 0.82rem;
  }
  .kb-dropzone:hover, .kb-dropzone.kb-drag { border-color: var(--brand-primary); background: rgba(99,102,241,0.05); color: var(--text-main); }
  /* Tags */
  .kb-tag-chip {
    display: inline-flex; align-items: center; gap: 4px;
    background: rgba(99,102,241,0.1); color: var(--brand-primary-hover);
    border: 1px solid rgba(99,102,241,0.2); border-radius: var(--radius-full);
    font-size: 0.68rem; font-weight: 600; padding: 2px 8px; cursor: pointer;
    transition: all 0.15s; user-select: none;
  }
  .kb-tag-chip:hover, .kb-tag-chip.kb-tag-active { background: var(--brand-primary); color: #fff; border-color: var(--brand-primary); }
  .kb-tags-row { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 5px; }
  /* Relacionados */
  .kb-relacionados { border-top: 1px solid var(--border-color); padding: 14px 24px 20px; flex-shrink: 0; }
  .kb-rel-title { font-size: 0.72rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 8px; }
  .kb-rel-list { display: flex; flex-direction: column; gap: 4px; }
  .kb-rel-item {
    display: flex; align-items: center; gap: 8px; padding: 7px 10px;
    border-radius: var(--radius-md); cursor: pointer; transition: all 0.15s;
    border: 1px solid transparent; font-size: 0.8rem;
  }
  .kb-rel-item:hover { background: rgba(99,102,241,0.08); border-color: rgba(99,102,241,0.2); }
  .kb-rel-item-title { color: var(--text-main); font-weight: 500; flex: 1; }
  .kb-rel-shared { font-size: 0.66rem; color: var(--text-light); white-space: nowrap; }
  /* Panel de acceso */
  .kb-acceso-wrap { position: relative; }
  .kb-acceso-panel {
    position: absolute; top: calc(100% + 6px); right: 0; z-index: 200;
    background: var(--bg-card); border: 1px solid var(--border-color);
    border-radius: var(--radius-lg); padding: 14px 16px; min-width: 220px;
    box-shadow: var(--shadow-lg); display: none; flex-direction: column; gap: 6px;
  }
  .kb-acceso-panel.open { display: flex; }
  .kb-acceso-panel-title { font-size: 0.72rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; }
  .kb-acceso-user { display: flex; align-items: center; gap: 8px; padding: 5px 4px; border-radius: 6px; cursor: pointer; }
  .kb-acceso-user:hover { background: rgba(99,102,241,0.06); }
  .kb-acceso-user input { width: auto; accent-color: var(--brand-primary); cursor: pointer; }
  .kb-acceso-user-name { font-size: 0.82rem; font-weight: 600; color: var(--text-main); }
  .kb-acceso-user-rol { font-size: 0.66rem; color: var(--text-light); background: rgba(255,255,255,0.05); padding: 1px 5px; border-radius: 3px; }
  @media (max-width: 900px) {
    #section-knowledge { height: auto; overflow-y: visible; }
    .kb-split {
      grid-template-columns: 1fr;
      flex: 0 0 auto;
      min-height: unset;
      height: auto;
      overflow: visible;
    }
    #kb-resizer { display: none; }
    .kb-list { max-height: 260px; overflow-y: auto; }
    .kb-viewer { min-height: 360px; }
    #kb-panels-wrap { flex-direction: column !important; }
    #kb-panel-2 { border-left: none !important; border-top: 1px solid var(--border-color); }
  }

  /* ===== SOPORTE: historial de búsqueda ===== */
  .kb-search-outer { position: relative; flex: 1; min-width: 240px; }
  .kb-search-history {
    position: absolute; top: calc(100% + 3px); left: 0; right: 0; z-index: 600;
    background: var(--bg-card); border: 1px solid var(--border-color);
    border-radius: var(--radius-md); box-shadow: var(--shadow-lg);
    display: none; max-height: 220px; overflow-y: auto;
  }
  .kb-search-history.open { display: block; }
  .kb-hist-item {
    display: flex; align-items: center; gap: 8px; padding: 7px 12px;
    cursor: pointer; font-size: 0.8rem; color: var(--text-main); transition: background 0.12s;
  }
  .kb-hist-item:hover { background: rgba(99,102,241,0.08); }
  .kb-hist-del { margin-left: auto; opacity: 0; font-size: 0.72rem; color: var(--text-light); flex-shrink: 0; }
  .kb-hist-item:hover .kb-hist-del { opacity: 1; }
  .kb-hist-footer { padding: 6px 12px; border-top: 1px solid var(--border-color); display: flex; justify-content: flex-end; }
  .kb-hist-clear-all { font-size: 0.72rem; color: var(--text-light); cursor: pointer; }
  .kb-hist-clear-all:hover { color: #f87171; }
  /* ===== SOPORTE: nube de etiquetas ===== */
  #kb-tag-cloud { display: none; flex-wrap: wrap; gap: 5px; padding: 0 0 10px; align-items: center; }
  .kb-tag-cloud-label { font-size: 0.68rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap; }
  /* ===== SOPORTE: paneles split view ===== */
  #kb-panels-wrap { display: flex; flex-direction: column; flex: 1; min-height: 0; overflow: hidden; }
  #kb-panels-wrap.kb-split-mode { flex-direction: row; }
  .kb-panel { flex: 1; display: flex; flex-direction: column; min-height: 0; overflow: hidden; }
  #kb-panel-2 { border-left: 1px solid var(--border-color); }
  /* ===== Logo empresa ===== */
  #sidebar-logo-img { width: 36px; height: 36px; object-fit: contain; border-radius: var(--radius-md); flex-shrink: 0; display: none; cursor: pointer; }
  #logo-lightbox { position: fixed; inset: 0; z-index: 9999; background: rgba(0,0,0,0.75); display: none; align-items: center; justify-content: center; cursor: zoom-out; }
  #logo-lightbox img { width: min(400px, 85vw); height: min(400px, 85vw); object-fit: contain; border-radius: var(--radius-lg); box-shadow: 0 20px 60px rgba(0,0,0,0.5); background: rgba(255,255,255,0.05); padding: 16px; }
  #cfg-logo-preview { width: 72px; height: 72px; border: 1px dashed var(--border-color); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; font-size: 2rem; background: var(--bg-input); overflow: hidden; flex-shrink: 0; }
  #cfg-logo-preview img { width: 100%; height: 100%; object-fit: contain; display: none; }
  /* ===== Exportar a Windows ===== */
  .kb-export-item { display: flex; align-items: flex-start; gap: 10px; padding: 10px 14px; border-bottom: 1px solid var(--border-color); transition: background 0.12s; }
  .kb-export-item:last-child { border-bottom: none; }
  .kb-export-item:hover { background: rgba(99,102,241,0.04); }
  .kb-export-item input[type="checkbox"] { width: auto; margin-top: 3px; flex-shrink: 0; accent-color: var(--brand-primary); cursor: pointer; padding: 0; border: none; background: none; box-shadow: none; }
  .kb-export-item-info { flex: 1; min-width: 0; }
  .kb-export-item-name { font-size: 0.83rem; font-weight: 600; color: var(--text-main); margin-bottom: 3px; word-break: break-all; }
  .kb-export-item-path { font-size: 0.7rem; color: var(--text-muted); font-family: 'Courier New', monospace; word-break: break-all; line-height: 1.4; margin-bottom: 3px; }
  .kb-export-item-meta { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .kb-exp-single { flex-shrink: 0; font-size: 0.78rem; padding: 4px 8px; margin-top: 1px; }
  .kb-export-empty { padding: 28px 20px; text-align: center; color: var(--text-light); font-size: 0.82rem; line-height: 1.6; }

  /* ===== NUEVAS FEATURES ===== */

  /* --- SLA badges --- */
  .badge-sla { display:inline-block; font-size:0.68rem; font-weight:700; padding:2px 7px; border-radius:20px; letter-spacing:0.02em; margin-top:3px; }
  .badge-sla-ok    { background:rgba(16,185,129,0.15); color:#34d399; border:1px solid rgba(52,211,153,0.25); }
  .badge-sla-warn  { background:rgba(251,191,36,0.15); color:#fbbf24; border:1px solid rgba(251,191,36,0.25); }
  .badge-sla-over  { background:rgba(239,68,68,0.15); color:#f87171; border:1px solid rgba(248,113,113,0.25); }
  tr.sla-vencido td { background:rgba(239,68,68,0.05) !important; }

  /* --- Dashboard charts grid --- */
  .dash-charts-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-top:16px; align-items:start; }
  @media(max-width:800px){ .dash-charts-grid { grid-template-columns:1fr; } }
  .dash-chart-card { background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--radius-lg); padding:18px; }
  .dash-chart-title { font-size:0.82rem; font-weight:700; color:var(--text-bright); margin-bottom:14px; display:flex; align-items:center; gap:6px; }

  /* Licencias próximas */
  .lic-item { display:flex; flex-direction:column; gap:3px; margin-bottom:10px; }
  .lic-item-header { display:flex; justify-content:space-between; align-items:center; font-size:0.78rem; }
  .lic-item-empresa { font-weight:600; color:var(--text-main); }
  .lic-item-dias { font-size:0.7rem; font-weight:700; padding:2px 7px; border-radius:20px; }
  .lic-dias-critico { background:rgba(239,68,68,0.15); color:#f87171; }
  .lic-dias-warn    { background:rgba(251,191,36,0.15); color:#fbbf24; }
  .lic-dias-ok      { background:rgba(99,102,241,0.12); color:#a5b4fc; }
  .lic-progress { height:5px; background:var(--bg-input); border-radius:4px; overflow:hidden; }
  .lic-progress-bar { height:100%; border-radius:4px; transition:width 0.4s; }
  .dash-empty-mini { text-align:center; padding:20px 0; color:var(--text-muted); font-size:0.8rem; }

  /* Tickets viejos */
  .tk-viejo-row { display:flex; justify-content:space-between; align-items:center; padding:7px 0; border-bottom:1px solid var(--border-color); font-size:0.78rem; }
  .tk-viejo-row:last-child { border-bottom:none; }

  /* --- Drawer lateral (Historial y Tareas) --- */
  .drawer-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.45); z-index:11000; display:none; }
  .drawer-overlay.open { display:block; }
  .drawer-panel { position:fixed; top:0; right:0; bottom:0; width:480px; max-width:95vw; background:var(--bg-card); border-left:1px solid var(--border-color); z-index:11001; display:flex; flex-direction:column; transform:translateX(100%); transition:transform 0.3s cubic-bezier(.4,0,.2,1); box-shadow:-8px 0 40px rgba(0,0,0,0.35); }
  .drawer-panel.open { transform:translateX(0); }
  .drawer-header { padding:18px 20px; border-bottom:1px solid var(--border-color); display:flex; align-items:center; justify-content:space-between; flex-shrink:0; }
  .drawer-empresa-nombre { font-size:1rem; font-weight:800; color:var(--text-bright); font-family:var(--font-heading); }
  .drawer-tabs { display:flex; gap:0; border-bottom:1px solid var(--border-color); flex-shrink:0; }
  .drawer-tab { flex:1; padding:10px; font-size:0.82rem; font-weight:600; text-align:center; cursor:pointer; color:var(--text-muted); border-bottom:2px solid transparent; transition:var(--transition-base); }
  .drawer-tab.active { color:var(--brand-primary); border-bottom-color:var(--brand-primary); }
  .drawer-body { flex:1; overflow-y:auto; padding:16px 20px; }
  .drawer-footer { padding:14px 20px; border-top:1px solid var(--border-color); flex-shrink:0; }

  /* Timeline de interacciones */
  .timeline { position:relative; padding-left:22px; }
  .timeline::before { content:""; position:absolute; left:7px; top:0; bottom:0; width:2px; background:var(--border-color); }
  .timeline-item { position:relative; margin-bottom:16px; }
  .timeline-dot { position:absolute; left:-19px; top:4px; width:12px; height:12px; border-radius:50%; border:2px solid var(--bg-card); flex-shrink:0; }
  .timeline-dot-nota    { background:#6366f1; }
  .timeline-dot-llamada { background:#10b981; }
  .timeline-dot-correo  { background:#f59e0b; }
  .timeline-dot-reunion { background:#8b5cf6; }
  .timeline-dot-ticket  { background:#ef4444; }
  .timeline-content { background:var(--bg-input); border-radius:var(--radius-md); padding:10px 12px; }
  .timeline-meta { font-size:0.7rem; color:var(--text-muted); margin-bottom:4px; display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
  .timeline-tipo { font-weight:700; font-size:0.72rem; padding:1px 6px; border-radius:10px; }
  .timeline-tipo-nota    { background:rgba(99,102,241,0.15); color:#a5b4fc; }
  .timeline-tipo-llamada { background:rgba(16,185,129,0.15); color:#34d399; }
  .timeline-tipo-correo  { background:rgba(245,158,11,0.15); color:#fbbf24; }
  .timeline-tipo-reunion { background:rgba(139,92,246,0.15); color:#c4b5fd; }
  .timeline-tipo-ticket  { background:rgba(239,68,68,0.15); color:#f87171; }
  .timeline-text { font-size:0.82rem; color:var(--text-main); line-height:1.5; white-space:pre-wrap; }
  .timeline-empty { text-align:center; padding:30px 0; color:var(--text-muted); font-size:0.82rem; }

  /* Formulario rápido en drawer */
  .drawer-form { background:var(--bg-input); border-radius:var(--radius-md); padding:14px; margin-bottom:16px; border:1px solid var(--border-color); }
  .drawer-form-title { font-size:0.8rem; font-weight:700; color:var(--brand-primary); margin-bottom:10px; }

  /* Tareas */
  .tarea-item { display:flex; gap:10px; align-items:flex-start; padding:10px 12px; background:var(--bg-input); border-radius:var(--radius-md); margin-bottom:8px; border-left:3px solid var(--border-color); }
  .tarea-item.vencida   { border-left-color:#f87171; }
  .tarea-item.hoy       { border-left-color:#fbbf24; }
  .tarea-item.proxima   { border-left-color:#34d399; }
  .tarea-item.completada { opacity:0.5; }
  .tarea-chk { width:18px; height:18px; border-radius:4px; cursor:pointer; accent-color:var(--brand-primary); flex-shrink:0; margin-top:2px; }
  .tarea-info { flex:1; min-width:0; }
  .tarea-titulo { font-size:0.83rem; font-weight:600; color:var(--text-bright); }
  .tarea-empresa { font-size:0.72rem; color:var(--text-muted); }
  .tarea-fecha { font-size:0.7rem; font-weight:600; padding:2px 7px; border-radius:10px; margin-top:4px; display:inline-block; }
  .tarea-fecha-vencida  { background:rgba(239,68,68,0.15); color:#f87171; }
  .tarea-fecha-hoy      { background:rgba(251,191,36,0.15); color:#fbbf24; }
  .tarea-fecha-proxima  { background:rgba(52,211,153,0.15); color:#34d399; }
  .tarea-acciones { display:flex; gap:4px; flex-shrink:0; }

  /* Panel filtros guardados */
  .filtros-panel { background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--radius-lg); padding:16px; margin-bottom:16px; }
  .filtro-guardado-item { display:flex; align-items:center; gap:8px; padding:8px 10px; background:var(--bg-input); border-radius:var(--radius-md); margin-bottom:6px; }
  .filtro-nombre { flex:1; font-size:0.82rem; font-weight:600; color:var(--text-main); }
  .filtro-desc { font-size:0.7rem; color:var(--text-muted); }

  /* Dashboard tareas pendientes */
  .dash-tareas-card { grid-column: 1 / -1; }
  </style>
</head>
