  function verificarAlertasVencimiento() {
    const hoy = new Date(); hoy.setHours(0,0,0,0);
    const alertas: { empresa: string; sistema: string; dias: number; fecha: string }[] = [];

    clientes.forEach(c => {
      if (!c.VENCIMIENTOS) return;
      Object.entries(c.VENCIMIENTOS).forEach(([sis, fecha]) => {
        if (!fecha) return;
        const dias = Math.ceil((new Date((fecha as string) + "T00:00:00").getTime() - hoy.getTime()) / 86400000);
        if (dias >= 0 && dias <= 30) alertas.push({ empresa: c.EMPRESA, sistema: sis, dias, fecha: fecha as string });
      });
    });

    alertas.sort((a, b) => a.dias - b.dias);

    const banner = document.getElementById("banner-vencimientos");
    const lista  = document.getElementById("banner-vencimientos-lista");
    if (!banner || !lista) return;

    if (!alertas.length) { banner.style.display = "none"; return; }

    lista.innerHTML = alertas.map(a => {
      const color = a.dias <= 5 ? "#f87171" : a.dias <= 15 ? "#fbbf24" : "#a5b4fc";
      const bg    = a.dias <= 5 ? "rgba(239,68,68,0.12)" : a.dias <= 15 ? "rgba(251,191,36,0.12)" : "rgba(99,102,241,0.1)";
      const txt   = a.dias === 0 ? "¡Vence HOY!" : a.dias === 1 ? "Vence mañana" : `${a.dias} días`;
      return `<span style="display:inline-flex;align-items:center;gap:5px;background:${bg};border:1px solid ${color}40;border-radius:20px;padding:3px 10px;font-size:0.75rem;font-weight:600;color:${color};">
        <strong>${a.empresa}</strong> · ${a.sistema} · <em>${txt}</em>
      </span>`;
    }).join("");

    banner.style.display = "flex";
  }

  // Ejecutar cada vez que se re-renderizan los datos
  document.addEventListener("crm:datosFirebase", () => {
    setTimeout(verificarAlertasVencimiento, 1000);
    setTimeout(enviarResumenSemanal, 4000);
    setTimeout(migrarContactosDeEmpresas, 2000);
  }, { once: true });

  // ============================================================
  // MIGRACIÓN: sincronizar CONTACTO + CONTACTO_2 de todas las
  // empresas hacia la sección Contactos (se ejecuta una sola vez)
  // ============================================================
  async function migrarContactosDeEmpresas(manual = false) {
    const KEY = "crm_migracion_contactos_v3";
    if (!manual && localStorage.getItem(KEY) === "done") return;
    if (!clientes.length) return;

    let cambios = 0;

    clientes.forEach((emp: any) => {
      const sincronizar = (nombre: string, correo: string, tel1: string) => {
        if (!nombre?.trim()) return;
        const yaExiste = contactos.find((c: any) =>
          c.empresa === emp.EMPRESA && c.nombre === nombre
        );
        if (yaExiste) {
          let actualizado = false;
          if (!yaExiste.correo    && correo) { yaExiste.correo    = correo; actualizado = true; }
          if (!yaExiste.telefono1 && tel1)   { yaExiste.telefono1 = tel1;   actualizado = true; }
          if (actualizado) cambios++;
        } else {
          contactos.push({ nombre, correo: correo || "", telefono1: tel1 || "", telefono2: "", empresa: emp.EMPRESA });
          cambios++;
        }
      };
      sincronizar(emp.CONTACTO,   emp.CORREO   || "", emp.TELEFONO_1 || "");
      sincronizar(emp.CONTACTO_2, emp.CORREO_2 || "", emp.TELEFONO_2 || "");
    });

    if (cambios > 0) {
      try {
        await guardarContactos(contactos);
        guardarLocal("crm_contactos", contactos);
        renderContactos?.();
        toast(`✅ ${cambios} contacto(s) sincronizados desde empresas`);
      } catch(e) {
        console.warn("[Migración contactos]", e);
      }
    } else if (manual) {
      toast("✅ Todo estaba ya sincronizado — no hubo cambios");
    }
    localStorage.setItem(KEY, "done");
    return cambios;
  }

  document.getElementById("btn-migrar-contactos")?.addEventListener("click", async () => {
    const btn = document.getElementById("btn-migrar-contactos") as HTMLButtonElement;
    const status = document.getElementById("btn-migrar-contactos-status");
    if (btn) { btn.disabled = true; btn.textContent = "Sincronizando..."; }
    const n = await migrarContactosDeEmpresas(true);
    if (btn) { btn.disabled = false; btn.textContent = "🔄 Sincronizar ahora"; }
    if (status) status.textContent = n ? `${n} contacto(s) agregados` : "Sin cambios";
  });

  // ============================================================
  // F_WEEKLY: RESUMEN SEMANAL (lunes automático)
  // ============================================================
  async function enviarResumenSemanal() {
    const hoy = new Date();
    if (hoy.getDay() !== 1) return; // Solo lunes
    const hoyStr = hoy.toISOString().split("T")[0];
    if (localStorage.getItem("crm_resumen_semanal_enviado") === hoyStr) return; // Ya se envió hoy
    const correos = parseEmailList(configTickets.correoSoporte);
    if (!correos.length || !firebaseEnabled) return;

    const lunes = new Date(hoy); lunes.setDate(hoy.getDate());
    const domingo = new Date(hoy); domingo.setDate(hoy.getDate() + 6);
    const fmtFecha = (d: Date) => d.toLocaleDateString("es-MX", { day:"numeric", month:"long" });

    const abiertos   = tickets.filter(t => t.estado === "Abierto" || t.estado === "Pendiente");
    const hoy0 = new Date(); hoy0.setHours(0,0,0,0);
    const dom0 = new Date(hoy0); dom0.setDate(hoy0.getDate() + 6);
    const tareasEsta = tareas.filter(t => {
      if (t.completada || !t.fechaVencimiento) return false;
      const fv = new Date(t.fechaVencimiento + "T00:00:00");
      return fv >= hoy0 && fv <= dom0;
    });
    const licencias = clientes.flatMap(c => {
      if (!c.VENCIMIENTOS) return [];
      return Object.entries(c.VENCIMIENTOS).flatMap(([sis, fVenc]) => {
        if (!fVenc) return [];
        const dias = Math.ceil((new Date((fVenc as string) + "T00:00:00").getTime() - hoy0.getTime()) / 86400000);
        return dias >= 0 && dias <= 30 ? [{ empresa: c.EMPRESA, sistema: sis, dias }] : [];
      });
    }).sort((a, b) => a.dias - b.dias);

    const rowsTickets = abiertos.slice(0, 10).map(t =>
      `<tr><td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;">#${t.numero}</td><td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;">${t.asunto}</td><td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;">${t.empresa||"—"}</td><td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;color:${t.prioridad==="Urgente"?"#ef4444":t.prioridad==="Alta"?"#f59e0b":"#6366f1"};">${t.prioridad||"—"}</td></tr>`
    ).join("");

    const rowsTareas = tareasEsta.map(t =>
      `<tr><td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;">${t.empresa||"—"}</td><td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;">${t.titulo}</td><td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;">${t.fechaVencimiento||"—"}</td><td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;">${t.asignado||"Sin asignar"}</td></tr>`
    ).join("");

    const rowsLic = licencias.slice(0, 10).map(l =>
      `<tr><td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;">${l.empresa}</td><td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;">${l.sistema}</td><td style="padding:6px 10px;border-bottom:1px solid #e2e8f0;font-weight:700;color:${l.dias<=5?"#ef4444":l.dias<=15?"#f59e0b":"#6366f1"};">${l.dias} días</td></tr>`
    ).join("");

    const html = `<div style="font-family:'Segoe UI',sans-serif;max-width:640px;margin:0 auto;">
  <div style="background:linear-gradient(135deg,#6366f1,#8b5cf6);padding:24px 28px;border-radius:12px 12px 0 0;">
    <h1 style="color:#fff;font-size:1.2rem;font-weight:800;margin:0;">📊 Resumen Semanal — CRM</h1>
    <p style="color:rgba(255,255,255,0.8);font-size:0.85rem;margin:6px 0 0;">Semana del ${fmtFecha(lunes)} al ${fmtFecha(domingo)}</p>
  </div>
  <div style="background:#f8fafc;padding:24px 28px;border:1px solid #e2e8f0;">

    <h2 style="color:#1e293b;font-size:1rem;margin:0 0 10px;">🎫 Tickets Abiertos (${abiertos.length})</h2>
    ${abiertos.length ? `<table style="width:100%;border-collapse:collapse;font-size:0.85rem;"><thead><tr style="background:#e2e8f0;"><th style="padding:6px 10px;text-align:left;">No.</th><th style="padding:6px 10px;text-align:left;">Asunto</th><th style="padding:6px 10px;text-align:left;">Empresa</th><th style="padding:6px 10px;text-align:left;">Prioridad</th></tr></thead><tbody>${rowsTickets}</tbody></table>` : "<p style='color:#64748b;font-size:0.85rem;'>✅ Sin tickets pendientes esta semana.</p>"}
    ${abiertos.length > 10 ? `<p style="font-size:0.78rem;color:#94a3b8;margin-top:4px;">...y ${abiertos.length - 10} más en el CRM.</p>` : ""}

    <h2 style="color:#1e293b;font-size:1rem;margin:24px 0 10px;">📌 Tareas que vencen esta semana (${tareasEsta.length})</h2>
    ${tareasEsta.length ? `<table style="width:100%;border-collapse:collapse;font-size:0.85rem;"><thead><tr style="background:#e2e8f0;"><th style="padding:6px 10px;text-align:left;">Empresa</th><th style="padding:6px 10px;text-align:left;">Tarea</th><th style="padding:6px 10px;text-align:left;">Vence</th><th style="padding:6px 10px;text-align:left;">Asignado a</th></tr></thead><tbody>${rowsTareas}</tbody></table>` : "<p style='color:#64748b;font-size:0.85rem;'>✅ Sin tareas por vencer esta semana.</p>"}

    <h2 style="color:#1e293b;font-size:1rem;margin:24px 0 10px;">⚠️ Licencias que vencen en 30 días (${licencias.length})</h2>
    ${licencias.length ? `<table style="width:100%;border-collapse:collapse;font-size:0.85rem;"><thead><tr style="background:#e2e8f0;"><th style="padding:6px 10px;text-align:left;">Empresa</th><th style="padding:6px 10px;text-align:left;">Sistema</th><th style="padding:6px 10px;text-align:left;">Días restantes</th></tr></thead><tbody>${rowsLic}</tbody></table>` : "<p style='color:#64748b;font-size:0.85rem;'>✅ Sin licencias por vencer este mes.</p>"}

  </div>
  <div style="background:#f1f5f9;padding:14px 28px;border-radius:0 0 12px 12px;text-align:center;">
    <p style="font-size:0.75rem;color:#94a3b8;margin:0;">Resumen generado automáticamente — DATTASOFT CRM · ${hoy.toLocaleDateString("es-MX")}</p>
  </div>
</div>`;

    try {
      await fetch("/send-email", {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ to: correos, subject: `📊 Resumen Semanal CRM — ${fmtFecha(lunes)} al ${fmtFecha(domingo)}`, html })
      });
      localStorage.setItem("crm_resumen_semanal_enviado", hoyStr);
      toast("📊 Resumen semanal enviado a " + correos.join(", "));
    } catch(e) { console.warn("[ResumenSemanal] Error al enviar:", e); }
  }

  // ============================================================
  // BÚSQUEDA GLOBAL — Ctrl+K
  // ============================================================
  (function() {
    const modal    = document.getElementById("modal-busqueda-global")!;
    const input    = document.getElementById("busqueda-global-input") as HTMLInputElement;
    const resDiv   = document.getElementById("busqueda-global-resultados")!;
    let idxActivo  = -1;

    const abrir = () => { modal.style.display = "flex"; input.value = ""; resDiv.innerHTML = ""; idxActivo = -1; setTimeout(() => input.focus(), 50); };
    const cerrar = () => { modal.style.display = "none"; };

    document.addEventListener("keydown", (e: KeyboardEvent) => {
      if ((e.ctrlKey || e.metaKey) && e.key === "k") { e.preventDefault(); abrir(); return; }
      if (e.key === "Escape") { cerrar(); return; }
    });
    modal.addEventListener("click", (e) => { if (e.target === modal) cerrar(); });

    const mark = (txt: string, q: string) => {
      if (!q) return txt;
      const idx = txt.toLowerCase().indexOf(q.toLowerCase());
      if (idx < 0) return txt;
      return txt.slice(0, idx) + `<mark style="background:rgba(99,102,241,0.3);color:var(--text-bright);border-radius:3px;">${txt.slice(idx, idx + q.length)}</mark>` + txt.slice(idx + q.length);
    };

    const navegar = (seccion: string, filtro?: string) => { cerrar(); navegarA(seccion, filtro || ""); };

    const buscar = () => {
      const q = input.value.trim();
      if (q.length < 2) { resDiv.innerHTML = `<div style="text-align:center;padding:24px;color:var(--text-muted);font-size:0.85rem;">Escribe al menos 2 caracteres para buscar...</div>`; return; }
      const ql = q.toLowerCase();
      const grupos: string[] = [];

      // Empresas
      const empRes = clientes.filter((c: any) => (c.EMPRESA||"").toLowerCase().includes(ql) || (c.RFC||"").toLowerCase().includes(ql) || (c.CONTACTO||"").toLowerCase().includes(ql)).slice(0, 5);
      if (empRes.length) {
        grupos.push(`<div class="bg-grupo-label">🏢 Empresas</div>`);
        empRes.forEach((c: any) => grupos.push(`<div class="bg-resultado" data-seccion="empresas" data-buscar="${c.EMPRESA}"><span class="bg-resultado-icon">🏢</span><div><div class="bg-resultado-titulo">${mark(c.EMPRESA||"", q)}</div><div class="bg-resultado-sub">${c.RFC||""} · ${c.CONTACTO||""}</div></div></div>`));
      }

      // Contactos
      const ctRes = contactos.filter((c: any) => (c.nombre||"").toLowerCase().includes(ql) || (c.correo||"").toLowerCase().includes(ql) || (c.empresa||"").toLowerCase().includes(ql)).slice(0, 4);
      if (ctRes.length) {
        grupos.push(`<div class="bg-grupo-label">📇 Contactos</div>`);
        ctRes.forEach((c: any) => grupos.push(`<div class="bg-resultado" data-seccion="contactos"><span class="bg-resultado-icon">📇</span><div><div class="bg-resultado-titulo">${mark(c.nombre||"", q)}</div><div class="bg-resultado-sub">${c.empresa||""} · ${c.correo||""}</div></div></div>`));
      }

      // Tickets
      const tkRes = tickets.filter((t: any) => (t.asunto||"").toLowerCase().includes(ql) || (t.empresa||"").toLowerCase().includes(ql) || String(t.numero||"").includes(ql)).slice(0, 4);
      if (tkRes.length) {
        grupos.push(`<div class="bg-grupo-label">🎫 Tickets</div>`);
        tkRes.forEach((t: any) => grupos.push(`<div class="bg-resultado" data-seccion="tickets"><span class="bg-resultado-icon">🎫</span><div><div class="bg-resultado-titulo">#${t.numero} — ${mark(t.asunto||"", q)}</div><div class="bg-resultado-sub">${t.empresa||""} · ${t.estado||""}</div></div></div>`));
      }

      // KB (base de conocimiento)
      const kbRes = (window as any)._kbDocs ? (window as any)._kbDocs.filter((d: any) => (d.title||"").toLowerCase().includes(ql) || (d.content||"").toLowerCase().includes(ql)).slice(0, 3) : [];
      if (kbRes.length) {
        grupos.push(`<div class="bg-grupo-label">📚 Base de Conocimiento</div>`);
        kbRes.forEach((d: any) => grupos.push(`<div class="bg-resultado" data-seccion="knowledge"><span class="bg-resultado-icon">📄</span><div><div class="bg-resultado-titulo">${mark(d.title||"", q)}</div><div class="bg-resultado-sub">${d.category||""}</div></div></div>`));
      }

      resDiv.innerHTML = grupos.length ? grupos.join("") : `<div style="text-align:center;padding:24px;color:var(--text-muted);font-size:0.85rem;">Sin resultados para "<strong>${q}</strong>"</div>`;
      idxActivo = -1;

      resDiv.querySelectorAll<HTMLElement>(".bg-resultado").forEach(el => {
        el.addEventListener("click", () => {
          const buscar = el.dataset.buscar || "";
          navegar(el.dataset.seccion || "dashboard");
          if (buscar) {
            setTimeout(() => {
              const inp = document.getElementById("search-empresas") as HTMLInputElement;
              if (inp) { inp.value = buscar; inp.dispatchEvent(new Event("input")); }
            }, 200);
          }
        });
      });
    };

    input.addEventListener("input", buscar);

    input.addEventListener("keydown", (e: KeyboardEvent) => {
      const items = Array.from(resDiv.querySelectorAll<HTMLElement>(".bg-resultado"));
      if (!items.length) return;
      if (e.key === "ArrowDown") { e.preventDefault(); idxActivo = Math.min(idxActivo + 1, items.length - 1); items.forEach((el, i) => el.classList.toggle("bg-activo", i === idxActivo)); items[idxActivo]?.scrollIntoView({ block: "nearest" }); }
      if (e.key === "ArrowUp")   { e.preventDefault(); idxActivo = Math.max(idxActivo - 1, 0); items.forEach((el, i) => el.classList.toggle("bg-activo", i === idxActivo)); items[idxActivo]?.scrollIntoView({ block: "nearest" }); }
      if (e.key === "Enter" && idxActivo >= 0) items[idxActivo]?.click();
    });
  })();

})();
</script>

<!-- MODAL: Crear punto de restauración GitHub -->
<div id="modal-gh-punto" style="display:none; position:fixed; inset:0; z-index:4000; background:rgba(0,0,0,0.75); align-items:center; justify-content:center; padding:20px; backdrop-filter:blur(4px);">
  <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--radius-xl); padding:28px 30px; width:100%; max-width:440px; box-shadow:0 20px 60px rgba(0,0,0,0.5);">
    <div style="font-size:1rem; font-weight:800; color:var(--text-bright); font-family:var(--font-heading); margin-bottom:6px;">🔖 Crear punto de restauración</div>
    <p style="font-size:0.78rem; color:var(--text-muted); margin-bottom:20px; line-height:1.5;">Se creará un tag anotado en GitHub apuntando al commit actual de <strong style="color:var(--text-main);">main</strong>.</p>
    <div class="form-group" style="margin-bottom:14px;">
      <label>Nombre del punto</label>
      <input id="gh-punto-nombre" type="text" placeholder="v2025.06.25-kb-completo" style="font-size:0.85rem;">
      <span style="font-size:0.7rem; color:var(--text-muted); margin-top:3px; display:block;">Sin espacios. Ejemplo: v1.2-fix-login</span>
    </div>
    <div class="form-group" style="margin-bottom:20px;">
      <label>Descripción (opcional)</label>
      <input id="gh-punto-desc" type="text" placeholder="Base de Conocimiento completa + pizarra" style="font-size:0.85rem;">
    </div>
    <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
      <button id="btn-gh-punto-crear" class="btn btn-primary btn-sm">🔖 Crear</button>
      <button id="btn-gh-punto-cancelar" class="btn btn-ghost btn-sm">Cancelar</button>
      <span id="gh-punto-status2" style="font-size:0.78rem; display:none;"></span>
    </div>
  </div>
</div>
<!-- Modal confirmación genérico -->
<div id="confirm-modal-overlay">
  <div id="confirm-modal-box">
    <div id="confirm-modal-icon">⚠️</div>
    <div id="confirm-modal-msg">¿Confirmar acción?</div>
    <div id="confirm-modal-actions">
      <button id="confirm-modal-cancel">Cancelar</button>
      <button id="confirm-modal-ok">Confirmar</button>
    </div>
  </div>
</div>

<!-- Lightbox logo empresa -->
<div id="logo-lightbox" role="dialog" aria-modal="true">
  <img id="logo-lightbox-img" alt="Logo empresa">
</div>
</body>
