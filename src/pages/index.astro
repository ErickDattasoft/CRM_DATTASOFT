    const f = e.target.files[0];
    if (!f) return;
    try {
      const reader = new FileReader();
      reader.onload = async (ev) => {
        try {
          const data = new Uint8Array(ev.target.result);
          const wb = XLSX.read(data, { type: 'array' });

          // Lee una hoja detectando automáticamente la fila de encabezados (la que más columnas tiene)
          const leerHojaInteligente = (sheet) => {
            // Leer todo como filas crudas (sin asumir que la fila 1 es el encabezado)
            const rawRows = XLSX.utils.sheet_to_json(sheet, { header: 1, defval: '' }) as any[][];
            if (!rawRows.length) return [];
            // Encontrar la fila con más celdas no vacías → ese es el encabezado real
            let headerIdx = 0, maxCols = 0;
            rawRows.forEach((row, i) => {
              const nonEmpty = row.filter(v => v !== '' && v !== null && v !== undefined).length;
              if (nonEmpty > maxCols) { maxCols = nonEmpty; headerIdx = i; }
            });
            const headerRow = rawRows[headerIdx] as string[];
            console.log('[Import] Encabezado encontrado en fila', headerIdx + 1, '→', headerRow);
            // Construir objetos clave-valor para cada fila de datos
            return rawRows.slice(headerIdx + 1)
              .filter(row => row.some(v => v !== '' && v !== null && v !== undefined))
              .map(row => {
                const obj: any = {};
                headerRow.forEach((key, i) => { if (key) obj[String(key).trim()] = row[i] ?? ''; });
                return obj;
              });
          };

          // Elegir la hoja con MÁS columnas (datos más completos)
          const sheetRanking = wb.SheetNames.map(name => {
            const rows = XLSX.utils.sheet_to_json(wb.Sheets[name], { header: 1, defval: '' }) as any[][];
            const maxCols = Math.max(0, ...rows.map(r => r.filter(v => v !== '').length));
            return { name, cols: maxCols };
          }).sort((a, b) => b.cols - a.cols);
          const sheetDefault = wb.SheetNames.find(n => /empresa|cliente/i.test(n)) || sheetRanking[0]?.name || wb.SheetNames[0];

          let clientesArr = leerHojaInteligente(wb.Sheets[sheetDefault]);
          let contactosArr = clientesArr; // misma hoja — contactos se derivan de empresas
          console.log('[Import] Hoja:', sheetDefault, '| Columnas detectadas:', Object.keys(clientesArr[0] || {}));

          // helpers para mapear cabeceras
          const normalize = (s) => (s||'').toString().normalize('NFKD').replace(/\p{Diacritic}/gu, '').replace(/[^a-z0-9]/gi,'').toLowerCase();
          const findKeyByNames = (sampleObj, candidates=[]) => {
            const keys = Object.keys(sampleObj||{});
            for (const c of candidates) {
              const nc = normalize(c);
              for (const k of keys) if (normalize(k) === nc) return k;
            }
            // try partial contains
            for (const k of keys) {
              const nk = normalize(k);
              for (const c of candidates) if (nk.includes(normalize(c))) return k;
            }
            return null;
          };

          let sampleCli = clientesArr[0] || {};
          const sampleCt = contactosArr[0] || {};

          // ── Función para (re)calcular el mapeo de columnas ──────────
          const calcularMapeo = (sample) => ({
            empresaKey:   findKeyByNames(sample, ['empresa','empresas','razon social','razon_social','company','nombre empresa']),
            contactoKey:  findKeyByNames(sample, ['contacto principal','contacto','contactos','nombre','name','representante']),
            contacto2Key: findKeyByNames(sample, ['contacto alternativo','contacto2','contacto alt','contacto_2','contactoalternativo']),
            correoKey:    findKeyByNames(sample, ['correo electronico contacto principal','correo contacto principal','correo principal','correo','correo electronico','email','mail']),
            correo2Key:   findKeyByNames(sample, ['correo electronico contacto alternativo','correo alternativo','correo2','correo_2']),
            telKey:       findKeyByNames(sample, ['telefono contacto principal','telefono principal','telefono1','telefono_1','telefono','phone','celular']),
            tel2Key:      findKeyByNames(sample, ['telefono contacto alternativo','telefono alternativo','telefono2','telefono_2']),
            rfcKey:       findKeyByNames(sample, ['rfc','r.f.c','registro federal','tax id']),
          });
          let mapeo = calcularMapeo(sampleCli);

          // Normalizar y validar correos antes de guardar en localStorage
          const normalizeEmailRaw = (s) => {
            if (!s && s !== 0) return '';
            let t = String(s).trim();
            if (!t) return '';
            // Reemplazos comunes
            t = t.replace(/\s+/g, '');
            t = t.replace(/\(at\)|\[at\]|\s+at\s+|\s+AT\s+/gi, '@');
            t = t.replace(/[;,]+/g, '');
            // quitar caracteres angulares o comillas
            t = t.replace(/[<>"']/g, '');
            // normalizar múltiple arroba
            t = t.replace(/@+/g, '@');
            t = t.toLowerCase();
            return t;
          };
          const isValidEmail = (e) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e);

          let emailsCorregidos = 0;
          let emailsInvalidos = 0;
          const invalidEmailsList = [];

          // helper para buscar clave de email en un objeto
          const findEmailKey = (obj) => {
            const keys = Object.keys(obj||{});
            const candidates = ['correo','correo electronico','correo_electronico','correoelectrico','email','e-mail','mail','correo1','email1'];
            for (const c of candidates) {
              for (const k of keys) if (k && k.toString().toLowerCase().replace(/\s|_|-/g,'').includes(c.replace(/\s|_|-/g,''))) return k;
            }
            return null;
          };

          // Normalizar contactos
          contactosArr.forEach(r => {
            const key = findEmailKey(r) || 'CORREO' || 'EMAIL';
            const orig = r[key] || r['CORREO'] || r['CORREO ELECTRONICO'] || r['EMAIL'] || '';
            const norm = normalizeEmailRaw(orig);
            if (norm && norm !== String(orig).trim()) emailsCorregidos++;
            if (norm && isValidEmail(norm)) {
              r['CORREO'] = norm;
            } else {
              if (norm) {
                emailsInvalidos++;
                invalidEmailsList.push({ source: 'contacto', raw: orig, normalized: norm });
              }
              r['CORREO'] = '';
            }
          });

          // Normalizar emails en clientes (si existen columnas de email)
          clientesArr.forEach(r => {
            const key = findEmailKey(r) || null;
            if (key) {
              const orig = r[key] || '';
              const norm = normalizeEmailRaw(orig);
              if (norm && norm !== String(orig).trim()) emailsCorregidos++;
              if (norm && isValidEmail(norm)) {
                r['CORREO'] = norm;
              } else {
                if (norm) {
                  emailsInvalidos++;
                  invalidEmailsList.push({ source: 'empresa', raw: orig, normalized: norm });
                }
                r['CORREO'] = '';
              }
            } else {
              // si no hay clave, dejar como está o vacio
              r['CORREO'] = r['CORREO'] || '';
            }
          });

          // Respaldo de los datos reales antes de pisarlos con la vista previa — si el usuario
          // cancela, se restauran. Antes, cancelar dejaba la vista previa del Excel viva en
          // memoria, y cualquier guardado no relacionado posterior la subía a Firebase sin querer.
          const clientesAntesImportXls = clientes;
          const contactosAntesImportXls = contactos;

          // Vista previa: cargar en memoria sin tocar localStorage ni Firebase aún
          clientes = normalizeImportedClientes(clientesArr || []);
          contactos = normalizeImportedContactos ? normalizeImportedContactos(contactosArr || []) : (contactosArr || []);
          renderEmpresas();
          renderContactos();

          // Preparar modal de confirmación/resumen
          const modal = document.getElementById('modal-xls-summary');
          if (modal) {
            document.getElementById('xls-summary-msg').textContent = `Se importaron ${clientesArr.length} empresas y ${contactosArr.length} contactos. Correos corregidos: ${emailsCorregidos}. Inválidos: ${emailsInvalidos}. Revisa la vista previa y confirma la subida a Firebase.`;
            const previewCli = document.getElementById('xls-preview-clientes');
            const previewCt = document.getElementById('xls-preview-contactos');
            previewCli.innerHTML = '';
            previewCt.innerHTML = '';

            // Mostrar columnas detectadas / mapeo
            const detectedDivId = 'xls-detected-columns';
            let detDiv = document.getElementById(detectedDivId);
            if (!detDiv) {
              detDiv = document.createElement('div');
              detDiv.id = detectedDivId;
              detDiv.style.marginBottom = '10px';
              detDiv.style.color = 'var(--muted)';
              const anchor = document.getElementById('xls-summary-msg');
              if (anchor) anchor.insertAdjacentElement('afterend', detDiv);
              else modal.prepend(detDiv);
            }
            const detectedHtml = [];
            detectedHtml.push(`<strong>Columnas detectadas (Empresa):</strong> ${Object.keys(sampleCli||{}).join(', ') || '—'}`);
            detectedHtml.push(`<strong>Columnas detectadas (Contacto):</strong> ${Object.keys(sampleCt||{}).join(', ') || '—'}`);
            detectedHtml.push(`<strong>Mapeo inferido:</strong> Empresa → ${mapeo.empresaKey||'(no detectada)'}; Contacto → ${mapeo.contactoKey||'(no detectado)'}; Correo → ${mapeo.correoKey||'(no detectado)'} `);
            detDiv.innerHTML = detectedHtml.join('<br>');
            // Mostrar lista de emails inválidos si existen
            let invalidDiv = document.getElementById('xls-invalid-emails');
            if (!invalidDiv) {
              invalidDiv = document.createElement('div');
              invalidDiv.id = 'xls-invalid-emails';
              invalidDiv.style.marginTop = '8px';
              invalidDiv.style.fontSize = '0.85rem';
              invalidDiv.style.color = 'var(--warning)';
              detDiv.insertAdjacentElement('afterend', invalidDiv);
            }
            if (invalidEmailsList.length > 0) {
              let editableHtml = `<strong>Correos inválidos detectados (${invalidEmailsList.length}) - Editar:</strong>`;
              editableHtml += `<div style="margin-top:6px; max-height:200px; overflow-y:auto; padding:6px; border:1px solid var(--border-color); border-radius:4px; background:var(--bg-subtle);">`;
              invalidEmailsList.slice(0,50).forEach((x, i) => {
                editableHtml += `<div style="display:flex; gap:6px; margin-bottom:6px; align-items:center; font-size:0.8rem;">`;
                editableHtml += `<span style="flex:1; color:var(--text-light);">[${x.source}]</span>`;
                editableHtml += `<input type="text" id="xls-invalid-edit-${i}" value="${x.normalized}" style="flex:2; padding:4px; border:1px solid var(--border-color); border-radius:3px; background:var(--bg-card); color:var(--text-main);">`;
                editableHtml += `</div>`;
              });
              editableHtml += `</div>`;
              invalidDiv.innerHTML = editableHtml;
            } else {
              invalidDiv.innerHTML = '';
            }

            // Añadir mapeador manual (selects) debajo del bloque detectado
            const mapContainerId = 'xls-map-controls';
            let mapContainer = document.getElementById(mapContainerId);
            if (!mapContainer) {
              mapContainer = document.createElement('div');
              mapContainer.id = mapContainerId;
              mapContainer.style.display = 'flex';
              mapContainer.style.gap = '8px';
              mapContainer.style.marginBottom = '8px';
              detDiv.insertAdjacentElement('afterend', mapContainer);
            }
            mapContainer.innerHTML = '';
            const makeSelect = (id, label, keys, selected) => {
              const wrapper = document.createElement('div');
              wrapper.style.cssText = 'display:flex;flex-direction:column;min-width:160px;';
              const lab = document.createElement('label');
              lab.style.cssText = 'font-size:0.75rem;margin-bottom:3px;color:var(--text-muted);';
              lab.textContent = label;
              const sel = document.createElement('select');
              sel.id = id;
              sel.style.padding = '5px';
              const noneOpt = document.createElement('option'); noneOpt.value = ''; noneOpt.textContent = '(ninguno)'; sel.appendChild(noneOpt);
              keys.forEach(k => { const o = document.createElement('option'); o.value = k; o.textContent = k; if (k===selected) o.selected = true; sel.appendChild(o); });
              wrapper.appendChild(lab); wrapper.appendChild(sel);
              return wrapper;
            };

            const renderColumnSelects = () => {
              // Limpiar selectores de columna (no el de hoja)
              Array.from(mapContainer.children).forEach(ch => {
                if ((ch as HTMLElement).dataset.role !== 'sheet-selector') ch.remove();
              });
              const allKeys = Object.keys(sampleCli || {});
              const m = calcularMapeo(sampleCli);
              mapContainer.appendChild(makeSelect('xls-map-empresa',   '★ Empresa (obligatorio)',  allKeys, m.empresaKey   || allKeys[0]));
              mapContainer.appendChild(makeSelect('xls-map-contacto',  '★ Contacto principal',     allKeys, m.contactoKey  || ''));
              mapContainer.appendChild(makeSelect('xls-map-contacto2', 'Contacto alternativo',     allKeys, m.contacto2Key || ''));
              mapContainer.appendChild(makeSelect('xls-map-correo',    'Correo principal',         allKeys, m.correoKey    || ''));
              mapContainer.appendChild(makeSelect('xls-map-correo2',   'Correo alternativo',       allKeys, m.correo2Key   || ''));
              mapContainer.appendChild(makeSelect('xls-map-telefono',  '📱 Celular principal',     allKeys, m.telKey       || ''));
              mapContainer.appendChild(makeSelect('xls-map-telefono2', '📱 Celular alternativo',   allKeys, m.tel2Key      || ''));
              mapContainer.appendChild(makeSelect('xls-map-rfc',       'RFC',                      allKeys, m.rfcKey       || ''));
            };

            // Selector de hoja (primero, destacado)
            mapContainer.style.cssText = 'display:flex;flex-wrap:wrap;gap:8px;margin-bottom:8px;';
            const sheetWrapper = document.createElement('div');
            sheetWrapper.dataset.role = 'sheet-selector';
            sheetWrapper.style.cssText = 'display:flex;flex-direction:column;min-width:200px;background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.3);border-radius:6px;padding:6px 8px;';
            const sheetLabel = document.createElement('label');
            sheetLabel.style.cssText = 'font-size:0.75rem;font-weight:700;color:#a5b4fc;margin-bottom:3px;';
            sheetLabel.textContent = '📋 Hoja del Excel';
            const sheetSel = document.createElement('select');
            sheetSel.id = 'xls-map-hoja';
            sheetSel.style.padding = '5px';
            wb.SheetNames.forEach(name => {
              const sample = XLSX.utils.sheet_to_json(wb.Sheets[name])[0] || {};
              const cols = Object.keys(sample).length;
              const o = document.createElement('option');
              o.value = name;
              o.textContent = `${name} (${cols} columnas)`;
              if (name === sheetDefault) o.selected = true;
              sheetSel.appendChild(o);
            });
            sheetSel.addEventListener('change', () => {
              clientesArr = leerHojaInteligente(wb.Sheets[sheetSel.value]);
              contactosArr = clientesArr;
              sampleCli = clientesArr[0] || {};
              renderColumnSelects();
            });
            sheetWrapper.appendChild(sheetLabel); sheetWrapper.appendChild(sheetSel);
            mapContainer.appendChild(sheetWrapper);
            renderColumnSelects();

            // función para renderizar preview según mapeo actual
            const renderPreview = () => {
              previewCli.innerHTML = '';
              previewCt.innerHTML = '';
              const mEmp = document.getElementById('xls-map-empresa')?.value;
              const mCt = document.getElementById('xls-map-contacto')?.value;
              const mMail = document.getElementById('xls-map-correo')?.value;
              const mTel = document.getElementById('xls-map-telefono')?.value;
              const mEmpMail = document.getElementById('xls-map-empresa-correo')?.value;
              clientesArr.slice(0,5).forEach((r) => {
                const tr = document.createElement('tr');
                const val = mEmp ? (r[mEmp] || '—') : (r.EMPRESA||r.Empresa||r.company||r['RAZON SOCIAL']||'—');
                const tel = mTel ? (r[mTel] || '') : (r.TELEFONO||r.TELEFONO1||'');
                const empMail = mEmpMail ? (r[mEmpMail] ? (' - '+r[mEmpMail]) : '') : (r.CORREO?(' - '+r.CORREO):'');
                tr.innerHTML = `<td style="padding:6px; border-bottom:1px solid var(--border-subtle);">${val}${tel?(' — '+tel):''}${empMail}</td>`;
                previewCli.appendChild(tr);
              });
              contactosArr.slice(0,5).forEach((r) => {
                const tr = document.createElement('tr');
                const name = mCt ? (r[mCt] || '—') : (r.CONTACTO||r['CONTACTO PRINCIPAL']||r.nombre||r.name||'—');
                const mail = mMail ? (r[mMail] ? (' - '+r[mMail]) : '') : (r.CORREO?(' - '+r.CORREO):'');
                tr.innerHTML = `<td style="padding:6px; border-bottom:1px solid var(--border-subtle);">${name}${mail}</td>`;
                previewCt.appendChild(tr);
              });
            };

            // actualizar preview cuando cambien selects
            ['xls-map-empresa','xls-map-contacto','xls-map-correo'].forEach(id => {
              document.getElementById(id)?.addEventListener('change', renderPreview);
            });

            // render inicial
            renderPreview();
            // deshabilitar el botón de subir hasta mapear Empresa y Contacto
            const btnUpload = document.getElementById('btnXlsConfirmUpload');
            if (btnUpload) {
              const ensureToggle = () => {
                const ok = Boolean(document.getElementById('xls-map-empresa')?.value && document.getElementById('xls-map-contacto')?.value);
                btnUpload.disabled = !ok;
                btnUpload.style.opacity = ok ? '1' : '0.5';
              };
              // inicial
              ensureToggle();
              ['xls-map-empresa','xls-map-contacto','xls-map-correo','xls-map-telefono','xls-map-empresa-correo'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.addEventListener('change', ensureToggle);
              });
            }
            modal.style.display = 'flex';

            // Setup modal buttons
            const cancelarImportXls = () => {
              modal.style.display = 'none';
              clientes = clientesAntesImportXls;
              contactos = contactosAntesImportXls;
              renderEmpresas();
              renderContactos();
            };
            document.getElementById('btnCerrarXlsSummary2').onclick = cancelarImportXls;
            document.getElementById('btnCerrarXlsSummary').onclick = cancelarImportXls;

            document.getElementById('btnXlsDescargarRespaldo').onclick = () => {
              const backup = { clientes, contactos, ts: new Date().toISOString() };
              const blob = new Blob([JSON.stringify(backup, null, 2)], { type: 'application/json' });
              const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
              a.download = `respaldo-crm-${new Date().toISOString().slice(0,10)}.json`; a.click();
              toast('⬇️ Respaldo descargado');
            };

            document.getElementById('btnXlsConfirmUpload').onclick = async () => {
              // Re-detectar mapeo desde los datos actuales (más confiable que leer los SELECTs)
              const currentSheet = (document.getElementById('xls-map-hoja') as HTMLSelectElement)?.value || sheetDefault;
              const currentArr   = leerHojaInteligente(wb.Sheets[currentSheet]);
              const currentSample = (currentArr[0] as any) || {};
              const autoM = calcularMapeo(currentSample);
              console.log('[Import] Hoja final:', currentSheet, '| Columnas:', Object.keys(currentSample));
              console.log('[Import] AutoMapeo → ct2:', autoM.contacto2Key, '| mail2:', autoM.correo2Key, '| tel2:', autoM.tel2Key);

              // SELECT tiene prioridad; si está vacío usa auto-detección
              const mEmp  = (document.getElementById('xls-map-empresa')  as HTMLSelectElement)?.value || autoM.empresaKey  || '';
              const mCt   = (document.getElementById('xls-map-contacto') as HTMLSelectElement)?.value || autoM.contactoKey || '';
              if (!mEmp) {
                alert('Por favor selecciona la columna de Empresa antes de subir.');
                modal.style.display = 'flex';
                return;
              }
              if (!await confirmar(`Esto REEMPLAZARÁ todas las empresas y contactos actuales con los datos del Excel.\n\n¿Ya descargaste el respaldo? Continuar de todos modos?`, "⚠️")) return;
              modal.style.display = 'none';
              mostrarEstado('🔄 Subiendo datos a Firebase...');
              // Usar datos de la hoja seleccionada
              clientesArr = currentArr as any[];
              contactosArr = clientesArr;
              try {
                const mCt2   = (document.getElementById('xls-map-contacto2')  as HTMLSelectElement)?.value || autoM.contacto2Key || '';
                const mMail  = (document.getElementById('xls-map-correo')     as HTMLSelectElement)?.value || autoM.correoKey   || '';
                const mMail2 = (document.getElementById('xls-map-correo2')    as HTMLSelectElement)?.value || autoM.correo2Key  || '';
                const mTel   = (document.getElementById('xls-map-telefono')   as HTMLSelectElement)?.value || autoM.telKey      || '';
                const mTel2  = (document.getElementById('xls-map-telefono2')  as HTMLSelectElement)?.value || autoM.tel2Key     || '';
                const mRfc   = (document.getElementById('xls-map-rfc')        as HTMLSelectElement)?.value || autoM.rfcKey      || '';
                console.log('[Import] Mapeo final → mCt2:', mCt2, '| mMail2:', mMail2, '| mTel2:', mTel2);

                // Convierte cualquier valor de celda Excel a string seguro para Firestore
                const xs = v => {
                  if (v === null || v === undefined) return '';
                  if (v instanceof Date) return v.toISOString().slice(0,10);
                  if (typeof v === 'object') return '';
                  return String(v).trim();
                };
                const col = (r, key) => key ? xs(r[key]) : '';

                // Mapear empresas desde el Excel — preservar versiones/vencimientos existentes
                const mappedClientes = (clientesArr||[]).map(r => {
                  // Buscar nombre de empresa en todas las columnas posibles
                  const empRaw = col(r, mEmp) || xs(r.EMPRESA) || xs(r.Empresa) || xs(r.empresa) || '';
                  const empNorm = empRaw.toUpperCase().trim();
                  if (!empNorm || empNorm === 'UNDEFINED') return null;
                  const previa = clientes.find(c => (c.EMPRESA||'').toUpperCase().trim() === empNorm);
                  return {
                    EMPRESA:     empNorm,
                    CONTACTO:    col(r, mCt)   || xs(r['Contacto principal']) || xs(r.CONTACTO) || '',
                    CONTACTO_2:  col(r, mCt2)  || '',
                    CORREO:      (col(r, mMail)  || '').toLowerCase(),
                    CORREO_2:    (col(r, mMail2) || '').toLowerCase(),
                    RFC:         col(r, mRfc) || xs(previa?.RFC) || '',
                    TELEFONO_1:  col(r, mTel)  || '',
                    TELEFONO_2:  col(r, mTel2) || '',
                    FAVORITO:    previa?.FAVORITO === true,
                    CAMPOS_EXTRAS: previa?.CAMPOS_EXTRAS || {},
                    SISTEMAS:      previa?.SISTEMAS      || {},
                    VENCIMIENTOS:  previa?.VENCIMIENTOS  || {}
                  };
                }).filter(Boolean);

                if (mappedClientes.length === 0) {
                  toast('⚠️ No se detectaron empresas. Verifica que la columna "Empresa" esté seleccionada correctamente.');
                  ocultarEstado();
                  return;
                }

                // Sanitización profunda: garantiza que no haya undefined, funciones, ni tipos inválidos para Firestore
                const fsClean = (v) => {
                  if (v === undefined || v === null) return null;
                  if (typeof v === 'function' || typeof v === 'symbol') return null;
                  if (typeof v === 'number') return isFinite(v) ? v : null;
                  if (typeof v === 'boolean' || typeof v === 'string') return v;
                  if (v instanceof Date) return v.toISOString();
                  if (Array.isArray(v)) return v.map(fsClean).filter(x => x !== undefined);
                  if (typeof v === 'object') {
                    const out = {};
                    for (const [k, val] of Object.entries(v)) {
                      if (typeof k === 'string' && k.length > 0) out[k] = fsClean(val);
                    }
                    return out;
                  }
                  return String(v);
                };
                const cleanedClientes = mappedClientes.map(fsClean);

                // DEBUG: mostrar columna detectada para CONTACTO_2
                const ct2Count = mappedClientes.filter(e => e.CONTACTO_2).length;
                console.log('[Import] mCt2 =', mCt2, '| empresas con CONTACTO_2:', ct2Count);
                console.log('[Import] Ejemplo CONTACTO_2:', mappedClientes.find(e => e.CONTACTO_2)?.CONTACTO_2 || '(ninguno)');
                console.log('[Import] Primera empresa completa:', JSON.stringify(cleanedClientes[0]));

                // Contactos desde empresa: principal + alternativo
                const mappedContactos: any[] = [];
                mappedClientes.forEach(e => {
                  if (e.CONTACTO) {
                    mappedContactos.push({ nombre: e.CONTACTO, correo: e.CORREO || '', telefono1: e.TELEFONO_1 || '', telefono2: '', empresa: e.EMPRESA });
                  }
                  if (e.CONTACTO_2) {
                    mappedContactos.push({ nombre: e.CONTACTO_2, correo: e.CORREO_2 || '', telefono1: e.TELEFONO_2 || '', telefono2: '', empresa: e.EMPRESA });
                  }
                });

                const ctPrincipales = mappedContactos.filter(c => mappedClientes.find(e => e.CONTACTO === c.nombre && e.EMPRESA === c.empresa)).length;
                const ctAlternativos = mappedContactos.length - ctPrincipales;
                console.log('[Import] Contactos totales:', mappedContactos.length, '| principales:', ctPrincipales, '| alternativos:', ctAlternativos);

                // Guardar empresas primero
                const okCli = await guardarClientes(cleanedClientes);
                if (okCli === true) {
                  clientes = mappedClientes;
                  renderEmpresas(); renderDashboard();
                } else {
                  toast(`⚠️ Error al guardar empresas: ${okCli?.error || 'revisa la consola'}`);
                  ocultarEstado(); return;
                }

                // Guardar contactos y forzar re-render después para ganar la race condition con onSnapshot
                const okCt = await guardarContactos(mappedContactos);
                if (okCt === true) {
                  contactos = mappedContactos;
                  renderContactos();
                  renderDashboard();
                  // Re-render adicional tras 1.5s para asegurar que onSnapshot no sobreescriba
                  setTimeout(() => {
                    contactos = mappedContactos;
                    renderContactos();
                  }, 1500);
                }

                toast(`✅ ${mappedClientes.length} empresas · ${mappedContactos.length} contactos (${ctAlternativos} alternativos) importados`);
              } catch (err) {
                console.error('Error subiendo a Firebase:', err);
                toast('❌ Error subiendo a Firebase. Revisa la consola.');
              } finally {
                ocultarEstado();
              }
            };
          }
        } catch (err) {
          console.error('Error parseando Excel:', err);
          alert('Error leyendo el archivo Excel. Revisa el formato.');
        }
      };
      reader.readAsArrayBuffer(f);
    } catch (err) {
      console.error(err);
      alert('No se pudo leer el archivo.');
