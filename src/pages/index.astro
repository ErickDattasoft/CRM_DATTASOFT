  function prepararEdicionEmpresa(e) {
    const idx = parseInt(e.target.closest("button").dataset.idx);
    const c = clientes[idx];
    cerrarFormEmpresa();
    document.getElementById("form-emp-titulo").textContent = "✏️ Editar Empresa";
    editEmpIdx.value = idx;
    document.getElementById("form-empresa").value = c.EMPRESA;
    document.getElementById("form-contacto").value = c.CONTACTO || "";
    document.getElementById("form-correo").value = c.CORREO || "";
    document.getElementById("form-empresa-rfc").value = c.RFC || "";
    document.getElementById("form-telefono1").value = c.TELEFONO_1 || "";
    document.getElementById("form-telefono2").value = c.TELEFONO_2 || "";
    // En modo edición mostrar todos los campos
    document.querySelectorAll(".form-emp-extras").forEach(el => el.classList.remove("hidden"));
    document.getElementById("form-emp-campos-extra-section")?.classList.remove("hidden");
    document.getElementById("form-emp-sistemas-section")?.classList.remove("hidden");
    document.getElementById("form-emp-contacto-select")?.classList.add("hidden");
    document.getElementById("form-contacto")?.classList.remove("hidden");
    if (c.CAMPOS_EXTRAS) {
      Object.entries(c.CAMPOS_EXTRAS).forEach(([k, v]) => crearInputCampoExtra(k, v));
    }
    listaSistemas.forEach(s => {
      const k = s.toUpperCase().trim();
      let v = c.SISTEMAS?.[k] || "";
      if (v === "No aplica") v = "";
      const inp = document.getElementById(`sys-${s.replace(/\s+/g, '_')}`);
      if (inp) inp.value = v;
    });
    formEmp?.classList.remove("hidden");
    formEmp?.scrollIntoView({ behavior: "smooth" });
  }

  document.getElementById("btnGuardarEmpresa")?.addEventListener("click", async () => {
    const idx = editEmpIdx.value;
    const nombre = document.getElementById("form-empresa").value.trim().toUpperCase();
    if (!nombre) return;

    const extras = {};
    document.querySelectorAll(".input-campo-extra").forEach(inp => {
      extras[inp.dataset.campo] = inp.value.trim();
    });

    // En modo nuevo, el contacto viene del select; en edición, del input de texto
    const selCt = document.getElementById("form-emp-contacto-select");
    const useSelect = selCt && !selCt.classList.contains("hidden");
    const contactoVal = useSelect ? selCt.value.trim() : document.getElementById("form-contacto").value.trim();

    const nuevo = {
      EMPRESA: nombre,
      CONTACTO: contactoVal,
      CORREO: document.getElementById("form-correo").value.trim(),
      RFC: document.getElementById("form-empresa-rfc").value.trim(),
      TELEFONO_1: document.getElementById("form-telefono1").value.trim(),
      TELEFONO_2: document.getElementById("form-telefono2").value.trim(),
      FAVORITO: idx !== "" ? clientes[parseInt(idx)]?.FAVORITO || false : false,
      CAMPOS_EXTRAS: extras,
      SISTEMAS: {}
    };

    listaSistemas.forEach(s => {
      const inp = document.getElementById(`sys-${s.replace(/\s+/g, '_')}`);
      const v = inp ? inp.value.trim() : "";
      nuevo.SISTEMAS[s.toUpperCase().trim()] = v === "" ? "No aplica" : v;
    });

    if (idx === "") clientes.push(nuevo);
    else clientes[parseInt(idx)] = nuevo;

    // Sync: si la empresa tiene contacto+correo, crear/actualizar el contacto correspondiente
    if (nuevo.CONTACTO && nuevo.CORREO) {
      const existe = contactos.find(c => c.correo && c.correo.toLowerCase() === nuevo.CORREO.toLowerCase());
      if (!existe) {
        contactos.push({ nombre: nuevo.CONTACTO, correo: nuevo.CORREO, telefono1: nuevo.TELEFONO_1 || "", telefono2: nuevo.TELEFONO_2 || "", empresa: nuevo.EMPRESA });
        if (crmLocalOnly) guardarLocal("crm_contactos", contactos); else guardarContactos(contactos);
      } else if (!existe.empresa) {
        existe.empresa = nuevo.EMPRESA;
        if (crmLocalOnly) guardarLocal("crm_contactos", contactos); else guardarContactos(contactos);
      }
    }

    guardarLocal("crm_clientes", clientes); // respaldo local siempre primero
    if (crmLocalOnly) {
      toast("💾 Empresa guardada (Local)");
      cerrarFormEmpresa();
      renderEmpresas();
      renderDashboard();
      return;
    }
    mostrarEstado("💾 Guardando...");
    const ok = await guardarClientes(clientes);
    if (ok) { toast("💾 Empresa guardada"); ocultarEstado(); }
    else { mostrarEstado("⚠️ Guardado localmente (sin conexión)", 3000); }
    cerrarFormEmpresa();
    renderEmpresas();
    renderDashboard();
  });

