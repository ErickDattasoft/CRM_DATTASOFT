  async function descargarBackupCompleto() {
    const backup = {
      version: "2.0",
      app: "CRM DATTASOFT",
      fecha: new Date().toISOString(),
      datos: {
        clientes,
        contactos,
        tickets,
        versionesMercado,
        cartasTecnicas,
