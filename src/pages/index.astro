      const needsNormalization = Boolean(sampleCt.CONTACTO || sampleCt['CONTACTO PRINCIPAL'] || sampleCt.CONTACTOS) && !sampleCt.nombre;
      if (needsNormalization) {
        contactos = normalizeImportedContactos(contactos);
