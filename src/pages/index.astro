  // ============================================================
  // COTIZACIONES
  // ============================================================

  function formatMoney(n) {
    return new Intl.NumberFormat("es-MX", { style: "currency", currency: "MXN" }).format(Number(n) || 0);
  }

  function fechaISO(d) { return d.toISOString().slice(0, 10); }

  function subtotalLineaConcepto(c) {
    return (Number(c.cantidad) || 0) * (Number(c.precioUnitario) || 0) * (1 - (Number(c.descuento) || 0) / 100);
  }

  function calcularTotalesCotizacion(conceptos) {
    let subtotalGeneral = 0, totalIVA = 0;
    (conceptos || []).forEach(c => {
      const sub = subtotalLineaConcepto(c);
      subtotalGeneral += sub;
      if (c.tieneIVA !== false) totalIVA += sub * 0.16;
    });
    return { subtotalGeneral, totalIVA, total: subtotalGeneral + totalIVA };
  }

  // "Vencida" se calcula al vuelo para listar/filtrar — nunca se persiste en Firestore, para no
  // generar escrituras automáticas silenciosas cada vez que alguien abre el CRM.
  function cotizacionEsVencida(c) {
    if (!c.fechaVigencia) return false;
    if (c.estado !== "borrador" && c.estado !== "enviada") return false;
    return new Date(c.fechaVigencia) < new Date(new Date().toDateString());
  }
  function estadoVisualCotizacion(c) {
    return cotizacionEsVencida(c) ? "vencida" : (c.estado || "borrador");
  }

  // Sincroniza el RFC de la empresa desde una cotización — mismo patrón que
  // sincronizarEmpresaDesdeContactos: prefiere el valor recién capturado, mutando en sitio el
  // array `clientes` y guardando. Solo escribe si el RFC realmente cambió (evita bitácora/escrituras
  // de más en cada guardado si el usuario no tocó el campo).
  function sincronizarRFCEmpresaDesdeCotizacion(empresaNombre, rfc) {
    if (!empresaNombre || !rfc) return;
    const empIdx = clientes.findIndex(c => (c.EMPRESA || "").toLowerCase() === empresaNombre.toLowerCase());
    if (empIdx === -1) return;
    if (clientes[empIdx].RFC === rfc) return;
    clientes[empIdx] = { ...clientes[empIdx], RFC: rfc };
    if (crmLocalOnly) guardarLocal("crm_clientes", clientes); else guardarClientes(clientes);
    logBitacora(`RFC de "${empresaNombre}" actualizado desde cotización`, "🔄");
    renderEmpresas();
  }

  // ----- Lista -----
  function renderCotizaciones() {
    const tbody = document.getElementById("tabla-cotizaciones-body");
    if (!tbody) return;
    tbody.innerHTML = "";

    const busq = document.getElementById("txtBuscarCotizacion")?.value.toLowerCase().trim() || "";
    const fEstado = document.getElementById("selectFiltroEstadoCot")?.value || "";

    const filtradas = cotizaciones.map((c, i) => ({ ...c, _idx: i })).filter(c => {
      const estadoVisual = estadoVisualCotizacion(c);
      if (fEstado && estadoVisual !== fEstado) return false;
      if (busq) {
        return (c.empresaNombre || "").toLowerCase().includes(busq) ||
               (c.numero || "").toLowerCase().includes(busq);
      }
      return true;
    }).sort((a, b) => (b.numero || "").localeCompare(a.numero || ""));

    filtradas.forEach(c => {
      const totales = calcularTotalesCotizacion(c.conceptos);
      const estadoVisual = estadoVisualCotizacion(c);
      const tr = document.createElement("tr");
      tr.dataset.idx = c._idx;
      if (estadoVisual === "vencida") tr.style.color = "#f87171";
      tr.innerHTML = `
        <td style="font-weight:700;">${escapeHtml(c.numero) || "—"}</td>
        <td>${escapeHtml(c.empresaNombre) || "—"}</td>
        <td style="font-size:0.8rem;">${c.fechaCreacion ? new Date(c.fechaCreacion).toLocaleDateString() : "—"}</td>
        <td style="font-size:0.8rem;">${c.fechaVigencia ? new Date(c.fechaVigencia).toLocaleDateString() : "—"}</td>
        <td style="text-align:right; font-weight:600;">${formatMoney(totales.total)}</td>
        <td style="text-align:center;"><span class="badge badge-${slugBadge(estadoVisual)}">${escapeHtml(estadoVisual)}</span></td>
        <td style="text-align:center;">
          <div style="display:inline-flex; gap:4px;">
            <button class="btn btn-primary btn-xs btn-edit-cot" data-idx="${c._idx}" title="Editar">✏️</button>
            <button class="btn btn-secondary btn-xs btn-pdf-cot" data-idx="${c._idx}" title="PDF">📄</button>
            <button class="btn btn-secondary btn-xs btn-mail-cot" data-idx="${c._idx}" title="Enviar correo">✉️</button>
            <button class="btn btn-ghost btn-xs btn-dup-cot" data-idx="${c._idx}" title="Duplicar">📋</button>
            <button class="btn btn-danger btn-xs btn-del-cot" data-idx="${c._idx}" title="Eliminar">🗑️</button>
          </div>
        </td>
      `;
      tbody.appendChild(tr);
    });

    tbody.querySelectorAll(".btn-edit-cot").forEach(b => b.addEventListener("click", prepararEdicionCotizacion));
    tbody.querySelectorAll(".btn-pdf-cot").forEach(b => b.addEventListener("click", (e) => {
      const idx = parseInt(e.target.closest("button").dataset.idx);
      descargarPDFCotizacion(cotizaciones[idx]);
    }));
    tbody.querySelectorAll(".btn-mail-cot").forEach(b => b.addEventListener("click", (e) => {
      const idx = parseInt(e.target.closest("button").dataset.idx);
      abrirModalEnviarCotizacion(cotizaciones[idx]);
    }));
    tbody.querySelectorAll(".btn-dup-cot").forEach(b => b.addEventListener("click", duplicarCotizacion));
    tbody.querySelectorAll(".btn-del-cot").forEach(b => b.addEventListener("click", eliminarCotizacion));

    const el = id => document.getElementById(id);
    el("cot-count-total").textContent = cotizaciones.length;
    el("cot-count-activas").textContent = cotizaciones.filter(c => c.estado === "borrador" || c.estado === "enviada").length;
    el("cot-count-aceptadas").textContent = cotizaciones.filter(c => c.estado === "aceptada").length;
    el("cot-count-vencidas").textContent = cotizaciones.filter(cotizacionEsVencida).length;
  }
  document.getElementById("txtBuscarCotizacion")?.addEventListener("input", renderCotizaciones);
  document.getElementById("selectFiltroEstadoCot")?.addEventListener("change", renderCotizaciones);

  // ----- Conceptos (tabla editable dentro del formulario) -----
  const tablaCotConceptosBody = document.getElementById("tabla-cot-conceptos-body");
  let conceptosCotActual: any[] = [];

  function actualizarTotalesFormCotizacion() {
    const t = calcularTotalesCotizacion(conceptosCotActual);
    const elSub = document.getElementById("cot-subtotal");
    const elIva = document.getElementById("cot-iva");
    const elTot = document.getElementById("cot-total");
    if (elSub) elSub.textContent = formatMoney(t.subtotalGeneral);
    if (elIva) elIva.textContent = formatMoney(t.totalIVA);
    if (elTot) elTot.textContent = formatMoney(t.total);
  }

  // Actualiza solo las celdas derivadas (dto highlight, subtotal, totales) de una fila sin
  // reconstruir el <tbody> — reconstruirlo en cada tecleo le robaría el foco al input activo.
  function actualizarFilaConceptoCot(i) {
    const row = tablaCotConceptosBody?.querySelector(`tr[data-cidx="${i}"]`);
    if (!row) return;
    const c = conceptosCotActual[i];
    const dtoTd = row.children[3] as HTMLElement;
    if (dtoTd) dtoTd.style.background = (Number(c.descuento) > 0) ? "rgba(250,204,21,0.15)" : "";
    const subTd = row.children[5] as HTMLElement;
    if (subTd) {
      const bruto = (Number(c.cantidad) || 0) * (Number(c.precioUnitario) || 0);
      const sub = subtotalLineaConcepto(c);
      subTd.innerHTML = (Number(c.descuento) > 0)
        ? `<span style="text-decoration:line-through; color:var(--text-muted); font-size:0.72rem; display:block;">${formatMoney(bruto)}</span>${formatMoney(sub)}`
        : formatMoney(sub);
    }
    actualizarTotalesFormCotizacion();
  }

  function renderConceptosCotizacion() {
    if (!tablaCotConceptosBody) return;
    tablaCotConceptosBody.innerHTML = "";
    conceptosCotActual.forEach((c, i) => {
      const tr = document.createElement("tr");
      tr.dataset.cidx = String(i);
      const bruto = (Number(c.cantidad) || 0) * (Number(c.precioUnitario) || 0);
      const sub = subtotalLineaConcepto(c);
      tr.innerHTML = `
        <td class="autocomplete-wrap">
          <input class="cot-concepto-desc" data-cidx="${i}" value="${escapeHtml(c.descripcion || "")}" placeholder="Descripción o elige del catálogo" autocomplete="off" style="width:100%;">
          <div class="autocomplete-list hidden cot-concepto-catalogo-list" data-cidx="${i}"></div>
          <button type="button" class="btn btn-ghost btn-xs cot-concepto-add-catalogo" data-cidx="${i}" style="margin-top:4px; font-size:0.68rem;" title="Guarda esta descripción, precio y descuento en el Catálogo de Conceptos Rápidos para no volver a escribirla en la próxima cotización">💾 Guardar en catálogo</button>
        </td>
        <td><input type="number" min="0" step="1" class="cot-concepto-cant" data-cidx="${i}" data-field="cantidad" value="${c.cantidad ?? 1}" style="width:100%; text-align:center;"></td>
        <td><input type="number" min="0" step="0.01" class="cot-concepto-precio" data-cidx="${i}" data-field="precioUnitario" value="${c.precioUnitario ?? 0}" style="width:100%; text-align:right;"></td>
        <td style="${Number(c.descuento) > 0 ? "background:rgba(250,204,21,0.15);" : ""}"><input type="number" min="0" max="100" step="1" class="cot-concepto-dto" data-cidx="${i}" data-field="descuento" value="${c.descuento ?? 0}" style="width:100%; text-align:center;" title="Descuento aplicado a esta línea. Se pre-llena del catálogo pero puedes cambiarlo."></td>
        <td style="text-align:center;"><input type="checkbox" class="cot-concepto-iva" data-cidx="${i}" ${c.tieneIVA !== false ? "checked" : ""}></td>
        <td class="cot-concepto-subtotal" style="text-align:right; font-weight:600;">${Number(c.descuento) > 0 ? `<span style="text-decoration:line-through; color:var(--text-muted); font-size:0.72rem; display:block;">${formatMoney(bruto)}</span>${formatMoney(sub)}` : formatMoney(sub)}</td>
        <td style="text-align:center;"><button type="button" class="btn btn-danger btn-xs cot-concepto-del" data-cidx="${i}">🗑️</button></td>
      `;
      tablaCotConceptosBody.appendChild(tr);
    });
    actualizarTotalesFormCotizacion();
  }

  function agregarConceptoCotizacion() {
    conceptosCotActual.push({ descripcion: "", cantidad: 1, precioUnitario: 0, descuento: 0, tieneIVA: true });
    renderConceptosCotizacion();
  }
  document.getElementById("btnAgregarConceptoCot")?.addEventListener("click", agregarConceptoCotizacion);

  function setConceptoDesdeCatalogo(i, item) {
    conceptosCotActual[i].descripcion = item.nombre;
    conceptosCotActual[i].precioUnitario = Number(item.precioUnitario) || 0;
    conceptosCotActual[i].descuento = Number(item.descuentoPorDefecto) || 0;
    const row = tablaCotConceptosBody?.querySelector(`tr[data-cidx="${i}"]`);
    if (row) {
      const descInp = row.querySelector(".cot-concepto-desc") as HTMLInputElement | null;
      const precioInp = row.querySelector(".cot-concepto-precio") as HTMLInputElement | null;
      const dtoInp = row.querySelector(".cot-concepto-dto") as HTMLInputElement | null;
      if (descInp) descInp.value = conceptosCotActual[i].descripcion;
      if (precioInp) precioInp.value = String(conceptosCotActual[i].precioUnitario);
      if (dtoInp) dtoInp.value = String(conceptosCotActual[i].descuento);
      row.querySelector(".cot-concepto-catalogo-list")?.classList.add("hidden");
    }
    actualizarFilaConceptoCot(i);
  }

  function existeEnCatalogoConceptos(nombre) {
    const n = (nombre || "").trim().toLowerCase();
    if (!n) return false;
    return (configCotizaciones.catalogo || []).some((it: any) => (it.nombre || "").trim().toLowerCase() === n);
  }

  // Guarda un concepto de la cotización actual en el catálogo de Configuración, para no
  // tener que volver a escribirlo (mismo nombre/precio/descuento) en la próxima cotización.
  // Explícito por botón, nunca automático — ver preferencia del usuario contra creación
  // silenciosa de registros (mismo criterio que empresa/contacto desde ticket del portal).
  async function guardarConceptoEnCatalogo(i) {
    const c = conceptosCotActual[i];
    const nombre = (c?.descripcion || "").trim();
    if (!nombre) { toast("⚠️ Escribe una descripción antes de guardarla en el catálogo", "warning"); return; }
    if (existeEnCatalogoConceptos(nombre)) { toast("Ese concepto ya está en el catálogo", "info"); return; }
    configCotizaciones.catalogo = configCotizaciones.catalogo || [];
    configCotizaciones.catalogo.push({ nombre, precioUnitario: Number(c.precioUnitario) || 0, descuentoPorDefecto: Number(c.descuento) || 0 });
    guardarLocal("crm_config_cotizaciones", configCotizaciones);
    if (firebaseEnabled && !crmLocalOnly) await guardarConfigCotizaciones(configCotizaciones).catch(() => {});
    toast(`💾 "${nombre}" agregado al catálogo — ya no hace falta volver a escribirlo`);
  }

  // Eventos delegados en la tabla de conceptos — se registran UNA sola vez (no dentro de
  // renderConceptosCotizacion) para no reconstruir el <tbody> en cada tecleo.
  attachAutocompleteKeyboardNav(tablaCotConceptosBody, (e: Event) => {
    const target = e.target as HTMLElement;
    if (!target.classList?.contains("cot-concepto-desc")) return null;
    const i = (target as HTMLInputElement).dataset.cidx;
    return tablaCotConceptosBody?.querySelector(`.cot-concepto-catalogo-list[data-cidx="${i}"]`);
  });
  tablaCotConceptosBody?.addEventListener("input", (e) => {
    const target = e.target as HTMLInputElement;
    const i = parseInt(target.dataset.cidx || "");
    if (isNaN(i) || !conceptosCotActual[i]) return;
    if (target.classList.contains("cot-concepto-desc")) {
      conceptosCotActual[i].descripcion = target.value;
      const val = target.value.toLowerCase().trim();
      const list = tablaCotConceptosBody.querySelector(`.cot-concepto-catalogo-list[data-cidx="${i}"]`);
      if (!list) return;
      if (!val) { list.classList.add("hidden"); return; }
      const matches = (configCotizaciones.catalogo || []).filter((it: any) => (it.nombre || "").toLowerCase().includes(val)).slice(0, 8);
      if (!matches.length) { list.classList.add("hidden"); return; }
      list.innerHTML = "";
      matches.forEach((item: any) => {
        const div = document.createElement("div");
        div.className = "autocomplete-item";
        div.innerHTML = `<span style="font-weight:600;">${escapeHtml(item.nombre)}</span> <span style="color:var(--text-muted); font-size:0.75rem;">— ${formatMoney(item.precioUnitario)}${item.descuentoPorDefecto ? ` (${item.descuentoPorDefecto}% dto.)` : ""}</span>`;
        div.addEventListener("click", () => setConceptoDesdeCatalogo(i, item));
        list.appendChild(div);
      });
      list.classList.remove("hidden");
      return;
    }
    if (target.classList.contains("cot-concepto-cant") || target.classList.contains("cot-concepto-precio") || target.classList.contains("cot-concepto-dto")) {
      conceptosCotActual[i][target.dataset.field as string] = parseFloat(target.value) || 0;
      actualizarFilaConceptoCot(i);
    }
  });
  tablaCotConceptosBody?.addEventListener("change", (e) => {
    const target = e.target as HTMLInputElement;
    const i = parseInt(target.dataset.cidx || "");
    if (isNaN(i) || !conceptosCotActual[i]) return;
    if (target.classList.contains("cot-concepto-iva")) {
      conceptosCotActual[i].tieneIVA = target.checked;
      actualizarTotalesFormCotizacion();
    }
  });
  tablaCotConceptosBody?.addEventListener("click", (e) => {
    const btnCat = (e.target as HTMLElement).closest(".cot-concepto-add-catalogo") as HTMLElement | null;
    if (btnCat) {
      guardarConceptoEnCatalogo(parseInt(btnCat.dataset.cidx || ""));
      return;
    }
    const btn = (e.target as HTMLElement).closest(".cot-concepto-del") as HTMLElement | null;
    if (!btn) return;
    const i = parseInt(btn.dataset.cidx || "");
    conceptosCotActual.splice(i, 1);
    renderConceptosCotizacion();
  });
  document.addEventListener("click", e => {
    if (!(e.target as HTMLElement).closest(".cot-concepto-desc") && !(e.target as HTMLElement).closest(".cot-concepto-catalogo-list")) {
      tablaCotConceptosBody?.querySelectorAll(".cot-concepto-catalogo-list").forEach(l => l.classList.add("hidden"));
    }
  });

  // ----- Autocomplete de empresa (receptor) -----
  const cotEmpBuscar = document.getElementById("form-cot-empresa-buscar");
  const cotEmpHidden = document.getElementById("form-cot-empresa") as HTMLInputElement | null;
  const cotEmpList = document.getElementById("cot-empresa-autocomplete");
  attachAutocompleteKeyboardNav(cotEmpBuscar, cotEmpList);

  function setEmpresaCotizacion(c: any) {
    const nombre = typeof c === "string" ? c : (c.EMPRESA || "");
    if (cotEmpBuscar) (cotEmpBuscar as HTMLInputElement).value = nombre;
    if (cotEmpHidden) cotEmpHidden.value = nombre;
    if (typeof c !== "string") {
      const fRfc = document.getElementById("form-cot-rfc") as HTMLInputElement | null; if (fRfc) fRfc.value = c.RFC || "";
      const fCt = document.getElementById("form-cot-contacto") as HTMLInputElement | null; if (fCt) fCt.value = c.CONTACTO || "";
      const fCo = document.getElementById("form-cot-correo") as HTMLInputElement | null; if (fCo) fCo.value = c.CORREO || "";
    }
    cotEmpList?.classList.add("hidden");
  }

  cotEmpBuscar?.addEventListener("input", function() {
    const val = (this as HTMLInputElement).value.toLowerCase().trim();
    if (cotEmpHidden) cotEmpHidden.value = (this as HTMLInputElement).value.trim();
    if (!val) { cotEmpList?.classList.add("hidden"); return; }
    const matches = clientes.filter((c: any) => (c.EMPRESA || "").toLowerCase().includes(val)).slice(0, 12);
    if (!matches.length) { cotEmpList?.classList.add("hidden"); return; }
    if (!cotEmpList) return;
    cotEmpList.innerHTML = "";
    matches.forEach((c: any) => {
      const div = document.createElement("div");
      div.className = "autocomplete-item";
      div.innerHTML = `<span style="font-weight:600; color:#f1f5f9;">🏢 ${escapeHtml(c.EMPRESA)}</span>`;
      div.addEventListener("click", () => setEmpresaCotizacion(c));
      cotEmpList.appendChild(div);
    });
    cotEmpList.classList.remove("hidden");
  });

  document.addEventListener("click", e => {
    if (!(e.target as HTMLElement).closest("#form-cot-empresa-buscar") && !(e.target as HTMLElement).closest("#cot-empresa-autocomplete")) {
      cotEmpList?.classList.add("hidden");
    }
  });

  // ----- Formulario: abrir / cerrar / editar -----
  const formCot = document.getElementById("formulario-cotizacion");
  const editCotId = document.getElementById("edit-cot-id") as HTMLInputElement | null;

  function cerrarFormCotizacion() {
    formCot?.classList.add("hidden");
    if (editCotId) editCotId.value = "";
    ["form-cot-emisor-nombre", "form-cot-emisor-cargo", "form-cot-emisor-tel", "form-cot-emisor-correo",
     "form-cot-empresa-buscar", "form-cot-empresa", "form-cot-rfc", "form-cot-contacto", "form-cot-correo",
     "form-cot-numero", "form-cot-notas"].forEach(id => {
      const el = document.getElementById(id) as HTMLInputElement | null;
      if (el) el.value = "";
    });
    document.getElementById("form-cot-estado-wrap")?.classList.add("hidden");
    conceptosCotActual = [];
    renderConceptosCotizacion();
    document.getElementById("btnCrearTicketDesdeCot")?.classList.add("hidden");
    document.getElementById("btnVerTicketDeCotizacion")?.classList.add("hidden");
  }

  // conceptoInicial permite prellenar el primer renglón de conceptos (usado al cotizar desde un ticket).
  function abrirNuevaCotizacion(conceptoInicial?: string) {
    cerrarFormCotizacion();
    const tituloEl = document.getElementById("form-cot-titulo");
    if (tituloEl) tituloEl.textContent = "➕ Nueva Cotización";
    const uActual = getUsuarioActual();
    const uFull = uActual ? getUsuarios().find(u => u.nombre === uActual.nombre) : null;
    const fNom = document.getElementById("form-cot-emisor-nombre") as HTMLInputElement | null; if (fNom) fNom.value = uActual?.nombre || "";
    const fCorreo = document.getElementById("form-cot-emisor-correo") as HTMLInputElement | null; if (fCorreo) fCorreo.value = uFull?.authEmail || "";
    const hoy = new Date();
    const vigencia = new Date(hoy.getTime() + 15 * 86400000);
    (document.getElementById("form-cot-fecha-creacion") as HTMLInputElement).value = fechaISO(hoy);
    (document.getElementById("form-cot-fecha-vigencia") as HTMLInputElement).value = fechaISO(vigencia);
    (document.getElementById("form-cot-notas") as HTMLTextAreaElement).value = configCotizaciones.terminos || "";
    conceptosCotActual = [{ descripcion: conceptoInicial || "", cantidad: 1, precioUnitario: 0, descuento: 0, tieneIVA: true }];
    renderConceptosCotizacion();
    formCot?.classList.remove("hidden");
    formCot?.scrollIntoView({ behavior: "smooth" });
  }
  document.getElementById("btnNuevaCotizacion")?.addEventListener("click", () => abrirNuevaCotizacion());

  document.getElementById("btnCancelarCotizacion")?.addEventListener("click", () => {
    // Cancelar de verdad: si venía de "🧾 Cotizar" en un ticket sin guardar, no debe quedar
    // arrastrado el vínculo para la próxima cotización que se cree sin relación alguna.
    cotizandoDesdeTicketNumero = null;
    cerrarFormCotizacion();
  });

  function abrirCotizacionParaEditar(c) {
    if (!c) return;
    cerrarFormCotizacion();
    const tituloEl = document.getElementById("form-cot-titulo");
    if (tituloEl) tituloEl.textContent = "✏️ Editar Cotización";
    if (editCotId) editCotId.value = c.id;
    (document.getElementById("form-cot-emisor-nombre") as HTMLInputElement).value = c.emisorNombre || "";
    (document.getElementById("form-cot-emisor-cargo") as HTMLInputElement).value = c.emisorCargo || "";
    (document.getElementById("form-cot-emisor-tel") as HTMLInputElement).value = c.emisorTel || "";
    (document.getElementById("form-cot-emisor-correo") as HTMLInputElement).value = c.emisorCorreo || "";
    setEmpresaCotizacion(c.empresaNombre || "");
    (document.getElementById("form-cot-rfc") as HTMLInputElement).value = c.empresaRFC || "";
    (document.getElementById("form-cot-contacto") as HTMLInputElement).value = c.empresaContacto || "";
    (document.getElementById("form-cot-correo") as HTMLInputElement).value = c.empresaCorreo || "";
    (document.getElementById("form-cot-numero") as HTMLInputElement).value = c.numero || "";
    (document.getElementById("form-cot-fecha-creacion") as HTMLInputElement).value = (c.fechaCreacion || "").slice(0, 10);
    (document.getElementById("form-cot-fecha-vigencia") as HTMLInputElement).value = (c.fechaVigencia || "").slice(0, 10);
    (document.getElementById("form-cot-notas") as HTMLTextAreaElement).value = c.notas || "";
    document.getElementById("form-cot-estado-wrap")?.classList.remove("hidden");
    (document.getElementById("form-cot-estado") as HTMLSelectElement).value = c.estado || "borrador";
    conceptosCotActual = (c.conceptos || []).map((x: any) => ({ ...x }));
    renderConceptosCotizacion();
    document.getElementById("btnCrearTicketDesdeCot")?.classList.remove("hidden");
    const btnVerTk = document.getElementById("btnVerTicketDeCotizacion");
    if (c.ticketNumero) {
      document.getElementById("form-cot-ticket-numero").textContent = String(c.ticketNumero);
      btnVerTk?.classList.remove("hidden");
    } else {
      btnVerTk?.classList.add("hidden");
    }
    formCot?.classList.remove("hidden");
    formCot?.scrollIntoView({ behavior: "smooth" });
  }

  function prepararEdicionCotizacion(e) {
    const idx = parseInt((e.target as HTMLElement).closest("button")!.getAttribute("data-idx") || "");
    abrirCotizacionParaEditar(cotizaciones[idx]);
  }

  function abrirCotizacionPorId(id: string) {
    navegarA("cotizaciones");
    abrirCotizacionParaEditar(cotizaciones.find(c => c.id === id));
  }

  async function reservarFolioCotizacion() {
    const anio = new Date().getFullYear();
    if (!firebaseEnabled || crmLocalOnly) {
      // Modo local (sin Firebase): folio calculado localmente. Acepta el mismo riesgo de
      // duplicado bajo uso concurrente que ya existe hoy para folios de Tickets en modo local —
      // no hay forma de hacerlo atómico sin backend.
      const usados = cotizaciones.filter(c => (c.numero || "").startsWith(`COT-${anio}-`)).map(c => parseInt((c.numero || "").split("-")[2]) || 0);
      const numero = usados.length ? Math.max(...usados) + 1 : 1;
      return { ok: true, folio: `COT-${anio}-${String(numero).padStart(3, "0")}` };
    }
    return await obtenerSiguienteFolioCotizacion(anio);
  }

  async function guardarCotizacionDesdeForm(generarPdfDespues: boolean) {
    const empresaNombre = (document.getElementById("form-cot-empresa") as HTMLInputElement).value.trim()
      || (document.getElementById("form-cot-empresa-buscar") as HTMLInputElement).value.trim();
    if (!empresaNombre) { toast("⚠️ Indica la empresa receptora"); return; }
    if (!conceptosCotActual.length || conceptosCotActual.every(c => !c.descripcion.trim())) {
      toast("⚠️ Agrega al menos un concepto"); return;
    }

    const rfc = (document.getElementById("form-cot-rfc") as HTMLInputElement).value.trim();
    const estadoWrapVisible = !document.getElementById("form-cot-estado-wrap")?.classList.contains("hidden");
    const datosForm = {
      emisorNombre: (document.getElementById("form-cot-emisor-nombre") as HTMLInputElement).value.trim(),
      emisorCargo: (document.getElementById("form-cot-emisor-cargo") as HTMLInputElement).value.trim(),
      emisorTel: (document.getElementById("form-cot-emisor-tel") as HTMLInputElement).value.trim(),
      emisorCorreo: (document.getElementById("form-cot-emisor-correo") as HTMLInputElement).value.trim(),
      empresaNombre,
      empresaRFC: rfc,
      empresaContacto: (document.getElementById("form-cot-contacto") as HTMLInputElement).value.trim(),
      empresaCorreo: (document.getElementById("form-cot-correo") as HTMLInputElement).value.trim(),
      fechaCreacion: (document.getElementById("form-cot-fecha-creacion") as HTMLInputElement).value,
      fechaVigencia: (document.getElementById("form-cot-fecha-vigencia") as HTMLInputElement).value,
      conceptos: conceptosCotActual.filter(c => c.descripcion.trim()).map(c => ({
        descripcion: c.descripcion, cantidad: Number(c.cantidad) || 0, precioUnitario: Number(c.precioUnitario) || 0,
        descuento: Number(c.descuento) || 0, tieneIVA: c.tieneIVA !== false
      })),
      notas: (document.getElementById("form-cot-notas") as HTMLTextAreaElement).value,
    };

    const id = editCotId?.value || "";
    let cot;
    if (id) {
      cot = cotizaciones.find(c => c.id === id);
      if (!cot) { toast("⚠️ No se encontró la cotización a editar"); return; }
      const estadoAnterior = cot.estado;
      Object.assign(cot, datosForm);
      if (estadoWrapVisible) {
        const nuevoEstado = (document.getElementById("form-cot-estado") as HTMLSelectElement).value;
        cot.estado = nuevoEstado;
      }
      if (crmLocalOnly) guardarLocal("crm_cotizaciones", cotizaciones); else await guardarCotizaciones(cotizaciones);
      if (estadoWrapVisible && cot.estado !== estadoAnterior) {
        logBitacora(`Cotización ${cot.numero} → ${cot.estado}`, "📋");
      } else {
        logBitacora(`Cotización ${cot.numero} actualizada`, "📋");
      }

      // Reacción automática del ticket vinculado al aceptar/rechazar (nunca crea nada nuevo,
      // solo cambia el estado del ticket que el propio usuario ligó a esta cotización).
      if (estadoWrapVisible && cot.estado !== estadoAnterior && cot.ticketNumero) {
        const tLigado = ticketPorNumero(cot.ticketNumero);
        if (tLigado) {
          if (cot.estado === "aceptada") {
            if (tLigado.estado === "Pendiente cotización") {
              tLigado.estado = tLigado.estadoPreCotizacion || "Abierto";
              delete tLigado.estadoPreCotizacion;
            }
            registrarActividadTicket(tLigado, `Cotización ${cot.numero} aceptada — ticket reanudado automáticamente (estado: "${tLigado.estado}")`);
            logBitacora(`Cotización ${cot.numero} aceptada → ticket #${tLigado.numero} reanudado`, "✅");
            if (crmLocalOnly) guardarLocal("crm_tickets", tickets); else await guardarTickets(tickets);
          } else if (cot.estado === "rechazada") {
            registrarActividadTicket(tLigado, `Cotización ${cot.numero} fue rechazada por el cliente`);
            logBitacora(`Cotización ${cot.numero} rechazada — ticket #${tLigado.numero} sigue pendiente, requiere revisión manual`, "⚠️");
            if (crmLocalOnly) guardarLocal("crm_tickets", tickets); else await guardarTickets(tickets);
            toast(`⚠️ Ticket #${tLigado.numero} sigue en "Pendiente cotización" — decide si recotizar o cerrarlo`, "warning");
          }
        }
      }
    } else {
      const res = await reservarFolioCotizacion();
      if (!res.ok) { toast("⚠️ No se pudo generar el folio, intenta de nuevo"); return; }
      cot = {
        id: "cot_" + Date.now(),
        numero: res.folio,
        estado: "borrador",
        creadoPor: getUsuarioActual()?.nombre || "Sistema",
        ...datosForm,
      };
      cotizaciones.push(cot);
      if (crmLocalOnly) guardarLocal("crm_cotizaciones", cotizaciones); else await agregarCotizacion(cot);
      logBitacora(`Cotización ${cot.numero} creada para ${cot.empresaNombre}`, "📋");
      if (editCotId) editCotId.value = cot.id;
      (document.getElementById("form-cot-numero") as HTMLInputElement).value = cot.numero;

      // Puente Ticket → Cotización: si esta cotización nació de "🧾 Cotizar" en un ticket,
      // se guarda el vínculo cruzado y el ticket se pausa hasta que el cliente responda.
      if (cotizandoDesdeTicketNumero !== null) {
        const tOrigen = ticketPorNumero(cotizandoDesdeTicketNumero);
        if (tOrigen) {
          if (!configTickets.estados.includes("Pendiente cotización")) {
            configTickets.estados.push("Pendiente cotización");
            if (crmLocalOnly) guardarLocal("crm_config_tickets", configTickets);
            else guardarConfigTickets({ estados: configTickets.estados }).catch(() => {});
          }
          tOrigen.estadoPreCotizacion = tOrigen.estado;
          tOrigen.estado = "Pendiente cotización";
          tOrigen.cotizacionId = cot.id;
          tOrigen.cotizacionNumero = cot.numero;
          cot.ticketNumero = tOrigen.numero;
          registrarActividadTicket(tOrigen, `Cotización ${cot.numero} generada — ticket en espera de aceptación del cliente`);
          logBitacora(`Ticket #${tOrigen.numero} pasó a "Pendiente cotización" (${cot.numero})`, "🧾");
          if (crmLocalOnly) guardarLocal("crm_tickets", tickets); else await guardarTickets(tickets);
        }
        cotizandoDesdeTicketNumero = null;
      }
    }

    if (rfc) sincronizarRFCEmpresaDesdeCotizacion(empresaNombre, rfc);

    guardarLocal("crm_cotizaciones", cotizaciones);
    document.getElementById("form-cot-estado-wrap")?.classList.remove("hidden");
    (document.getElementById("form-cot-estado") as HTMLSelectElement).value = cot.estado;
    document.getElementById("btnCrearTicketDesdeCot")?.classList.remove("hidden");
    toast(id ? "💾 Cotización actualizada" : "💾 Cotización guardada");
    renderCotizaciones();
    renderDashboard();
    if (generarPdfDespues) descargarPDFCotizacion(cot);
  }

  document.getElementById("btnGuardarCotizacionBorrador")?.addEventListener("click", () => guardarCotizacionDesdeForm(false));
  document.getElementById("btnGuardarCotizacionPDF")?.addEventListener("click", () => guardarCotizacionDesdeForm(true));

  // ----- Duplicar / Eliminar -----
  async function duplicarCotizacion(e) {
    const idx = parseInt((e.target as HTMLElement).closest("button")!.getAttribute("data-idx") || "");
    const orig = cotizaciones[idx];
    if (!orig) return;
    if (!await confirmar(`¿Duplicar la cotización ${orig.numero}?`, "📋")) return;
    const res = await reservarFolioCotizacion();
    if (!res.ok) { toast("⚠️ No se pudo generar el folio, intenta de nuevo"); return; }
    const hoy = new Date();
    const vigencia = new Date(hoy.getTime() + 15 * 86400000);
    const copia = {
      ...orig,
      id: "cot_" + Date.now(),
      numero: res.folio,
      estado: "borrador",
      fechaCreacion: fechaISO(hoy),
      fechaVigencia: fechaISO(vigencia),
      conceptos: (orig.conceptos || []).map((c: any) => ({ ...c })),
    };
    cotizaciones.push(copia);
    if (crmLocalOnly) guardarLocal("crm_cotizaciones", cotizaciones); else await agregarCotizacion(copia);
    logBitacora(`Cotización ${copia.numero} creada para ${copia.empresaNombre} (duplicada de ${orig.numero})`, "📋");
    guardarLocal("crm_cotizaciones", cotizaciones);
    toast(`📋 Duplicada como ${copia.numero}`);
    renderCotizaciones();
    renderDashboard();
  }

  async function eliminarCotizacion(e) {
    const idx = parseInt((e.target as HTMLElement).closest("button")!.getAttribute("data-idx") || "");
    const c = cotizaciones[idx];
    if (!c) return;
    if (!await confirmar(`¿Eliminar la cotización ${c.numero}? Esta acción no se puede deshacer.`, "🗑️")) return;
    cotizaciones = cotizaciones.filter(x => x.id !== c.id);
    if (crmLocalOnly) guardarLocal("crm_cotizaciones", cotizaciones); else await guardarCotizaciones(cotizaciones);
    logBitacora(`Cotización ${c.numero} eliminada`, "🗑️");
    guardarLocal("crm_cotizaciones", cotizaciones);
    toast("🗑️ Cotización eliminada");
    renderCotizaciones();
    renderDashboard();
  }

  // ----- Puente a Tickets -----
  // Nunca crea el ticket automáticamente: abre el formulario ya prellenado y el usuario revisa
