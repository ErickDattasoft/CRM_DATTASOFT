  // ============================================================
  // EMPRESAS
  // ============================================================
  function obtenerEmpresasFiltradas() {
    const busq = document.getElementById("txtBuscar")?.value.toLowerCase().trim() || "";
    const sf = document.getElementById("selectFiltroSistema")?.value || "";
    return clientes.map((c, i) => ({ ...c, _idx: i })).filter(c => {
      if (filtrarSoloFavoritos && !c.FAVORITO) return false;
      if (sf) {
        const v = c.SISTEMAS?.[sf.toUpperCase().trim()] || "";
        if (!v || v.toUpperCase() === "NO APLICA") return false;
      }
      if (busq && !(c.EMPRESA || "").toLowerCase().includes(busq) && !(c.CONTACTO || "").toLowerCase().includes(busq)) return false;
      return true;
    });
  }

  function renderEmpresas() {
    const tbody = document.getElementById("tabla-empresas-body");
    if (!tbody) return;
    tbody.innerHTML = "";

    // Aviso si no hay versiones oficiales configuradas
    const hayVersionesOficiales = Object.values(versionesMercado).some(v => v && /\d/.test(v));
    const avisoEl = document.getElementById("aviso-sin-versiones");
    if (avisoEl) avisoEl.style.display = hayVersionesOficiales ? "none" : "flex";

    const vis = obtenerEmpresasFiltradas();
    vis.sort((a, b) => {
      // Favoritos siempre al tope, sin importar el orden A-Z
      if (a.FAVORITO && !b.FAVORITO) return -1;
      if (!a.FAVORITO && b.FAVORITO) return 1;
      // Entre sí, respetan el orden alfabético seleccionado
      return sortEmpresasDir === 'asc'
        ? (a.EMPRESA || '').localeCompare(b.EMPRESA || '', 'es', { sensitivity: 'base' })
        : (b.EMPRESA || '').localeCompare(a.EMPRESA || '', 'es', { sensitivity: 'base' });
    });
    const arrowEmp = document.getElementById('sort-arrow-emp');
    if (arrowEmp) { arrowEmp.textContent = sortEmpresasDir === 'asc' ? '↑' : '↓'; arrowEmp.className = 'sort-arrow active'; }
    vis.forEach(c => {
      const idx = c._idx;
      const tr = document.createElement("tr");
      tr.className = "empresa-row";
      tr.dataset.idx = idx;
      // Colorear fila según vencimiento de licencia (el más próximo de cualquier sistema)
      if (c.VENCIMIENTOS && Object.keys(c.VENCIMIENTOS).length > 0) {
        const hoy = new Date(); hoy.setHours(0,0,0,0);
        let minDias = Infinity;
        Object.values(c.VENCIMIENTOS).forEach(fecha => {
          if (!fecha) return;
          const d = Math.ceil((new Date(fecha + "T00:00:00") - hoy) / 86400000);
          if (d < minDias) minDias = d;
        });
        if (minDias < Infinity) {
          if (minDias < 0) tr.classList.add("tr-licencia-vencida");
          else if (minDias <= 30) tr.classList.add("tr-licencia-vence");
        }
      }
      const checked = seleccionadosIdx.includes(idx) ? "checked" : "";

      let extras = "";
      if (c.CAMPOS_EXTRAS) {
        Object.entries(c.CAMPOS_EXTRAS).forEach(([k, v]) => {
          if (v) extras += `<span class="extra-badge">💻 ${k}: ${v}</span>`;
        });
      }

      // Badge licencia vencimiento (todos los sistemas vencidos o por vencer ≤30 días)
      let badgeLicencia = "";
      if (c.VENCIMIENTOS && Object.keys(c.VENCIMIENTOS).length > 0) {
        const hoy2 = new Date(); hoy2.setHours(0,0,0,0);
        const vencidos = []; const proximos = [];
        Object.entries(c.VENCIMIENTOS).forEach(([sis, fecha]) => {
          if (!fecha) return;
          const d = Math.ceil((new Date(fecha + "T00:00:00") - hoy2) / 86400000);
          if (d < 0) vencidos.push({ sis, d });
          else if (d <= 30) proximos.push({ sis, d });
        });
        const tooltipVenc = vencidos.map(x => `🔴 ${x.sis}: vencida hace ${Math.abs(x.d)} días`).join("\n");
        const tooltipProx = proximos.sort((a,b) => a.d - b.d).map(x => `⚠️ ${x.sis}: vence en ${x.d} días`).join("\n");
        if (vencidos.length > 0) badgeLicencia += `<span class="badge-licencia badge-licencia-vencida" title="${tooltipVenc}">🔴 ${vencidos.length > 1 ? vencidos.length + " licencias vencidas" : vencidos[0].sis + " vencida"}</span>`;
        if (proximos.length > 0) {
          const primero = proximos.sort((a,b) => a.d - b.d)[0];
          badgeLicencia += `<span class="badge-licencia badge-licencia-vence" title="${tooltipProx}">⚠️ ${proximos.length > 1 ? primero.d + "d · " + proximos.length + " sistemas" : primero.sis + " · " + primero.d + "d"}</span>`;
        }
      }

      const tdBase = "vertical-align:top; padding:12px 14px;";
      const pillBase = "display:inline-block; padding:3px 9px; border-radius:5px; font-size:0.73rem; font-weight:700; white-space:nowrap;";
      // Calcular estado global de versiones para el indicador del botón
      let verEstado = "sin-datos";
      if (listaSistemas.length > 0) {
        const hoyV = new Date(); hoyV.setHours(0,0,0,0);
        for (const s of listaSistemas) {
          const sKey = s.toUpperCase().trim();
          const vC = String(c.SISTEMAS?.[sKey] || "").trim();
          const vO = String(versionesMercado[sKey] || "").trim();
          const vOTieneNumero = /\d/.test(vO);
          const vencFecha = c.VENCIMIENTOS?.[sKey] || "";
          if (vencFecha) {
            const dias = Math.ceil((new Date(vencFecha + "T00:00:00") - hoyV) / 86400000);
            if (dias < 0 && verEstado !== "error") verEstado = "error";
            else if (dias <= 30 && verEstado === "sin-datos") verEstado = "alerta";
          }
          if (vC && vC.toUpperCase() !== "NO APLICA" && vO && vOTieneNumero) {
            const cmp = compararVersiones(vC, vO);
            if (cmp < 0) verEstado = "error";
            else if (verEstado === "sin-datos") verEstado = "ok";
          }
        }
      }
      const verBtnStyle = {
        "sin-datos": "background:rgba(100,116,139,0.2); border:1px solid #475569; color:#94a3b8;",
        "ok":        "background:rgba(22,163,74,0.15); border:1px solid #16a34a; color:#4ade80;",
        "alerta":    "background:rgba(245,158,11,0.15); border:1px solid #d97706; color:#fbbf24;",
        "error":     "background:rgba(220,38,38,0.15); border:1px solid #dc2626; color:#f87171;",
      }[verEstado];
      const verIcon = { "sin-datos": "💻", "ok": "✅", "alerta": "⚠️", "error": "🔴" }[verEstado];

      let html = `
        <td style="${tdBase} text-align:center; padding-top:15px;"><input type="checkbox" class="chk-emp" data-idx="${idx}" ${checked} style="cursor:pointer;"></td>
        <td style="${tdBase} max-width:0; overflow:hidden;">
          <div style="display:flex; align-items:center; gap:6px; overflow:hidden;">
            <span class="btn-fav" data-idx="${idx}" style="flex-shrink:0; font-size:1rem; cursor:pointer; color:${c.FAVORITO ? '#fbbf24' : '#64748b'};">${c.FAVORITO ? '⭐' : '☆'}</span>
            <strong title="${c.EMPRESA}" style="color:#f1f5f9; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; min-width:0; font-size:0.88rem;">${c.EMPRESA}</strong>
            ${badgeLicencia}
          </div>
          ${extras ? `<div style="margin-top:3px;">${extras}</div>` : ''}
        </td>
        ${(() => {
          const ci = getInfoContacto(c);
          const ctAdicionales = contactos.filter((ct: any) => ct.empresa === c.EMPRESA && ct.nombre !== c.CONTACTO);
          const ct2 = ctAdicionales[0];
          const nombre2 = ct2?.nombre || c.CONTACTO_2 || '';
          const correo2 = ct2?.correo  || c.CORREO_2   || '';
          const tel2    = ct2?.telefono1 || c.TELEFONO_2 || '';
          const lineaContacto = (nombre, correo, tel, esPrincipal) => {
            if (!nombre) return '<span style="color:#475569;">—</span>';
            const nSize  = esPrincipal ? '0.87rem' : '0.82rem';
            const subSize = esPrincipal ? '0.72rem' : '0.70rem';
            return `
              <div style="font-weight:${esPrincipal?'700':'500'}; color:${esPrincipal?'#f1f5f9':'#cbd5e1'}; font-size:${nSize}; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${nombre}</div>
              ${correo ? `<div style="font-size:${subSize}; color:#7dd3fc; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; margin-top:1px;">✉ ${correo}</div>` : ''}
              ${tel    ? `<div style="font-size:${subSize}; color:#94a3b8; white-space:nowrap; margin-top:1px;">📱 ${tel}</div>` : ''}`;
          };
          return `
        <td style="${tdBase} max-width:0; overflow:hidden;">${lineaContacto(c.CONTACTO || '', ci.correo || '', ci.telefono1 || '', true)}</td>
        <td style="${tdBase} max-width:0; overflow:hidden;">${lineaContacto(nombre2, correo2, tel2, false)}</td>`;
        })()}
        <td style="${tdBase} white-space:nowrap; color:#a5b4fc; font-size:0.82rem; font-family:monospace;">${c.RFC || '—'}</td>
        <td style="text-align:center; vertical-align:middle; padding:6px 4px; min-width:90px;">
          <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:3px; width:fit-content; margin:0 auto;">
            <button class="btn btn-secondary btn-xs btn-edit-emp" data-idx="${idx}" title="Editar" style="padding:3px 5px;">✏️</button>
            <button class="btn btn-whatsapp btn-xs btn-wsp-emp" data-idx="${idx}" title="WhatsApp" style="padding:3px 5px;">💬</button>
            <button class="btn btn-ghost btn-xs btn-mail-emp-zoho" data-idx="${idx}" title="Email" style="background:rgba(249,115,22,0.15);border:1px solid rgba(249,115,22,0.4);color:#f97316;padding:3px 5px;">✉️</button>
            <button class="btn btn-danger btn-xs btn-del-emp" data-idx="${idx}" title="Eliminar" style="padding:3px 5px;">🗑️</button>
            <button class="btn btn-ghost btn-xs btn-toggle-versiones" data-idx="${idx}" title="Versiones" style="${verBtnStyle} font-size:0.65rem;font-weight:700;padding:2px 3px;grid-column:span 2;">${verIcon} Ver</button>
            <button class="btn btn-ghost btn-xs btn-historial-emp" data-idx="${idx}" title="Ver historial de interacciones" style="background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.3);color:#a5b4fc;padding:2px 3px;font-size:0.65rem;display:flex;align-items:center;gap:2px;position:relative;">📋<span style="font-size:0.6rem;line-height:1;">Hist.</span>${interacciones.filter((i:any)=>i.empresa===c.EMPRESA).length > 0 ? `<span style="position:absolute;top:-5px;right:-5px;background:#6366f1;color:white;border-radius:10px;font-size:0.58rem;padding:0 4px;font-weight:800;min-width:14px;text-align:center;">${interacciones.filter((i:any)=>i.empresa===c.EMPRESA).length}</span>` : ""}</button>
            <button class="btn btn-ghost btn-xs btn-tareas-emp" data-idx="${idx}" title="Ver tareas pendientes" style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);color:#34d399;padding:2px 3px;font-size:0.65rem;display:flex;align-items:center;gap:2px;position:relative;">📌<span style="font-size:0.6rem;line-height:1;">Tar.</span>${tareas.filter((t:any)=>t.empresa===c.EMPRESA&&!t.completada).length > 0 ? `<span style="position:absolute;top:-5px;right:-5px;background:#10b981;color:white;border-radius:10px;font-size:0.58rem;padding:0 4px;font-weight:800;min-width:14px;text-align:center;">${tareas.filter((t:any)=>t.empresa===c.EMPRESA&&!t.completada).length}</span>` : ""}</button>
          </div>
        </td>
      `;
      tr.innerHTML = html;
      tbody.appendChild(tr);

      // Segunda fila: versiones — oculta por defecto
      if (listaSistemas.length > 0) {
        const tr2 = document.createElement("tr");
        tr2.className = "empresa-row-versiones";
        tr2.dataset.idx = idx;
        tr2.style.display = "none";
        let vHtml = `<td></td><td colspan="6" style="padding:6px 16px 14px 16px; border-top:1px solid rgba(255,255,255,0.05);">`;
        vHtml += `<div style="display:flex; flex-wrap:wrap; gap:8px; align-items:flex-start; padding:6px 0;">`;
        listaSistemas.forEach(s => {
          const sKey = s.toUpperCase().trim();
          const vC = String(c.SISTEMAS?.[sKey] || "").trim();
          const vO = String(versionesMercado[sKey] || "").trim();
          const vOTieneNumero = /\d/.test(vO);
          const vencFecha = c.VENCIMIENTOS?.[sKey] || "";

          let bg, txtColor, txt, subtxt = "";
          if (!vC || vC.toUpperCase() === "NO APLICA") {
            txt = "Sin versión"; subtxt = vO ? `Oficial: ${vO}` : "";
            bg = vO && vOTieneNumero ? "rgba(3,105,161,0.3)" : "rgba(30,41,59,0.6)";
            txtColor = vO && vOTieneNumero ? "#7dd3fc" : "#475569";
          } else {
            txt = vC;
            if (!vO || !vOTieneNumero) {
              bg = "rgba(3,105,161,0.3)"; txtColor = "#7dd3fc"; subtxt = "Sin versión oficial";
            } else {
              const cmp = compararVersiones(vC, vO);
              if (cmp < 0) { bg = "rgba(220,38,38,0.2)"; txtColor = "#fca5a5"; subtxt = `Oficial: ${vO} ↑`; }
              else { bg = "rgba(22,163,74,0.2)"; txtColor = "#86efac"; subtxt = `Al día`; }
            }
          }

          let vencTag = "";
          if (vencFecha) {
            const hoyV2 = new Date(); hoyV2.setHours(0,0,0,0);
            const dias = Math.ceil((new Date(vencFecha + "T00:00:00") - hoyV2) / 86400000);
            const [vy, vm, vd] = vencFecha.split("-");
            const fechaCorta = `${vd}/${vm}/${vy.slice(2)}`;
            const cV = dias < 0 ? "#f87171" : dias <= 30 ? "#fbbf24" : "#6ee7b7";
            const iV = dias < 0 ? "🔴" : dias <= 30 ? "⚠️" : "📅";
            vencTag = `<span style="display:block; font-size:0.6rem; color:${cV}; margin-top:3px;">${iV} Vence: ${fechaCorta}${dias < 0 ? ` (hace ${Math.abs(dias)}d)` : ` (${dias}d)`}</span>`;
          }

          vHtml += `<div style="background:${bg}; border:1px solid rgba(255,255,255,0.08); border-radius:6px; padding:7px 10px; min-width:120px;">
            <div style="font-size:0.65rem; color:#94a3b8; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:2px;">${s}</div>
            <div style="font-size:0.82rem; font-weight:700; color:${txtColor};">${txt}</div>
            ${subtxt ? `<div style="font-size:0.62rem; color:#64748b; margin-top:1px;">${subtxt}</div>` : ""}
            ${vencTag}
          </div>`;
        });
        vHtml += `</div></td>`;
        tr2.innerHTML = vHtml;
        tbody.appendChild(tr2);
      }
    });

    // Events
    tbody.querySelectorAll(".btn-edit-emp").forEach(b => b.addEventListener("click", prepararEdicionEmpresa));
    tbody.querySelectorAll(".btn-del-emp").forEach(b => b.addEventListener("click", eliminarEmpresa));
    tbody.querySelectorAll(".btn-wsp-emp").forEach(b => b.addEventListener("click", enviarWhatsApp));
    tbody.querySelectorAll(".btn-fav").forEach(b => b.addEventListener("click", toggleFavorito));
    tbody.querySelectorAll(".btn-toggle-versiones").forEach(b => b.addEventListener("click", function() {
      const i = this.dataset.idx;
      const tr2 = tbody.querySelector(`.empresa-row-versiones[data-idx="${i}"]`);
      if (!tr2) return;
      const visible = tr2.style.display !== "none";
      tr2.style.display = visible ? "none" : "";
      this.style.fontWeight = visible ? "700" : "900";
      this.style.boxShadow = visible ? "" : "0 0 0 2px currentColor";
    }));
    tbody.querySelectorAll(".btn-historial-emp").forEach(b => b.addEventListener("click", function() {
      abrirDrawerEmpresa(parseInt(this.dataset.idx), "historial");
    }));
    tbody.querySelectorAll(".btn-tareas-emp").forEach(b => b.addEventListener("click", function() {
      abrirDrawerEmpresa(parseInt(this.dataset.idx), "tareas");
    }));
    tbody.querySelectorAll(".chk-emp").forEach(b => {
      b.addEventListener("change", function() {
        const i = parseInt(this.dataset.idx);
        if (this.checked) { if (!seleccionadosIdx.includes(i)) seleccionadosIdx.push(i); }
        else { seleccionadosIdx = seleccionadosIdx.filter(x => x !== i); }
        actualizarContSel();
      });
    });
    actualizarContSel();

    // Click selecciona fila (morado), doble click abre edición
    tbody.addEventListener("click", (e) => {
      if (e.target.closest("button, input, select")) return;
      const row = e.target.closest(".empresa-row");
      if (!row) return;
      tbody.querySelectorAll(".empresa-row td").forEach(td => { td.style.background = ""; td.style.borderLeft = ""; td.style.paddingLeft = ""; });
      row.querySelectorAll("td").forEach((td, i) => {
        td.style.background = "rgba(99,102,241,0.18)";
        if (i === 0) { td.style.borderLeft = "4px solid #6366f1"; td.style.paddingLeft = "14px"; }
      });
    });
    tbody.addEventListener("dblclick", (e) => {
      e.preventDefault();
      if (e.target.closest("button, input, select")) return;
      const row = e.target.closest(".empresa-row");
      if (!row) return;
      row.querySelector(".btn-edit-emp")?.click();
    });
  }

  function actualizarContSel() {
    document.querySelectorAll(".lblCountSel").forEach(l => l.textContent = seleccionadosIdx.length);
  }

  // Empresa Form
  const formEmp = document.getElementById("formulario-empresa");
  const editEmpIdx = document.getElementById("edit-emp-index");

  function cerrarFormEmpresa() {
    formEmp?.classList.add("hidden");
    document.getElementById("formulario-empresa-versiones")?.classList.add("hidden");
    editEmpIdx.value = "";
    (document.getElementById("form-empresa") as HTMLInputElement).value = "";
    (document.getElementById("form-empresa-rfc") as HTMLInputElement).value = "";
    formContactosTemp = [];
    renderFormContactos();
    (document.getElementById("form-ct-inline-nombre") as HTMLInputElement).value = "";
    (document.getElementById("form-ct-inline-tel") as HTMLInputElement).value = "";
    (document.getElementById("form-ct-inline-correo") as HTMLInputElement).value = "";
    document.getElementById("contenedorCamposExtras").innerHTML = "";
    const sel = document.getElementById("form-emp-contacto-select");
    if (sel) { sel.innerHTML = ""; sel.classList.add("hidden"); }
    document.getElementById("form-contacto")?.classList.remove("hidden");
    document.querySelectorAll(".form-emp-extras").forEach(el => el.classList.remove("hidden"));
    document.getElementById("form-emp-campos-extra-section")?.classList.remove("hidden");
    listaSistemas.forEach(s => {
      const key = s.replace(/\s+/g, '_');
      const inp = document.getElementById(`sys-${key}`);
      if (inp) inp.value = "";
      const vencInp = document.getElementById(`venc-${key}`);
      if (vencInp) vencInp.value = "";
    });
  }

  document.getElementById("btnNuevoEmpresa")?.addEventListener("click", () => {
    cerrarFormEmpresa();
    document.getElementById("form-emp-titulo").textContent = "➕ Registrar Empresa";
    document.getElementById("form-emp-campos-extra-section")?.classList.add("hidden");
    document.getElementById("formulario-empresa-versiones")?.classList.remove("hidden");
    formContactosTemp = [];
    renderFormContactos();
    formEmp?.classList.remove("hidden");
    formEmp?.scrollIntoView({ behavior: "smooth" });
  });

  // Botón agregar contacto inline
  document.getElementById("btnAddCtInline")?.addEventListener("click", () => {
    const nombre = (document.getElementById("form-ct-inline-nombre") as HTMLInputElement).value.trim();
    const tel    = (document.getElementById("form-ct-inline-tel")    as HTMLInputElement).value.trim();
    const correo = (document.getElementById("form-ct-inline-correo") as HTMLInputElement).value.trim().toLowerCase();
    if (!nombre) { toast("⚠️ El nombre del contacto es obligatorio"); return; }
    formContactosTemp.push({ nombre, telefono1: tel, correo, telefono2: "", empresa: "" });
    renderFormContactos();
    (document.getElementById("form-ct-inline-nombre") as HTMLInputElement).value = "";
    (document.getElementById("form-ct-inline-tel")    as HTMLInputElement).value = "";
    (document.getElementById("form-ct-inline-correo") as HTMLInputElement).value = "";
    (document.getElementById("form-ct-inline-nombre") as HTMLInputElement).focus();
  });

  // Enter en nombre agrega contacto
  document.getElementById("form-ct-inline-correo")?.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Enter") { e.preventDefault(); document.getElementById("btnAddCtInline")?.click(); }
  });

  document.getElementById("btnCancelarEmpresa")?.addEventListener("click", cerrarFormEmpresa);

  document.getElementById("btnAgregarCampoExtra")?.addEventListener("click", () => {
    const nombre = prompt("Nombre del campo extra (Ej: Servidor, Terminales):");
    if (nombre) crearInputCampoExtra(nombre.trim(), "");
  });

  function crearInputCampoExtra(nombre, valor) {
    const cont = document.getElementById("contenedorCamposExtras");
    const div = document.createElement("div");
    div.className = "form-group";
    div.style.position = "relative";
    div.innerHTML = `
      <label style="font-size:0.72rem;">${nombre}</label>
      <div style="display:flex; gap:4px;">
        <input class="input-campo-extra" data-campo="${nombre}" value="${valor}" style="flex:1;">
        <button type="button" class="btn btn-danger btn-xs" style="flex-shrink:0;">🗑️</button>
      </div>
    `;
    div.querySelector("button").addEventListener("click", () => div.remove());
    cont.appendChild(div);
  }

  let formContactosTemp: any[] = [];

  function renderFormContactos() {
    const lista = document.getElementById("form-emp-ct-lista");
    if (!lista) return;
    if (!formContactosTemp.length) {
      lista.innerHTML = `<div style="font-size:0.78rem;color:var(--text-muted);padding:4px 0;">Sin contactos — agrega al menos uno abajo</div>`;
      return;
    }
    lista.innerHTML = formContactosTemp.map((ct, i) => `
      <div style="display:grid;grid-template-columns:auto 2fr 1.5fr 2fr auto auto;gap:6px;align-items:center;padding:5px 0;border-bottom:1px solid rgba(255,255,255,0.05);">
        <span style="font-size:0.65rem;font-weight:700;padding:2px 6px;border-radius:4px;background:${i===0?'rgba(99,102,241,0.2)':'rgba(16,185,129,0.15)'};color:${i===0?'#a5b4fc':'#6ee7b7'};white-space:nowrap;">${i===0?'⭐ Principal':'Alt. '+i}</span>
        <span style="font-weight:600;color:var(--text-bright);font-size:0.82rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${ct.nombre}">${ct.nombre}</span>
        <span style="color:#94a3b8;font-size:0.78rem;">${ct.telefono1||'—'}</span>
        <span style="color:#7dd3fc;font-size:0.75rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="${ct.correo||''}">${ct.correo||'—'}</span>
        ${i===0 ? '<span></span>' : `<button type="button" data-ct-principal="${i}" title="Hacer principal" style="background:rgba(99,102,241,0.15);border:1px solid rgba(99,102,241,0.35);color:#a5b4fc;border-radius:4px;padding:2px 6px;cursor:pointer;font-size:0.7rem;white-space:nowrap;">⭐ Principal</button>`}
        <button type="button" data-ct-del="${i}" style="background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.3);color:#f87171;border-radius:4px;padding:2px 6px;cursor:pointer;font-size:0.7rem;flex-shrink:0;">🗑</button>
      </div>`).join("");
    lista.querySelectorAll("[data-ct-principal]").forEach(btn => {
      btn.addEventListener("click", () => {
        const idx = parseInt((btn as HTMLElement).dataset.ctPrincipal || "0");
        const [promovido] = formContactosTemp.splice(idx, 1);
        formContactosTemp.unshift(promovido);
        renderFormContactos();
      });
    });
    lista.querySelectorAll("[data-ct-del]").forEach(btn => {
      btn.addEventListener("click", () => {
        const idx = parseInt((btn as HTMLElement).dataset.ctDel || "0");
        formContactosTemp.splice(idx, 1);
        renderFormContactos();
      });
    });
  }

  function actualizarPanelContactosVinculados(empresaNombre: string) {
    const panel = document.getElementById("form-emp-contactos-vinculados");
    const lista = document.getElementById("form-emp-contactos-lista");
    if (!panel || !lista) return;
    const cts = contactos.filter((c: any) => c.empresa === empresaNombre);
    if (!cts.length) { panel.style.display = "none"; return; }
    panel.style.display = "block";
    lista.innerHTML = cts.map((ct: any) =>
      `<div style="display:flex;gap:10px;align-items:center;padding:5px 0;border-bottom:1px solid rgba(255,255,255,0.05);">
        <span style="font-size:0.9rem;">👤</span>
        <div>
          <div style="font-weight:700;color:var(--text-bright);font-size:0.82rem;">${ct.nombre}</div>
          <div style="font-size:0.72rem;color:var(--text-muted);">${[ct.correo,ct.telefono1,ct.telefono2].filter(Boolean).join(" · ") || "Sin datos adicionales"}</div>
        </div>
      </div>`
    ).join("");
  }

  function prepararEdicionEmpresa(e) {
    const idx = parseInt(e.target.closest("button").dataset.idx);
    const c = clientes[idx];
    cerrarFormEmpresa();
    document.getElementById("form-emp-titulo").textContent = "✏️ Editar Empresa";
    editEmpIdx.value = idx;
    (document.getElementById("form-empresa") as HTMLInputElement).value = c.EMPRESA;
    (document.getElementById("form-empresa-rfc") as HTMLInputElement).value = c.RFC || "";
    // Cargar contactos de esta empresa al array temporal
    const ctExistentes = contactos.filter((ct: any) => ct.empresa === c.EMPRESA);
    if (ctExistentes.length) {
      formContactosTemp = ctExistentes.map((ct: any) => ({ ...ct }));
    } else {
      // fallback: si no hay en Contactos, usar los campos legacy de empresa
      formContactosTemp = [];
      if (c.CONTACTO) formContactosTemp.push({ nombre: c.CONTACTO, correo: c.CORREO || "", telefono1: c.TELEFONO_1 || "", telefono2: "", empresa: c.EMPRESA });
      if (c.CONTACTO_2) formContactosTemp.push({ nombre: c.CONTACTO_2, correo: c.CORREO_2 || "", telefono1: c.TELEFONO_2 || "", telefono2: "", empresa: c.EMPRESA });
    }
    renderFormContactos();
    document.getElementById("form-emp-campos-extra-section")?.classList.remove("hidden");
    document.getElementById("formulario-empresa-versiones")?.classList.remove("hidden");
    if (c.CAMPOS_EXTRAS) {
      Object.entries(c.CAMPOS_EXTRAS).forEach(([k, v]) => crearInputCampoExtra(k, v));
    }
    listaSistemas.forEach(s => {
      const k = s.toUpperCase().trim();
      const key = s.replace(/\s+/g, '_');
      let v = c.SISTEMAS?.[k] || "";
      if (v === "No aplica") v = "";
      const inp = document.getElementById(`sys-${key}`);
      if (inp) inp.value = v;
      const vencInp = document.getElementById(`venc-${key}`);
      if (vencInp) vencInp.value = c.VENCIMIENTOS?.[k] || "";
    });
    formEmp?.classList.remove("hidden");
    formEmp?.scrollIntoView({ behavior: "smooth" });
  }

  document.getElementById("btnGuardarEmpresa")?.addEventListener("click", async () => {
    const idx = editEmpIdx.value;
    const nombre = document.getElementById("form-empresa").value.trim().toUpperCase();
    if (!nombre) return;

    if (!formContactosTemp.length) {
      toast("⚠️ Agrega al menos un contacto antes de guardar");
      return;
    }

    const extras = {};
    document.querySelectorAll(".input-campo-extra").forEach(inp => {
      extras[inp.dataset.campo] = inp.value.trim();
    });

    const empExistente = idx !== "" ? clientes[parseInt(idx)] : null;
    const ct1 = formContactosTemp[0];
    const ct2 = formContactosTemp[1];

    const nuevo = {
      EMPRESA: nombre,
      CONTACTO:   ct1?.nombre   || "",
      CORREO:     ct1?.correo   || "",
      TELEFONO_1: ct1?.telefono1 || "",
      CONTACTO_2: ct2?.nombre   || "",
      CORREO_2:   ct2?.correo   || "",
      TELEFONO_2: ct2?.telefono1 || "",
      RFC: (document.getElementById("form-empresa-rfc") as HTMLInputElement).value.trim(),
      FAVORITO: empExistente?.FAVORITO || false,
      CAMPOS_EXTRAS: extras,
      SISTEMAS: {},
      VENCIMIENTOS: {}
    };

    listaSistemas.forEach(s => {
      const key = s.replace(/\s+/g, '_');
      const k = s.toUpperCase().trim();
      const inp = document.getElementById(`sys-${key}`);
      const v = inp ? inp.value.trim() : "";
      nuevo.SISTEMAS[k] = v === "" ? "No aplica" : v;
      const vencInp = document.getElementById(`venc-${key}`);
      if (vencInp && vencInp.value) nuevo.VENCIMIENTOS[k] = vencInp.value;
    });

    if (idx === "") clientes.push(nuevo);
    else clientes[parseInt(idx)] = nuevo;

    // Sincronizar formContactosTemp → array global contactos
    formContactosTemp.forEach((ct: any) => { ct.empresa = nombre; });
    contactos = contactos.filter((c: any) => c.empresa !== nombre);
    formContactosTemp.forEach((ct: any) => contactos.push({ ...ct }));
    if (crmLocalOnly) guardarLocal("crm_contactos", contactos);
    else guardarContactos(contactos);

    guardarLocal("crm_clientes", clientes); // respaldo local siempre primero
    const isEdit = document.getElementById("edit-emp-index")?.value !== "";
    logBitacora(`Empresa "${nuevo.EMPRESA}" ${isEdit ? "actualizada" : "creada"}`, "🏢");
    if (crmLocalOnly) {
      toast("💾 Empresa guardada (Local)");
      cerrarFormEmpresa();
      renderEmpresas();
      renderDashboard();
      checkLicenciasPorVencer();
      return;
    }
    mostrarEstado("💾 Guardando...");
    const ok = await guardarClientes(clientes);
    if (ok === true) { toast("💾 Empresa guardada"); ocultarEstado(); }
    else { mostrarEstado(`⚠️ Guardado localmente (sin conexión) — ${ok?.error || "error desconocido"}`, 6000); }
    cerrarFormEmpresa();
    renderEmpresas();
    renderDashboard();
    checkLicenciasPorVencer();
  });

  async function eliminarEmpresa(e) {
    const idx = parseInt(e.target.closest("button").dataset.idx);
    if (!confirm("¿Eliminar esta empresa?")) return;
    const nombreEmp = clientes[idx]?.EMPRESA || "desconocida";
    clientes.splice(idx, 1);
    guardarLocal("crm_clientes", clientes);
    logBitacora(`Empresa "${nombreEmp}" eliminada`, "🗑️");
    if (crmLocalOnly) {
      toast("🗑️ Empresa eliminada (Local)");
      renderEmpresas();
      renderDashboard();
      return;
    }
    await guardarClientes(clientes);
    renderEmpresas();
    renderDashboard();
  }

  // Fuente única de verdad para datos de contacto de una empresa:
  // busca primero en el array contactos[], luego usa los campos legados de empresa.
  function getInfoContacto(emp: any, nombreContacto?: string) {
    const nombre = nombreContacto || emp.CONTACTO || "";
    const ctFound = contactos.find((c: any) =>
      c.empresa === emp.EMPRESA && (nombre ? c.nombre === nombre : true)
    );
    return {
      correo:   ctFound?.correo   || emp.CORREO   || "",
      telefono1: ctFound?.telefono1 || emp.TELEFONO_1 || "",
      telefono2: ctFound?.telefono2 || emp.TELEFONO_2 || "",
      nombre:   ctFound?.nombre   || nombre,
    };
  }

  async function toggleFavorito(e) {
    const idx = parseInt(e.target.dataset.idx);
    clientes[idx].FAVORITO = !clientes[idx].FAVORITO;
    renderEmpresas();
    guardarLocal("crm_clientes", clientes);
    if (!crmLocalOnly) await guardarClientes(clientes);
  }

  function abrirWhatsApp(tel: string, nombre: string = "") {
    const num = tel.replace(/\D/g, "");
    if (!num) return;
    window.open(`https://web.whatsapp.com/send?phone=${num}`, "_blank");
  }

  function sincronizarEmpresaDesdeContactos(empresaNombre: string) {
    if (!empresaNombre) return;
    const empIdx = clientes.findIndex((c: any) => c.EMPRESA === empresaNombre);
    if (empIdx === -1) return;
    const cts = contactos.filter((c: any) => c.empresa === empresaNombre);
    if (!cts.length) return;
    const ct1 = cts[0]; const ct2 = cts[1];
    clientes[empIdx] = {
      ...clientes[empIdx],
      CONTACTO:   ct1?.nombre    || clientes[empIdx].CONTACTO   || "",
      CORREO:     ct1?.correo    || clientes[empIdx].CORREO     || "",
      TELEFONO_1: ct1?.telefono1 || clientes[empIdx].TELEFONO_1 || "",
      CONTACTO_2: ct2?.nombre    || clientes[empIdx].CONTACTO_2 || "",
      CORREO_2:   ct2?.correo    || clientes[empIdx].CORREO_2   || "",
      TELEFONO_2: ct2?.telefono1 || clientes[empIdx].TELEFONO_2 || "",
    };
    if (crmLocalOnly) guardarLocal("crm_clientes", clientes); else guardarClientes(clientes);
  }

  function enviarWhatsApp(e) {
    const idx = parseInt(e.target.closest("button").dataset.idx);
    const c = clientes[idx];
    const ci = getInfoContacto(c);
    const tel = ci.telefono1 || ci.telefono2;
    if (!tel) return alert("No tiene teléfono.");
    const msg = generarMensaje(c);
    const encoded = msg ? encodeURIComponent(msg) : "";
    window.open(`https://web.whatsapp.com/send?phone=${tel}${encoded ? `&text=${encoded}` : ""}`, "_blank");
  }

  function getMailProviderConfig() {
    const fromInput = document.getElementById("cfg-correo-soporte")?.value.trim();
    return {
      provider: configCorreo.provider || "brevo",
      apiKey: configCorreo.apiKey || "",
      from: parseEmailList(fromInput || configTickets.correoSoporte)[0] || "",
    };
  }

  async function enviarEmailConProveedor({ to, subject, html, text, replyTo = "" }) {
    const cuerpo = html || `<pre style="font-family:sans-serif; white-space:pre-wrap;">${text || ""}</pre>`;
    const fromEmail = parseEmailList(document.getElementById("cfg-correo-soporte")?.value.trim() || configTickets.correoSoporte)[0] || "";
    try {
      const response = await fetch("/send-email", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ to, subject, html: cuerpo, replyTo, from: fromEmail }),
      });
      const data = await response.json();
      if (!response.ok) throw new Error(data.error || data.message || JSON.stringify(data));
      toast("✉️ Correo enviado correctamente");
      return { ok: true };
    } catch (error) {
      console.error("Error enviando email:", error);
      toast(`⚠️ No se pudo enviar: ${error.message}`, "error");
      return { ok: false, error: error.message };
    }
  }

  async function enviarEmailEmpresa(e) {
    const idx = parseInt(e.target.closest("button").dataset.idx);
    const c = clientes[idx];
    const ci = getInfoContacto(c);
    if (!ci.correo) return alert("No tiene correo electrónico. Agrégalo en la sección Contactos.");
    const msg = generarMensaje(c);
    const subject = `Actualización de Sistemas CONTPAQi — ${c.EMPRESA}`;
    const body = msg || "";
    const sent = await enviarEmailConProveedor({ to: ci.correo, subject, text: body });
    if (!sent?.ok) {
      window.open(`mailto:${ci.correo}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`, "_blank");
    }
  }

  document.getElementById("btnIrContactosEmp")?.addEventListener("click", () => {
    cerrarFormEmpresa();
    navegarA("contactos");
  });

  // Filters
  document.getElementById("txtBuscar")?.addEventListener("input", renderEmpresas);
  document.getElementById("selectFiltroSistema")?.addEventListener("change", renderEmpresas);
  document.getElementById("btnFiltroFavoritos")?.addEventListener("click", () => {
    filtrarSoloFavoritos = !filtrarSoloFavoritos;
    document.getElementById("btnFiltroFavoritos").textContent = filtrarSoloFavoritos ? "⭐ Favoritos" : "☆ Favoritos";
    renderEmpresas();
  });

  // ============================================================
  // FILTROS GUARDADOS
  // ============================================================
  function renderListaFiltros() {
    const cont = document.getElementById("lista-filtros-guardados");
    if (!cont) return;
    if (!filtrosGuardados.length) { cont.innerHTML = '<div style="font-size:0.78rem;color:var(--text-muted);padding:6px 0;">No tienes filtros guardados aún.</div>'; return; }
    cont.innerHTML = filtrosGuardados.map(f => {
      const desc = [f.busqueda ? `"${f.busqueda}"` : "", f.sistema ? f.sistema : "", f.vencimientoDias ? `Vence en ${f.vencimientoDias}d` : ""].filter(Boolean).join(" · ");
      return `<div class="filtro-guardado-item">
        <div style="flex:1;min-width:0;">
          <div class="filtro-nombre">${f.nombre}</div>
          <div class="filtro-desc">${desc || "Sin condiciones"}</div>
        </div>
        <button class="btn btn-success btn-xs btn-aplicar-filtro" data-id="${f.id}" title="Aplicar filtro">▶ Aplicar</button>
        <button class="btn btn-danger btn-xs btn-del-filtro" data-id="${f.id}" title="Eliminar">🗑️</button>
      </div>`;
    }).join("");
    cont.querySelectorAll(".btn-aplicar-filtro").forEach(b => b.addEventListener("click", function() {
      const f = filtrosGuardados.find(x => x.id === this.dataset.id);
      if (!f) return;
      if (f.busqueda) (document.getElementById("txtBuscar") as HTMLInputElement).value = f.busqueda;
      if (f.sistema) (document.getElementById("selectFiltroSistema") as HTMLSelectElement).value = f.sistema;
      renderEmpresas();
      // Auto-seleccionar empresas que coinciden
      const vis = obtenerEmpresasFiltradas();
      seleccionadosIdx = [];
      if (f.vencimientoDias) {
        const hoy = new Date(); hoy.setHours(0,0,0,0);
        vis.forEach(c => {
          if (!c.VENCIMIENTOS) return;
          const vence = Object.values(c.VENCIMIENTOS).some((fecha: any) => {
            if (!fecha) return false;
            const dias = Math.ceil((new Date(fecha + "T00:00:00").getTime() - hoy.getTime()) / 86400000);
            return dias >= 0 && dias <= parseInt(f.vencimientoDias);
          });
          if (vence) seleccionadosIdx.push(c._idx);
        });
      } else {
        vis.forEach(c => { if (!seleccionadosIdx.includes(c._idx)) seleccionadosIdx.push(c._idx); });
      }
      renderEmpresas();
      document.getElementById("panel-filtros-guardados").classList.add("hidden");
      toast(`✅ Filtro "${f.nombre}" aplicado — ${seleccionadosIdx.length} empresas seleccionadas`);
    }));
    cont.querySelectorAll(".btn-del-filtro").forEach(b => b.addEventListener("click", async function() {
      filtrosGuardados = filtrosGuardados.filter(x => x.id !== this.dataset.id);
      await guardarFiltrosGuardados(filtrosGuardados);
      renderListaFiltros();
    }));
  }

  document.getElementById("btnFiltrosGuardados")?.addEventListener("click", () => {
    const panel = document.getElementById("panel-filtros-guardados");
    panel.classList.toggle("hidden");
    if (!panel.classList.contains("hidden")) renderListaFiltros();
  });
  document.getElementById("btnCerrarFiltrosPanel")?.addEventListener("click", () => {
    document.getElementById("panel-filtros-guardados").classList.add("hidden");
  });
  document.getElementById("btnGuardarFiltroActual")?.addEventListener("click", async () => {
    const nombre = (document.getElementById("filtro-nuevo-nombre") as HTMLInputElement).value.trim();
    if (!nombre) { toast("Escribe un nombre para el filtro", "error"); return; }
    const busqueda = (document.getElementById("txtBuscar") as HTMLInputElement).value.trim();
    const sistema = (document.getElementById("selectFiltroSistema") as HTMLSelectElement).value;
    const nuevo = { id: "filtro_" + Date.now(), nombre, busqueda, sistema, vencimientoDias: "" };
    filtrosGuardados.push(nuevo);
    await guardarFiltrosGuardados(filtrosGuardados);
    (document.getElementById("filtro-nuevo-nombre") as HTMLInputElement).value = "";
    renderListaFiltros();
    toast(`✅ Filtro "${nombre}" guardado`);
  });

  // Select all checkbox
  document.getElementById("chkSeleccionarTodo")?.addEventListener("change", function() {
    const vis = obtenerEmpresasFiltradas();
    if (this.checked) {
      vis.forEach(c => { if (!seleccionadosIdx.includes(c._idx)) seleccionadosIdx.push(c._idx); });
    } else {
      seleccionadosIdx = [];
    }
    renderEmpresas();
  });

  // Masivo WhatsApp
  document.getElementById("btnWspMasivo")?.addEventListener("click", () => {
    if (seleccionadosIdx.length === 0) return alert("Selecciona al menos una empresa.");
    seleccionadosIdx.forEach((idx, i) => {
      setTimeout(() => {
        const c = clientes[idx];
        const tel = c.TELEFONO_1 || c.TELEFONO_2;
        if (!tel) return;
        const msg = generarMensaje(c);
        const encoded = msg ? encodeURIComponent(msg) : "";
        window.open(`https://web.whatsapp.com/send?phone=${tel}${encoded ? `&text=${encoded}` : ""}`, "_blank");
      }, i * 500);
    });
  });

  // Masivo Email
  document.getElementById("btnMailMasivo")?.addEventListener("click", async () => {
    if (seleccionadosIdx.length === 0) return alert("Selecciona al menos una empresa.");
    const emails = seleccionadosIdx.map(i => clientes[i]?.CORREO).filter(Boolean);
    if (emails.length === 0) return alert("Ninguna empresa seleccionada tiene correo.");
    const subject = "Actualización de Sistemas CONTPAQi";
    const body = "";
    const sent = await enviarEmailConProveedor({
      to: emails,
      subject,
      text: body,
    });
    if (!sent?.ok) {
      window.open(`mailto:${emails.join(",")}?subject=${encodeURIComponent(subject)}`, "_blank");
    }
  });

  // ============================================================
  // CONTACTOS
  // ============================================================
  function renderContactos() {
    const tbody = document.getElementById("tabla-contactos-body");
    if (!tbody) return;
    tbody.innerHTML = "";
    const busq = document.getElementById("txtBuscarContacto")?.value.toLowerCase().trim() || "";

    const filtrados = contactos.filter(c => {
      if (!busq) return true;
      return (c.nombre || "").toLowerCase().includes(busq) ||
             (c.correo || "").toLowerCase().includes(busq) ||
             (c.empresa || "").toLowerCase().includes(busq);
    });
    filtrados.sort((a, b) => sortContactosDir === 'asc'
      ? (a.nombre || '').localeCompare(b.nombre || '', 'es', { sensitivity: 'base' })
      : (b.nombre || '').localeCompare(a.nombre || '', 'es', { sensitivity: 'base' })
    );
    const arrowCt = document.getElementById('sort-arrow-ct');
    if (arrowCt) { arrowCt.textContent = sortContactosDir === 'asc' ? '↑' : '↓'; arrowCt.className = 'sort-arrow active'; }

    filtrados.forEach((c, _) => {
      const idx = contactos.indexOf(c);
      const tr = document.createElement("tr");
      tr.className = "ct-row";
      tr.dataset.idx = idx;
      const tdStyle = "overflow:hidden; white-space:nowrap; text-overflow:ellipsis; max-width:0;";
      const isFirst = c.empresa ? contactos.find((x: any) => x.empresa === c.empresa) === c : true;
      const rolBadge = c.empresa
        ? `<div style="font-size:0.65rem;color:${isFirst?'#a5b4fc':'#6ee7b7'};font-weight:600;">${isFirst?'Principal':'Alternativo'}</div>`
        : '';
      tr.innerHTML = `
        <td style="${tdStyle}">
          <strong title="${c.nombre || ''}" style="color:var(--text-bright);">${c.nombre || "—"}</strong>
          ${rolBadge}
        </td>
        <td style="${tdStyle}" title="${c.empresa || ''}">
          ${c.empresa ? `<span style="font-size:0.8rem;font-weight:600;color:#f1f5f9;">${c.empresa}</span>` : '<span style="color:var(--text-muted);font-size:0.78rem;">Sin empresa</span>'}
        </td>
        <td style="${tdStyle} color:var(--brand-secondary); font-size:0.82rem;" title="${c.correo || ''}">${c.correo || "—"}</td>
        <td style="white-space:nowrap; font-size:0.82rem;">${c.telefono1 || "—"}</td>
        <td style="white-space:nowrap; font-size:0.82rem; color:#94a3b8;">${c.telefono2 || "—"}</td>
        <td style="text-align:center;">
          <div style="display:inline-flex; gap:3px;">
            ${c.telefono1 ? `<button class="btn btn-whatsapp btn-xs btn-ct-wsp" data-idx="${idx}" title="WhatsApp" style="padding:3px 5px;">💬</button>` : ''}
            ${c.correo    ? `<button class="btn btn-ghost btn-xs btn-ct-mail" data-idx="${idx}" title="Email" style="padding:3px 5px;background:rgba(249,115,22,0.15);border:1px solid rgba(249,115,22,0.4);color:#f97316;">✉️</button>` : ''}
            <button class="btn btn-secondary btn-xs btn-edit-ct" data-idx="${idx}" title="Editar" style="padding:3px 5px;">✏️</button>
            <button class="btn btn-danger btn-xs btn-del-ct" data-idx="${idx}" title="Eliminar" style="padding:3px 5px;">🗑️</button>
          </div>
        </td>
      `;
      tbody.appendChild(tr);
    });

    tbody.querySelectorAll(".btn-edit-ct").forEach(b => b.addEventListener("click", prepararEdicionContacto));
    tbody.querySelectorAll(".btn-del-ct").forEach(b => b.addEventListener("click", eliminarContacto));
    tbody.querySelectorAll(".btn-ct-wsp").forEach(b => b.addEventListener("click", () => {
      const ct = contactos[parseInt((b as HTMLElement).dataset.idx)];
      if (ct?.telefono1) abrirWhatsApp(ct.telefono1, ct.nombre || "");
    }));
    tbody.querySelectorAll(".btn-ct-mail").forEach(b => b.addEventListener("click", () => {
      const ct = contactos[parseInt((b as HTMLElement).dataset.idx)];
      if (ct?.correo) abrirZohoMail({ to: ct.correo, subject: "", body: "" });
    }));
  }

  const formCt = document.getElementById("formulario-contacto");
  const editCtIdx = document.getElementById("edit-ct-index");

  function cerrarFormContacto() {
    formCt?.classList.add("hidden");
    editCtIdx.value = "";
    ["form-ct-nombre", "form-ct-correo", "form-ct-tel1", "form-ct-tel2", "form-ct-empresa", "form-ct-empresa-buscar"].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.value = "";
    });
  }

  // Autocomplete empresa en formulario de contacto
  const ctEmpBuscar = document.getElementById("form-ct-empresa-buscar");
  const ctEmpHidden = document.getElementById("form-ct-empresa");
  const ctEmpList   = document.getElementById("ct-empresa-autocomplete");

  function setEmpresaContacto(nombre) {
    if (ctEmpBuscar) ctEmpBuscar.value = nombre;
    if (ctEmpHidden) ctEmpHidden.value = nombre;
    ctEmpList?.classList.add("hidden");
  }

  ctEmpBuscar?.addEventListener("input", function() {
    const val = this.value.toLowerCase().trim();
    if (ctEmpHidden) ctEmpHidden.value = this.value.trim();
    if (!val) { ctEmpList?.classList.add("hidden"); return; }
    const matches = clientes.filter(c => (c.EMPRESA || "").toLowerCase().includes(val)).slice(0, 12);
    if (!matches.length) { ctEmpList?.classList.add("hidden"); return; }
    ctEmpList.innerHTML = "";
    matches.forEach(c => {
      const div = document.createElement("div");
      div.className = "autocomplete-item";
      div.innerHTML = `<span style="font-weight:600; color:#f1f5f9;">🏢 ${c.EMPRESA}</span>`;
      div.addEventListener("click", () => setEmpresaContacto(c.EMPRESA));
