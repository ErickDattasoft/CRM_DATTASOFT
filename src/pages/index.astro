  #confirm-modal-msg { font-size: 0.95rem; font-weight: 600; color: var(--text-main, #e2e8f0); margin-bottom: 20px; line-height: 1.4; white-space: pre-line; }
  #confirm-modal-actions { display: flex; gap: 10px; }
  #confirm-modal-actions button { flex: 1; padding: 11px; border-radius: 10px; font-size: 0.9rem; font-weight: 700; cursor: pointer; border: none; }
