    if (Array.isArray(clientes) && clientes.length > 0) {
      const sample = clientes[0] || {};
      const looksLikeRows = Boolean(sample.SISTEMA || sample.Sistema || sample.sistema || sample.VERSION || sample.VERSIONES || sample.EMPRESAS || sample.EMPRESA && !sample.SISTEMAS);
      if (looksLikeRows) {
        clientes = normalizeImportedClientes(clientes);
        guardarLocal("crm_clientes", clientes);
      } else {
        // asegurar campos mínimos
        clientes = clientes.map(c => ({
          ...c,
          EMPRESA: c.EMPRESA || c.EMPRESAS || '',
          CONTACTO: c.CONTACTO || c['CONTACTO PRINCIPAL'] || c.CONTACTO || '',
          TELEFONO_1: c.TELEFONO_1 || c.TELEFONO || c.telefono || '',
          CORREO: c.CORREO || c.CORREO_ELECTRONICO || c.EMAIL || c.correo || ''
        }));
      }
    }
    if (Array.isArray(contactos) && contactos.length > 0) {
      const sampleCt = contactos[0] || {};
