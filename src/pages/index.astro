    const brandLogoEl  = document.getElementById("sidebar-brand-logo-el") as HTMLElement | null;
    const logoImg      = document.getElementById("sidebar-logo-img")       as HTMLImageElement | null;
    const topbarImg    = document.getElementById("topbar-logo-img")        as HTMLImageElement | null;
    const loginImg     = document.getElementById("login-logo-img")         as HTMLImageElement | null;
    const loginEmoji   = document.getElementById("login-icon-emoji")       as HTMLElement | null;
    const previewImg   = document.getElementById("cfg-logo-preview-img")   as HTMLImageElement | null;
    const previewEmoji = document.getElementById("cfg-logo-preview-emoji") as HTMLElement | null;
    const lbImg        = document.getElementById("logo-lightbox-img")      as HTMLImageElement | null;
    if (saved) {
      if (brandLogoEl) brandLogoEl.style.display = "none";
      if (logoImg)    { logoImg.src = saved;    logoImg.style.display = "block"; }
      if (topbarImg)  { topbarImg.src = saved;  topbarImg.style.display = "block"; }
      if (loginImg)   { loginImg.src = saved;   loginImg.style.display = "block"; }
      if (loginEmoji) loginEmoji.style.display = "none";
