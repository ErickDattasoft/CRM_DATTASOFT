  // Dispara un evento a n8n si hay webhook configurado, la regla está activa y tiene
  // destinatarios seleccionados. Silencioso: nunca bloquea la UI ni el flujo que lo llama.
  async function dispararN8n(eventoId, datos) {
    try {
      const url = configN8n.webhookUrl;
      if (!url) return;
      const regla = (configN8n.reglas || []).find(r => r.id === eventoId);
      if (!regla || !regla.activo) return;
      const destinatariosIds = regla.destinatariosIds || [];
      const destinatarios = (configN8n.destinatarios || [])
        .filter(d => d.activo && destinatariosIds.includes(d.id))
        .map(d => ({ nombre: d.nombre, telefono: d.telefono, apiKey: d.apiKey }));
      if (!destinatarios.length) return;
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 5000);
      await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ evento: eventoId, datos, destinatarios }),
        signal: controller.signal,
      }).catch(() => {});
      clearTimeout(timeoutId);
    } catch (err) {
      console.warn("[n8n] Error al disparar evento", eventoId, err);
    }
  }

  // Envía un WhatsApp de prueba directo vía CallMeBot (no pasa por n8n — CallMeBot solo
  // funciona con números pre-registrados del equipo interno, ver nota en el panel).
  async function probarWhatsAppCallMeBot(telefono, apiKey, mensaje) {
    try {
      const url = `https://api.callmebot.com/whatsapp.php?phone=${encodeURIComponent(telefono)}&text=${encodeURIComponent(mensaje)}&apikey=${encodeURIComponent(apiKey)}`;
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 8000);
      const res = await fetch(url, { signal: controller.signal });
      clearTimeout(timeoutId);
      const text = await res.text();
      return res.ok && !/error/i.test(text);
    } catch {
      return false;
    }
  }

