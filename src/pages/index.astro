  async function enviarEmailConProveedor({ to, subject, html, text, replyTo = "", cc = "", bcc = "", attachment = null }) {
    const cuerpo = html || `<pre style="font-family:sans-serif; white-space:pre-wrap;">${text || ""}</pre>`;
    const fromEmail = parseEmailList(document.getElementById("cfg-correo-soporte")?.value.trim() || configTickets.correoSoporte)[0] || "";
    try {
      const response = await fetch("/send-email", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ to, subject, html: cuerpo, replyTo, cc, bcc, from: fromEmail, ...(attachment ? { attachment } : {}) }),
      });
      const data = await response.json();
      if (!response.ok) throw new Error(data.error || data.message || JSON.stringify(data));
      toast("✉️ Correo enviado correctamente");
      return { ok: true };
    } catch (error) {
      console.error("Error enviando email:", error);
      toast(`⚠️ No se pudo enviar: ${error.message}`, "error");
      return { ok: false, error: error.message };
    }
  }

  // Convierte el HTML del editor de descripción a HTML de correo preservando saltos de línea:
  // .replace(/<[^>]*>/g,"") a secas borraba <div>/<p>/<br> sin dejar separador, pegando todo el texto.
  function descripcionTicketAHtml(html) {
    const texto = (html || "")
      .replace(/<br\s*\/?>/gi, "\n")
      .replace(/<\/(p|div|li|h[1-6]|tr)>/gi, "\n")
      .replace(/<[^>]+>/g, "")
      .replace(/&nbsp;/gi, " ")
      .replace(/\n{3,}/g, "\n\n")
      .trim();
    return texto.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/\n/g, "<br>");
  }

  async function enviarNotificacionTicket(t) {
    const mailTo = t.contactoCorreo || contactos.find(c => c.nombre === t.contacto)?.correo || "";
    const soporteEmails = parseEmailList(configTickets.correoSoporte);
    const ccTicket = parseEmailList(t.cc || "");
    const bccTicket = parseEmailList(t.cco || "").filter(e => e !== mailTo).join(",");
    const mailSubject = `[Ticket #${t.numero}] ${t.asunto}`;
    const avisoSinContacto = mailTo ? "" : `
      <p style="background:#fef3c7; color:#92400e; padding:8px 12px; border-radius:6px; font-family:sans-serif; font-size:13px;">
        ⚠️ El contacto no tiene correo registrado — este ticket no se notificó al cliente.
      </p>`;
    const htmlTicket = `
      ${avisoSinContacto}
      <h2 style="color:#4f46e5; font-family:sans-serif;">[Ticket #${t.numero}] ${t.asunto}</h2>
      <table style="border-collapse:collapse; width:100%; font-family:sans-serif; font-size:14px;">
        <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6; width:130px;">Empresa</td><td style="padding:6px 12px;">${t.empresa || ""}</td></tr>
        <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6;">Contacto</td><td style="padding:6px 12px;">${t.contacto || ""}</td></tr>
        <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6;">Tipo</td><td style="padding:6px 12px;">${t.tipo || ""}</td></tr>
        <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6;">Prioridad</td><td style="padding:6px 12px;">${t.prioridad || ""}</td></tr>
        <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6;">Estado</td><td style="padding:6px 12px;">${t.estado || ""}</td></tr>
        <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6;">Solicitado por</td><td style="padding:6px 12px;">${t.solicitado || ""}</td></tr>
        <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6;">Canalizado a</td><td style="padding:6px 12px;">${t.canalizado || ""}</td></tr>
        <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6;">Agente</td><td style="padding:6px 12px;">${t.agente || ""}</td></tr>
      </table>
      <h3 style="margin-top:16px; font-family:sans-serif;">Descripción</h3>
      <div style="background:#f9fafb; padding:12px; border-radius:6px; font-family:sans-serif;">${descripcionTicketAHtml(t.descripcion)}</div>
      <hr style="margin-top:24px; border:none; border-top:1px solid #e5e7eb;">
      <p style="font-size:12px; color:#6b7280; font-family:sans-serif;">DATTASOFT BY INFOXPERT — Sistema de Tickets</p>
    `;

    let sent;
    if (mailTo) {
      const mailReplyTo = soporteEmails[0] || "";
      const mailCC = [...new Set([...soporteEmails, ...ccTicket])].filter(e => e !== mailTo).join(",");
      sent = await enviarEmailConProveedor({ to: mailTo, subject: mailSubject, html: htmlTicket, replyTo: mailReplyTo, cc: mailCC, bcc: bccTicket });
      if (sent?.ok) { toast(`✉️ Notificación enviada a ${mailTo}`); logBitacora(`✉️ Correo enviado a ${mailTo} — Ticket #${t.numero}`, "📧"); }
      else toast(`⚠️ No se pudo enviar: ${sent?.error || "error desconocido"}`, "error");
      return sent;
    }

    // Sin correo de contacto: notificar de todos modos a soporte/CC, no abortar en silencio.
    const destinatarios = [...new Set([...soporteEmails, ...ccTicket])];
    if (!destinatarios.length) {
      toast("⚠️ El contacto no tiene correo y no hay correo de soporte configurado — no se pudo notificar a nadie", "warning");
      return { ok: false };
    }
    toast("⚠️ El contacto no tiene correo registrado — se notificó solo a soporte", "warning");
    sent = await enviarEmailConProveedor({ to: destinatarios, subject: mailSubject, html: htmlTicket, replyTo: soporteEmails[0] || "", bcc: bccTicket });
    if (sent?.ok) logBitacora(`✉️ Correo enviado a soporte (sin contacto) — Ticket #${t.numero}`, "📧");
    else toast(`⚠️ No se pudo notificar a soporte: ${sent?.error || "error desconocido"}`, "error");
    return sent;
  }

  // Datos comunes que se mandan a n8n para cualquier evento relacionado con un ticket.
  function datosEventoTicket(t, extra = {}) {
    return {
      numero: t.numero, empresa: t.empresa || "", contacto: t.contacto || "", asunto: t.asunto,
      estado: t.estado, agenteAsignado: t.agente || "", notaInterna: t.notasInternas || "",
      cambiadoPor: getUsuarioActual()?.nombre || "Sistema", fecha: new Date().toISOString(),
      ...extra,
    };
  }

  // Se llama cada vez que se guarda un ticket (creación o edición) — si el estado ACABA de
  // cambiar a "Cerrado" en esta misma acción, dispara ticket_cerrado. No hace nada si el ticket
  // ya estaba cerrado antes de esta acción (para no reenviar en cada edición posterior de un
  // ticket que sigue cerrado).
  async function procesarCierreTicket(t, estadoAnterior) {
    const seAcabaDeCerrar = (t.estado || "").toLowerCase() === "cerrado" && (estadoAnterior || "").toLowerCase() !== "cerrado";
    if (seAcabaDeCerrar) dispararN8n("ticket_cerrado", datosEventoTicket(t));
  }

  // Correo + evento n8n de "cerrado y facturado" — se dispara la primera vez que la combinación
  // (estado === Cerrado) Y (facturación === FACTURADO) se cumple, sin importar cuál de los dos
  // campos fue el que acaba de cambiar: cerrar un ticket ya marcado FACTURADO, o marcar FACTURADO
  // un ticket que ya estaba cerrado, ambos disparan el correo igual. Si la combinación ya estaba
  // cumplida antes de esta acción, no se reenvía (evita mandar el correo de nuevo en cada edición
  // posterior de un ticket que sigue cerrado y facturado).
  async function procesarFacturacion(t, estadoAnterior, facturadoAnterior) {
    const estaCerrado = (t.estado || "").toLowerCase() === "cerrado";
    const estaFacturado = (t.facturado || "").toUpperCase() === "FACTURADO";
    const yaEstabaCumplida = (estadoAnterior || "").toLowerCase() === "cerrado" && (facturadoAnterior || "").toUpperCase() === "FACTURADO";
    if (!estaCerrado || !estaFacturado || yaEstabaCumplida) return;
    const destino = parseEmailList(configTickets.correoSoporte);
    if (destino.length) {
      const html = `<div style="font-family:sans-serif; padding:16px; line-height:1.7; font-size:14px;">
        <p>El ticket #${t.numero} de ${escapeHtml(t.empresa || "")} fue cerrado y marcado como <strong>FACTURADO</strong>.</p>
        <p>
          <strong>Contacto:</strong> ${escapeHtml(t.contacto || "")}<br>
          <strong>Asunto:</strong> ${escapeHtml(t.asunto || "")}<br>
          ${(t.notasInternas || "").trim() ? `<strong>Nota interna:</strong> ${escapeHtml(t.notasInternas)}<br>` : ""}
          <strong>Actualizado por:</strong> ${escapeHtml(getUsuarioActual()?.nombre || "Sistema")}<br>
          <strong>Fecha:</strong> ${new Date().toLocaleString("es-MX")}
        </p>
      </div>`;
      enviarEmailConProveedor({
        to: destino,
        subject: `✅ Ticket #${t.numero} cerrado — ${t.empresa || t.contacto || ""} [FACTURADO]`,
        html,
      }).catch(() => {});
    }
    dispararN8n("ticket_cerrado_facturado", datosEventoTicket(t));
    logBitacora(`🧾 Ticket #${t.numero} cerrado y FACTURADO — correo enviado`, "🧾");
  }

  async function enviarEmailEmpresa(e) {
    const idx = parseInt(e.target.closest("button").dataset.idx);
    const c = clientes[idx];
    const ci = getInfoContacto(c);
    if (!ci.correo) return alert("No tiene correo electrónico. Agrégalo en la sección Contactos.");
    const msg = generarMensaje(c);
    const subject = `Actualización de Sistemas CONTPAQi — ${c.EMPRESA}`;
    const body = msg || "";
    const sent = await enviarEmailConProveedor({ to: ci.correo, subject, text: body });
    if (!sent?.ok) {
      window.open(`mailto:${ci.correo}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`, "_blank");
    }
  }

