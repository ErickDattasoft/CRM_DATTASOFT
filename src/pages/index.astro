  function kbFiltrar(): KBDoc[] {
    const q = kbNorm((document.getElementById("kb-search-input") as HTMLInputElement)?.value || "");
    let docs = kbCat === "all" ? [...kbDocs] : kbDocs.filter(d => d.category === kbCat);
    if (kbTagFilter) docs = docs.filter(d => (d.tags || []).map(t => kbNorm(t)).includes(kbNorm(kbTagFilter!)));
    if (q) docs = docs.filter(d => {
      const t = kbNorm(d.title), c = kbNorm(d.content), tg = kbNorm((d.tags || []).join(" "));
      if (kbExact) return t.includes(q) || c.includes(q) || tg.includes(q);
      return q.trim().split(/\s+/).every(w => t.includes(w) || c.includes(w) || tg.includes(w));
    });
    docs.sort((a, b) => {
      const cmp = kbNorm(a.title).localeCompare(kbNorm(b.title));
      return kbSort === "asc" ? cmp : -cmp;
    });
    return docs;
  }

  function kbHighlight(text: string, q: string): string {
    if (!q) return kbEsc(text);
    const safe = q.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    return kbEsc(text).replace(new RegExp(safe, "gi"), m => `<mark class="kb-hl">${m}</mark>`);
  }

  function kbHighlightContent(content: string, rawQ: string): string {
    if (!rawQ) return content;
    const words = kbExact ? [rawQ] : rawQ.trim().split(/\s+/).filter(Boolean);
    let result = content;
    for (const w of words) {
      if (!w) continue;
      const safe = w.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
      // Alternation: match HTML tags (keep) OR text nodes (highlight)
      result = result.replace(/(<[^>]+>)|([^<]+)/g, (_, tag, text) => {
        if (tag) return tag;
        if (!text) return "";
        if (!kbNorm(text).includes(kbNorm(w))) return text;
        return text.replace(new RegExp(safe, "gi"), m => `<mark class="kb-hl-content">${m}</mark>`);
      });
    }
    return result;
  }

  function kbRenderMarkdown(md: string): string {
    try {
      const mk = (window as any).marked;
      if (mk) {
        mk.setOptions({ breaks: true, gfm: true });
        return mk.parse(md);
      }
    } catch {}
    return `<pre style="white-space:pre-wrap; font-size:0.85rem;">${kbEsc(md)}</pre>`;
  }

  function kbRenderList() {
    const list = document.getElementById("kb-doc-list");
    if (!list) return;
    const docs = kbFiltrar();
    const total   = kbDocs.length;
    const empresa = kbDocs.filter(d => d.category === "empresa").length;
    const solucion= kbDocs.filter(d => d.category === "solucion").length;
    const script  = kbDocs.filter(d => d.category === "script").length;
    const setN = (id: string, n: number) => { const el = document.getElementById(id); if (el) el.textContent = String(n); };
    setN("kb-cnt-all", total); setN("kb-cnt-empresa", empresa); setN("kb-cnt-solucion", solucion); setN("kb-cnt-script", script);

    if (!docs.length) {
      list.innerHTML = `<div class="kb-list-empty">${kbDocs.length ? "🔍 Sin resultados." : "📭 Sin documentos.<br>Sube archivos o crea uno nuevo."}</div>`;
      return;
    }
    const q = kbNorm((document.getElementById("kb-search-input") as HTMLInputElement)?.value || "");
    list.innerHTML = docs.map(d => {
      const ft = kbFmtType(d.file_type), fc = kbFmtCat(d.category);
      const titleHtml = q ? kbHighlight(d.title, q) : kbEsc(d.title);
      const tags = (d.tags || []).slice(0, 4);
      const tagsHtml = tags.map(t =>
        `<span class="kb-tag-chip ${kbTagFilter && kbNorm(t) === kbNorm(kbTagFilter) ? "kb-tag-active" : ""}" data-tag="${kbEsc(t)}">${kbTagIcon(t)} ${kbEsc(t)}</span>`
      ).join("");
      return `<div class="kb-doc-item ${kbSelId === d._id ? "kb-sel" : ""}" data-kid="${d._id}">
        <div class="kb-item-title">${titleHtml}</div>
        <div class="kb-item-foot">
          <span class="kb-badge ${ft.cls}">${ft.ext}</span>
          <span class="kb-badge ${fc.cls}">${fc.label}</span>
          <span class="kb-item-date">${kbFmtDate(d.updated_at)}</span>
        </div>
        ${tagsHtml ? `<div class="kb-tags-row" style="margin-top:5px;">${tagsHtml}</div>` : ""}
      </div>`;
    }).join("");
    kbUpdateTagCloud();
  }

  function kbRelacionados(doc: KBDoc): KBDoc[] {
    if (!doc.tags?.length) return [];
    const myTags = doc.tags.map(t => kbNorm(t));
    return kbDocs
      .filter(d => d._id !== doc._id && (d.tags || []).some(t => myTags.includes(kbNorm(t))))
      .map(d => ({ doc: d, shared: (d.tags || []).filter(t => myTags.includes(kbNorm(t))).length }))
      .sort((a, b) => b.shared - a.shared)
      .slice(0, 6)
      .map(x => x.doc);
  }

  function kbRenderDocInPanel(id: string, panelNum: number) {
    const p2 = panelNum === 2;
    const emptyId   = p2 ? "kb-viewer-empty-2"  : "kb-viewer-empty";
    const viewId    = p2 ? "kb-doc-view-2"       : "kb-doc-view";
    const titleId   = p2 ? "kb-view-title-2"     : "kb-view-title";
    const metaId    = p2 ? "kb-view-meta-2"      : "kb-view-meta";
    const contentId = p2 ? "kb-content-wrap-2"   : "kb-content-wrap";

    const doc = kbDocs.find(d => d._id === id);
    if (!doc) return;
    const emptyEl = document.getElementById(emptyId);
    const viewEl  = document.getElementById(viewId);
    if (emptyEl) emptyEl.style.display = "none";
    if (viewEl)  viewEl.style.display = "flex";

    (document.getElementById(titleId) as HTMLElement).textContent = doc.title;
    const fc = kbFmtCat(doc.category), ft = kbFmtType(doc.file_type);
    const tagsHtml = (doc.tags || []).map(t =>
      `<span class="kb-tag-chip" data-tag="${kbEsc(t)}">${kbTagIcon(t)} ${kbEsc(t)}</span>`
    ).join("");
    (document.getElementById(metaId) as HTMLElement).innerHTML =
      `<span class="kb-badge ${ft.cls}">${ft.ext}</span>
       <span class="kb-badge ${fc.cls}">${fc.label}</span>
       ${doc.updated_at ? `<span>· ${kbFmtDate(doc.updated_at)}</span>` : ""}
       ${tagsHtml ? `<span style="display:flex;gap:4px;flex-wrap:wrap;">${tagsHtml}</span>` : ""}`;

    document.getElementById(metaId)?.querySelectorAll<HTMLElement>(".kb-tag-chip").forEach(chip => {
      chip.addEventListener("click", () => { kbTagFilter = chip.dataset.tag!; kbRenderList(); });
    });

    const wrap = document.getElementById(contentId);
    if (wrap) {
      const qVisor = ((document.getElementById("kb-search-input") as HTMLInputElement)?.value || "").trim();
      const ps1Note = doc.file_type === "ps1"
        ? `<div style="display:flex;align-items:center;gap:8px;padding:7px 12px;margin-bottom:8px;background:rgba(251,191,36,0.07);border:1px solid rgba(251,191,36,0.2);border-radius:var(--radius-sm);font-size:0.75rem;color:#fbbf24;">
            ⚠️ Si no corre con doble clic: clic derecho → <strong>Propiedades → Desbloquear</strong>, o pega el contenido directo en la terminal PowerShell.
           </div>`
        : "";
      const rawMd  = kbRenderMarkdown(doc.content);
      const rawScr = kbEsc(doc.content);
      const contentHtml = doc.file_type === "md"
        ? `<div class="kb-md">${qVisor ? kbHighlightContent(rawMd, qVisor) : rawMd}</div>`
        : ps1Note + `<div class="kb-script">${qVisor ? kbHighlightContent(rawScr, qVisor) : rawScr}</div>`;

      const rel = kbRelacionados(doc);
      const relHtml = rel.length ? `
        <div class="kb-relacionados">
          <div class="kb-rel-title">📎 Ver también (${rel.length})</div>
          <div class="kb-rel-list">${rel.map(r => {
            const rf = kbFmtType(r.file_type), rc = kbFmtCat(r.category);
            const sharedTags = (r.tags || []).filter(t => (doc.tags || []).map(x => kbNorm(x)).includes(kbNorm(t)));
            return `<div class="kb-rel-item" data-kid="${r._id}" data-panel="${panelNum}">
              <span class="kb-badge ${rf.cls}">${rf.ext}</span>
              <span class="kb-rel-item-title">${kbEsc(r.title)}</span>
              <span class="kb-rel-shared">${sharedTags.slice(0,2).map(t => kbTagIcon(t)+" "+kbEsc(t)).join(" · ")}</span>
            </div>`;
          }).join("")}</div>
        </div>` : "";

      wrap.innerHTML = contentHtml + relHtml;
      wrap.querySelectorAll<HTMLElement>(".kb-rel-item").forEach(el => {
        el.addEventListener("click", () => kbAbrirDoc(el.dataset.kid!, parseInt(el.dataset.panel || "1")));
      });
    }
  }

  function kbAbrirDoc(id: string, targetPanel?: number) {
    const panel = targetPanel ?? (kbSplitMode ? kbActivePanel : 1);
    if (panel === 2) {
      kbSelId2 = id;
      kbRenderDocInPanel(id, 2);
    } else {
      kbSelId = id;
      document.querySelectorAll<HTMLElement>(".kb-doc-item").forEach(el => {
        el.classList.toggle("kb-sel", el.dataset.kid === id);
      });
      kbRenderDocInPanel(id, 1);
    }
  }

  function kbRenderTagsPreview(raw: string) {
    const preview = document.getElementById("kb-form-tags-preview");
    if (!preview) return;
    const tags = raw.split(",").map(t => t.trim()).filter(Boolean);
    if (!tags.length) { preview.style.display = "none"; preview.innerHTML = ""; return; }
    preview.style.display = "flex";
    preview.innerHTML = tags.map(t => `<span class="kb-tag-chip">${kbTagIcon(t)} ${kbEsc(t)}</span>`).join("");
  }

  function kbAbrirModal(editId?: string) {
    kbEditId = editId || null;
    const doc = editId ? kbDocs.find(d => d._id === editId) : null;
    (document.getElementById("kb-modal-title") as HTMLElement).textContent = doc ? "Editar documento" : "Nuevo documento";
    (document.getElementById("kb-form-title") as HTMLInputElement).value      = doc?.title   || "";
    (document.getElementById("kb-form-cat") as HTMLSelectElement).value       = doc?.category || "solucion";
    (document.getElementById("kb-form-type") as HTMLSelectElement).value      = doc?.file_type || "md";
    (document.getElementById("kb-form-tags") as HTMLInputElement).value       = (doc?.tags || []).join(", ");
    (document.getElementById("kb-form-content") as HTMLTextAreaElement).value = doc?.content || "";
    kbRenderTagsPreview((doc?.tags || []).join(", "));
    const modal = document.getElementById("kb-modal");
    if (modal) modal.style.display = "flex";
    setTimeout(() => (document.getElementById("kb-form-title") as HTMLInputElement)?.focus(), 80);
  }

  function kbCerrarModal() {
    const modal = document.getElementById("kb-modal");
    if (modal) modal.style.display = "none";
  }

  function kbGuardarLocal(data: Omit<KBDoc, "_id">, id?: string) {
    const now = { toDate: () => new Date(), seconds: Date.now() / 1000 };
    if (id) {
      const idx = kbDocs.findIndex(d => d._id === id);
      if (idx >= 0) kbDocs[idx] = { ...kbDocs[idx], ...data, updated_at: now };
    } else {
      const newDoc: KBDoc = { _id: "kb_" + Date.now(), ...data, created_at: now, updated_at: now };
      kbDocs.unshift(newDoc);
      kbSelId = newDoc._id;
    }
    localStorage.setItem("crm_kb", JSON.stringify(kbDocs));
    kbRenderList();
    if (kbSelId) kbAbrirDoc(kbSelId);
  }

  async function kbGuardar() {
    const title    = (document.getElementById("kb-form-title") as HTMLInputElement).value.trim();
    const category = (document.getElementById("kb-form-cat") as HTMLSelectElement).value as KBDoc["category"];
    const file_type= (document.getElementById("kb-form-type") as HTMLSelectElement).value as KBDoc["file_type"];
    const content  = (document.getElementById("kb-form-content") as HTMLTextAreaElement).value;
    const tagsRaw  = (document.getElementById("kb-form-tags") as HTMLInputElement).value;
    const tags     = tagsRaw.split(",").map(t => t.trim()).filter(Boolean);
    if (!title) { (document.getElementById("kb-form-title") as HTMLInputElement).focus(); toast("⚠️ El título es obligatorio", "warning"); return; }

    const saveBtn = document.getElementById("kb-form-save") as HTMLButtonElement;
    saveBtn.disabled = true; saveBtn.textContent = "Guardando...";

    const data = { title, category, file_type, content, tags };
    if (firebaseEnabled) {
      if (kbEditId) {
        await actualizarDocKB(kbEditId, data);
        if (kbSelId === kbEditId) setTimeout(() => kbAbrirDoc(kbEditId!), 200);
      } else {
        const newId = await crearDocKB(data);
        if (newId) kbSelId = newId;
      }
    } else {
      kbGuardarLocal(data, kbEditId || undefined);
    }
    saveBtn.disabled = false; saveBtn.textContent = "💾 Guardar documento";
    kbCerrarModal();
    toast("✅ Documento guardado");
  }

  async function kbRecuperarEnFirestore(localDocs: KBDoc[]) {
    toast("🔄 Recuperando KB en Firestore...", "info");
    let ok = 0, err = 0;
    for (const d of localDocs) {
      try {
        await crearDocKB({ title: d.title, category: d.category, file_type: d.file_type, content: d.content, tags: d.tags || [] });
        ok++;
      } catch { err++; }
    }
    toast(`✅ ${ok} documentos recuperados en Firestore${err ? ` · ${err} errores` : ""}`, err ? "warning" : "success");
  }

  async function kbEliminar(id: string) {
    if (!confirm("¿Eliminar este documento? Esta acción no se puede deshacer.")) return;
    if (firebaseEnabled) {
      await eliminarDocKB(id);
    } else {
      kbDocs = kbDocs.filter(d => d._id !== id);
      localStorage.setItem("crm_kb", JSON.stringify(kbDocs));
      kbRenderList();
    }
    if (kbSelId === id) {
      kbSelId = null;
      const emptyEl = document.getElementById("kb-viewer-empty");
      const viewEl  = document.getElementById("kb-doc-view");
      if (emptyEl) emptyEl.style.display = "";
      if (viewEl)  viewEl.style.display = "none";
    }
    toast("🗑️ Documento eliminado");
  }

  async function kbCargarArchivo(file: File, forcedCategory?: KBDoc["category"]): Promise<string | null> {
    const text = await file.text();
    const title = file.name.replace(/\.(md|ps1|bat|txt)$/i, "");
    const file_type = kbGuessType(file.name);
    const category  = forcedCategory || kbGuessCat(file.name);
    const tags: string[] = [];
    const data = { title, category, file_type, content: text, tags };
    if (firebaseEnabled) {
      return await crearDocKB(data);
    } else {
      kbGuardarLocal(data);
      return "local_" + Date.now();
    }
  }

  async function kbSubidaMasiva(files: FileList | File[], forcedCategory?: KBDoc["category"]) {
    const lista = Array.from(files).filter(f => /\.(md|ps1|bat|sql|txt)$/i.test(f.name));
    if (!lista.length) { toast("⚠️ No se encontraron archivos .md .ps1 .bat", "warning"); return; }

    const progressEl  = document.getElementById("kb-upload-progress");
    const statusEl    = document.getElementById("kb-upload-status");
    const counterEl   = document.getElementById("kb-upload-counter");
    const barEl       = document.getElementById("kb-upload-bar");
    const errorsEl    = document.getElementById("kb-upload-errors");
    if (progressEl) progressEl.style.display = "block";
    if (errorsEl) errorsEl.textContent = "";
    if (barEl) barEl.style.width = "0%";

    const total = lista.length;
    let done = 0, errors = 0;
    const errNames: string[] = [];

    const updateProgress = () => {
      const pct = Math.round((done / total) * 100);
      if (barEl) barEl.style.width = pct + "%";
      if (counterEl) counterEl.textContent = `${done} / ${total}`;
      if (statusEl) statusEl.textContent = done < total ? `Subiendo... (${pct}%)` : errors ? `✅ Listo con ${errors} error(es)` : "✅ Todos subidos";
    };

    // Subida en lotes de 8 simultáneos
    const BATCH = 8;
    for (let i = 0; i < lista.length; i += BATCH) {
      const lote = lista.slice(i, i + BATCH);
      const resultados = await Promise.allSettled(lote.map(f => kbCargarArchivo(f, forcedCategory)));
      resultados.forEach((r, idx) => {
        done++;
        if (r.status === "rejected" || (r.status === "fulfilled" && !r.value)) {
          errors++;
          errNames.push(lote[idx].name);
        }
      });
      updateProgress();
    }

    if (errNames.length && errorsEl)
      errorsEl.textContent = `❌ Fallaron: ${errNames.slice(0,5).join(", ")}${errNames.length > 5 ? ` y ${errNames.length-5} más` : ""}`;

    setTimeout(() => { if (progressEl) progressEl.style.display = "none"; }, 3500);
    toast(`✅ ${done - errors} subidos${errors ? ` · ${errors} errores` : ""}`);
  }

  async function kbIndexar(files: FileList | File[]) {
    const lista = Array.from(files).filter(f => /\.(md|ps1|bat|sql|txt)$/i.test(f.name));
    if (!lista.length) { toast("⚠️ No se encontraron archivos válidos", "warning"); return; }

    const progressEl = document.getElementById("kb-upload-progress");
    const statusEl   = document.getElementById("kb-upload-status");
    const counterEl  = document.getElementById("kb-upload-counter");
    const barEl      = document.getElementById("kb-upload-bar");
    const errorsEl   = document.getElementById("kb-upload-errors");
    if (progressEl) progressEl.style.display = "block";
    if (errorsEl)   errorsEl.textContent = "";
    if (barEl)      barEl.style.width = "0%";

    const total = lista.length;
    let done = 0, actualizados = 0, nuevos = 0, sinCambios = 0, errores = 0;

    const updateProgress = () => {
      const pct = Math.round((done / total) * 100);
      if (barEl)    barEl.style.width = pct + "%";
      if (counterEl) counterEl.textContent = `${done} / ${total}`;
      if (statusEl)  statusEl.textContent = done < total
        ? `Indexando... (${pct}%)`
        : `✅ ${actualizados} actualizados · ${nuevos} nuevos${sinCambios ? ` · ${sinCambios} sin cambios` : ""}${errores ? ` · ${errores} errores` : ""}`;
    };

    const BATCH = 8;
    for (let i = 0; i < lista.length; i += BATCH) {
      const lote = lista.slice(i, i + BATCH);
      await Promise.allSettled(lote.map(async (f) => {
        try {
          const text    = await f.text();
          const title   = f.name.replace(/\.(md|ps1|bat|sql|txt)$/i, "");
          const existing = kbDocs.find(d => kbNorm(d.title) === kbNorm(title));
          if (existing) {
            const sp = (f as any).webkitRelativePath as string || "";
            if (existing.content === text) {
              if (sp && !existing.sourcePath) await actualizarSourcePathKB(existing._id, sp);
              sinCambios++;
            } else {
              const upd: any = { content: text };
              if (sp) upd.sourcePath = sp;
              await actualizarDocKB(existing._id, upd);
              actualizados++;
            }
          } else {
            const sp = (f as any).webkitRelativePath as string || "";
            await crearDocKB({
              title,
              category: kbGuessCat(f.name),
              file_type: kbGuessType(f.name),
              content: text,
              tags: [],
              ...(sp ? { sourcePath: sp } : {})
            });
            nuevos++;
          }
        } catch { errores++; }
        done++;
        updateProgress();
      }));
    }
    setTimeout(() => { if (progressEl) progressEl.style.display = "none"; }, 4000);
    toast(`🔄 Indexado: ${actualizados} actualizados · ${nuevos} nuevos${sinCambios ? ` · ${sinCambios} sin cambios` : ""}`);
  }

  function kbGetDocExtension(doc: KBDoc): string {
    const m: Record<string, string> = { md: "md", ps1: "ps1", bat: "bat", sql: "sql" };
    return m[doc.file_type] || "txt";
  }

  function kbBuildFullPath(doc: KBDoc, basePath: string): string {
    const ext = kbGetDocExtension(doc);
    const filename = `${doc.title}.${ext}`;
    const rel = doc.sourcePath ? doc.sourcePath.replace(/\//g, "\\") : filename;
    if (!basePath) return rel;
    return basePath.replace(/[/\\]*$/, "") + "\\" + rel;
  }

  function kbGetTs(d: KBDoc): number {
    // content_updated_at solo se actualiza con cambios de contenido, no de ruta
    const u = (d as any).content_updated_at ?? null;
    if (!u) return 0;
    if (typeof u.toDate === "function") {
      try { return u.toDate().getTime(); } catch { /* fallback */ }
    }
    if (typeof u.seconds === "number") return u.seconds * 1000;
    if (u instanceof Date) return u.getTime();
    return 0;
  }

  function kbGetExportDocs(filter: string): KBDoc[] {
    const now = Date.now();
    const lastStr = localStorage.getItem("crm_kb_last_export");
    const lastMs = lastStr ? new Date(lastStr).getTime() : 0;
    return kbDocs.filter(d => {
      const ts = kbGetTs(d);
      switch (filter) {
        case "today": { const sod = new Date(); sod.setHours(0,0,0,0); return ts > 0 && ts >= sod.getTime(); }
        case "week":  return ts > 0 && ts >= now - 7 * 86_400_000;
        case "changed": return ts > lastMs;
        default: return true; // all
      }
    });
  }

  function kbRenderExportList() {
    const list = document.getElementById("kb-export-list");
    if (!list) return;
    const basePath = (document.getElementById("kb-export-basepath") as HTMLInputElement)?.value ?? "";
    const filter = (document.getElementById("kb-export-filter") as HTMLSelectElement)?.value || "changed";
    const docs = kbGetExportDocs(filter);
    const countEl = document.getElementById("kb-export-count");
    if (countEl) countEl.textContent = docs.length ? `${docs.length} archivo(s)` : "";

    if (!docs.length) {
      list.innerHTML = `<div class="kb-export-empty">✅ Sin cambios detectados — todos los documentos están al día<br><span style="font-size:0.7rem; color:var(--text-muted);">Cambia el filtro a "Todos los documentos" para descargar la colección completa.</span></div>`;
      return;
    }

    const selAll = (document.getElementById("kb-export-sel-all") as HTMLInputElement)?.checked ?? true;
    list.innerHTML = docs.map(d => {
      const ext = kbGetDocExtension(d);
      const filename = `${d.title}.${ext}`;
      const fullPath = kbBuildFullPath(d, basePath);
      const date = kbFmtDate((d as any).content_updated_at ?? d.updated_at);
      const fc = kbFmtCat(d.category);
      return `<div class="kb-export-item" data-id="${d._id}">
        <input type="checkbox" class="kb-export-check" ${selAll ? "checked" : ""}>
        <div class="kb-export-item-info">
          <div class="kb-export-item-name">${kbEsc(filename)}</div>
          ${fullPath !== filename ? `<div class="kb-export-item-path">📁 ${kbEsc(fullPath)}</div>` : ""}
          <div class="kb-export-item-meta">
            <span class="kb-badge ${fc.cls}" style="font-size:0.62rem;">${fc.label}</span>
            <span style="font-size:0.68rem; color:var(--text-light);">${date}</span>
          </div>
        </div>
        <button class="btn btn-ghost btn-sm kb-exp-single" data-id="${d._id}" title="Descargar este archivo">⬇</button>
      </div>`;
    }).join("");
  }

  async function kbDescargarDocs(ids: string[]) {
    const docs = ids.map(id => kbDocs.find(d => d._id === id)).filter(Boolean) as KBDoc[];
    if (!docs.length) { toast("⚠️ No hay archivos seleccionados", "warning"); return; }

    // Escritura directa al filesystem si hay handle activo
    if (kbExportDirHandle) {
      let ok = 0, err = 0;
      for (const d of docs) {
        try {
          const ext = kbGetDocExtension(d);
          const sp = d.sourcePath?.replace(/\\/g, "/") ?? "";
          const parts = sp ? sp.split("/") : [];
          let dirH = kbExportDirHandle;
          // Navegar/crear subcarpetas según sourcePath
          for (let i = 0; i < parts.length - 1; i++) {
            if (parts[i]) dirH = await dirH.getDirectoryHandle(parts[i], { create: true });
          }
          const fname = parts.length > 0 ? parts[parts.length - 1] : `${d.title}.${ext}`;
          const fh = await dirH.getFileHandle(fname || `${d.title}.${ext}`, { create: true });
          const wr = await fh.createWritable();
          await wr.write(d.content);
          await wr.close();
          ok++;
        } catch { err++; }
      }
      localStorage.setItem("crm_kb_last_export", new Date().toISOString());
      const lastLabel = document.getElementById("kb-export-last-label");
      if (lastLabel) lastLabel.textContent = `Última exportación: ${new Date().toLocaleString("es-MX")}`;
      if (err === 0) toast(`✅ ${ok} archivo(s) guardado(s) directamente en Windows`);
      else toast(`⚠️ ${ok} guardados · ${err} con error — verifica permisos`, "warning");
      return;
    }

    // Sin handle: pedir que seleccione carpeta
    toast("📂 Primero selecciona la carpeta destino con el botón 'Seleccionar carpeta'", "warning");
  }

  function kbSetupEvents() {
    // Búsqueda
    const kbSearchInput = document.getElementById("kb-search-input") as HTMLInputElement | null;
    const kbHistEl = document.getElementById("kb-search-history");
    kbSearchInput?.addEventListener("input", kbRenderList);
    kbSearchInput?.addEventListener("focus", () => {
      if (!kbSearchInput.value.trim()) kbRenderHistorial();
    });
    kbSearchInput?.addEventListener("blur", () => {
      setTimeout(() => kbHistEl?.classList.remove("open"), 220);
    });
    kbSearchInput?.addEventListener("keydown", (e) => {
      const key = (e as KeyboardEvent).key;
      if (key === "Enter") {
        const q = kbSearchInput.value.trim();
        if (q.length >= 2) kbSaveSearch(q);
        kbHistEl?.classList.remove("open");
      }
      if (key === "Escape") kbHistEl?.classList.remove("open");
    });
    kbHistEl?.addEventListener("click", (e) => {
      const t = e.target as HTMLElement;
      const item    = t.closest<HTMLElement>(".kb-hist-item");
      const del     = t.closest<HTMLElement>(".kb-hist-del");
      const clearAll = t.closest<HTMLElement>(".kb-hist-clear-all");
      if (del) {
        const idx = parseInt(del.dataset.idx || "0");
        kbHistorial.splice(idx, 1);
        localStorage.setItem("crm_kb_historial", JSON.stringify(kbHistorial));
        kbRenderHistorial();
        return;
      }
      if (clearAll) {
        kbHistorial = [];
        localStorage.setItem("crm_kb_historial", JSON.stringify(kbHistorial));
        kbHistEl.classList.remove("open");
        return;
      }
      if (item && !del) {
        const q = item.dataset.q || "";
        if (kbSearchInput) kbSearchInput.value = q;
        kbRenderList();
        kbHistEl.classList.remove("open");
      }
    });

    // Toggle frase exacta
    document.getElementById("kb-exact-btn")?.addEventListener("click", () => {
      kbExact = !kbExact;
      document.getElementById("kb-exact-btn")?.classList.toggle("active", kbExact);
      kbRenderList();
    });

    // Pestañas de categoría
    document.querySelectorAll<HTMLButtonElement>(".kb-tab").forEach(btn => {
      btn.addEventListener("click", () => {
        kbCat = btn.dataset.kbCat!;
        document.querySelectorAll(".kb-tab").forEach(t => t.classList.remove("kb-tab-active"));
        btn.classList.add("kb-tab-active");

        // Cerrar visor si el doc activo no pertenece a esta categoría
        if (kbSelId && kbCat !== "all") {
          const docActivo = kbDocs.find(d => d._id === kbSelId);
          if (docActivo && docActivo.category !== kbCat) {
            kbSelId = null;
            const emptyEl = document.getElementById("kb-viewer-empty");
            const viewEl  = document.getElementById("kb-doc-view");
            if (emptyEl) emptyEl.style.display = "flex";
            if (viewEl)  viewEl.style.display  = "none";
          }
        }

        kbRenderList();
      });
    });

    // Click y doble clic delegados en el contenedor (sobreviven re-renders)
    const docList = document.getElementById("kb-doc-list");
    docList?.addEventListener("click", (e) => {
      const tagChip = (e.target as HTMLElement).closest<HTMLElement>(".kb-tag-chip");
      if (tagChip) {
        kbTagFilter = kbTagFilter === tagChip.dataset.tag ? null : tagChip.dataset.tag!;
        kbRenderList();
        return;
      }
      const item = (e.target as HTMLElement).closest<HTMLElement>(".kb-doc-item");
      if (item?.dataset.kid) kbAbrirDoc(item.dataset.kid);
    });
    docList?.addEventListener("dblclick", (e) => {
      if ((e.target as HTMLElement).closest(".kb-tag-chip")) return;
      const item = (e.target as HTMLElement).closest<HTMLElement>(".kb-doc-item");
      if (item?.dataset.kid) kbAbrirModal(item.dataset.kid);
    });

    // Orden alfabético
    document.getElementById("kb-sort-az")?.addEventListener("click", () => {
      kbSort = "asc";
      document.getElementById("kb-sort-az")?.classList.add("active");
      document.getElementById("kb-sort-za")?.classList.remove("active");
      kbRenderList();
    });
    document.getElementById("kb-sort-za")?.addEventListener("click", () => {
      kbSort = "desc";
      document.getElementById("kb-sort-za")?.classList.add("active");
      document.getElementById("kb-sort-az")?.classList.remove("active");
      kbRenderList();
    });

    // Nuevo documento
    document.getElementById("kb-btn-nuevo")?.addEventListener("click", () => kbAbrirModal());
    document.getElementById("kb-btn-export")?.addEventListener("click", () => {
      if (!kbDocs.length) { toast("⚠️ No hay documentos para exportar", "warning"); return; }
      const backup = { fecha: new Date().toISOString(), total: kbDocs.length, documentos: kbDocs };
      const blob = new Blob([JSON.stringify(backup, null, 2)], { type: "application/json" });
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = `kb-backup-${new Date().toISOString().slice(0,10)}.json`;
      a.click();
      URL.revokeObjectURL(a.href);
      toast(`✅ Backup exportado: ${kbDocs.length} documentos`);
    });

    // Exportar a Windows
    document.getElementById("kb-btn-export-win")?.addEventListener("click", () => {
      if (!kbDocs.length) { toast("⚠️ No hay documentos en SOPORTE", "warning"); return; }
      const lastExport = localStorage.getItem("crm_kb_last_export");
      const lastLabel = document.getElementById("kb-export-last-label");
      if (lastLabel) lastLabel.textContent = lastExport ? `Última exportación: ${new Date(lastExport).toLocaleString("es-MX")}` : "Nunca exportado";
      const baseInput = document.getElementById("kb-export-basepath") as HTMLInputElement | null;
      if (baseInput) baseInput.value = "";
      // Registrar onchange aquí garantiza que siempre esté activo
      const filterEl = document.getElementById("kb-export-filter");
      if (filterEl) (filterEl as HTMLSelectElement).onchange = kbRenderExportList;
      kbRenderExportList();
      const modal = document.getElementById("kb-export-modal");
      if (modal) modal.style.display = "flex";
    });
    const kbCerrarExportModal = () => {
      const modal = document.getElementById("kb-export-modal");
      if (modal) modal.style.display = "none";
      kbExportDirHandle = null;
      const btn = document.getElementById("kb-export-download");
      if (btn) btn.textContent = "💾 Guardar seleccionados";
      const hint = document.getElementById("kb-export-path-hint");
      if (hint) hint.innerHTML = "💡 Selecciona la carpeta raíz donde están tus scripts. Los archivos se guardarán en sus rutas originales automáticamente.";
      const input = document.getElementById("kb-export-basepath") as HTMLInputElement | null;
      if (input) input.value = "";
    };
    document.getElementById("kb-export-close")?.addEventListener("click", kbCerrarExportModal);
    document.getElementById("kb-export-modal")?.addEventListener("click", (e) => {
      if (e.target === document.getElementById("kb-export-modal")) kbCerrarExportModal();
    });
    document.getElementById("kb-export-filter")?.addEventListener("change", kbRenderExportList);
    document.getElementById("kb-export-pick-folder")?.addEventListener("click", async () => {
      const input = document.getElementById("kb-export-basepath") as HTMLInputElement | null;
      const hint  = document.getElementById("kb-export-path-hint");
      const btnDownload = document.getElementById("kb-export-download");
      try {
        const handle = await (window as any).showDirectoryPicker({ mode: "readwrite" });
        kbExportDirHandle = handle;
        const folderName: string = handle.name;
        if (input) { input.value = folderName + "\\"; localStorage.setItem("crm_kb_export_base", input.value); kbRenderExportList(); }
        if (hint) hint.innerHTML = `✅ Carpeta "<strong>${folderName}</strong>" lista — los archivos se guardarán <strong>directamente</strong> en ella con su ruta original.`;
        if (btnDownload) btnDownload.textContent = `💾 Guardar en "${folderName}"`;
      } catch (e: any) {
        if (e?.name !== "AbortError") toast("❌ Tu navegador no soporta escritura directa. Usa Chrome o Edge.", "warning");
      }
    });
    document.getElementById("kb-export-sel-all")?.addEventListener("change", (e) => {
      const checked = (e.target as HTMLInputElement).checked;
      document.querySelectorAll<HTMLInputElement>(".kb-export-check").forEach(cb => { cb.checked = checked; });
    });
    document.getElementById("kb-export-list")?.addEventListener("click", async (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>(".kb-exp-single");
      if (btn) { await kbDescargarDocs([btn.dataset.id!]); return; }
    });
    document.getElementById("kb-export-download")?.addEventListener("click", async () => {
      const checked = [...document.querySelectorAll<HTMLInputElement>(".kb-export-check")]
        .filter(cb => cb.checked)
        .map(cb => cb.closest<HTMLElement>(".kb-export-item")?.dataset.id!)
        .filter(Boolean);
      await kbDescargarDocs(checked);
    });
    document.getElementById("kb-export-copy-paths")?.addEventListener("click", () => {
      const basePath = (document.getElementById("kb-export-basepath") as HTMLInputElement)?.value ?? "";
      const checked = [...document.querySelectorAll<HTMLInputElement>(".kb-export-check")]
        .filter(cb => cb.checked)
        .map(cb => {
          const id = cb.closest<HTMLElement>(".kb-export-item")?.dataset.id!;
          const doc = kbDocs.find(d => d._id === id);
          return doc ? kbBuildFullPath(doc, basePath) : null;
        })
        .filter(Boolean) as string[];
      if (!checked.length) { toast("⚠️ No hay archivos seleccionados", "warning"); return; }
      navigator.clipboard.writeText(checked.join("\r\n"))
        .then(() => toast(`📋 ${checked.length} ruta(s) copiada(s) al portapapeles`))
        .catch(() => toast("❌ Error al copiar rutas", "error"));
    });

    // Modal: cerrar
    document.getElementById("kb-modal-close")?.addEventListener("click", kbCerrarModal);
    document.getElementById("kb-form-cancel")?.addEventListener("click", kbCerrarModal);
    document.getElementById("kb-modal")?.addEventListener("click", (e) => { if (e.target === document.getElementById("kb-modal")) kbCerrarModal(); });

    // Modal: guardar
    document.getElementById("kb-form-save")?.addEventListener("click", kbGuardar);

    // Preview en tiempo real de etiquetas al escribir
    document.getElementById("kb-form-tags")?.addEventListener("input", (e) => {
      kbRenderTagsPreview((e.target as HTMLInputElement).value);
    });

    // Escape cierra modal KB
    document.addEventListener("keydown", (e) => {
      const modal = document.getElementById("kb-modal");
      if ((e as KeyboardEvent).key === "Escape" && modal?.style.display !== "none") kbCerrarModal();
    });

    // Copiar contenido
    document.getElementById("kb-btn-copy")?.addEventListener("click", () => {
      const doc = kbDocs.find(d => d._id === kbSelId);
      if (!doc) return;
      navigator.clipboard.writeText(doc.content).then(() => toast("📋 Contenido copiado al portapapeles"));
    });

    // Descargar como archivo
    document.getElementById("kb-btn-download")?.addEventListener("click", () => {
      const doc = kbDocs.find(d => d._id === kbSelId);
      if (!doc) return;
      const ext = doc.file_type === "md" ? "md" : doc.file_type === "ps1" ? "ps1" : doc.file_type === "sql" ? "sql" : "bat";
      const mime = ext === "md" ? "text/markdown" : "text/plain";
      const blob = new Blob([doc.content], { type: mime });
      const url  = URL.createObjectURL(blob);
      const a    = document.createElement("a");
      a.href     = url;
      a.download = `${doc.title}.${ext}`;
      a.click();
      URL.revokeObjectURL(url);
      toast(`⬇ Descargando ${doc.title}.${ext}`);
    });

    // Editar
    document.getElementById("kb-btn-edit")?.addEventListener("click", () => { if (kbSelId) kbAbrirModal(kbSelId); });

    // Eliminar
    document.getElementById("kb-btn-del")?.addEventListener("click", () => { if (kbSelId) kbEliminar(kbSelId); });

    // Cerrar panel 1
    document.getElementById("kb-btn-close-1")?.addEventListener("click", () => {
      kbSelId = null;
      document.querySelectorAll<HTMLElement>(".kb-doc-item").forEach(el => el.classList.remove("kb-sel"));
      const docView = document.getElementById("kb-doc-view");
      const empty = document.getElementById("kb-viewer-empty");
      if (docView) docView.style.display = "none";
      if (empty) empty.style.display = "flex";
    });

    // Split view toggle
    document.getElementById("kb-btn-split")?.addEventListener("click", () => {
      kbSplitMode = !kbSplitMode;
      document.getElementById("kb-btn-split")?.classList.toggle("active", kbSplitMode);
      const panelsWrap = document.getElementById("kb-panels-wrap");
      const panel2 = document.getElementById("kb-panel-2");
      if (kbSplitMode) {
        panelsWrap?.classList.add("kb-split-mode");
        if (panel2) panel2.style.display = "flex";
        kbActivePanel = 1;
      } else {
        panelsWrap?.classList.remove("kb-split-mode");
        if (panel2) panel2.style.display = "none";
        kbSelId2 = null;
        kbActivePanel = 1;
      }
    });
    // Definir panel activo al hacer clic
    document.getElementById("kb-panel-1")?.addEventListener("click", () => { kbActivePanel = 1; });
    document.getElementById("kb-panel-2")?.addEventListener("click", () => { kbActivePanel = 2; });

    // Panel 2: acciones
    document.getElementById("kb-btn-copy-2")?.addEventListener("click", () => {
      const doc = kbDocs.find(d => d._id === kbSelId2);
      if (doc) navigator.clipboard.writeText(doc.content).then(() => toast("📋 Contenido copiado"));
    });
    document.getElementById("kb-btn-download-2")?.addEventListener("click", () => {
      const doc = kbDocs.find(d => d._id === kbSelId2);
      if (!doc) return;
      const ext = doc.file_type === "md" ? "md" : doc.file_type === "ps1" ? "ps1" : doc.file_type === "sql" ? "sql" : "bat";
      const blob = new Blob([doc.content], { type: "text/plain" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a"); a.href = url; a.download = `${doc.title}.${ext}`; a.click();
      URL.revokeObjectURL(url);
    });
    document.getElementById("kb-btn-edit-2")?.addEventListener("click", () => { if (kbSelId2) kbAbrirModal(kbSelId2); });
    document.getElementById("kb-btn-close-2")?.addEventListener("click", () => {
      kbSelId2 = null;
      kbActivePanel = 1;
      const emptyEl2 = document.getElementById("kb-viewer-empty-2");
      const viewEl2  = document.getElementById("kb-doc-view-2");
      if (emptyEl2) emptyEl2.style.display = "flex";
      if (viewEl2)  viewEl2.style.display  = "none";
    });

    // Nube de etiquetas: filtrar al hacer clic
    document.getElementById("kb-tag-cloud")?.addEventListener("click", (e) => {
      const chip = (e.target as HTMLElement).closest<HTMLElement>(".kb-tag-chip");
      if (chip) {
        kbTagFilter = kbTagFilter === chip.dataset.tag ? null : chip.dataset.tag!;
        kbRenderList();
      }
    });

    // Menú desplegable de carga
    const uploadBtn  = document.getElementById("kb-upload-btn");
    const uploadMenu = document.getElementById("kb-upload-menu");
    uploadBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = uploadMenu?.style.display === "none";
      if (uploadMenu) uploadMenu.style.display = open ? "block" : "none";
    });
    document.addEventListener("click", () => { if (uploadMenu) uploadMenu.style.display = "none"; });
    uploadMenu?.addEventListener("click", (e) => e.stopPropagation());

    // Upload: archivos individuales o múltiples
    document.getElementById("kb-upload-input")?.addEventListener("change", async (e) => {
      const files = (e.target as HTMLInputElement).files;
      if (uploadMenu) uploadMenu.style.display = "none";
      if (!files?.length) return;
      await kbSubidaMasiva(files);
      (e.target as HTMLInputElement).value = "";
    });

    // Upload: carpeta completa — muestra confirmación de categoría
    let pendingFolderFiles: FileList | null = null;
    document.getElementById("kb-upload-folder")?.addEventListener("change", (e) => {
      const files = (e.target as HTMLInputElement).files;
      if (uploadMenu) uploadMenu.style.display = "none";
      if (!files?.length) return;
      pendingFolderFiles = files;

      // Detectar nombre de carpeta y preseleccionar categoría
      const firstPath = (files[0] as any).webkitRelativePath as string || "";
      const folderName = firstPath.split("/")[0] || "Carpeta";
      const fn = folderName.toLowerCase();
      const catGuess: KBDoc["category"] =
        /empresa|client|company/.test(fn) ? "empresa" :
        /script|ps1|bat|cmd|auto|sql|quer/.test(fn) ? "script" : "solucion";

      const validFiles = Array.from(files).filter(f => /\.(md|ps1|bat|txt)$/i.test(f.name));
      const confirmEl = document.getElementById("kb-folder-confirm");
      const nameEl    = document.getElementById("kb-folder-name");
      const countEl   = document.getElementById("kb-folder-count");
      const catEl     = document.getElementById("kb-folder-cat") as HTMLSelectElement;
      if (nameEl)  nameEl.textContent  = folderName;
      if (countEl) countEl.textContent = `${validFiles.length} archivos`;
      if (catEl)   catEl.value         = catGuess;
      if (confirmEl) confirmEl.style.display = "block";
    });

    document.getElementById("kb-folder-ok")?.addEventListener("click", async () => {
      const catEl = document.getElementById("kb-folder-cat") as HTMLSelectElement;
      const cat   = (catEl?.value || "solucion") as KBDoc["category"];
      const confirmEl = document.getElementById("kb-folder-confirm");
      if (confirmEl) confirmEl.style.display = "none";
      if (!pendingFolderFiles) return;
      const files = pendingFolderFiles;
      pendingFolderFiles = null;
      await kbSubidaMasiva(files, cat);
      const folderInput = document.getElementById("kb-upload-folder") as HTMLInputElement;
      if (folderInput) folderInput.value = "";
    });

    document.getElementById("kb-folder-cancel")?.addEventListener("click", () => {
      const confirmEl = document.getElementById("kb-folder-confirm");
      if (confirmEl) confirmEl.style.display = "none";
      pendingFolderFiles = null;
      const folderInput = document.getElementById("kb-upload-folder") as HTMLInputElement;
      if (folderInput) folderInput.value = "";
    });

    // Indexar: actualizar existentes por nombre, crear nuevos
    document.getElementById("kb-index-input")?.addEventListener("change", async (e) => {
      const files = (e.target as HTMLInputElement).files;
      if (uploadMenu) uploadMenu.style.display = "none";
      if (!files?.length) return;
      await kbIndexar(files);
      (e.target as HTMLInputElement).value = "";
    });

    // Resizer del panel lista ↔ visor
    const resizerEl = document.getElementById("kb-resizer");
    let kbResizing = false, kbResizeStartX = 0, kbResizeStartW = 290;
    resizerEl?.addEventListener("mousedown", (e) => {
      kbResizing = true;
      kbResizeStartX = e.clientX;
      kbResizeStartW = parseInt(
        getComputedStyle(document.documentElement).getPropertyValue("--kb-list-w") || "290"
      ) || 290;
      resizerEl.classList.add("kb-resizing");
      document.body.style.cursor = "col-resize";
      document.body.style.userSelect = "none";
    });
    document.addEventListener("mousemove", (e) => {
      if (!kbResizing) return;
      const w = Math.max(160, Math.min(820, kbResizeStartW + e.clientX - kbResizeStartX));
      document.documentElement.style.setProperty("--kb-list-w", w + "px");
    });
    document.addEventListener("mouseup", () => {
      if (!kbResizing) return;
      kbResizing = false;
      resizerEl?.classList.remove("kb-resizing");
      document.body.style.cursor = "";
      document.body.style.userSelect = "";
    });

    // Drag & drop sobre el panel principal (kb-split)
    const kbSplit = document.getElementById("kb-split");
    let dragCounter = 0;
    kbSplit?.addEventListener("dragenter", (e) => {
      e.preventDefault();
      dragCounter++;
      kbSplit.classList.add("kb-dragging");
    });
    kbSplit?.addEventListener("dragleave", () => {
      dragCounter--;
      if (dragCounter <= 0) { dragCounter = 0; kbSplit.classList.remove("kb-dragging"); }
    });
    kbSplit?.addEventListener("dragover", (e) => e.preventDefault());
    kbSplit?.addEventListener("drop", async (e) => {
      e.preventDefault();
      dragCounter = 0;
      kbSplit.classList.remove("kb-dragging");
      const files = (e as DragEvent).dataTransfer?.files;
      if (files?.length) await kbSubidaMasiva(files);
    });

    // Dropzone en modal
    const dropzone = document.getElementById("kb-dropzone");
    const dropInput = document.getElementById("kb-drop-input") as HTMLInputElement;
    dropzone?.addEventListener("click", () => dropInput?.click());
    dropzone?.addEventListener("dragover", (e) => { e.preventDefault(); dropzone.classList.add("kb-drag"); });
    dropzone?.addEventListener("dragleave", () => dropzone.classList.remove("kb-drag"));
    dropzone?.addEventListener("drop", async (e) => {
      e.preventDefault(); dropzone.classList.remove("kb-drag");
      const file = (e as DragEvent).dataTransfer?.files[0];
      if (!file) return;
      const text = await file.text();
      (document.getElementById("kb-form-title") as HTMLInputElement).value = file.name.replace(/\.(md|ps1|bat|txt)$/i, "");
      (document.getElementById("kb-form-type") as HTMLSelectElement).value = kbGuessType(file.name);
      (document.getElementById("kb-form-cat") as HTMLSelectElement).value  = kbGuessCat(file.name);
      (document.getElementById("kb-form-content") as HTMLTextAreaElement).value = text;
    });
    dropInput?.addEventListener("change", async () => {
      const file = dropInput.files?.[0];
      if (!file) return;
      const text = await file.text();
      (document.getElementById("kb-form-title") as HTMLInputElement).value = file.name.replace(/\.(md|ps1|bat|txt)$/i, "");
      (document.getElementById("kb-form-type") as HTMLSelectElement).value = kbGuessType(file.name);
      (document.getElementById("kb-form-cat") as HTMLSelectElement).value  = kbGuessCat(file.name);
      (document.getElementById("kb-form-content") as HTMLTextAreaElement).value = text;
    });
  }

