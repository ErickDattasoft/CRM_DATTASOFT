<div id="data-bridge" data-iniciales={JSON.stringify(datosIniciales)} data-contactos={JSON.stringify(datosInicialesContactos)} data-sistemas={JSON.stringify(listaSistemasOpciones)} data-soporte-mail={CONFIG_CRM.CORREO_SOPORTE_PRINCIPAL}></div>

<script>
import { firebaseEnabled, cargarDatosCRM, guardarClientes, guardarConfiguracion, guardarPlantilla, guardarTickets, guardarContactos, guardarConfigTickets } from "../data/firebase.js";

(() => {
  // ============================================================
  // DATA & STATE
  // ============================================================
  const bridge = document.getElementById("data-bridge");
  const datosInicialesCliente = JSON.parse(bridge?.dataset.iniciales || "[]");
  const datosInicialesContactos = JSON.parse(bridge?.dataset.contactos || "[]");
  const listaSistemas = JSON.parse(bridge?.dataset.sistemas || "[]");

  let clientes = [];
  let contactos = [];
  let versionesMercado = {};
  let cartasTecnicas = {};
  let tickets = [];
  let plantillaMensaje = "Hola [contacto] de [empresa].\n\nTe saludamos de parte del equipo de DATTASOFT By INFOXPERT. Te escribimos para comentarte que ya se encuentran disponibles las últimas versiones oficiales y estables para tus sistemas CONTPAQi.\n\nRevisando tu perfil, notamos que tienes la oportunidad de actualizar los siguientes módulos:\n\n[sistemas_pendientes]\n\nMantenerlos al día te garantiza la mayor estabilidad, seguridad y el cumplimiento de los cambios fiscales más recientes. Estamos para atenderles con gusto.\n\nSaludos cordiales,\nEquipo DATTASOFT BY INFOXPERT";

  let crmLocalOnly = localStorage.getItem("crm_local_only") === "true";

  let configTickets = {
    tipos: ["General", "Soporte Técnico", "Consultoría Sitio", "Consultoría Remoto", "Instalación", "Correo Electrónico"],
    estados: ["Abierto", "Pendiente", "Resuelto", "Cerrado"],
    prioridades: ["Baja", "Media", "Alta", "Urgente"],
    grupos: ["Ventas", "Soporte", "Marketing", "Otros"],
    agentes: ["Erick", "Arturo", "Gelmi", "Gaby"],
    correoSoporte: "erick.casas@dattasoft.mx"
  };

  let filtrarSoloFavoritos = false;
  let seleccionadosIdx = [];
  let sortEmpresasDir = 'asc';
  let sortContactosDir = 'asc';
  let importCSVTarget = "empresas"; // or "contactos"
  let csvParsedData = [];

  // ============================================================
  // UTILITY
  // ============================================================
  const statusEl = document.getElementById("loading-status");

  function mostrarEstado(msg, dur = 0) {
    if (!statusEl) return;
    statusEl.style.display = "flex";
    statusEl.innerHTML = msg;
    if (dur > 0) setTimeout(() => { statusEl.style.display = "none"; }, dur);
  }
  function ocultarEstado() { if (statusEl) statusEl.style.display = "none"; }

  function updateBrowserTabTitle() {
    const count = tickets.filter(t =>
      (t.tipo || "").toLowerCase().includes("correo") &&
      t.estado !== "Resuelto" &&
      t.estado !== "Cerrado"
    ).length;
    document.title = count > 0
      ? `(${count} sin leer) — DATTASOFT CRM`
      : 'DATTASOFT BY INFOXPERT CRM — Panel de Control';
  }

  function toast(msg, type = "success") {
    const el = document.createElement("div");
    el.className = `toast toast-${type}`;
    el.textContent = msg;
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 2500);
  }

  function safeParseLocal(key, fallback) {
    try {
      const raw = localStorage.getItem(key);
      return raw ? JSON.parse(raw) : fallback;
    } catch (err) {
      return fallback;
    }
  }

  function cargarDesdeLocalStorage(msg = "📡 Cargando desde Local Storage...") {
    mostrarEstado(msg, 2000);
    clientes = safeParseLocal("crm_clientes", unificarDatosIniciales());
    versionesMercado = safeParseLocal("crm_versiones", {});
    cartasTecnicas = safeParseLocal("crm_cartas", {});
    plantillaMensaje = localStorage.getItem("crm_plantilla") || plantillaMensaje;
    tickets = safeParseLocal("crm_tickets", []);
    contactos = safeParseLocal("crm_contactos", unificarContactosIniciales());
    // Si los datos cargados vienen del import Excel (filas), normalizarlos a la forma esperada
    if (Array.isArray(clientes) && clientes.length > 0) {
      const sample = clientes[0] || {};
      const looksLikeRows = Boolean(sample.SISTEMA || sample.Sistema || sample.sistema || sample.VERSION || sample.VERSIONES || sample.EMPRESAS || sample.EMPRESA && !sample.SISTEMAS);
      if (looksLikeRows) {
        clientes = normalizeImportedClientes(clientes);
        guardarLocal("crm_clientes", clientes);
      } else {
        // asegurar campos mínimos
        clientes = clientes.map(c => ({
          ...c,
          EMPRESA: c.EMPRESA || c.EMPRESAS || '',
          CONTACTO: c.CONTACTO || c['CONTACTO PRINCIPAL'] || c.CONTACTO || '',
          TELEFONO_1: c.TELEFONO_1 || c.TELEFONO || c.telefono || '',
          CORREO: c.CORREO || c.CORREO_ELECTRONICO || c.EMAIL || c.correo || ''
        }));
      }
    }
    if (Array.isArray(contactos) && contactos.length > 0) {
      const sampleCt = contactos[0] || {};
      // Si tiene CONTACTO en mayúsculas pero no tiene 'nombre' en minúsculas, necesita normalización
      const needsNormalization = Boolean(sampleCt.CONTACTO || sampleCt['CONTACTO PRINCIPAL'] || sampleCt.CONTACTOS) && !sampleCt.nombre;
      if (needsNormalization) {
        contactos = normalizeImportedContactos(contactos);
        guardarLocal("crm_contactos", contactos);
      } else if (Array.isArray(contactos) && contactos.length > 0) {
        // Asegurar que todos los contactos tengan propiedades en minúsculas
        contactos = contactos.map(c => ({
          nombre: c.nombre || c.CONTACTO || c['CONTACTO PRINCIPAL'] || c.CONTACTOS || '',
          correo: c.correo || c.CORREO || c.CORREO_ELECTRONICO || c['CORREO ELECTRONICO'] || c.EMAIL || '',
          telefono1: c.telefono1 || c.TELEFONO || c.TELEFONO_1 || c.telefono || '',
          telefono2: c.telefono2 || c.TELEFONO_2 || '',
          empresa: c.empresa || c.EMPRESA || c.EMPRESAS || ''
        }));
      }
    }
    const cfgLocal = safeParseLocal("crm_config_tickets", null);
    if (cfgLocal) configTickets = { ...configTickets, ...cfgLocal };

    listaSistemas.forEach(s => {
      const k = s.toUpperCase().trim();
      if (versionesMercado[k] === undefined) versionesMercado[k] = "";
      if (cartasTecnicas[k] === undefined) cartasTecnicas[k] = "";
    });

    if (!localStorage.getItem("crm_clientes") || clientes.length === 0) {
      clientes = unificarDatosIniciales();
      guardarLocal("crm_clientes", clientes);
    }
    if (!localStorage.getItem("crm_contactos") || contactos.length === 0) {
      contactos = unificarContactosIniciales();
      guardarLocal("crm_contactos", contactos);
    }

    document.getElementById("txtPlantillaMensaje").value = plantillaMensaje;
    initMarketForms();
    renderDashboard();
    renderEmpresas();
    renderContactos();
    renderConfig();
    initStickyHeaders();
    console.log("[CRM DEBUG] cargarDesdeLocalStorage => clientes:", clientes.length, clientes.slice(0,2));
    console.log("[CRM DEBUG] cargarDesdeLocalStorage => contactos:", contactos.length, contactos.slice(0,2));
    mostrarEstado(`📥 Cargados ${clientes.length} empresas y ${contactos.length} contactos`, 3000);
  }

  function compararVersiones(vC, vO) {
    const normalize = v => String(v || "").toLowerCase().trim();
    vC = normalize(vC);
    vO = normalize(vO);
    if (!vO) return 0; // no official version to compare
    if (!vC || vC === "no aplica") return -1; // company missing version while official exists
    if (vC === vO) return 0;

    const parse = v => {
      const spMatch = v.match(/sp\s*(\d+)/);
      const sp = spMatch ? parseInt(spMatch[1]) : 0;
      const base = v.split(/sp/)[0].replace(/[^0-9.]/g, "").split(".").map(n => parseInt(n) || 0);
      return { base, sp };
    };

    const pC = parse(vC);
    const pO = parse(vO);
    const maxLen = Math.max(pC.base.length, pO.base.length);
    while (pC.base.length < maxLen) pC.base.push(0);
    while (pO.base.length < maxLen) pO.base.push(0);

    for (let i = 0; i < maxLen; i++) {
      if (pC.base[i] < pO.base[i]) return -1;
      if (pC.base[i] > pO.base[i]) return 1;
    }
    if (pC.sp < pO.sp) return -1;
    if (pC.sp > pO.sp) return 1;
    return 0;
  }

  function esVersionMenor(vC, vO) {
    return compararVersiones(vC, vO) < 0;
  }

  function getSistemasPendientes(cliente) {
    const pendientes = [];
    listaSistemas.forEach(s => {
      const sKey = s.toUpperCase().trim();
      const vC = String(cliente.SISTEMAS?.[sKey] || "").trim();
      const vO = String(versionesMercado[sKey] || "").trim();
      if (vC && vC !== "" && vC.toUpperCase() !== "NO APLICA" && esVersionMenor(vC, vO)) {
        pendientes.push(`• ${s}: ${vC} → ${vO}`);
      }
    });
    return pendientes;
  }

  function generarMensaje(cliente) {
    const pendientes = getSistemasPendientes(cliente);
    if (pendientes.length === 0) return null;
    return plantillaMensaje
      .replace(/\[contacto\]/g, cliente.CONTACTO || "Estimado cliente")
      .replace(/\[empresa\]/g, cliente.EMPRESA || "")
      .replace(/\[sistemas_pendientes\]/g, pendientes.join("\n"));
  }

