  // Formatea horas SLA como "Xd Yh" cuando pasan de 24h, para que se entienda más rápido
  function formatDuracionSLA(horasDecimal) {
    const totalHoras = Math.max(0, Math.round(horasDecimal));
    if (totalHoras < 24) return `${totalHoras}h`;
    const dias = Math.floor(totalHoras / 24);
    const horas = totalHoras % 24;
    return horas > 0 ? `${dias}d ${horas}h` : `${dias}d`;
  }

  function estaVencidoProgramado(t) {
    if (!t.fechaProgramada) return false;
    if ((t.estado || "").toLowerCase() === "cerrado") return false;
    return new Date(`${t.fechaProgramada}T${t.horaProgramada || "23:59"}`).getTime() < Date.now();
  }

  document.getElementById("btnFiltroAgenda")?.addEventListener("click", () => {
    filtroAgendaActivo = !filtroAgendaActivo;
    document.getElementById("btnFiltroAgenda")?.classList.toggle("btn-primary", filtroAgendaActivo);
    renderTickets();
  });

  function renderTickets() {
    const tbody = document.getElementById("tabla-tickets-body");
    if (!tbody) return;
    tbody.innerHTML = "";

    populateTipoAgenteFilters();

    const busq = document.getElementById("txtBuscarTicket")?.value.toLowerCase().trim() || "";
    const fEstado = document.getElementById("selectFiltroEstado")?.value || "";
    const fPrior = document.getElementById("selectFiltroPrioridad")?.value || "";
    const fTipo = document.getElementById("selectFiltroTipo")?.value || "";
    const fAgente = document.getElementById("selectFiltroAgente")?.value || "";
    const fFacturado = document.getElementById("selectFiltroFacturado")?.value || "";

    const filtrados = tickets.map((t, i) => ({ ...t, _idx: i })).filter(t => {
      if (filtroAgendaActivo && !t.fechaProgramada) return false;
      if (fEstado && t.estado !== fEstado) return false;
      if (fPrior && t.prioridad !== fPrior) return false;
      if (fTipo && t.tipo !== fTipo) return false;
      if (fAgente && t.agente !== fAgente) return false;
      if (fFacturado && (t.facturado || "NO FACTURADO") !== fFacturado) return false;
      if (busq) {
        return (t.asunto || "").toLowerCase().includes(busq) ||
               (t.empresa || "").toLowerCase().includes(busq) ||
               (t.contacto || "").toLowerCase().includes(busq) ||
               (t.agente || "").toLowerCase().includes(busq) ||
               String(t.numero).includes(busq);
      }
      return true;
    }).sort((a, b) => {
      if (filtroAgendaActivo) {
        const fa = new Date(`${a.fechaProgramada}T${a.horaProgramada || "23:59"}`).getTime();
        const fb = new Date(`${b.fechaProgramada}T${b.horaProgramada || "23:59"}`).getTime();
        return fa - fb;
      }
      return b.numero - a.numero;
    });

    filtrados.forEach(t => {
      const tr = document.createElement("tr");
      tr.dataset.idx = t._idx;
      // SLA cálculo
      let slaBadge = "";
      const esActivo = t.estado === "Abierto" || t.estado === "Pendiente";
      if (esActivo && t.fechaCreacion) {
        const slaHoras = configTickets.sla?.[t.prioridad] ?? null;
        if (slaHoras) {
          const horasTranscurridas = (Date.now() - new Date(t.fechaCreacion).getTime()) / 3600000;
          const pct = horasTranscurridas / slaHoras;
          if (pct >= 1) { slaBadge = `<br><span class="badge-sla badge-sla-over">⏰ +${formatDuracionSLA(horasTranscurridas - slaHoras)} SLA</span>`; tr.classList.add("sla-vencido"); }
          else if (pct >= 0.8) { slaBadge = `<br><span class="badge-sla badge-sla-warn">⚠️ ${formatDuracionSLA(slaHoras - horasTranscurridas)}</span>`; }
          else { slaBadge = `<br><span class="badge-sla badge-sla-ok">✅ ${formatDuracionSLA(slaHoras - horasTranscurridas)}</span>`; }
        }
      }
      tr.innerHTML = `
        <td style="text-align:center; font-weight:700; color:var(--text-muted);">#${t.numero}</td>
        <td><strong style="color:var(--text-bright);">${escapeHtml(t.asunto)}</strong></td>
        <td>
          <span style="display:block; font-weight:600;">👤 ${escapeHtml(t.contacto) || "—"}</span>
          <span style="display:block; font-size:0.72rem; color:var(--text-light);">🏢 ${escapeHtml(t.empresa) || "—"}</span>
        </td>
        <td style="text-align:center;">
          <span class="badge" style="background:rgba(99,102,241,0.12); color:#a5b4fc;">${escapeHtml(t.tipo) || "General"}</span>
          ${t.sistema && t.sistema !== "No aplica" ? `<br><span style="font-size:0.68rem; color:var(--text-light);">💻 ${escapeHtml(t.sistema)}</span>` : ""}
        </td>
        <td style="text-align:center;"><span class="badge badge-${slugBadge(t.prioridad || "media")}">${escapeHtml(t.prioridad)}</span>${slaBadge}</td>
        <td style="text-align:center;"><span class="badge badge-${slugBadge(t.estado || "abierto")}">${escapeHtml(t.estado)}</span></td>
        <td style="text-align:center;"><span class="badge badge-${slugBadge(t.facturado || "no facturado")}">${escapeHtml(t.facturado) || "NO FACTURADO"}</span></td>
        <td style="font-size:0.8rem; color:var(--text-muted);">${escapeHtml(t.agente) || "—"}</td>
        <td style="font-size:0.78rem; color:var(--text-light);">
          ${t.fechaCreacion ? new Date(t.fechaCreacion).toLocaleDateString() : "—"}
          ${t.fechaProgramada ? `<br><span class="badge-sla ${estaVencidoProgramado(t) ? "badge-sla-over" : "badge-sla-ok"}" style="display:inline-block; margin-top:2px;">📅 ${t.fechaProgramada}${t.horaProgramada ? " " + t.horaProgramada : ""}</span>` : ""}
        </td>
        <td style="text-align:center;">
          <div style="display:inline-flex; gap:4px;">
            <button class="btn btn-secondary btn-xs btn-ver-tk" data-idx="${t._idx}">👁️</button>
            <button class="btn btn-primary btn-xs btn-edit-tk" data-idx="${t._idx}">✏️</button>
            <button class="btn btn-danger btn-xs btn-del-tk" data-idx="${t._idx}">🗑️</button>
          </div>
        </td>
      `;
      tbody.appendChild(tr);
    });

    tbody.querySelectorAll(".btn-ver-tk").forEach(b => b.addEventListener("click", abrirDetalleTicket));
    tbody.querySelectorAll(".btn-edit-tk").forEach(b => b.addEventListener("click", prepararEdicionTicket));
    tbody.querySelectorAll(".btn-del-tk").forEach(b => b.addEventListener("click", eliminarTicket));

    // Click selecciona fila (morado), doble click abre edición
    tbody.addEventListener("click", (e) => {
      if (e.target.closest("button")) return;
      const row = e.target.closest("tr");
      if (!row) return;
      tbody.querySelectorAll("tr td").forEach(td => { td.style.background = ""; td.style.borderLeft = ""; td.style.paddingLeft = ""; });
      row.querySelectorAll("td").forEach((td, i) => {
        td.style.background = "rgba(99,102,241,0.18)";
        if (i === 0) { td.style.borderLeft = "4px solid #6366f1"; td.style.paddingLeft = "14px"; }
      });
    });
    tbody.addEventListener("dblclick", (e) => {
      e.preventDefault();
      if (e.target.closest("button")) return;
      const row = e.target.closest("tr");
      if (!row) return;
      row.querySelector(".btn-edit-tk")?.click();
    });

    updateBrowserTabTitle();

    // Update counters
    const el = id => document.getElementById(id);
    el("tk-count-total").textContent = tickets.length;
    el("tk-count-abiertos").textContent = tickets.filter(t => t.estado === "Abierto").length;
    el("tk-count-pendientes").textContent = tickets.filter(t => t.estado === "Pendiente").length;
    el("tk-count-resueltos").textContent = tickets.filter(t => t.estado === "Resuelto").length;
    el("tk-count-cerrados").textContent = tickets.filter(t => t.estado === "Cerrado").length;
  }

