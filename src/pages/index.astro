  // ============================================================
  // MIGRACIÓN: sincronizar CONTACTO + CONTACTO_2 de todas las
  // empresas hacia la sección Contactos (se ejecuta una sola vez)
  // ============================================================
  async function migrarContactosDeEmpresas(manual = false) {
    const KEY = "crm_migracion_contactos_v3";
    if (!manual && localStorage.getItem(KEY) === "done") return;
    if (!clientes.length) return;

    let cambios = 0;

    clientes.forEach((emp: any) => {
      const sincronizar = (nombre: string, correo: string, tel1: string) => {
        if (!nombre?.trim()) return;
        const yaExiste = contactos.find((c: any) =>
          c.empresa === emp.EMPRESA && c.nombre === nombre
        );
        if (yaExiste) {
          let actualizado = false;
          if (!yaExiste.correo    && correo) { yaExiste.correo    = correo; actualizado = true; }
          if (!yaExiste.telefono1 && tel1)   { yaExiste.telefono1 = tel1;   actualizado = true; }
          if (actualizado) cambios++;
        } else {
          contactos.push({ nombre, correo: correo || "", telefono1: tel1 || "", telefono2: "", empresa: emp.EMPRESA });
          cambios++;
        }
      };
      sincronizar(emp.CONTACTO,   emp.CORREO   || "", emp.TELEFONO_1 || "");
      sincronizar(emp.CONTACTO_2, emp.CORREO_2 || "", emp.TELEFONO_2 || "");
    });

    if (cambios > 0) {
      try {
        await guardarContactos(contactos);
        guardarLocal("crm_contactos", contactos);
        renderContactos?.();
        toast(`✅ ${cambios} contacto(s) sincronizados desde empresas`);
      } catch(e) {
        console.warn("[Migración contactos]", e);
      }
    } else if (manual) {
      toast("✅ Todo estaba ya sincronizado — no hubo cambios");
    }
    localStorage.setItem(KEY, "done");
    return cambios;
  }

