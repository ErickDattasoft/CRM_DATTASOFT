  const ALERTAS_DESCARTADAS_KEY = "crm_alertas_vencimiento_descartadas";

  function firmaAlertas(alertas: { empresa: string; sistema: string; fecha: string }[]) {
    return alertas.map(a => `${a.empresa}|${a.sistema}|${a.fecha}`).sort().join(";");
  }

  function descartarAlertasVencimiento(firma: string) {
    localStorage.setItem(ALERTAS_DESCARTADAS_KEY, JSON.stringify({ fecha: new Date().toISOString().slice(0, 10), firma }));
    const banner = document.getElementById("banner-vencimientos");
    if (banner) banner.style.display = "none";
  }
  (window as any).descartarAlertasVencimiento = descartarAlertasVencimiento;

  function verificarAlertasVencimiento() {
    const hoy = new Date(); hoy.setHours(0,0,0,0);
    const alertas: { empresa: string; sistema: string; dias: number; fecha: string }[] = [];

    clientes.forEach(c => {
      if (!c.VENCIMIENTOS) return;
      Object.entries(c.VENCIMIENTOS).forEach(([sis, fecha]) => {
        if (!fecha) return;
        const dias = Math.ceil((new Date((fecha as string) + "T00:00:00").getTime() - hoy.getTime()) / 86400000);
        if (dias >= 0 && dias <= 30) alertas.push({ empresa: c.EMPRESA, sistema: sis, dias, fecha: fecha as string });
      });
    });

    alertas.sort((a, b) => a.dias - b.dias);

    const banner = document.getElementById("banner-vencimientos");
    const lista  = document.getElementById("banner-vencimientos-lista");
    if (!banner || !lista) return;

    if (!alertas.length) { banner.style.display = "none"; return; }

    // Si el usuario ya descartó exactamente este mismo conjunto de alertas hoy, no lo repitas.
    // Si cambió (nueva licencia entra en el rango, o una se renovó y desapareció), sí se vuelve a mostrar.
    const firmaActual = firmaAlertas(alertas);
    const descartado = JSON.parse(localStorage.getItem(ALERTAS_DESCARTADAS_KEY) || "null");
    const hoyStr = new Date().toISOString().slice(0, 10);
    if (descartado && descartado.fecha === hoyStr && descartado.firma === firmaActual) {
      banner.style.display = "none";
      return;
    }

    const btnDescartar = document.getElementById("btn-descartar-alertas-venc");
    if (btnDescartar) btnDescartar.onclick = () => descartarAlertasVencimiento(firmaActual);

    lista.innerHTML = alertas.map(a => {
      const color = a.dias <= 5 ? "#f87171" : a.dias <= 15 ? "#fbbf24" : "#a5b4fc";
      const bg    = a.dias <= 5 ? "rgba(239,68,68,0.12)" : a.dias <= 15 ? "rgba(251,191,36,0.12)" : "rgba(99,102,241,0.1)";
      const txt   = a.dias === 0 ? "¡Vence HOY!" : a.dias === 1 ? "Vence mañana" : `${a.dias} días`;
      return `<span style="display:inline-flex;align-items:center;gap:5px;background:${bg};border:1px solid ${color}40;border-radius:20px;padding:3px 10px;font-size:0.75rem;font-weight:600;color:${color};">
        <strong>${a.empresa}</strong> · ${a.sistema} · <em>${txt}</em>
      </span>`;
    }).join("");

    banner.style.display = "flex";
  }

