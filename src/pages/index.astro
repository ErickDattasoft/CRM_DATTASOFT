        // Asegurar que todos los contactos tengan propiedades en minúsculas
        contactos = contactos.map(c => ({
          nombre: c.nombre || c.CONTACTO || c['CONTACTO PRINCIPAL'] || c.CONTACTOS || '',
          correo: c.correo || c.CORREO || c.CORREO_ELECTRONICO || c['CORREO ELECTRONICO'] || c.EMAIL || '',
          telefono1: c.telefono1 || c.TELEFONO || c.TELEFONO_1 || c.telefono || '',
          telefono2: c.telefono2 || c.TELEFONO_2 || '',
          empresa: c.empresa || c.EMPRESA || c.EMPRESAS || ''
        }));
      }
    }
    const cfgLocal = safeParseLocal("crm_config_tickets", null);
    if (cfgLocal) configTickets = { ...configTickets, ...cfgLocal };

    listaSistemas.forEach(s => {
      const k = s.toUpperCase().trim();
