  let chartTicketsMes = null;
  let chartEstados = null;

  function renderDashboardCharts() {
    const Chart = (window as any).Chart;
    if (!Chart) return;

    // --- Gráfica 1: Tickets por mes ---
    const canvasMes = document.getElementById("chart-tickets-mes") as HTMLCanvasElement;
    if (canvasMes) {
      if (chartTicketsMes) { chartTicketsMes.destroy(); chartTicketsMes = null; }
      const meses = [];
      const counts = [];
      const ahora = new Date();
      for (let i = 5; i >= 0; i--) {
        const d = new Date(ahora.getFullYear(), ahora.getMonth() - i, 1);
        meses.push(d.toLocaleDateString("es-MX", { month: "short", year: "2-digit" }));
        counts.push(tickets.filter(t => {
          if (!t.fechaCreacion) return false;
          const fd = new Date(t.fechaCreacion);
          return fd.getFullYear() === d.getFullYear() && fd.getMonth() === d.getMonth();
        }).length);
      }
      const isDark = !document.body.classList.contains("light-mode");
      const textColor = isDark ? "#94a3b8" : "#64748b";
      chartTicketsMes = new Chart(canvasMes, {
        type: "bar",
        data: { labels: meses, datasets: [{ label: "Tickets", data: counts, backgroundColor: "rgba(99,102,241,0.65)", borderRadius: 6, borderSkipped: false }] },
        options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { display: false } },
          scales: { x: { ticks: { color: textColor, font: { size: 11 } }, grid: { display: false } }, y: { ticks: { color: textColor, font: { size: 11 }, stepSize: 1 }, grid: { color: isDark ? "rgba(255,255,255,0.05)" : "rgba(0,0,0,0.05)" } } } }
      });
    }

    // --- Gráfica 2: Distribución por estado ---
    const canvasEst = document.getElementById("chart-estados") as HTMLCanvasElement;
    if (canvasEst) {
      if (chartEstados) { chartEstados.destroy(); chartEstados = null; }
      const estados = ["Abierto","Pendiente","Resuelto","Cerrado"];
      const colores = ["rgba(248,113,113,0.8)","rgba(251,191,36,0.8)","rgba(52,211,153,0.8)","rgba(148,163,184,0.8)"];
      const dataEst = estados.map(e => tickets.filter(t => t.estado === e).length);
      if (dataEst.some(v => v > 0)) {
        chartEstados = new Chart(canvasEst, {
          type: "doughnut",
          data: { labels: estados, datasets: [{ data: dataEst, backgroundColor: colores, borderWidth: 2, borderColor: "transparent" }] },
          options: { responsive: true, maintainAspectRatio: true, cutout: "65%",
            plugins: { legend: { position: "right", labels: { color: document.body.classList.contains("light-mode") ? "#475569" : "#94a3b8", font: { size: 11 }, padding: 10 } } } }
        });
      } else {
        canvasEst.parentElement.innerHTML = '<div class="dash-empty-mini" style="height:160px;display:flex;align-items:center;justify-content:center;">Sin tickets aún</div>';
      }
    }

    // --- Licencias por vencer en 90 días ---
    const licDiv = document.getElementById("dash-licencias-prox");
    if (licDiv) {
      const hoy = new Date(); hoy.setHours(0,0,0,0);
      const items = [];
      clientes.forEach(c => {
        if (!c.VENCIMIENTOS) return;
        Object.entries(c.VENCIMIENTOS).forEach(([sis, fecha]) => {
          if (!fecha) return;
          const d = Math.ceil((new Date((fecha as string) + "T00:00:00").getTime() - hoy.getTime()) / 86400000);
          if (d >= 0 && d <= 90) items.push({ empresa: c.EMPRESA, sistema: sis, dias: d });
        });
      });
      items.sort((a, b) => a.dias - b.dias);
      if (!items.length) {
        licDiv.innerHTML = '<div class="dash-empty-mini">No hay licencias por vencer en 90 días</div>';
      } else {
        licDiv.innerHTML = items.slice(0, 6).map(it => {
          const pct = Math.max(0, Math.round((1 - it.dias / 90) * 100));
          const cls = it.dias <= 15 ? "lic-dias-critico" : it.dias <= 30 ? "lic-dias-warn" : "lic-dias-ok";
          const barColor = it.dias <= 15 ? "#f87171" : it.dias <= 30 ? "#fbbf24" : "#6366f1";
          return `<div class="lic-item">
            <div class="lic-item-header">
              <span class="lic-item-empresa">${it.empresa} <span style="font-weight:400;color:var(--text-muted);font-size:0.7rem;">${it.sistema}</span></span>
              <span class="lic-item-dias ${cls}">${it.dias === 0 ? "Hoy" : it.dias + "d"}</span>
            </div>
            <div class="lic-progress"><div class="lic-progress-bar" style="width:${pct}%;background:${barColor};"></div></div>
          </div>`;
        }).join("");
      }
    }

    // --- Tickets abiertos >5 días ---
    const tkViejosDiv = document.getElementById("dash-tickets-viejos");
    if (tkViejosDiv) {
      const hoyMs = Date.now();
      const viejos = tickets
        .filter(t => (t.estado === "Abierto" || t.estado === "Pendiente") && t.fechaCreacion)
        .map(t => ({ ...t, diasAbierto: Math.floor((hoyMs - new Date(t.fechaCreacion).getTime()) / 86400000) }))
        .filter(t => t.diasAbierto >= 5)
        .sort((a, b) => b.diasAbierto - a.diasAbierto);
      if (!viejos.length) {
        tkViejosDiv.innerHTML = '<div class="dash-empty-mini">No hay tickets abiertos con más de 5 días</div>';
      } else {
        tkViejosDiv.innerHTML = viejos.slice(0, 6).map(t =>
          `<div class="tk-viejo-row">
            <div><strong>#${t.numero}</strong> <span style="color:var(--text-main);font-size:0.8rem;">${t.asunto}</span><div style="font-size:0.7rem;color:var(--text-muted);">🏢 ${t.empresa||"—"} · 🧑 ${t.agente||"—"}</div></div>
            <span class="badge-sla badge-sla-over">${t.diasAbierto}d</span>
          </div>`
        ).join("");
      }
    }
  }

  function renderDashboardTareas() {
    const lista = document.getElementById("dash-tareas-lista");
    if (!lista) return;
    const hoy = new Date(); hoy.setHours(0,0,0,0);
    const pendientes = tareas.filter(t => !t.completada).sort((a, b) => new Date(a.fechaVencimiento || "9999").getTime() - new Date(b.fechaVencimiento || "9999").getTime());
    if (!pendientes.length) {
      lista.innerHTML = '<div class="dash-empty-mini">No hay tareas pendientes 🎉</div>';
      return;
    }
    lista.innerHTML = pendientes.slice(0, 8).map(t => {
      const fv = t.fechaVencimiento ? new Date(t.fechaVencimiento + "T00:00:00") : null;
      const diasDiff = fv ? Math.ceil((fv.getTime() - hoy.getTime()) / 86400000) : null;
      const cls = diasDiff === null ? "proxima" : diasDiff < 0 ? "vencida" : diasDiff === 0 ? "hoy" : "proxima";
      const fechaCls = diasDiff === null ? "" : diasDiff < 0 ? "tarea-fecha-vencida" : diasDiff === 0 ? "tarea-fecha-hoy" : "tarea-fecha-proxima";
      const fechaTxt = fv ? (diasDiff < 0 ? `⚠️ Venció ${fv.toLocaleDateString("es-MX")}` : diasDiff === 0 ? "🔔 Vence hoy" : `📅 ${fv.toLocaleDateString("es-MX")}`) : "";
      return `<div class="tarea-item ${cls}" data-tarea-id="${t.id}">
        <input type="checkbox" class="tarea-chk" data-id="${t.id}">
        <div class="tarea-info">
          <div class="tarea-titulo">${t.titulo}</div>
          ${t.empresa ? `<div class="tarea-empresa">🏢 ${t.empresa}</div>` : ""}
          ${fechaTxt ? `<span class="tarea-fecha ${fechaCls}">${fechaTxt}</span>` : ""}
          ${t.asignado ? `<span style="font-size:0.7rem;color:var(--text-muted);margin-left:6px;">👤 ${t.asignado}</span>` : ""}
        </div>
        <div class="tarea-acciones">
          <button class="btn btn-danger btn-xs btn-del-tarea" data-id="${t.id}" title="Eliminar">🗑️</button>
        </div>
      </div>`;
    }).join("");
    lista.querySelectorAll(".tarea-chk").forEach(chk => chk.addEventListener("change", async function() {
      const id = this.dataset.id;
      const idx = tareas.findIndex(t => t.id === id);
      if (idx < 0) return;
      tareas[idx].completada = true;
      await guardarTareas(tareas);
      renderDashboardTareas();
      renderDrawerTareas();
      toast("✅ Tarea completada");
    }));
    lista.querySelectorAll(".btn-del-tarea").forEach(b => b.addEventListener("click", async function() {
      const id = this.dataset.id;
      tareas = tareas.filter(t => t.id !== id);
      await guardarTareas(tareas);
      renderDashboardTareas();
      renderDrawerTareas();
    }));
  }

  // ============================================================
  // CALENDARIO DEL DASHBOARD
  // ============================================================
  let calMesActual = new Date().getMonth();
  let calAnioActual = new Date().getFullYear();

  function renderCalendario() {
    const cont = document.getElementById("dash-calendario");
    const label = document.getElementById("cal-mes-label");
    if (!cont || !label) return;

    const hoy = new Date(); hoy.setHours(0,0,0,0);
    const primerDia = new Date(calAnioActual, calMesActual, 1);
    const ultimoDia = new Date(calAnioActual, calMesActual + 1, 0);
    label.textContent = primerDia.toLocaleDateString("es-MX", { month: "long", year: "numeric" }).replace(/^./, s => s.toUpperCase());

    // Indexar eventos y tareas por fecha "YYYY-MM-DD"
    const dotsPorFecha: Record<string, {tipo: string; label: string}[]> = {};
    const addDot = (fecha: string, tipo: string, lbl: string) => {
      if (!dotsPorFecha[fecha]) dotsPorFecha[fecha] = [];
      dotsPorFecha[fecha].push({ tipo, label: lbl });
    };

    (eventos || []).forEach((ev: any) => {
      if (ev.fecha) addDot(ev.fecha, "ev", ev.nombre || "Evento");
    });
    tareas.filter((t: any) => !t.completada && t.fechaVencimiento).forEach((t: any) => {
      const fv = new Date(t.fechaVencimiento + "T00:00:00");
      const tipo = fv < hoy ? "venc" : "tar";
      addDot(t.fechaVencimiento, tipo, t.titulo);
    });

    const diasSemana = ["Dom","Lun","Mar","Mié","Jue","Vie","Sáb"];
    let html = `<div class="cal-grid">`;
    diasSemana.forEach(d => { html += `<div class="cal-head">${d}</div>`; });

    const inicioSem = primerDia.getDay(); // 0=Dom
    for (let i = 0; i < inicioSem; i++) {
      const d = new Date(calAnioActual, calMesActual, -inicioSem + i + 1);
      html += `<div class="cal-dia cal-dia-otro"><div class="cal-dia-num">${d.getDate()}</div></div>`;
    }
    for (let d = 1; d <= ultimoDia.getDate(); d++) {
      const dateStr = `${calAnioActual}-${String(calMesActual+1).padStart(2,"0")}-${String(d).padStart(2,"0")}`;
      const esHoy = new Date(calAnioActual, calMesActual, d).getTime() === hoy.getTime();
      const dots = dotsPorFecha[dateStr] || [];
      html += `<div class="cal-dia${esHoy ? " cal-dia-hoy" : ""}">
        <div class="cal-dia-num">${d}</div>
        ${dots.slice(0, 2).map(dot => `<span class="cal-dot cal-dot-${dot.tipo}" title="${dot.label}">${dot.label}</span>`).join("")}
        ${dots.length > 2 ? `<span style="font-size:0.6rem;color:var(--text-muted);">+${dots.length - 2} más</span>` : ""}
      </div>`;
    }
    const totalCeldas = inicioSem + ultimoDia.getDate();
    const restante = totalCeldas % 7 === 0 ? 0 : 7 - (totalCeldas % 7);
    for (let i = 1; i <= restante; i++) {
      html += `<div class="cal-dia cal-dia-otro"><div class="cal-dia-num">${i}</div></div>`;
    }
    html += `</div>`;
    cont.innerHTML = html;
  }

  document.getElementById("cal-prev")?.addEventListener("click", () => {
    calMesActual--; if (calMesActual < 0) { calMesActual = 11; calAnioActual--; } renderCalendario();
  });
  document.getElementById("cal-next")?.addEventListener("click", () => {
    calMesActual++; if (calMesActual > 11) { calMesActual = 0; calAnioActual++; } renderCalendario();
  });

