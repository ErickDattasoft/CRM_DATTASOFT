    input?.addEventListener("change", () => { if (input.files?.[0]) doUpload(input.files[0]); input.value = ""; });

    document.getElementById("kb-transfer-copy")?.addEventListener("click", () => {
      navigator.clipboard.writeText(urlInput?.value || "");
      toast("📋 Enlace copiado");
    });

    // Drag & drop en la zona de subida
    drop?.addEventListener("dragover", (e) => { e.preventDefault(); (drop as HTMLElement).style.borderColor = "var(--brand-primary)"; });
    drop?.addEventListener("dragleave", () => { (drop as HTMLElement).style.borderColor = ""; });
    drop?.addEventListener("drop", (e) => {
      e.preventDefault();
      (drop as HTMLElement).style.borderColor = "";
      const file = e.dataTransfer?.files[0];
      if (file) doUpload(file);
    });
  }

  function kbSetupPizarra() {
    const LS_KEY  = "crm_kb_pizarra";
    const texto   = document.getElementById("kb-pizarra-texto") as HTMLElement;
    const savedEl = document.getElementById("kb-pizarra-saved");
    const body    = document.getElementById("kb-pizarra-body");
    const toggle  = document.getElementById("kb-pizarra-toggle");
    if (!texto) return;

    // Restaurar contenido guardado
    const saved = localStorage.getItem(LS_KEY);
    if (saved) texto.innerHTML = saved;

    // Auto-guardar con debounce
    let saveTimer: ReturnType<typeof setTimeout>;
    const doSave = () => {
      localStorage.setItem(LS_KEY, texto.innerHTML);
      if (savedEl) { savedEl.style.opacity = "1"; setTimeout(() => { savedEl.style.opacity = "0"; }, 1500); }
    };
    texto.addEventListener("input", () => { clearTimeout(saveTimer); saveTimer = setTimeout(doSave, 600); });

    // Botones de formato
    document.querySelectorAll<HTMLButtonElement>(".kb-fmt-btn").forEach(btn => {
      btn.addEventListener("mousedown", (e) => {
        e.preventDefault(); // Evita perder el foco del editor
        const cmd = btn.dataset.cmd!;
        const val = btn.dataset.val || undefined;
        document.execCommand(cmd, false, val);
        texto.focus();
        doSave();
      });
    });

    // Colapsar / expandir
    let collapsed = false;
    toggle?.addEventListener("click", () => {
      collapsed = !collapsed;
      if (body)   body.style.display = collapsed ? "none" : "";
      if (toggle) toggle.textContent = collapsed ? "▶" : "▼";
    });

    // Limpiar
    document.getElementById("kb-pizarra-limpiar")?.addEventListener("click", () => {
      if (!texto.innerText.trim() || confirm("¿Limpiar la pizarra?")) {
        texto.innerHTML = "";
        localStorage.removeItem(LS_KEY);
      }
    });

    // Guardar como documento en la KB
    document.getElementById("kb-pizarra-guardar")?.addEventListener("click", () => {
      if (!texto.innerText.trim()) { toast("⚠️ La pizarra está vacía", "warning"); return; }
      kbAbrirModal();
      setTimeout(() => {
        const formContent = document.getElementById("kb-form-content") as HTMLTextAreaElement;
        if (formContent) formContent.value = texto.innerText;
      }, 80);
    });
  }

  function initKB() {
    const usuario = getUsuarioActual();
    const tieneAcceso = kbAcceso.includes(usuario?.nombre || "");
    if (!usuario || !tieneAcceso) return;

    const navKB = document.getElementById("nav-kb");
    const lblKB = document.getElementById("kb-nav-label");
    if (navKB) navKB.style.display = "";
    if (lblKB) lblKB.style.display = "";

    if (kbInited) return;
    kbInited = true;
    kbSetupEvents();
    kbSetupPizarra();

    // Panel de acceso: solo para ERICK (propietario)
    if (usuario.nombre === "ERICK") {
      const wrap = document.getElementById("kb-acceso-wrap");
      if (wrap) wrap.style.display = "";
      document.getElementById("kb-btn-acceso")?.addEventListener("click", (e) => {
        e.stopPropagation();
        const panel = document.getElementById("kb-acceso-panel");
        if (!panel) return;
        const open = panel.classList.toggle("open");
        if (open) kbRenderAccesoPanel();
      });
      document.addEventListener("click", (e) => {
        const wrap = document.getElementById("kb-acceso-wrap");
        if (wrap && !wrap.contains(e.target as Node)) {
          document.getElementById("kb-acceso-panel")?.classList.remove("open");
        }
      });
    }

    if (firebaseEnabled && !kbUnsubscribe) {
      // Mostrar cache local mientras llegan los datos de Firestore
      try { const c = localStorage.getItem("crm_kb"); if (c) { kbDocs = JSON.parse(c); kbRenderList(); } } catch {}
      kbUnsubscribe = suscribirKB((docs: KBDoc[]) => {
        if (docs.length > 0) {
          kbDocs = docs.sort((a, b) => {
            const ta = a.updated_at?.seconds || 0, tb = b.updated_at?.seconds || 0;
            return tb - ta;
          });
          (window as any)._kbDocs = kbDocs; // exponer para búsqueda global
          localStorage.setItem("crm_kb", JSON.stringify(kbDocs));
          kbRenderList();
          if (kbSelId) kbAbrirDoc(kbSelId);
        } else {
          // Firestore vacío — recuperar desde cache local si existe
          const cached = localStorage.getItem("crm_kb");
          if (cached) {
            try {
              const localDocs: KBDoc[] = JSON.parse(cached);
              if (localDocs.length > 0) {
                kbDocs = localDocs;
                kbRenderList();
                kbRecuperarEnFirestore(localDocs);
              } else {
                kbDocs = []; kbRenderList();
              }
            } catch { kbDocs = []; kbRenderList(); }
          } else {
            kbDocs = []; kbRenderList();
          }
        }
      });
    } else if (!firebaseEnabled) {
      try { kbDocs = JSON.parse(localStorage.getItem("crm_kb") || "[]"); } catch { kbDocs = []; }
      kbRenderList();
    }
  }

