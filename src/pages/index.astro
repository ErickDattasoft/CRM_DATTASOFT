  /* ── Botón portal en sidebar ── */
  .sidebar-portal-btn {
    display: flex; align-items: center; gap: 10px; padding: 10px 14px; margin: 6px 10px 2px;
    background: rgba(99,102,241,0.1); border: 1px dashed rgba(99,102,241,0.35);
    border-radius: var(--radius-md); color: #818cf8; font-size: 0.78rem; font-weight: 600;
    cursor: pointer; text-decoration: none; transition: var(--transition-base);
  }
  .sidebar-portal-btn:hover { background: rgba(99,102,241,0.2); border-color: rgba(99,102,241,0.6); }
  .sidebar.collapsed .sidebar-portal-btn .portal-label { display: none; }
  .sidebar-logout-btn {
    display: flex; align-items: center; gap: 10px; padding: 9px 14px; margin: 2px 10px 8px;
    background: transparent; border: 1px solid rgba(239,68,68,0.2);
