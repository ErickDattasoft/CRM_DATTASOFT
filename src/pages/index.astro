      if (cartasTecnicas[k] === undefined) cartasTecnicas[k] = "";
    });

    if (!localStorage.getItem("crm_clientes") || clientes.length === 0) {
      clientes = unificarDatosIniciales();
      guardarLocal("crm_clientes", clientes);
    }
    if (!localStorage.getItem("crm_contactos") || contactos.length === 0) {
      contactos = unificarContactosIniciales();
      guardarLocal("crm_contactos", contactos);
    }

