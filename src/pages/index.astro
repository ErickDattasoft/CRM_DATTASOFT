  // ============================================================
  // INITIALIZATION
  // ============================================================
  function unificarDatosIniciales() {
    const map = {};
    datosInicialesCliente.forEach(item => {
      if (!item.EMPRESA) return;
      const key = item.EMPRESA.trim().toUpperCase();
      if (!map[key]) {
        map[key] = {
          EMPRESA: key,
          CONTACTO: item.CONTACTO || item["CONTACTO PRINCIPAL"] || "",
          CORREO: item.CORREO || "",
          TELEFONO_1: item.TELEFONO || item.TELEFONO_1 || "",
          TELEFONO_2: item.TELEFONO_2 || "",
          FAVORITO: false,
          CAMPOS_EXTRAS: {},
          SISTEMAS: {}
        };
      }
      if (item["CONTACTO PRINCIPAL"] && !map[key].CONTACTO) {
        map[key].CONTACTO = item["CONTACTO PRINCIPAL"];
      }
      if (item.TELEFONO && !map[key].TELEFONO_1) {
        map[key].TELEFONO_1 = item.TELEFONO;
      }
      if (item.SISTEMA) {
        const sysKey = item.SISTEMA.toUpperCase().trim();
        map[key].SISTEMAS[sysKey] = String(item.VERSION || "").trim();
      }
    });
    return Object.values(map);
  }

  function unificarContactosIniciales() {
    const map = {};
    // Prefer explicit contactos sheet if provided; otherwise derive from clientes sheet
    const fuente = (datosInicialesContactos && datosInicialesContactos.length > 0) ? datosInicialesContactos : datosInicialesCliente;
    fuente.forEach(item => {
      const name = item.CONTACTO || item["CONTACTO PRINCIPAL"];
      if (!name) return;
      const key = `${item.EMPRESA?.trim().toUpperCase()}||${name.trim().toUpperCase()}`;
      if (!map[key]) {
        map[key] = {
          nombre: name.trim(),
          correo: item.CORREO || "",
          telefono1: item.TELEFONO || item.TELEFONO_1 || "",
          telefono2: item.TELEFONO_2 || "",
          empresa: item.EMPRESA?.trim().toUpperCase() || ""
        };
      } else {
        const tel = item.TELEFONO || item.TELEFONO_1;
        if (tel && map[key].telefono1 !== tel && !map[key].telefono2) {
          map[key].telefono2 = tel;
        }
      }
    });
    return Object.values(map);
  }

  // Normalizar arrays importados directamente desde Excel (filas) a la forma esperada por la UI
  function normalizeImportedClientes(rows) {
    const map = {};
    (rows||[]).forEach(item => {
      const rawEmpresa = item.EMPRESA || item.EMPRESAS || item['Razon Social'] || item['RAZON SOCIAL'] || '';
      if (!rawEmpresa) return;
      const key = rawEmpresa.toString().trim().toUpperCase();
      if (!map[key]) {
        map[key] = {
          EMPRESA: rawEmpresa.toString().trim(),
          CONTACTO: item.CONTACTO || item['CONTACTO PRINCIPAL'] || item.nombre || item.NAME || '',
          CORREO: item.CORREO || item['CORREO ELECTRONICO'] || item['CORREO_ELECTRONICO'] || item.EMAIL || '',
          TELEFONO_1: item.TELEFONO || item.TELEFONO_1 || item.telefono || '',
          TELEFONO_2: item.TELEFONO_2 || '',
          FAVORITO: false,
          CAMPOS_EXTRAS: {},
          SISTEMAS: {}
        };
      }
      // agregar sistema/version si vienen por fila
      if (item.SISTEMA || item.Sistema || item.sistema) {
        const sysKey = (item.SISTEMA || item.Sistema || item.sistema).toString().toUpperCase().trim();
        map[key].SISTEMAS[sysKey] = String(item.VERSION || item.Version || item.version || '').trim();
      }
    });
    return Object.values(map);
  }

  function normalizeImportedContactos(rows) {
    const out = [];
    (rows||[]).forEach(item => {
      const empresa = item.EMPRESA || item.EMPRESAS || '';
      const name = item.CONTACTO || item['CONTACTO PRINCIPAL'] || item.nombre || item.NAME || '';
      if (!name) return;
      out.push({
        nombre: name.toString().trim(),
        correo: item.CORREO || item['CORREO ELECTRONICO'] || item.EMAIL || '',
        telefono1: item.TELEFONO || item.TELEFONO_1 || item.telefono || '',
        telefono2: item.TELEFONO_2 || '',
        empresa: empresa.toString().trim().toUpperCase()
      });
    });
    return out;
  }

  // Detecta si algún formulario de edición está abierto (para no interrumpirlo con actualizaciones remotas)
  function hayFormularioActivo() {
    const formsInline = ["formulario-empresa", "formulario-contacto", "formulario-ticket", "formulario-evento"];
    if (formsInline.some(id => { const el = document.getElementById(id); return el && !el.classList.contains("hidden"); })) return true;
    const modalesForm = ["modal-empresa-rapida", "modal-acerca-de"];
    return modalesForm.some(id => { const m = document.getElementById(id); return m && m.style.display !== "none" && m.style.display !== ""; });
  }

  // Aplica datos recibidos de Firebase a las variables en memoria
  function aplicarDatosFirebase(datos, preservarConfig = false) {
    if (!datos) return;
    // Regla: solo sobreescribir un campo si Firebase TIENE ese campo (no undefined).
    // Si el campo no existe en el doc de Firestore, conservar lo que hay en memoria.
    if (datos.clientes !== undefined && (datos.clientes.length > 0 || clientes.length === 0)) clientes = datos.clientes || [];
    if (datos.versionesMercado !== undefined && Object.values(datos.versionesMercado).some((v: any) => v)) versionesMercado = datos.versionesMercado;
    if (datos.cartasTecnicas !== undefined && Object.values(datos.cartasTecnicas).some((v: any) => v)) cartasTecnicas = datos.cartasTecnicas;
    if (datos.plantillaMensaje !== undefined) plantillaMensaje = datos.plantillaMensaje;
    if (datos.tickets !== undefined && (datos.tickets.length > 0 || tickets.length === 0)) tickets = datos.tickets || [];
    if (datos.contactos !== undefined && (datos.contactos.length > 0 || contactos.length === 0)) contactos = datos.contactos || [];
    // Si el usuario está en la sección de configuración y aún no ha guardado, preservar
    // los cambios en memoria para no pisar ediciones en progreso (prioridades, estados, etc.)
    if (datos.configTickets && !preservarConfig) configTickets = { ...configTickets, ...datos.configTickets };
    if (datos.usuarios && datos.usuarios.length > 0) saveUsuariosLocal(datos.usuarios);
    // Merge eventos: Firebase es fuente de verdad sólo cuando tiene datos.
    // Si Firebase tiene menos eventos que la memoria local (race condition entre
    // guardarEventosFB y otra escritura), mezclamos para no perder eventos recientes.
    if (datos.eventos !== undefined && datos.eventos !== null) {
      if (datos.eventos.length >= eventos.length) {
        eventos = datos.eventos;
      } else if (datos.eventos.length > 0) {
        const fbIds = new Set(datos.eventos.map((e: any) => e.id));
        const soloLocales = eventos.filter((e: any) => !fbIds.has(e.id));
        if (soloLocales.length > 0) {
          eventos = [...datos.eventos, ...soloLocales];
          if (!crmLocalOnly && firebaseEnabled) guardarEventosFB(eventos);
        } else {
          eventos = datos.eventos;
        }
      }
      // Si Firebase devuelve array vacío, conservamos eventos locales (evita borrar si FB aún no confirmó)
    }
    // Bitácora NO se toca aquí — se carga solo en primeraCargaFB y se actualiza
    // únicamente desde logBitacora(), para evitar que writes ajenos sobreescriban
    // entradas recientes aún no confirmadas por el servidor.
    if (datos.papelera) papelera = datos.papelera;
    if (datos.acercaDe) acercaDe = datos.acercaDe;
    if (datos.configCorreo) configCorreo = datos.configCorreo;
    if (datos.logoEmpresa !== undefined) {
      if (datos.logoEmpresa) {
        localStorage.setItem("crm_logo", datos.logoEmpresa);
      } else {
        localStorage.removeItem("crm_logo");
      }
      logoCargar();
    }
    if (datos.interacciones !== undefined && (datos.interacciones.length > 0 || interacciones.length === 0))
      interacciones = datos.interacciones || [];
    if (datos.tareas !== undefined && (datos.tareas.length > 0 || tareas.length === 0))
      tareas = datos.tareas || [];
    if (datos.filtrosGuardados !== undefined)
      filtrosGuardados = datos.filtrosGuardados || [];
    if (datos.alertasVencimiento !== undefined)
      alertasVencimiento = datos.alertasVencimiento || {};
    document.dispatchEvent(new CustomEvent("crm:datosFirebase", { detail: datos }));
  }

  // Re-renderiza todas las secciones principales tras una actualización remota
  function renderCompleto() {
    renderDashboard();
    renderEmpresas();
    renderContactos();
    renderTickets();
    actualizarBadgePapelera();
    checkLicenciasPorVencer();
    const secActiva = document.querySelector(".nav-item.active")?.dataset.section;
    if (secActiva === "bitacora") renderBitacora();
    if (secActiva === "eventos") renderSeccionEventos();
    if (secActiva === "versiones") initMarketForms();
  }

  function inicializarApp() {
    // Limpiar listener previo si existe (ej. al cambiar modo local/online)
    if (unsubscribeCRM) { unsubscribeCRM(); unsubscribeCRM = null; }
    primeraCargaFB = true;

    if (crmLocalOnly) {
      cargarDesdeLocalStorage("📡 Modo Local Activo. Cargando desde Local Storage...");
      return;
    }
    if (!firebaseEnabled) {
      mostrarEstado("⚠️ Firebase no configurado. Usando Local Storage.", 3000);
      cargarDesdeLocalStorage();
      return;
    }

    mostrarEstado("🔄 Conectando a Firebase...");

    // Pre-cargar caché de localStorage mientras llega Firebase, para que el
    // autocomplete y la UI respondan inmediatamente sin esperar la red.
    {
      const _lc = safeParseLocal("crm_clientes", []);
      const _lcont = safeParseLocal("crm_contactos", []);
      const _lt = safeParseLocal("crm_tickets", []);
      if (_lc.length > 0) { clientes = _lc; renderEmpresas(); renderDashboard(); }
      if (_lcont.length > 0) { contactos = _lcont; }
      if (_lt.length > 0) { tickets = _lt; }
    }

    // Timeout de seguridad solo para la primera carga
    const timeoutInicial = setTimeout(() => {
      if (primeraCargaFB) {
        primeraCargaFB = false;
        console.error("[CRM] Firebase: timeout en carga inicial");
        mostrarEstado("⚠️ Error de conexión a Firebase. Reintentando en la próxima carga.", 4000);
        cargarDesdeLocalStorage();
      }
    }, 7000);

    unsubscribeCRM = suscribirCRM(async (datos, hasPendingWrites) => {
      try {
        if (primeraCargaFB) {
          // ── PRIMERA CARGA ─────────────────────────────────────────────
          clearTimeout(timeoutInicial);
          primeraCargaFB = false;

          if (datos) {
            aplicarDatosFirebase(datos);

            // Si Firebase no tiene versiones/cartas/eventos, recuperar del caché local
            // para no perder datos que sólo existían en localStorage
            if (datos.versionesMercado === undefined) {
              const localV = safeParseLocal("crm_versiones", null);
              if (localV && Object.values(localV).some((v: any) => v)) {
                versionesMercado = localV;
                guardarConfiguracion(versionesMercado, cartasTecnicas); // subir a Firebase
              }
            }
            if (datos.cartasTecnicas === undefined) {
              const localC = safeParseLocal("crm_cartas", null);
              if (localC && Object.values(localC).some((v: any) => v)) cartasTecnicas = localC;
            }
            if ((datos.eventos === undefined || datos.eventos === null || datos.eventos.length === 0)) {
              const localEv = safeParseLocal("crm_eventos", null);
              if (localEv && localEv.length > 0 && localEv.length > eventos.length) {
                eventos = localEv;
                guardarEventosFB(eventos); // subir a Firebase
              }
            }
            // Si Firebase no tiene clientes/contactos/tickets, recuperar del caché local
            if ((datos.clientes === undefined || datos.clientes.length === 0) && clientes.length === 0) {
              const localCl = safeParseLocal("crm_clientes", null);
              if (localCl && localCl.length > 0) {
                clientes = localCl;
                guardarClientes(clientes); // subir a Firebase
              }
            }
            if ((datos.contactos === undefined || datos.contactos.length === 0) && contactos.length === 0) {
              const localCo = safeParseLocal("crm_contactos", null);
              if (localCo && localCo.length > 0) {
                contactos = localCo;
                guardarContactos(contactos);
              }
            }
            if ((datos.tickets === undefined || datos.tickets.length === 0) && tickets.length === 0) {
              const localTk = safeParseLocal("crm_tickets", null);
              if (localTk && localTk.length > 0) {
                tickets = localTk;
                guardarTickets(tickets);
              }
            }

            // Carga inicial de bitácora: fusionar Firebase + entradas locales aún no confirmadas
            if (datos.bitacora && datos.bitacora.length > 0) {
              const fechasFB = new Set(datos.bitacora.map(e => e.fecha));
              const localExtras = bitacoraLog.filter(e => !fechasFB.has(e.fecha));
              bitacoraLog = [...localExtras, ...datos.bitacora].sort(
                (a, b) => new Date(b.fecha).getTime() - new Date(a.fecha).getTime()
              );
              guardarLocal("crm_bitacora", bitacoraLog);
            }
            // Respaldo en localStorage (caché para offline) — solo si hay datos reales
            if (clientes.length > 0) guardarLocal("crm_clientes", clientes);
            if (contactos.length > 0) guardarLocal("crm_contactos", contactos);
            if (tickets.length > 0) guardarLocal("crm_tickets", tickets);
            // Solo actualizar caché local de versiones/cartas si Firebase tiene datos reales
            if (Object.values(versionesMercado).some((v: any) => v)) guardarLocal("crm_versiones", versionesMercado);
            if (Object.values(cartasTecnicas).some((v: any) => v)) guardarLocal("crm_cartas", cartasTecnicas);
            if (eventos.length > 0) guardarLocal("crm_eventos", eventos);
            if (plantillaMensaje) localStorage.setItem("crm_plantilla", plantillaMensaje);
            console.log("[CRM] Firebase cargado: clientes=", clientes.length, "contactos=", contactos.length);
            mostrarEstado(`🔌 Cargados ${clientes.length} empresas desde Firebase`, 2500);
          } else {
            // Firebase vacío — migrar desde respaldo local si existe
            const localClientes = safeParseLocal("crm_clientes", null);
            const localContactos = safeParseLocal("crm_contactos", null);
            const localTickets = safeParseLocal("crm_tickets", null);
            if (localClientes && localClientes.length > 0) {
              mostrarEstado("📦 Restaurando datos desde respaldo local...");
              clientes = localClientes;
              contactos = localContactos || [];
              tickets = localTickets || [];
              versionesMercado = safeParseLocal("crm_versiones", {});
              cartasTecnicas = safeParseLocal("crm_cartas", {});
              plantillaMensaje = localStorage.getItem("crm_plantilla") || plantillaMensaje;
              await guardarClientes(clientes);
              await guardarContactos(contactos);
              await guardarTickets(tickets);
              await guardarConfiguracion(versionesMercado, cartasTecnicas);
              await guardarPlantilla(plantillaMensaje);
              mostrarEstado(`✅ ${clientes.length} empresas restauradas de respaldo local`, 3000);
            } else {
              clientes = []; contactos = []; tickets = [];
              mostrarEstado("⚠️ Firebase vacío y sin respaldo local. Ve a Configuración → Importar datos.", 6000);
            }
          }

          listaSistemas.forEach(s => {
            const k = s.toUpperCase().trim();
            if (versionesMercado[k] === undefined) versionesMercado[k] = "";
            if (cartasTecnicas[k] === undefined) cartasTecnicas[k] = "";
          });
          document.getElementById("txtPlantillaMensaje").value = plantillaMensaje;
          initMarketForms();
          renderDashboard();
          renderEmpresas();
          renderContactos();
          renderConfig();
          ocultarEstado();
          initStickyHeaders();
          checkLicenciasPorVencer();
          aplicarPermisosNavegacion();

        } else {
          // ── ACTUALIZACIÓN REMOTA (otro dispositivo guardó algo) ───────
          if (hasPendingWrites) return; // Escritura propia aún pendiente, ignorar

          const enConfiguracion = document.querySelector(".nav-item.active")?.dataset.section === "configuracion";
          aplicarDatosFirebase(datos, enConfiguracion);

          if (hayFormularioActivo()) return; // Form abierto: datos listos en memoria, UI se actualiza al cerrar
          if (enConfiguracion) return; // Edición de config en progreso: no sobreescribir UI

          renderCompleto();
        }
      } catch (err) {
        if (primeraCargaFB) {
          primeraCargaFB = false;
          console.error("[CRM] Error en carga inicial Firebase:", err);
          mostrarEstado("⚠️ Error de conexión a Firebase. Reintentando en la próxima carga.", 4000);
          cargarDesdeLocalStorage();
        }
      }
    });
  }

  async function guardarLocal(key, data) {
    try { localStorage.setItem(key, JSON.stringify(data)); } catch(e) {}
  }

  // ============================================================
  // PERMISOS DE NAVEGACIÓN
  // ============================================================
  function aplicarPermisosNavegacion() {
    const u = getUsuarioActual();
    const esAdmin = u?.rol === "admin";
    const navBitacora = document.getElementById("nav-item-bitacora");
    if (navBitacora) navBitacora.style.display = esAdmin ? "" : "none";
    // Importar JSON solo para admins — puede sobreescribir datos
    const btnImport = document.getElementById("btnImportarJSON") as HTMLButtonElement | null;
    if (btnImport) btnImport.style.display = esAdmin ? "" : "none";
    // Solicitar permiso de notificaciones del navegador
    if (esAdmin && "Notification" in window && Notification.permission === "default") {
      Notification.requestPermission();
    }
  }

  // ============================================================
  // BITÁCORA
  // ============================================================
  function logBitacora(msg, icon = "📌") {
    const u = getUsuarioActual();
    const entry = { fecha: new Date().toISOString(), msg, icon, usuario: u?.nombre || "Sistema" };
    bitacoraLog.unshift(entry);
    const limite60 = new Date();
    limite60.setDate(limite60.getDate() - 60);
    bitacoraLog = bitacoraLog.filter(e => new Date(e.fecha) >= limite60);
    guardarLocal("crm_bitacora", bitacoraLog);
    if (firebaseEnabled) guardarBitacora(bitacoraLog).catch(err => console.error("[Bitácora] Error al guardar en Firebase:", err));
  }

  // Listener para el evento de login (cruzar scope IIFE ↔ auth)
  document.addEventListener("crm:login", () => {
    aplicarPermisosNavegacion();
    logBitacora("Sesión iniciada", "🔐");
    initKB();
  }, { once: false });

  function renderBitacora() {
    const cont = document.getElementById("bitacora-list");
    if (!cont) return;
    const u = getUsuarioActual();
    if (!u || u.rol !== "admin") {
      cont.innerHTML = '<div style="text-align:center; color:var(--text-muted); padding:24px; font-size:0.85rem;">🔒 Acceso restringido a administradores.</div>';
      return;
    }
    if (!bitacoraLog.length) {
      cont.innerHTML = '<div style="text-align:center; color:var(--text-muted); padding:24px; font-size:0.85rem;">Sin actividad registrada.</div>';
      return;
    }
    const hoy = new Date().getFullYear();
    cont.innerHTML = bitacoraLog.map(e => {
      const d = new Date(e.fecha);
      const opts = d.getFullYear() !== hoy
        ? { day:'2-digit', month:'2-digit', year:'2-digit', hour:'2-digit', minute:'2-digit' }
        : { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' };
      return `
      <div class="bitacora-entry">
        <span class="bitacora-time">${d.toLocaleString('es-MX', opts)}</span>
        ${e.usuario ? `<span style="font-size:0.68rem; color:#818cf8; font-weight:700; background:rgba(99,102,241,0.12); padding:1px 6px; border-radius:3px; white-space:nowrap; flex-shrink:0;">${e.usuario}</span>` : ""}
        <span class="bitacora-msg">${e.icon} ${e.msg}</span>
      </div>`;
    }).join("");
  }

