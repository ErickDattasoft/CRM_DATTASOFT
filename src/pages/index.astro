  });

  document.getElementById("btnCerrarImportCSV")?.addEventListener("click", () => {
    if (modalCSV) modalCSV.style.display = "none";
  });

  document.getElementById("btnCancelarImport")?.addEventListener("click", () => {
    document.getElementById("import-csv-preview")?.classList.add("hidden");
    csvParsedData = [];
  });

  const csvZone = document.getElementById("import-csv-zone");
  const csvInput = document.getElementById("import-csv-input");

  csvZone?.addEventListener("click", () => csvInput?.click());
  csvZone?.addEventListener("dragover", e => { e.preventDefault(); csvZone.style.borderColor = "var(--brand-primary)"; });
  csvZone?.addEventListener("dragleave", () => { csvZone.style.borderColor = ""; });
  csvZone?.addEventListener("drop", e => {
    e.preventDefault();
    csvZone.style.borderColor = "";
    if (e.dataTransfer.files.length) processCSV(e.dataTransfer.files[0]);
  });
  csvInput?.addEventListener("change", () => { if (csvInput.files.length) processCSV(csvInput.files[0]); });

  function processCSV(file) {
    const reader = new FileReader();
    reader.onload = e => {
      const text = e.target.result;
      const lines = text.split(/\r?\n/).filter(l => l.trim());
      if (lines.length < 2) return alert("CSV vacío.");

      const delimiter = lines[0].includes(";") ? ";" : ",";
      const headers = lines[0].replace(/^\uFEFF/, "").split(delimiter).map(h => h.trim().replace(/^"|"$/g, "")).map(h => h.toUpperCase());
      const rows = [];
      for (let i = 1; i < lines.length; i++) {
        const vals = lines[i].split(",").map(v => v.trim().replace(/^"|"$/g, ""));
        const obj = {};
        headers.forEach((h, j) => { obj[h] = vals[j] || ""; });
        rows.push(obj);
      }

      csvParsedData = rows;
      document.getElementById("import-csv-count").textContent = rows.length;

      // Render preview
      const thead = document.getElementById("import-csv-thead");
      const tbody = document.getElementById("import-csv-tbody");
      thead.innerHTML = `<tr>${headers.map(h => `<th>${h}</th>`).join("")}</tr>`;
      tbody.innerHTML = "";
      rows.slice(0, 10).forEach(row => {
        const tr = document.createElement("tr");
        tr.innerHTML = headers.map(h => `<td>${row[h] || ""}</td>`).join("");
        tbody.appendChild(tr);
      });
      document.getElementById("import-csv-preview")?.classList.remove("hidden");
    };
    // Leer primero como binario para detectar encoding Windows-1252 (Excel) vs UTF-8
    const sniff = new FileReader();
    sniff.onload = ev => {
      const bytes = new Uint8Array(ev.target.result.slice(0, 4));
      // BOM UTF-8: EF BB BF — si está presente, es UTF-8 seguro
      const enc = (bytes[0] === 0xEF && bytes[1] === 0xBB && bytes[2] === 0xBF)
        ? 'UTF-8' : 'windows-1252';
      reader.readAsText(file, enc);
    };
    sniff.readAsArrayBuffer(file);
  }

  document.getElementById("btnConfirmarImport")?.addEventListener("click", async () => {
    if (csvParsedData.length === 0) return;

    if (importCSVTarget === "empresas") {
      csvParsedData.forEach(row => {
        const nombre = (row["EMPRESA"] || row["NOMBRE"] || row["EMPRESA"] || row["NOMBRE"] || "").toUpperCase().trim();
        if (!nombre) return;
        if (clientes.find(c => c.EMPRESA === nombre)) return; // skip duplicates
        clientes.push({
          EMPRESA: nombre,
          CONTACTO: row["CONTACTO"] || row["Contacto"] || row["contacto"] || "",
          CORREO: row["CORREO"] || row["Correo"] || row["correo"] || row["EMAIL"] || "",
          TELEFONO_1: row["TELEFONO"] || row["Telefono"] || row["telefono1"] || row["TELEFONO_1"] || "",
          TELEFONO_2: row["TELEFONO_2"] || row["telefono2"] || "",
          FAVORITO: false,
          CAMPOS_EXTRAS: {},
          SISTEMAS: {}
        });
      });
      if (crmLocalOnly) {
        guardarLocal("crm_clientes", clientes);
        toast(`✅ ${csvParsedData.length} empresas importadas (Local)`);
      } else {
        await guardarClientes(clientes);
        toast(`✅ ${csvParsedData.length} empresas importadas`);
      }
      renderEmpresas();
    } else {
      csvParsedData.forEach(row => {
        const nombre = (row["NOMBRE"] || row["Nombre"] || row["nombre"] || "").trim();
        if (!nombre) return;
        contactos.push({
          nombre,
          correo: row["CORREO"] || row["Correo"] || row["correo"] || row["EMAIL"] || "",
          telefono1: row["TELEFONO"] || row["Telefono"] || row["telefono1"] || row["TELEFONO_1"] || "",
          telefono2: row["TELEFONO_2"] || row["telefono2"] || "",
          empresa: row["EMPRESA"] || row["Empresa"] || row["empresa"] || ""
        });
      });
      if (crmLocalOnly) {
        guardarLocal("crm_contactos", contactos);
        toast(`✅ ${csvParsedData.length} contactos importados (Local)`);
      } else {
        await guardarContactos(contactos);
        toast(`✅ ${csvParsedData.length} contactos importados`);
      }
      renderContactos();
    }

    csvParsedData = [];
    if (modalCSV) modalCSV.style.display = "none";
    renderDashboard();
  });

  // ============================================================
  // IMPORT JSON
  // ============================================================
  const modalImportJSON = document.getElementById("modal-import-json");
  let jsonImportData = null;

  document.getElementById("btnImportarJSON")?.addEventListener("click", () => {
    jsonImportData = null;
    document.getElementById("import-json-info")?.classList.add("hidden");
    const actions = document.getElementById("import-json-actions");
    if (actions) actions.style.display = "none";
    const inp = document.getElementById("import-json-input");
    if (inp) inp.value = "";
    if (modalImportJSON) modalImportJSON.style.display = "flex";
  });

  document.getElementById("btnCerrarImportJSON")?.addEventListener("click", () => {
    if (modalImportJSON) modalImportJSON.style.display = "none";
  });

  document.getElementById("btnCancelarImportJSON")?.addEventListener("click", () => {
    jsonImportData = null;
    document.getElementById("import-json-info")?.classList.add("hidden");
    const actions = document.getElementById("import-json-actions");
    if (actions) actions.style.display = "none";
  });

  const jsonZone = document.getElementById("import-json-zone");
  const jsonInput = document.getElementById("import-json-input");

  jsonZone?.addEventListener("click", () => jsonInput?.click());
  jsonZone?.addEventListener("dragover", e => { e.preventDefault(); jsonZone.style.borderColor = "var(--brand-primary)"; });
  jsonZone?.addEventListener("dragleave", () => { jsonZone.style.borderColor = ""; });
  jsonZone?.addEventListener("drop", e => {
    e.preventDefault(); jsonZone.style.borderColor = "";
    if (e.dataTransfer.files.length) processImportJSON(e.dataTransfer.files[0]);
  });
  jsonInput?.addEventListener("change", () => { if (jsonInput.files.length) processImportJSON(jsonInput.files[0]); });

  function processImportJSON(file) {
    const reader = new FileReader();
    reader.onload = e => {
      try {
        const data = JSON.parse(e.target.result);
        jsonImportData = data;
        const mode = document.getElementById("json-import-mode")?.value || "full";
        const info = document.getElementById("import-json-info");
        const actions = document.getElementById("import-json-actions");
        let resumen = "";
        if (mode === "full" || mode === "empresas") resumen += `• Empresas: <strong>${(data.clientes||[]).length}</strong><br>`;
        if (mode === "full" || mode === "contactos") resumen += `• Contactos: <strong>${(data.contactos||[]).length}</strong><br>`;
        if (mode === "full" || mode === "tickets") resumen += `• Tickets: <strong>${(data.tickets||[]).length}</strong><br>`;
        if (!resumen) resumen = "No se encontraron datos para el modo seleccionado.";
        if (info) { info.innerHTML = `<strong>📄 ${file.name}</strong><br>${resumen}`; info.classList.remove("hidden"); }
        if (actions) actions.style.display = "flex";
      } catch (err) {
        alert("Error al leer el archivo JSON. Asegúrate de que sea un JSON válido exportado desde esta aplicación.");
      }
    };
    reader.readAsText(file, 'UTF-8');
  }

  document.getElementById("btnConfirmarImportJSON")?.addEventListener("click", async () => {
    if (!jsonImportData) return;
    const mode = document.getElementById("json-import-mode")?.value || "full";
    let msg = "";

    if ((mode === "full" || mode === "empresas") && Array.isArray(jsonImportData.clientes)) {
      const nuevos = jsonImportData.clientes.filter(n => !clientes.find(c => c.EMPRESA === n.EMPRESA));
      clientes.push(...nuevos);
      msg += `✅ ${nuevos.length} empresas importadas. `;
      if (crmLocalOnly) guardarLocal("crm_clientes", clientes); else await guardarClientes(clientes);
    }
    if ((mode === "full" || mode === "contactos") && Array.isArray(jsonImportData.contactos)) {
      const nuevos = jsonImportData.contactos.filter(n => !contactos.find(c => c.correo && c.correo === n.correo));
      contactos.push(...nuevos);
      msg += `✅ ${nuevos.length} contactos importados. `;
      if (crmLocalOnly) guardarLocal("crm_contactos", contactos); else await guardarContactos(contactos);
    }
    if ((mode === "full" || mode === "tickets") && Array.isArray(jsonImportData.tickets)) {
      const maxNum = tickets.length > 0 ? Math.max(...tickets.map(t => t.numero)) : 1000;
      const nuevos = jsonImportData.tickets.map((t, i) => ({ ...t, numero: maxNum + i + 1 }));
      tickets.push(...nuevos);
      msg += `✅ ${nuevos.length} tickets importados. `;
      if (crmLocalOnly) guardarLocal("crm_tickets", tickets); else await guardarTickets(tickets);
    }

    toast(msg || "Sin cambios realizados.");
    if (modalImportJSON) modalImportJSON.style.display = "none";
    renderDashboard();
    renderEmpresas();
    renderContactos();
    renderTickets();
  });

  // ============================================================
  // EXPORT JSON
  // ============================================================
  document.getElementById("btnExportarJSON")?.addEventListener("click", () => {
    const allData = { clientes, contactos, tickets, versionesMercado, cartasTecnicas, configTickets, plantillaMensaje };
    const str = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(allData, null, 2));
    const a = document.createElement("a");
    a.setAttribute("href", str);
    a.setAttribute("download", "crm_completo.json");
    document.body.appendChild(a);
    a.click();
    a.remove();
    toast("📥 JSON exportado");
  });

  document.getElementById("btnExportarTicketsJSON")?.addEventListener("click", () => {
    const str = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(tickets, null, 2));
    const a = document.createElement("a");
    a.setAttribute("href", str);
    a.setAttribute("download", "tickets_soporte.json");
    document.body.appendChild(a);
    a.click();
    a.remove();
    toast("📥 Tickets exportados");
  });

  // ============================================================
  // EXPORT CSV
  // ============================================================
  function descargarCSV(filename, headers, rows) {
    const escape = v => `"${String(v || '').replace(/"/g, '""')}"`;
    const csv = [headers.join(','), ...rows.map(r => r.map(escape).join(','))].join('\r\n');
    const blob = new Blob(['﻿' + csv], { type: 'text/csv;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = filename; a.click();
    URL.revokeObjectURL(url);
  }

  document.getElementById("btnExportCSVEmpresas")?.addEventListener("click", () => {
    const headers = ['EMPRESA', 'CONTACTO', 'TELEFONO_1', 'TELEFONO_2', 'CORREO'];
    const rows = clientes.map(c => [c.EMPRESA, c.CONTACTO, c.TELEFONO_1, c.TELEFONO_2, c.CORREO]);
    descargarCSV('empresas.csv', headers, rows);
    toast("📤 Empresas exportadas como CSV");
  });

  document.getElementById("btnExportCSVContactos")?.addEventListener("click", () => {
    const headers = ['NOMBRE', 'CORREO', 'TELEFONO_1', 'TELEFONO_2', 'EMPRESA'];
    const rows = contactos.map(c => [c.nombre, c.correo, c.telefono1, c.telefono2, c.empresa]);
    descargarCSV('contactos.csv', headers, rows);
    toast("📤 Contactos exportados como CSV");
  });

  // ============================================================
  // STICKY TABLE HEADERS (JS — más confiable que CSS en scroll containers)
  // ============================================================
  function initStickyHeaders() {
    document.querySelectorAll('.table-wrap').forEach(wrap => {
      if (wrap._stickyBound) return;
      wrap._stickyBound = true;
      const ths = wrap.querySelectorAll('thead th');
      if (!ths.length) return;
      wrap.addEventListener('scroll', () => {
        const y = wrap.scrollTop;
        ths.forEach(th => {
          th.style.transform = y > 0 ? `translateY(${y}px)` : '';
        });
      }, { passive: true });
    });
  }

  // ============================================================
  // INIT
  // ============================================================
  inicializarApp();

  // ============================================================
  // COLUMN RESIZE (drag borde de columna como Excel)
  // ============================================================
  function saveColWidths(tableId) {
    const table = document.getElementById(tableId);
    if (!table) return;
    const widths = Array.from(table.querySelectorAll('thead th')).map(th => th.offsetWidth);
    localStorage.setItem('crm_colw_' + tableId, JSON.stringify(widths));
  }

  function restoreColWidths(tableId) {
    const table = document.getElementById(tableId);
    if (!table) return;
    const saved = localStorage.getItem('crm_colw_' + tableId);
    if (!saved) return;
    try {
      const widths = JSON.parse(saved);
      const ths = table.querySelectorAll('thead th');
      widths.forEach((w, i) => {
        if (ths[i] && w > 0) {
          ths[i].style.width = w + 'px';
          ths[i].style.minWidth = w + 'px';
        }
      });
    } catch {}
  }

  function initColResize(tableId) {
    const table = document.getElementById(tableId);
    if (!table) return;
    table.querySelectorAll('.col-resize-handle').forEach(handle => {
      let startX, startW, th;
      handle.addEventListener('mousedown', e => {
        th = handle.closest('th');
        startX = e.pageX;
        startW = th.offsetWidth;
        handle.classList.add('resizing');
        document.body.style.cursor = 'col-resize';
        document.body.style.userSelect = 'none';
        const onMove = ev => {
          const w = Math.max(60, startW + (ev.pageX - startX));
          th.style.width = w + 'px';
          th.style.minWidth = w + 'px';
        };
        const onUp = () => {
          handle.classList.remove('resizing');
          document.body.style.cursor = '';
          document.body.style.userSelect = '';
          saveColWidths(tableId);
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onUp);
        };
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
        e.preventDefault();
      });
    });
  }
  initColResize('tabla-empresas');
  initColResize('tabla-contactos');
  restoreColWidths('tabla-empresas');
  restoreColWidths('tabla-contactos');

  // ============================================================
  // MOBILE SIDEBAR MENU
  // ============================================================
  const mobileMenuBtn = document.getElementById('btnMobileMenu');
  const sidebarOverlay = document.getElementById('sidebar-overlay');

  function openMobileSidebar() {
    mainSidebar?.classList.add('mobile-open');
    sidebarOverlay?.classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  function closeMobileSidebar() {
    mainSidebar?.classList.remove('mobile-open');
    sidebarOverlay?.classList.remove('active');
    document.body.style.overflow = '';
  }
  mobileMenuBtn?.addEventListener('click', openMobileSidebar);
  sidebarOverlay?.addEventListener('click', closeMobileSidebar);

  // Cerrar sidebar al navegar en móvil
  navItems.forEach(n => n.addEventListener('click', () => {
    if (window.innerWidth <= 768) closeMobileSidebar();
  }));

  // PWA — registrar service worker
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js').catch(() => {});
  }
})();
</script>
</body>
</html>