  function populateSelectOptions(selectId, items, selectedVal) {
    const sel = document.getElementById(selectId);
    if (!sel) return;
    sel.innerHTML = "";
    items.forEach(item => {
      const opt = document.createElement("option");
      opt.value = item;
      opt.textContent = item;
      if (item === selectedVal) opt.selected = true;
      sel.appendChild(opt);
    });
  }

  function initTicketFormDropdowns(ticket) {
    populateSelectOptions("form-tk-tipo", configTickets.tipos, ticket?.tipo || configTickets.tipos[0]);
    populateSelectOptions("form-tk-sistema", ["No aplica", ...(configTickets.sistemas || listaSistemas), "__otro__"], ticket?.sistema || "No aplica");
    const optOtroSistema = document.querySelector('#form-tk-sistema option[value="__otro__"]');
    if (optOtroSistema) optOtroSistema.textContent = "➕ Otro (especificar)";
    const inputOtroSistema = document.getElementById("form-tk-sistema-otro") as HTMLInputElement | null;
    if (inputOtroSistema) { inputOtroSistema.style.display = "none"; inputOtroSistema.value = ""; }
    populateSelectOptions("form-tk-estado", configTickets.estados, ticket?.estado || "Abierto");
    populateSelectOptions("form-tk-facturado", configTickets.facturacion, ticket?.facturado || "NO FACTURADO");
    populateSelectOptions("form-tk-prioridad", configTickets.prioridades, ticket?.prioridad || "Media");
    populateSelectOptions("form-tk-grupo", configTickets.grupos, ticket?.grupo || configTickets.grupos[0]);
    populateSelectOptions("form-tk-agente", ["", ...getListaAgentes()], ticket?.agente || "");

    // Also populate detail modal estado selector
    populateSelectOptions("selectCambiarEstadoDetalle", configTickets.estados, ticket?.estado || "Abierto");

    // Agenda: dropdown de agente asignado, dinámico — solo usuarios reales activos del CRM
    // (no la lista de "agentes" configurados a mano), porque el recordatorio necesita cruzar
    // con configN8n.destinatarios[].usuarioCRM para saber a quién avisarle por WhatsApp.
    const selAsignado = document.getElementById("form-tk-agente-asignado") as HTMLSelectElement | null;
    if (selAsignado) {
      selAsignado.innerHTML = `<option value="">— Sin asignar —</option>` +
        getUsuarios().filter(u => u.activo).map(u => `<option value="${escapeHtml(u.nombre)}">${escapeHtml(u.nombre)}</option>`).join("");
      selAsignado.value = ticket?.agenteAsignado || "";
    }
    const fechaInp = document.getElementById("form-tk-fecha-programada") as HTMLInputElement | null;
    if (fechaInp) fechaInp.value = ticket?.fechaProgramada || "";
    const horaInp = document.getElementById("form-tk-hora-programada") as HTMLInputElement | null;
    if (horaInp) horaInp.value = ticket?.horaProgramada || "09:00";
    const chkRec = document.getElementById("chk-recordatorio-wsp") as HTMLInputElement | null;
    if (chkRec) chkRec.checked = !!(ticket?.recordatorioDestinatariosIds || []).length;
    renderRecordatorioCheckboxes(ticket?.recordatorioDestinatariosIds || []);
    actualizarVisibilidadProgramacion();
    const avisoRec = document.getElementById("form-tk-recordatorio-aviso");
    if (avisoRec) avisoRec.style.display = "none";
    populateCcPicker();
  }

  function actualizarVisibilidadProgramacion() {
    const fecha = (document.getElementById("form-tk-fecha-programada") as HTMLInputElement | null)?.value;
    const horaWrap = document.getElementById("form-tk-hora-programada-wrap");
    const recWrap = document.getElementById("form-tk-recordatorio-wrap");
    const mostrar = !!fecha;
    if (horaWrap) horaWrap.style.display = mostrar ? "" : "none";
    if (recWrap) recWrap.style.display = mostrar ? "" : "none";
  }
  document.getElementById("form-tk-fecha-programada")?.addEventListener("change", actualizarVisibilidadProgramacion);

  function renderRecordatorioCheckboxes(preseleccionIds = []) {
    const cont = document.getElementById("form-tk-recordatorio-destinatarios");
    if (!cont) return;
    const activos = (configN8n.destinatarios || []).filter(d => d.activo);
    cont.innerHTML = activos.length ? activos.map(d => `
      <label style="display:flex; align-items:center; gap:4px; font-size:0.78rem; cursor:pointer;">
        <input type="checkbox" class="chk-recordatorio-dest" value="${d.id}" ${preseleccionIds.includes(d.id) ? "checked" : ""}> ${escapeHtml(d.nombre)}
      </label>`).join("") : `<span style="font-size:0.76rem; color:var(--text-muted);">Sin destinatarios activos — configúralos en Configuración → Automatizaciones.</span>`;
  }

  document.getElementById("form-tk-agente-asignado")?.addEventListener("change", function() {
    const nombre = (this as HTMLSelectElement).value;
    const avisoEl = document.getElementById("form-tk-recordatorio-aviso");
    if (!avisoEl) return;
    if (!nombre) { avisoEl.style.display = "none"; return; }
    const dest = (configN8n.destinatarios || []).find(d => d.usuarioCRM === nombre);
    if (dest && dest.activo && dest.telefono) {
      const chk = document.querySelector(`.chk-recordatorio-dest[value="${dest.id}"]`) as HTMLInputElement | null;
      if (chk) chk.checked = true;
      const chkMaster = document.getElementById("chk-recordatorio-wsp") as HTMLInputElement | null;
      if (chkMaster) chkMaster.checked = true;
      avisoEl.style.display = "none";
    } else {
      avisoEl.innerHTML = `⚠️ ${escapeHtml(nombre)} no tiene WhatsApp configurado → <a href="#" id="link-ir-config-n8n" style="color:#818cf8;">Configuración</a>`;
      avisoEl.style.display = "block";
    }
  });
  document.addEventListener("click", (e) => {
    if ((e.target as HTMLElement)?.id === "link-ir-config-n8n") { e.preventDefault(); navegarA("configuracion"); }
