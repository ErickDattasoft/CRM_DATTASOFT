      .split(/[,;]/)
      .map(e => e.trim())
      .filter(e => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e));
  }

  // Ningún dato de usuario (nombres, asuntos, descripciones, correos...) se escapaba antes de
  // insertarse con innerHTML — cualquier ticket, contacto o registro público con un nombre tipo
  // <img src=x onerror=...> ejecutaba ese script en la sesión de quien lo viera después.
  // "new Date().toISOString()" da la fecha en UTC — en México (UTC-6), cualquier hora después
  // de las 18:00 ya cayó en el día siguiente en UTC, así que usarlo para "hoy" hace que un
  // formulario abierto en la noche precargue la fecha de mañana. hoyLocalStr() calcula el
  // día calendario correcto según la zona horaria del navegador.
  function hoyLocalStr() {
    const d = new Date();
    const offsetMs = d.getTimezoneOffset() * 60000;
    return new Date(d.getTime() - offsetMs).toISOString().split("T")[0];
  }
  // Un string "YYYY-MM-DD" (sin hora) se interpreta como medianoche UTC por el motor de JS —
  // convertirlo de vuelta a fecha local puede mover el día mostrado. Forzar T00:00:00 hace
  // que se interprete en la zona horaria local, evitando el corrimiento. Los timestamps
  // completos (con hora/zona, ej. los de actividad de tickets) no necesitan este ajuste.
  function parseFechaLocal(fecha) {
    if (typeof fecha === "string" && /^\d{4}-\d{2}-\d{2}$/.test(fecha)) return new Date(fecha + "T00:00:00");
    return new Date(fecha);
  }

  function escapeHtml(s) {
    return (s === null || s === undefined) ? "" : String(s)
      .replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;").replace(/'/g, "&#39;");
  }

  // Navegación por teclado (↑/↓/Enter/Escape) para cualquier lista tipo autocomplete del CRM
  // (buscador de contacto en tickets, empresa en contactos/cotizaciones/eventos, tarea rápida,
  // catálogo de conceptos de cotización...). El resaltado se guarda como clase "highlighted" en
  // el DOM en vez de un índice en una variable — así funciona igual para listas estáticas y para
  // listas reconstruidas por delegación de eventos, sin que cada widget tenga que llevar su
  // propio estado. getListEl puede ser el elemento de la lista o una función que lo devuelva
  // (para los casos donde la lista se resuelve dinámicamente, ej. por fila de una tabla).
  function attachAutocompleteKeyboardNav(inputEl, getListEl) {
    if (!inputEl) return;
    inputEl.addEventListener("keydown", (e) => {
      const listEl = typeof getListEl === "function" ? getListEl(e) : getListEl;
      if (!listEl || listEl.classList.contains("hidden")) return;
      const items = Array.from(listEl.querySelectorAll(".autocomplete-item"));
      if (!items.length) return;
      const curIdx = items.findIndex(it => it.classList.contains("highlighted"));
      if (e.key === "ArrowDown") {
        e.preventDefault();
        const next = Math.min(curIdx + 1, items.length - 1);
        items.forEach((it, i) => it.classList.toggle("highlighted", i === next));
        items[next]?.scrollIntoView({ block: "nearest" });
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        const prev = Math.max(curIdx - 1, 0);
        items.forEach((it, i) => it.classList.toggle("highlighted", i === prev));
        items[prev]?.scrollIntoView({ block: "nearest" });
      } else if (e.key === "Enter") {
        if (curIdx < 0) return;
        e.preventDefault();
        items[curIdx].dispatchEvent(new Event("click", { bubbles: true }));
      } else if (e.key === "Escape") {
        listEl.classList.add("hidden");
      }
    });
  }

  // La descripción de un ticket sí se muestra como HTML real (viene del editor con
  // negritas/listas, vía document.execCommand), así que no se puede escapar sin más o se
  // perdería el formato — pero también puede venir tal cual de un textarea de texto plano en
  // el portal público, sin ningún filtro. Se quitan scripts/iframes/atributos de evento
  // (onerror, onclick...) y cualquier etiqueta fuera de lo que el editor realmente genera.
  function sanitizeDescripcionHtml(html) {
    let s = String(html || "");
    s = s.replace(/<script[\s\S]*?<\/script>/gi, "");
    s = s.replace(/<style[\s\S]*?<\/style>/gi, "");
    s = s.replace(/<iframe[\s\S]*?<\/iframe>/gi, "");
    s = s.replace(/\son\w+\s*=\s*("[^"]*"|'[^']*'|[^\s>]+)/gi, "");
    s = s.replace(/\s(href|src)\s*=\s*("javascript:[^"]*"|'javascript:[^']*'|javascript:[^\s>]+)/gi, "");
    s = s.replace(/<(?!\/?(b|strong|i|em|u|ul|ol|li|br|div|p|span|font)\b)[^>]*>/gi, "");
