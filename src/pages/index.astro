  async function enviarEmailConProveedor({ to, subject, html, text, replyTo = "" }) {
    const cuerpo = html || `<pre style="font-family:sans-serif; white-space:pre-wrap;">${text || ""}</pre>`;
    const fromEmail = document.getElementById("cfg-correo-soporte")?.value.trim() || configTickets.correoSoporte || "";
    try {
      const response = await fetch("/send-email", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ to, subject, html: cuerpo, replyTo, from: fromEmail }),
      });
      const data = await response.json();
      if (!response.ok) throw new Error(data.error || data.message || JSON.stringify(data));
      toast("✉️ Correo enviado correctamente");
      return { ok: true };
    } catch (error) {
      console.error("Error enviando email:", error);
      toast(`⚠️ No se pudo enviar: ${error.message}`, "error");
      return { ok: false, error: error.message };
    }
  }

  async function enviarEmailEmpresa(e) {
    const idx = parseInt(e.target.closest("button").dataset.idx);
    const c = clientes[idx];
    if (!c.CORREO) return alert("No tiene correo electrónico.");
    const msg = generarMensaje(c);
    const subject = `Actualización de Sistemas CONTPAQi — ${c.EMPRESA}`;
    const body = msg || "";
    const sent = await enviarEmailConProveedor({
      to: c.CORREO,
      subject,
      text: body,
    });
    if (!sent?.ok) {
      const mailLink = `mailto:${c.CORREO}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      window.open(mailLink, "_blank");
    }
  }

