  function construirWorkbookReporteVersiones(companies) {
    const rows = [];
    companies.forEach(c => {
      c.sistemasDesactualizados.forEach(s => {
        rows.push({ Empresa: c.empresa, RFC: c.rfc, Contacto: c.contacto, Correo: c.correo, Sistema: s.sistema, "Tipo Issue": "Versión desactualizada", Instalada: s.versionInstalada, "Oficial/Vencimiento": s.versionOficial, "Días": "" });
      });
      c.licenciasProblema.forEach(l => {
        rows.push({ Empresa: c.empresa, RFC: c.rfc, Contacto: c.contacto, Correo: c.correo, Sistema: l.sistema, "Tipo Issue": l.vencida ? "Licencia vencida" : "Licencia por vencer", Instalada: "", "Oficial/Vencimiento": l.fechaVencimiento, "Días": l.dias });
      });
    });
    const wb = XLSX.utils.book_new();
    const ws = XLSX.utils.json_to_sheet(rows);
    XLSX.utils.book_append_sheet(wb, ws, "Versiones y Licencias");
    return wb;
