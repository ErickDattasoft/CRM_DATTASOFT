          <button class="btn btn-sm tf-del" data-id="${t._id}" data-path="${t.path}" style="font-size:0.7rem; padding:3px 7px; background:rgba(239,68,68,0.1); color:#f87171; border:1px solid rgba(239,68,68,0.2);">🗑️</button>
        </div>`).join("");
      listEl.querySelectorAll<HTMLElement>(".tf-copy").forEach(btn => {
        btn.addEventListener("click", () => {
          navigator.clipboard.writeText(btn.dataset.url!);
          toast("📋 Enlace copiado");
        });
      });
      listEl.querySelectorAll<HTMLElement>(".tf-del").forEach(btn => {
        btn.addEventListener("click", async () => {
          if (!confirm("¿Eliminar este archivo? El enlace dejará de funcionar.")) return;
          await eliminarArchivoTransferencia(btn.dataset.path!);
          await eliminarRegistroTransferencia(btn.dataset.id!);
          transferList = transferList.filter(t => t._id !== btn.dataset.id);
          renderList();
          toast("🗑️ Archivo eliminado");
        });
      });
    };

    transferList = await cargarTransferencias();
    renderList();

    // Subir archivo
    const doUpload = async (file: File) => {
      if (!file) return;
      if (progWrap) progWrap.style.display = "block";
      if (result)   result.style.display   = "none";
      if (progSts)  progSts.textContent     = `Subiendo ${file.name}...`;

      try {
        const data = await subirArchivo(file, (pct: number) => {
          if (progBar) progBar.style.width = pct + "%";
          if (progPct) progPct.textContent = pct + "%";
        });
        const id = await guardarRegistroTransferencia({ name: data.name, url: data.url, path: data.path, size: data.size });
        if (id) transferList.unshift({ _id: id, ...data });
        renderList();
        if (urlInput) urlInput.value = data.url;
        if (result)   result.style.display = "block";
        if (progSts)  progSts.textContent  = "✅ Subida completa";
        navigator.clipboard.writeText(data.url).catch(() => {});
        toast("✅ Enlace copiado al portapapeles");
      } catch (err) {
        if (progSts) progSts.textContent = "❌ Error al subir";
        toast("❌ Error al subir el archivo", "error");
      }
    };

    input?.addEventListener("change", () => { if (input.files?.[0]) doUpload(input.files[0]); input.value = ""; });

    document.getElementById("kb-transfer-copy")?.addEventListener("click", () => {
      navigator.clipboard.writeText(urlInput?.value || "");
      toast("📋 Enlace copiado");
    });

    // Drag & drop en la zona de subida
    drop?.addEventListener("dragover", (e) => { e.preventDefault(); (drop as HTMLElement).style.borderColor = "var(--brand-primary)"; });
    drop?.addEventListener("dragleave", () => { (drop as HTMLElement).style.borderColor = ""; });
    drop?.addEventListener("drop", (e) => {
      e.preventDefault();
      (drop as HTMLElement).style.borderColor = "";
      const file = e.dataTransfer?.files[0];
      if (file) doUpload(file);
    });
  }

  function kbSetupPizarra() {
    const LS_KEY  = "crm_kb_pizarra";
    const texto   = document.getElementById("kb-pizarra-texto") as HTMLElement;
    const savedEl = document.getElementById("kb-pizarra-saved");
    const body    = document.getElementById("kb-pizarra-body");
    const toggle  = document.getElementById("kb-pizarra-toggle");
    if (!texto) return;

    // Restaurar contenido guardado
    const saved = localStorage.getItem(LS_KEY);
    if (saved) texto.innerHTML = saved;

    // Auto-guardar con debounce
    let saveTimer: ReturnType<typeof setTimeout>;
    const doSave = () => {
      localStorage.setItem(LS_KEY, texto.innerHTML);
      if (savedEl) { savedEl.style.opacity = "1"; setTimeout(() => { savedEl.style.opacity = "0"; }, 1500); }
    };
    texto.addEventListener("input", () => { clearTimeout(saveTimer); saveTimer = setTimeout(doSave, 600); });

    // Botones de formato
    document.querySelectorAll<HTMLButtonElement>(".kb-fmt-btn").forEach(btn => {
      btn.addEventListener("mousedown", (e) => {
        e.preventDefault(); // Evita perder el foco del editor
        const cmd = btn.dataset.cmd!;
        const val = btn.dataset.val || undefined;
        document.execCommand(cmd, false, val);
        texto.focus();
        doSave();
      });
    });

    // Colapsar / expandir
    let collapsed = false;
    toggle?.addEventListener("click", () => {
      collapsed = !collapsed;
      if (body)   body.style.display = collapsed ? "none" : "";
      if (toggle) toggle.textContent = collapsed ? "▶" : "▼";
    });

    // Limpiar
    document.getElementById("kb-pizarra-limpiar")?.addEventListener("click", () => {
      if (!texto.innerText.trim() || confirm("¿Limpiar la pizarra?")) {
        texto.innerHTML = "";
        localStorage.removeItem(LS_KEY);
      }
    });

    // Guardar como documento en la KB
    document.getElementById("kb-pizarra-guardar")?.addEventListener("click", () => {
      if (!texto.innerText.trim()) { toast("⚠️ La pizarra está vacía", "warning"); return; }
      kbAbrirModal();
      setTimeout(() => {
        const formContent = document.getElementById("kb-form-content") as HTMLTextAreaElement;
        if (formContent) formContent.value = texto.innerText;
      }, 80);
    });
  }

  function initKB() {
    const usuario = getUsuarioActual();
    const tieneAcceso = kbAcceso.includes(usuario?.nombre || "");
    if (!usuario || !tieneAcceso) return;

    const navKB = document.getElementById("nav-kb");
    const lblKB = document.getElementById("kb-nav-label");
    if (navKB) navKB.style.display = "";
    if (lblKB) lblKB.style.display = "";

    if (kbInited) return;
    kbInited = true;
    kbSetupEvents();
    kbSetupPizarra();

    // Panel de acceso: solo para ERICK (propietario)
    if (usuario.nombre === "ERICK") {
      const wrap = document.getElementById("kb-acceso-wrap");
      if (wrap) wrap.style.display = "";
      document.getElementById("kb-btn-acceso")?.addEventListener("click", (e) => {
        e.stopPropagation();
        const panel = document.getElementById("kb-acceso-panel");
        if (!panel) return;
        const open = panel.classList.toggle("open");
        if (open) kbRenderAccesoPanel();
      });
      document.addEventListener("click", (e) => {
        const wrap = document.getElementById("kb-acceso-wrap");
        if (wrap && !wrap.contains(e.target as Node)) {
          document.getElementById("kb-acceso-panel")?.classList.remove("open");
        }
      });
    }

    if (firebaseEnabled && !kbUnsubscribe) {
      // Mostrar cache local mientras llegan los datos de Firestore
      try { const c = localStorage.getItem("crm_kb"); if (c) { kbDocs = JSON.parse(c); kbRenderList(); } } catch {}
      kbUnsubscribe = suscribirKB((docs: KBDoc[]) => {
        if (docs.length > 0) {
          kbDocs = docs.sort((a, b) => {
            const ta = a.updated_at?.seconds || 0, tb = b.updated_at?.seconds || 0;
            return tb - ta;
          });
          localStorage.setItem("crm_kb", JSON.stringify(kbDocs));
          kbRenderList();
          if (kbSelId) kbAbrirDoc(kbSelId);
        } else {
          // Firestore vacío — recuperar desde cache local si existe
          const cached = localStorage.getItem("crm_kb");
          if (cached) {
            try {
              const localDocs: KBDoc[] = JSON.parse(cached);
              if (localDocs.length > 0) {
                kbDocs = localDocs;
                kbRenderList();
                kbRecuperarEnFirestore(localDocs);
              } else {
                kbDocs = []; kbRenderList();
              }
            } catch { kbDocs = []; kbRenderList(); }
          } else {
            kbDocs = []; kbRenderList();
          }
        }
      });
    } else if (!firebaseEnabled) {
      try { kbDocs = JSON.parse(localStorage.getItem("crm_kb") || "[]"); } catch { kbDocs = []; }
      kbRenderList();
    }
  }

  // Sincronizar kbAcceso desde Firebase cuando llegan datos del CRM
  document.addEventListener("crm:datosFirebase", (e: Event) => {
    const datos = (e as CustomEvent).detail;
    if (datos?.kbAcceso && Array.isArray(datos.kbAcceso)) {
      kbAcceso = datos.kbAcceso;
      localStorage.setItem("crm_kb_acceso", JSON.stringify(kbAcceso));
    }
    const usuario = getUsuarioActual();
    if (usuario && kbAcceso.includes(usuario.nombre) && !kbInited) initKB();
  });

  // Inicializar KB si ya hay sesión activa con acceso
  initKB();

  // ── PUNTOS DE RESTAURACIÓN (GitHub API) ──────────────────────────────
  const GH_OWNER = "ErickDattasoft";
  const GH_REPO  = "CRM_DATTASOFT";
  const GH_PAT_KEY = "crm_gh_pat";

  // Cargar PAT guardado
  const patInput = document.getElementById("cfg-gh-pat") as HTMLInputElement;
  if (patInput) patInput.value = localStorage.getItem(GH_PAT_KEY) || "";

  document.getElementById("btn-gh-pat-save")?.addEventListener("click", () => {
    const v = patInput?.value.trim() || "";
    if (!v) { toast("⚠️ Ingresa un token antes de guardar", "warning"); return; }
    localStorage.setItem(GH_PAT_KEY, v);
    toast("✓ Token guardado", "success");
  });

  document.getElementById("btn-ver-puntos")?.addEventListener("click", () => {
    window.open(`https://github.com/${GH_OWNER}/${GH_REPO}/tags`, "_blank");
  });

  document.getElementById("btn-crear-punto")?.addEventListener("click", () => {
    const pat = localStorage.getItem(GH_PAT_KEY) || "";
    if (!pat) { toast("⚠️ Primero guarda tu GitHub Token en Configuración", "warning"); return; }
    document.getElementById("modal-gh-punto")!.style.display = "flex";
    const hoy = new Date();
    const sugerido = `v${hoy.getFullYear()}.${String(hoy.getMonth()+1).padStart(2,"0")}.${String(hoy.getDate()).padStart(2,"0")}`;
    (document.getElementById("gh-punto-nombre") as HTMLInputElement).value = sugerido;
    (document.getElementById("gh-punto-desc") as HTMLInputElement).value = "";
    document.getElementById("gh-punto-status")!.style.display = "none";
    (document.getElementById("gh-punto-nombre") as HTMLInputElement).focus();
  });

  document.getElementById("btn-gh-punto-cancelar")?.addEventListener("click", () => {
    document.getElementById("modal-gh-punto")!.style.display = "none";
  });

  document.getElementById("btn-gh-punto-crear")?.addEventListener("click", async () => {
    const pat  = localStorage.getItem(GH_PAT_KEY) || "";
    const name = (document.getElementById("gh-punto-nombre") as HTMLInputElement).value.trim().replace(/\s+/g, "-");
    const desc = (document.getElementById("gh-punto-desc") as HTMLInputElement).value.trim() || `Punto de restauración ${name}`;
    const status = document.getElementById("gh-punto-status2")!;
    const btn = document.getElementById("btn-gh-punto-crear") as HTMLButtonElement;

    if (!name) { toast("⚠️ El nombre no puede estar vacío", "warning"); return; }

    btn.disabled = true;
    btn.textContent = "Creando...";
    status.style.display = "inline";
    status.style.color = "var(--text-muted)";
    status.textContent = "⏳ Obteniendo commit actual...";

    try {
      // 1. Obtener SHA del HEAD de main
      const refRes = await fetch(`https://api.github.com/repos/${GH_OWNER}/${GH_REPO}/git/ref/heads/main`, {
        headers: { Authorization: `Bearer ${pat}`, Accept: "application/vnd.github+json" }
      });
      if (!refRes.ok) throw new Error(refRes.status === 401 ? "Token inválido o sin permiso" : `Error ${refRes.status}`);
      const refData = await refRes.json();
      const sha = refData.object.sha;

      status.textContent = "⏳ Creando tag anotado...";

      // 2. Crear el objeto tag (anotado)
      const tagRes = await fetch(`https://api.github.com/repos/${GH_OWNER}/${GH_REPO}/git/tags`, {
        method: "POST",
        headers: { Authorization: `Bearer ${pat}`, Accept: "application/vnd.github+json", "Content-Type": "application/json" },
        body: JSON.stringify({ tag: name, message: desc, object: sha, type: "commit",
          tagger: { name: "CRM DATTASOFT", email: "crm@dattasoft.mx", date: new Date().toISOString() }
        })
      });
      if (!tagRes.ok) {
        const err = await tagRes.json();
        throw new Error(err.message || `Error ${tagRes.status}`);
      }
      const tagData = await tagRes.json();

      // 3. Crear la referencia del tag
      const refPostRes = await fetch(`https://api.github.com/repos/${GH_OWNER}/${GH_REPO}/git/refs`, {
        method: "POST",
        headers: { Authorization: `Bearer ${pat}`, Accept: "application/vnd.github+json", "Content-Type": "application/json" },
        body: JSON.stringify({ ref: `refs/tags/${name}`, sha: tagData.sha })
      });
      if (!refPostRes.ok) {
        const err = await refPostRes.json();
        throw new Error(err.message || `Error ${refPostRes.status}`);
      }

      status.style.color = "#34d399";
      status.textContent = `✓ Punto "${name}" creado en GitHub`;
      btn.textContent = "✓ Creado";
      setTimeout(() => {
        document.getElementById("modal-gh-punto")!.style.display = "none";
        toast(`🔖 Punto de restauración "${name}" guardado`, "success");
        btn.disabled = false;
        btn.textContent = "🔖 Crear";
      }, 1500);
    } catch (err: any) {
      status.style.color = "#f87171";
      status.textContent = `✗ ${err.message}`;
      btn.disabled = false;
      btn.textContent = "🔖 Crear";
    }
  });

  // Cerrar modal con Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      const m = document.getElementById("modal-gh-punto");
      if (m && m.style.display !== "none") m.style.display = "none";
    }
  });
})();
</script>

<!-- MODAL: Crear punto de restauración GitHub -->
<div id="modal-gh-punto" style="display:none; position:fixed; inset:0; z-index:4000; background:rgba(0,0,0,0.75); align-items:center; justify-content:center; padding:20px; backdrop-filter:blur(4px);">
  <div style="background:var(--bg-card); border:1px solid var(--border-color); border-radius:var(--radius-xl); padding:28px 30px; width:100%; max-width:440px; box-shadow:0 20px 60px rgba(0,0,0,0.5);">
    <div style="font-size:1rem; font-weight:800; color:var(--text-bright); font-family:var(--font-heading); margin-bottom:6px;">🔖 Crear punto de restauración</div>
    <p style="font-size:0.78rem; color:var(--text-muted); margin-bottom:20px; line-height:1.5;">Se creará un tag anotado en GitHub apuntando al commit actual de <strong style="color:var(--text-main);">main</strong>.</p>
    <div class="form-group" style="margin-bottom:14px;">
      <label>Nombre del punto</label>
      <input id="gh-punto-nombre" type="text" placeholder="v2025.06.25-kb-completo" style="font-size:0.85rem;">
      <span style="font-size:0.7rem; color:var(--text-muted); margin-top:3px; display:block;">Sin espacios. Ejemplo: v1.2-fix-login</span>
    </div>
    <div class="form-group" style="margin-bottom:20px;">
      <label>Descripción (opcional)</label>
      <input id="gh-punto-desc" type="text" placeholder="Base de Conocimiento completa + pizarra" style="font-size:0.85rem;">
    </div>
    <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
      <button id="btn-gh-punto-crear" class="btn btn-primary btn-sm">🔖 Crear</button>
      <button id="btn-gh-punto-cancelar" class="btn btn-ghost btn-sm">Cancelar</button>
      <span id="gh-punto-status2" style="font-size:0.78rem; display:none;"></span>
    </div>
  </div>
</div>
</body>
</html>