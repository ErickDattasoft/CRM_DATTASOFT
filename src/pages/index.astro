  });

  // Masivo WhatsApp
  // WhatsApp masivo: si hay webhook de n8n configurado y la regla "version_whatsapp_clientes"
  // está activa, manda UN solo webhook con todas las empresas seleccionadas (n8n decide con qué
  // servicio de WhatsApp reenviarlo — CallMeBot no sirve aquí, solo funciona con números del
  // equipo interno pre-registrados). Si no hay n8n configurado, se conserva el comportamiento
  // anterior (abrir pestañas de WhatsApp Web una por una) como respaldo, para no dejar la función
  // sin efecto mientras alguien termina de configurar n8n.
  document.getElementById("btnWspMasivo")?.addEventListener("click", async () => {
    if (seleccionadosIdx.length === 0) return alert("Selecciona al menos una empresa.");

    const reglaVersiones = (configN8n.reglas || []).find(r => r.id === "version_whatsapp_clientes");
    const n8nListo = !!(configN8n.webhookUrl && reglaVersiones?.activo);

    if (!n8nListo) {
      if (!configN8n.webhookUrl) {
        toast("⚠️ Configura el webhook de n8n en Configuración → Automatizaciones para usar WhatsApp masivo.", "warning");
      }
      seleccionadosIdx.forEach((idx, i) => {
        setTimeout(() => {
          const c = clientes[idx];
          const tel = c.TELEFONO_1 || c.TELEFONO_2;
          if (!tel) return;
          const msg = generarMensaje(c);
          const encoded = msg ? encodeURIComponent(msg) : "";
          window.open(`https://web.whatsapp.com/send?phone=${tel}${encoded ? `&text=${encoded}` : ""}`, "_blank");
        }, i * 500);
      });
      return;
    }

    const empresasSinTelefono = [];
    const empresas = seleccionadosIdx.map(idx => {
      const c = clientes[idx];
      const tel = c.TELEFONO_1 || c.TELEFONO_2;
      if (!tel) { empresasSinTelefono.push(c.EMPRESA); return null; }
      return {
        nombre: c.EMPRESA || "", contacto: c.CONTACTO || "", telefono: tel, correo: c.CORREO || "",
        sistemasPendientes: getSistemasPendientes(c).join("\n"),
      };
    }).filter(Boolean);

    if (empresasSinTelefono.length) {
      toast(`⚠️ ${empresasSinTelefono.length} empresa(s) no tienen teléfono y se omitieron del envío.`, "warning");
    }
    if (!empresas.length) { toast("⚠️ Ninguna empresa seleccionada tiene teléfono registrado.", "error"); return; }

    try {
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 8000);
      await fetch(configN8n.webhookUrl, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          evento: "version_whatsapp_clientes",
          plantillaMensaje,
          empresas,
          totalEmpresas: empresas.length,
          enviadoPor: getUsuarioActual()?.nombre || "Sistema",
          fecha: new Date().toISOString(),
        }),
        signal: controller.signal,
      });
      clearTimeout(timeoutId);
      toast(`📢 WhatsApp masivo enviado a ${empresas.length} empresa(s) vía n8n`);
      logBitacora(`📢 WhatsApp masivo enviado a ${empresas.length} empresas vía n8n — por ${getUsuarioActual()?.nombre || "Sistema"}`, "📢");
    } catch (err) {
      toast("❌ Error al enviar a n8n — revisa el webhook", "error");
    }
  });

  // Masivo Email — un correo individual y personalizado por empresa (misma plantilla y
  // placeholders [contacto]/[empresa]/[sistemas_pendientes] que ya usa el WhatsApp masivo vía
  // generarMensaje), no un solo envío genérico con el cuerpo vacío a todos los correos juntos —
  // así cada empresa solo ve sus propios sistemas pendientes, y no un correo en blanco.
  document.getElementById("btnMailMasivo")?.addEventListener("click", async () => {
    if (seleccionadosIdx.length === 0) return alert("Selecciona al menos una empresa.");
    const subject = "Actualización de Sistemas CONTPAQi";
    const sinCorreo = [];
    const sinPendientes = [];
    let enviados = 0;
    for (const idx of seleccionadosIdx) {
      const c = clientes[idx];
      if (!c?.CORREO) { sinCorreo.push(c?.EMPRESA || "—"); continue; }
      const mensaje = generarMensaje(c);
      if (!mensaje) { sinPendientes.push(c.EMPRESA); continue; }
      const sent = await enviarEmailConProveedor({ to: c.CORREO, subject, text: mensaje });
      if (sent?.ok) enviados++;
    }
    if (sinPendientes.length) toast(`ℹ️ ${sinPendientes.length} empresa(s) sin sistemas pendientes, se omitieron: ${sinPendientes.join(", ")}`, "warning");
    if (sinCorreo.length) toast(`⚠️ ${sinCorreo.length} empresa(s) sin correo registrado, se omitieron.`, "warning");
    if (enviados) logBitacora(`✉️ Email masivo de versiones enviado (personalizado) a ${enviados} empresa(s)`, "📧");
  });

