  function renderAdjuntosForm() {
    const list = document.getElementById("tk-attachment-list");
    if (!list) return;
    list.innerHTML = "";
    adjuntosTicketActual.forEach((f, i) => {
      const chip = document.createElement("span");
      chip.className = "attachment-chip";
      const ext = f.nombre.split(".").pop().toUpperCase();
      chip.innerHTML = `<span>${ext === "PDF" ? "📄" : ext === "XML" ? "📋" : "🖼️"} <span title="${f.nombre}">${f.nombre}</span></span><button data-i="${i}" title="Quitar">×</button>`;
      chip.querySelector("button").addEventListener("click", () => {
        adjuntosTicketActual.splice(i, 1);
        renderAdjuntosForm();
      });
      list.appendChild(chip);
    });
  }

  function renderAdjuntosDetalle(t) {
    const sec = document.getElementById("det-tk-adjuntos-section");
    const cont = document.getElementById("det-tk-adjuntos");
    if (!sec || !cont) return;
    const adjuntos = t.adjuntos || [];
    if (!adjuntos.length) { sec.style.display = "none"; return; }
    sec.style.display = "block";
    cont.innerHTML = "";
    adjuntos.forEach(f => {
      const chip = document.createElement("a");
      chip.className = "attachment-chip";
      chip.style.textDecoration = "none";
      chip.style.cursor = "pointer";
      const ext = (f.nombre || "").split(".").pop().toUpperCase();
      chip.innerHTML = `<span>${ext === "PDF" ? "📄" : ext === "XML" ? "📋" : "🖼️"} <span title="${f.nombre}">${f.nombre}</span></span>`;
      if (f.data) {
        chip.href = f.data;
        chip.download = f.nombre;
      }
      cont.appendChild(chip);
    });
  }

  const tkAttachZone = document.getElementById("tk-attachment-zone");
  const tkAttachInput = document.getElementById("tk-attachment-input");

  tkAttachZone?.addEventListener("click", () => tkAttachInput?.click());
  tkAttachZone?.addEventListener("dragover", e => { e.preventDefault(); tkAttachZone.classList.add("drag-over"); });
  tkAttachZone?.addEventListener("dragleave", () => tkAttachZone.classList.remove("drag-over"));
  tkAttachZone?.addEventListener("drop", e => {
    e.preventDefault(); tkAttachZone.classList.remove("drag-over");
    procesarAdjuntos(Array.from(e.dataTransfer.files));
  });
  tkAttachInput?.addEventListener("change", () => { if (tkAttachInput.files.length) procesarAdjuntos(Array.from(tkAttachInput.files)); });

  function procesarAdjuntos(files) {
    // Antes: "MIME permitido O termina en .xml" dejaba pasar CUALQUIER archivo con solo
    // renombrarlo a *.xml (el MIME real no importaba). Ahora exige extensión Y MIME consistentes.
    const permitidos = {
      png: ["image/png"], jpg: ["image/jpeg", "image/jpg"], jpeg: ["image/jpeg", "image/jpg"],
      pdf: ["application/pdf"], xml: ["text/xml", "application/xml", ""],
    };
    files.forEach(f => {
      const ext = (f.name.split(".").pop() || "").toLowerCase();
      const mimesValidos = permitidos[ext];
      if (!mimesValidos || !mimesValidos.includes(f.type)) { toast(`⚠️ Tipo no permitido: ${f.name}`, "error"); return; }
      if (f.size > 5 * 1024 * 1024) { toast(`⚠️ ${f.name} supera 5MB`, "error"); return; }
      const reader = new FileReader();
      reader.onload = ev => {
        adjuntosTicketActual.push({ nombre: f.name, tipo: f.type, data: ev.target.result });
        renderAdjuntosForm();
      };
      reader.readAsDataURL(f);
    });
    if (tkAttachInput) tkAttachInput.value = "";
  }

