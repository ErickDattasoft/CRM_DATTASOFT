  const modalCSV = document.getElementById("modal-import-csv");

  document.getElementById("btnImportCSVEmpresas")?.addEventListener("click", () => {
    importCSVTarget = "empresas";
    document.getElementById("import-csv-titulo").textContent = "📥 Importar CSV — Empresas";
