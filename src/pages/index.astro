    if (!ev2.empresas) ev2.empresas = [];
    const yaExiste = ev2.empresas.some((e: any) => e.nombre.toLowerCase() === val.toLowerCase());
    if (yaExiste) { toast("⚠️ La empresa ya está en el evento"); return; }
    ev2.empresas.push({ nombre: val.toUpperCase(), sistema: "", invitadoPor: "", invitadoPorManual: "", invitado: false, respuesta: "PENDIENTE", notas: "" });
    guardarEventos();
