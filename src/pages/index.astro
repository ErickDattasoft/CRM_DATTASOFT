  function seleccionarContacto(c) {
    if (tkBuscarInput) tkBuscarInput.value = "";
    if (tkContactoInput) tkContactoInput.value = c.nombre || "";
    if (tkCorreoContactoInput) tkCorreoContactoInput.value = c.correo || "";
    if (tkEmpresaInput) tkEmpresaInput.value = c.empresa || "";
    tkAutoList?.classList.add("hidden");
