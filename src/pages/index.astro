  // Buscar empresa para agregar al evento — usa event delegation para ser
  // robusto ante re-renders del panel sin perder los listeners.
  function mostrarEmpresasAutoComplete() {
    const input = document.getElementById("ev-buscar-empresa") as HTMLInputElement;
    const list  = document.getElementById("ev-empresas-autocomplete");
    if (!input || !list) return;
    const val = input.value.toLowerCase().trim();
    const ev = getEventoActivo(); if (!ev) return;
    const yaAgregadas = new Set((ev.empresas || []).map((e: any) => e.nombre));
    const matches = clientes.filter((c: any) => {
      const nombre = (c.EMPRESA || "");
      return (!val || nombre.toLowerCase().includes(val)) && !yaAgregadas.has(nombre);
    }).slice(0, 15);
    if (!matches.length) { list.classList.add("hidden"); return; }
    list.innerHTML = matches.map((c: any) => `<div class="autocomplete-item" data-nombre="${c.EMPRESA}">${c.EMPRESA}</div>`).join("");
    list.classList.remove("hidden");
    list.querySelectorAll(".autocomplete-item").forEach(item => {
      item.addEventListener("click", () => {
        const ev2 = getEventoActivo(); if (!ev2) return;
        if (!ev2.empresas) ev2.empresas = [];
        const nombre = (item as HTMLElement).dataset.nombre || "";
        ev2.empresas.push({ nombre, sistema: "", invitadoPor: "", invitadoPorManual: "", invitado: false, respuesta: "PENDIENTE", notas: "" });
        guardarEventos();
        mostrarPanelEvento(ev2);
        input.value = "";
        list.classList.add("hidden");
      });
    });
  }

  attachAutocompleteKeyboardNav(document.getElementById("ev-buscar-empresa"), document.getElementById("ev-empresas-autocomplete"));

  // Event delegation: escucha input y focus en el documento, filtra por id
  document.addEventListener("input", (e: Event) => {
    if ((e.target as HTMLElement)?.id === "ev-buscar-empresa") mostrarEmpresasAutoComplete();
  });
  document.addEventListener("focusin", (e: Event) => {
    if ((e.target as HTMLElement)?.id === "ev-buscar-empresa") mostrarEmpresasAutoComplete();
  });
  document.addEventListener("click", (e: Event) => {
    const target = e.target as HTMLElement;
    const list   = document.getElementById("ev-empresas-autocomplete");
    const input  = document.getElementById("ev-buscar-empresa");
    const btn    = document.getElementById("btnAgregarEmpresaEvento");
    if (!list) return;
    if (list.contains(target) || target === input || target === btn) return;
    list.classList.add("hidden");
  });

