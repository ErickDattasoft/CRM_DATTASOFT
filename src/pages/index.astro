  // ============================================================
  // BÚSQUEDA GLOBAL — Ctrl+K
  // ============================================================
  (function() {
    const modal    = document.getElementById("modal-busqueda-global")!;
    const input    = document.getElementById("busqueda-global-input") as HTMLInputElement;
    const resDiv   = document.getElementById("busqueda-global-resultados")!;
    let idxActivo  = -1;

    const abrir = () => { modal.style.display = "flex"; input.value = ""; resDiv.innerHTML = ""; idxActivo = -1; setTimeout(() => input.focus(), 50); };
    const cerrar = () => { modal.style.display = "none"; };

    document.addEventListener("keydown", (e: KeyboardEvent) => {
      if ((e.ctrlKey || e.metaKey) && e.key === "k") { e.preventDefault(); abrir(); return; }
      if (e.key === "Escape") { cerrar(); return; }
    });
    modal.addEventListener("click", (e) => { if (e.target === modal) cerrar(); });

    const mark = (txt: string, q: string) => {
      if (!q) return txt;
      const idx = txt.toLowerCase().indexOf(q.toLowerCase());
      if (idx < 0) return txt;
      return txt.slice(0, idx) + `<mark style="background:rgba(99,102,241,0.3);color:var(--text-bright);border-radius:3px;">${txt.slice(idx, idx + q.length)}</mark>` + txt.slice(idx + q.length);
    };

    const navegar = (seccion: string, filtro?: string) => { cerrar(); navegarA(seccion, filtro || ""); };

    const buscar = () => {
      const q = input.value.trim();
      if (q.length < 2) { resDiv.innerHTML = `<div style="text-align:center;padding:24px;color:var(--text-muted);font-size:0.85rem;">Escribe al menos 2 caracteres para buscar...</div>`; return; }
      const ql = q.toLowerCase();
      const grupos: string[] = [];

      // Empresas
      const empRes = clientes.filter((c: any) => (c.EMPRESA||"").toLowerCase().includes(ql) || (c.RFC||"").toLowerCase().includes(ql) || (c.CONTACTO||"").toLowerCase().includes(ql)).slice(0, 5);
      if (empRes.length) {
        grupos.push(`<div class="bg-grupo-label">🏢 Empresas</div>`);
        empRes.forEach((c: any) => grupos.push(`<div class="bg-resultado" data-seccion="empresas" data-buscar="${c.EMPRESA}"><span class="bg-resultado-icon">🏢</span><div><div class="bg-resultado-titulo">${mark(c.EMPRESA||"", q)}</div><div class="bg-resultado-sub">${c.RFC||""} · ${c.CONTACTO||""}</div></div></div>`));
      }

      // Contactos
      const ctRes = contactos.filter((c: any) => (c.nombre||"").toLowerCase().includes(ql) || (c.correo||"").toLowerCase().includes(ql) || (c.empresa||"").toLowerCase().includes(ql)).slice(0, 4);
      if (ctRes.length) {
        grupos.push(`<div class="bg-grupo-label">📇 Contactos</div>`);
        ctRes.forEach((c: any) => grupos.push(`<div class="bg-resultado" data-seccion="contactos"><span class="bg-resultado-icon">📇</span><div><div class="bg-resultado-titulo">${mark(c.nombre||"", q)}</div><div class="bg-resultado-sub">${c.empresa||""} · ${c.correo||""}</div></div></div>`));
      }

      // Tickets
      const tkRes = tickets.filter((t: any) => (t.asunto||"").toLowerCase().includes(ql) || (t.empresa||"").toLowerCase().includes(ql) || String(t.numero||"").includes(ql)).slice(0, 4);
      if (tkRes.length) {
        grupos.push(`<div class="bg-grupo-label">🎫 Tickets</div>`);
        tkRes.forEach((t: any) => grupos.push(`<div class="bg-resultado" data-seccion="tickets"><span class="bg-resultado-icon">🎫</span><div><div class="bg-resultado-titulo">#${t.numero} — ${mark(t.asunto||"", q)}</div><div class="bg-resultado-sub">${t.empresa||""} · ${t.estado||""}</div></div></div>`));
      }

      // KB (base de conocimiento)
      const kbRes = (window as any)._kbDocs ? (window as any)._kbDocs.filter((d: any) => (d.title||"").toLowerCase().includes(ql) || (d.content||"").toLowerCase().includes(ql)).slice(0, 3) : [];
      if (kbRes.length) {
        grupos.push(`<div class="bg-grupo-label">📚 Base de Conocimiento</div>`);
        kbRes.forEach((d: any) => grupos.push(`<div class="bg-resultado" data-seccion="knowledge"><span class="bg-resultado-icon">📄</span><div><div class="bg-resultado-titulo">${mark(d.title||"", q)}</div><div class="bg-resultado-sub">${d.category||""}</div></div></div>`));
      }

      resDiv.innerHTML = grupos.length ? grupos.join("") : `<div style="text-align:center;padding:24px;color:var(--text-muted);font-size:0.85rem;">Sin resultados para "<strong>${q}</strong>"</div>`;
      idxActivo = -1;

      resDiv.querySelectorAll<HTMLElement>(".bg-resultado").forEach(el => {
        el.addEventListener("click", () => {
          const buscar = el.dataset.buscar || "";
          navegar(el.dataset.seccion || "dashboard");
          if (buscar) {
            setTimeout(() => {
              const inp = document.getElementById("search-empresas") as HTMLInputElement;
              if (inp) { inp.value = buscar; inp.dispatchEvent(new Event("input")); }
            }, 200);
          }
        });
      });
    };

    input.addEventListener("input", buscar);

    input.addEventListener("keydown", (e: KeyboardEvent) => {
      const items = Array.from(resDiv.querySelectorAll<HTMLElement>(".bg-resultado"));
      if (!items.length) return;
      if (e.key === "ArrowDown") { e.preventDefault(); idxActivo = Math.min(idxActivo + 1, items.length - 1); items.forEach((el, i) => el.classList.toggle("bg-activo", i === idxActivo)); items[idxActivo]?.scrollIntoView({ block: "nearest" }); }
      if (e.key === "ArrowUp")   { e.preventDefault(); idxActivo = Math.max(idxActivo - 1, 0); items.forEach((el, i) => el.classList.toggle("bg-activo", i === idxActivo)); items[idxActivo]?.scrollIntoView({ block: "nearest" }); }
      if (e.key === "Enter" && idxActivo >= 0) items[idxActivo]?.click();
    });
  })();

})();
</script>

<!-- MODAL: Crear punto de restauración GitHub -->
<div id="modal-gh-punto" style="display:none; position:fixed; inset:0; z-index:4000; background:rgba(0,0,0,0.75); align-items:center; justify-content:center; padding:20px; backdrop-filter:blur(4px);">
