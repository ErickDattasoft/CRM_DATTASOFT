  function exportarExcel(tipo) {
    const wb = XLSX.utils.book_new();
    const fnClose = () => { const m = document.getElementById("modal-exportar-excel"); if(m) m.style.display = "none"; };

    if (tipo === "empresas" || tipo === "todo") {
      const rows = clientes.map(c => {
        const row = { Empresa: c.EMPRESA, Contacto: c.CONTACTO, Correo: c.CORREO, RFC: c.RFC || "", Teléfono1: c.TELEFONO_1, Teléfono2: c.TELEFONO_2 };
        listaSistemas.forEach(s => { row[s] = c.SISTEMAS?.[s.toUpperCase().trim()] || ""; });
        return row;
      });
      const ws = XLSX.utils.json_to_sheet(rows);
      XLSX.utils.book_append_sheet(wb, ws, "Empresas");
    }

    if (tipo === "contactos" || tipo === "todo") {
      const rows = contactos.map(c => ({ Nombre: c.nombre, Correo: c.correo, Teléfono1: c.telefono1, Teléfono2: c.telefono2, Empresa: c.empresa }));
      const ws = XLSX.utils.json_to_sheet(rows);
      XLSX.utils.book_append_sheet(wb, ws, "Contactos");
    }

    if (tipo === "tickets" || tipo === "todo") {
      const rows = tickets.map(t => ({
        Folio: t.numero, Asunto: t.asunto, Empresa: t.empresa, Contacto: t.contacto,
        Tipo: t.tipo, Sistema: t.sistema || "", Estado: t.estado, Prioridad: t.prioridad, Grupo: t.grupo,
        Agente: t.agente, Referido: t.referido, Solicitado: t.solicitado,
        Canalizado: t.canalizado, Realizado: t.realizado,
        Descripción: (t.descripcion || "").replace(/<[^>]+>/g, ""),
        Creado: t.fechaCreacion ? new Date(t.fechaCreacion).toLocaleString('es-MX') : "",
        Actualizado: t.fechaActualizacion ? new Date(t.fechaActualizacion).toLocaleString('es-MX') : ""
      }));
      const ws = XLSX.utils.json_to_sheet(rows);
      XLSX.utils.book_append_sheet(wb, ws, "Tickets");
    }

    const nombre = tipo === "todo" ? "CRM_DATTASOFT_completo" : `CRM_DATTASOFT_${tipo}`;
    XLSX.writeFile(wb, `${nombre}_${new Date().toISOString().slice(0,10)}.xlsx`);
    logBitacora(`Exportación Excel: ${tipo}`, "📊");
    toast(`📊 Excel exportado: ${nombre}`);
    fnClose();
  }

  document.getElementById("btnExcelEmpresas")?.addEventListener("click", () => exportarExcel("empresas"));
  document.getElementById("btnExcelContactos")?.addEventListener("click", () => exportarExcel("contactos"));
  document.getElementById("btnExcelTickets")?.addEventListener("click", () => exportarExcel("tickets"));
  document.getElementById("btnExcelTodo")?.addEventListener("click", () => exportarExcel("todo"));

  // ============================================================
  // MARKET VERSIONS
  // ============================================================
  function initMarketForms() {
    listaSistemas.forEach(s => {
      const k = s.toUpperCase().trim();
      const iv = document.querySelector(`.input-version-oficial[data-sistema="${s}"]`);
      const ic = document.querySelector(`.input-carta-tecnica[data-sistema="${s}"]`);
      if (iv) iv.value = versionesMercado[k] || "";
      if (ic) ic.value = cartasTecnicas[k] || "";
    });
    bindMarketVersionInputs();
    updateMarketStatusIndicators();
  }

  function bindMarketVersionInputs() {
    listaSistemas.forEach(s => {
      const k = s.toUpperCase().trim();
      const iv = document.querySelector(`.input-version-oficial[data-sistema="${s}"]`);
      if (!iv) return;
      iv.addEventListener("input", () => {
        versionesMercado[k] = iv.value.trim();
        updateMarketStatusIndicators();
        renderEmpresas();
      });
    });
  }

  function updateMarketStatusIndicators() {
    listaSistemas.forEach(s => {
      const k = s.toUpperCase().trim();
      const status = document.querySelector(`.version-status[data-sistema-status="${s}"]`);
      if (!status) return;
      const value = String(versionesMercado[k] || "").trim();
      if (!value) {
        status.textContent = "Sin versión oficial";
        status.className = "version-status status-empty";
      } else {
        status.textContent = "Versión registrada";
        status.className = "version-status status-defined";
      }
    });
  }

  document.getElementById("btnGuardarVersiones")?.addEventListener("click", async () => {
    listaSistemas.forEach(s => {
      const k = s.toUpperCase().trim();
      const iv = document.querySelector(`.input-version-oficial[data-sistema="${s}"]`);
      const ic = document.querySelector(`.input-carta-tecnica[data-sistema="${s}"]`);
      if (iv) versionesMercado[k] = iv.value.trim();
      if (ic) cartasTecnicas[k] = ic.value.trim();
    });
    if (crmLocalOnly || !firebaseEnabled) {
      guardarLocal("crm_versiones", versionesMercado);
      guardarLocal("crm_cartas", cartasTecnicas);
      toast("💾 Versiones guardadas (Local)");
      logBitacora("Versiones oficiales actualizadas", "🚀");
      updateMarketStatusIndicators();
      renderEmpresas();
      return;
    }
    mostrarEstado("💾 Guardando versiones...");
    const res = await guardarConfiguracion(versionesMercado, cartasTecnicas);
    if (res.ok) {
      toast("💾 Versiones guardadas en Firebase");
      ocultarEstado();
      logBitacora("Versiones oficiales actualizadas", "🚀");
    } else {
      guardarLocal("crm_versiones", versionesMercado);
      guardarLocal("crm_cartas", cartasTecnicas);
      mostrarEstado(`⚠️ Error Firebase: ${res.msg}`, 6000);
      console.error("[Versiones] Error al guardar en Firebase:", res.msg);
    }
    updateMarketStatusIndicators();
    renderEmpresas();
  });

  document.getElementById("txtPlantillaMensaje")?.addEventListener("change", async (e) => {
    plantillaMensaje = e.target.value;
    if (crmLocalOnly) {
      localStorage.setItem("crm_plantilla", plantillaMensaje);
      toast("💾 Plantilla guardada (Local)");
      return;
    }
    mostrarEstado("💾 Guardando plantilla...");
    const ok = await guardarPlantilla(plantillaMensaje);
    if (ok) { toast("💾 Plantilla guardada"); ocultarEstado(); }
    else { localStorage.setItem("crm_plantilla", plantillaMensaje); mostrarEstado("⚠️ Guardado localmente", 3000); }
  });

