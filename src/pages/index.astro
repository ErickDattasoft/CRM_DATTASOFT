    el("dash-tickets-pendientes").textContent = tickets.filter(t => t.estado === "Pendiente").length;
    el("dash-tickets-resueltos").textContent = tickets.filter(t => t.estado === "Resuelto").length;
    el("dash-tickets-cerrados").textContent = tickets.filter(t => t.estado === "Cerrado").length;

    // Sidebar badges
    el("badge-empresas").textContent = clientes.length;
