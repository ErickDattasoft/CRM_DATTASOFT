    clearCtSelection();
    row.classList.add("ct-selected");
    row.querySelectorAll("td").forEach((td, i) => {
      td.style.background = "rgba(34,211,238,0.22)";
      if (i === 0) {
        td.style.borderLeft = "4px solid #22d3ee";
        td.style.paddingLeft = "14px";
      }
