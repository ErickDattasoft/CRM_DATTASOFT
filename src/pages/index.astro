    (document.getElementById("kb-form-type") as HTMLSelectElement).value      = doc?.file_type || "md";
    (document.getElementById("kb-form-tags") as HTMLInputElement).value       = (doc?.tags || []).join(", ");
    (document.getElementById("kb-form-content") as HTMLTextAreaElement).value = doc?.content || "";
