      CONTACTO: "", CORREO: "", TELEFONO_1: "", TELEFONO_2: "",
      RFC: (document.getElementById("quick-emp-rfc") as HTMLInputElement).value.trim(),
      FAVORITO: false, CAMPOS_EXTRAS: {}, SISTEMAS: {}, VENCIMIENTOS: {}
    };
    clientes.push(nueva);
    if (crmLocalOnly) guardarLocal("crm_clientes", clientes);
    else await guardarClientes(clientes);
    document.getElementById("modal-empresa-rapida").style.display = "none";
