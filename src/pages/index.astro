  function prepararEdicionContacto(e) {
    const idx = parseInt(e.target.closest("button").dataset.idx);
    const c = contactos[idx];
    cerrarFormContacto();
    document.getElementById("form-ct-titulo").textContent = "✏️ Editar Contacto";
    editCtIdx.value = idx;
    document.getElementById("form-ct-nombre").value = c.nombre || "";
    document.getElementById("form-ct-correo").value = c.correo || "";
    document.getElementById("form-ct-tel1").value = c.telefono1 || "";
    document.getElementById("form-ct-tel2").value = c.telefono2 || "";
    setEmpresaContacto(c.empresa || "");
    formCt?.classList.remove("hidden");
  }

  document.getElementById("btnGuardarContacto")?.addEventListener("click", async () => {
    const idx = editCtIdx.value;
    const nombre = document.getElementById("form-ct-nombre").value.trim();
    if (!nombre) return alert("El nombre es obligatorio.");

    // Reconocer la empresa escrita contra las ya registradas (sin importar mayúsculas/minúsculas).
    // Si no existe ninguna igual, se crea automáticamente — igual que "🏢 Nueva empresa rápida" —
    // para que el contacto quede ligado a una empresa real y no a un texto suelto.
    let empresaTexto = document.getElementById("form-ct-empresa").value.trim();
    if (empresaTexto) {
      const empExistente = clientes.find((c: any) => (c.EMPRESA || "").toLowerCase() === empresaTexto.toLowerCase());
      if (empExistente) {
        empresaTexto = empExistente.EMPRESA;
      } else {
        empresaTexto = empresaTexto.toUpperCase();
        const nuevaEmp = {
          EMPRESA: empresaTexto,
          CONTACTO: "", CORREO: "", TELEFONO_1: "", TELEFONO_2: "",
          RFC: "", FAVORITO: false, CAMPOS_EXTRAS: {}, SISTEMAS: {}, VENCIMIENTOS: {}
        };
        clientes.push(nuevaEmp);
        if (crmLocalOnly) guardarLocal("crm_clientes", clientes); else await guardarClientes(clientes);
        logBitacora(`Empresa "${empresaTexto}" creada automáticamente al guardar contacto`, "🏢");
      }
    }

    const obj = {
      nombre,
      correo: document.getElementById("form-ct-correo").value.trim(),
      telefono1: document.getElementById("form-ct-tel1").value.trim(),
      telefono2: document.getElementById("form-ct-tel2").value.trim(),
      empresa: empresaTexto
    };

    const isEditCt = idx !== "";
    if (!isEditCt) contactos.push(obj);
    else contactos[parseInt(idx)] = obj;

    logBitacora(`Contacto "${nombre}"${obj.empresa ? ` (${obj.empresa})` : ""} ${isEditCt ? "actualizado" : "creado"}`, "👤");
    // Sincronizar empresa con los datos del contacto (mantiene CONTACTO/CORREO/TELEFONO_1 actualizados)
    if (obj.empresa) sincronizarEmpresaDesdeContactos(obj.empresa);
    guardarLocal("crm_contactos", contactos);
    if (crmLocalOnly) {
      toast("💾 Contacto guardado (Local)");
      cerrarFormContacto();
      renderContactos();
      renderEmpresas();
      renderDashboard();
      return;
    }
    mostrarEstado("💾 Guardando contacto...");
    const ok = await guardarContactos(contactos);
    if (ok) { toast("💾 Contacto guardado"); ocultarEstado(); }
    else { mostrarEstado("⚠️ Guardado localmente (sin conexión)", 3000); }
    cerrarFormContacto();
    renderContactos();
    renderEmpresas();
    renderDashboard();
  });

  async function eliminarContacto(e) {
    const idx = parseInt(e.target.closest("button").dataset.idx);
    if (!await confirmar("¿Eliminar este contacto?", "🗑️")) return;
    const ct = contactos[idx];
    const nombreCt = ct?.nombre || "desconocido";
    const empresaCt = ct?.empresa || "";
    contactos.splice(idx, 1);
    logBitacora(`Contacto "${nombreCt}"${empresaCt ? ` (${empresaCt})` : ""} eliminado`, "🗑️");
    if (empresaCt) sincronizarEmpresaDesdeContactos(empresaCt);
    guardarLocal("crm_contactos", contactos);
    if (crmLocalOnly) {
      toast("🗑️ Contacto eliminado (Local)");
      renderContactos();
      renderEmpresas();
      renderDashboard();
      return;
    }
    await guardarContactos(contactos);
    renderContactos();
    renderEmpresas();
    renderDashboard();
  }

