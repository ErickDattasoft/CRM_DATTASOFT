  async function kbSetupTransferencia_disabled() { // eliminado — sin Firebase Storage
    return;
    let transferList: any[] = [];

    const modal    = document.getElementById("kb-transfer-modal");
    const btnAbrir = document.getElementById("kb-btn-transferir");
    const btnCerr  = document.getElementById("kb-transfer-close");
    const input    = document.getElementById("kb-transfer-input") as HTMLInputElement;
    const drop     = document.getElementById("kb-transfer-drop");
    const progWrap = document.getElementById("kb-transfer-progress");
    const progBar  = document.getElementById("kb-transfer-bar");
    const progPct  = document.getElementById("kb-transfer-pct");
    const progSts  = document.getElementById("kb-transfer-status");
    const result   = document.getElementById("kb-transfer-result");
    const urlInput = document.getElementById("kb-transfer-url") as HTMLInputElement;
    const listEl   = document.getElementById("kb-transfer-list");

    const showModal  = () => { if (modal) modal.style.display = "flex"; };
