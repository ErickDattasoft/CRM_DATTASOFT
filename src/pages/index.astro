    drawerEmpresaActual = null;
  }

  function cambiarTabDrawer(tab) {
    document.querySelectorAll(".drawer-tab").forEach(t => t.classList.toggle("active", t.dataset.drawerTab === tab));
    document.getElementById("drawer-panel-historial").style.display = tab === "historial" ? "" : "none";
