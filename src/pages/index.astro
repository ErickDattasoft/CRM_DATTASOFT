  function inicializarApp() {
    // Limpiar listener previo si existe (ej. al cambiar modo local/online)
    if (unsubscribeCRM) { unsubscribeCRM(); unsubscribeCRM = null; }
    primeraCargaFB = true;

    if (crmLocalOnly) {
      cargarDesdeLocalStorage("📡 Modo Local Activo. Cargando desde Local Storage...");
      return;
    }
    if (!firebaseEnabled) {
      mostrarEstado("⚠️ Firebase no configurado. Usando Local Storage.", 3000);
      cargarDesdeLocalStorage();
      return;
    }

    mostrarEstado("🔄 Conectando a Firebase...");

    // Pre-cargar caché de localStorage mientras llega Firebase, para que el
    // autocomplete y la UI respondan inmediatamente sin esperar la red.
    {
      const _lc = safeParseLocal("crm_clientes", []);
      const _lcont = safeParseLocal("crm_contactos", []);
      const _lt = safeParseLocal("crm_tickets", []);
      if (_lc.length > 0) { clientes = _lc; renderEmpresas(); renderDashboard(); }
      if (_lcont.length > 0) { contactos = _lcont; }
      if (_lt.length > 0) { tickets = _lt; }
    }

    // Timeout de seguridad solo para la primera carga
    const timeoutInicial = setTimeout(() => {
      if (primeraCargaFB) {
        primeraCargaFB = false;
        console.error("[CRM] Firebase: timeout en carga inicial");
        mostrarEstado("⚠️ Error de conexión a Firebase. Reintentando en la próxima carga.", 4000);
        cargarDesdeLocalStorage();
      }
    }, 7000);

    unsubscribeCRM = suscribirCRM(async (datos, hasPendingWrites) => {
      try {
        if (primeraCargaFB) {
          // ── PRIMERA CARGA ─────────────────────────────────────────────
          clearTimeout(timeoutInicial);
          primeraCargaFB = false;

          if (datos) {
            aplicarDatosFirebase(datos);

            // Si Firebase no tiene versiones/cartas/eventos, recuperar del caché local
            // para no perder datos que sólo existían en localStorage
            if (datos.versionesMercado === undefined) {
              const localV = safeParseLocal("crm_versiones", null);
              if (localV && Object.values(localV).some((v: any) => v)) {
                versionesMercado = localV;
                guardarConfiguracion(versionesMercado, cartasTecnicas); // subir a Firebase
              }
            }
            if (datos.cartasTecnicas === undefined) {
              const localC = safeParseLocal("crm_cartas", null);
              if (localC && Object.values(localC).some((v: any) => v)) cartasTecnicas = localC;
            }
            if ((datos.eventos === undefined || datos.eventos === null || datos.eventos.length === 0)) {
              const localEv = safeParseLocal("crm_eventos", null);
              if (localEv && localEv.length > 0 && localEv.length > eventos.length) {
                eventos = localEv;
                guardarEventosFB(eventos); // subir a Firebase
              }
            }
            // Si Firebase no tiene clientes/contactos/tickets, recuperar del caché local
            if ((datos.clientes === undefined || datos.clientes.length === 0) && clientes.length === 0) {
              const localCl = safeParseLocal("crm_clientes", null);
              if (localCl && localCl.length > 0) {
                clientes = localCl;
                guardarClientes(clientes); // subir a Firebase
              }
            }
            if ((datos.contactos === undefined || datos.contactos.length === 0) && contactos.length === 0) {
              const localCo = safeParseLocal("crm_contactos", null);
              if (localCo && localCo.length > 0) {
                contactos = localCo;
                guardarContactos(contactos);
              }
            }
            if ((datos.tickets === undefined || datos.tickets.length === 0) && tickets.length === 0) {
              const localTk = safeParseLocal("crm_tickets", null);
              if (localTk && localTk.length > 0) {
                tickets = localTk;
                guardarTickets(tickets);
              }
            }

            // Carga inicial de bitácora: fusionar Firebase + entradas locales aún no confirmadas.
            fusionarBitacoraFirebase(datos.bitacora);
            // Respaldo en localStorage (caché para offline) — solo si hay datos reales
            if (clientes.length > 0) guardarLocal("crm_clientes", clientes);
            if (contactos.length > 0) guardarLocal("crm_contactos", contactos);
            if (tickets.length > 0) guardarLocal("crm_tickets", tickets);
            // Solo actualizar caché local de versiones/cartas si Firebase tiene datos reales
            if (Object.values(versionesMercado).some((v: any) => v)) guardarLocal("crm_versiones", versionesMercado);
            if (Object.values(cartasTecnicas).some((v: any) => v)) guardarLocal("crm_cartas", cartasTecnicas);
            if (eventos.length > 0) guardarLocal("crm_eventos", eventos);
            if (plantillaMensaje) localStorage.setItem("crm_plantilla", plantillaMensaje);
            console.log("[CRM] Firebase cargado: clientes=", clientes.length, "contactos=", contactos.length);
            mostrarEstado(`🔌 Cargados ${clientes.length} empresas desde Firebase`, 2500);
          } else {
            // Firebase vacío — migrar desde respaldo local si existe
            const localClientes = safeParseLocal("crm_clientes", null);
            const localContactos = safeParseLocal("crm_contactos", null);
            const localTickets = safeParseLocal("crm_tickets", null);
            if (localClientes && localClientes.length > 0) {
              mostrarEstado("📦 Restaurando datos desde respaldo local...");
              clientes = localClientes;
              contactos = localContactos || [];
              tickets = localTickets || [];
              versionesMercado = safeParseLocal("crm_versiones", {});
              cartasTecnicas = safeParseLocal("crm_cartas", {});
              plantillaMensaje = localStorage.getItem("crm_plantilla") || plantillaMensaje;
              await guardarClientes(clientes);
              await guardarContactos(contactos);
              await guardarTickets(tickets);
              await guardarConfiguracion(versionesMercado, cartasTecnicas);
              await guardarPlantilla(plantillaMensaje);
              mostrarEstado(`✅ ${clientes.length} empresas restauradas de respaldo local`, 3000);
            } else {
              clientes = []; contactos = []; tickets = [];
              mostrarEstado("⚠️ Firebase vacío y sin respaldo local. Ve a Configuración → Importar datos.", 6000);
            }
          }

          listaSistemas.forEach(s => {
            const k = s.toUpperCase().trim();
            if (versionesMercado[k] === undefined) versionesMercado[k] = "";
            if (cartasTecnicas[k] === undefined) cartasTecnicas[k] = "";
          });
          document.getElementById("txtPlantillaMensaje").value = plantillaMensaje;
          initMarketForms();
          renderDashboard();
          renderEmpresas();
          renderContactos();
          renderConfig();
          ocultarEstado();
          initStickyHeaders();
          checkLicenciasPorVencer();
          aplicarPermisosNavegacion();
          sincronizarConfigPublica();
          actualizarBadgeCuentaSegura();

        } else {
          // ── ACTUALIZACIÓN REMOTA (otro dispositivo guardó algo) ───────
          if (hasPendingWrites) return; // Escritura propia aún pendiente, ignorar

          const enConfiguracion = document.querySelector(".nav-item.active")?.dataset.section === "configuracion";
          aplicarDatosFirebase(datos, enConfiguracion);
          // Bitácora se fusiona aparte (no dentro de aplicarDatosFirebase): arrayUnion ya
          // garantiza que el servidor nunca pierde entradas, así que es seguro traer la
          // actividad de otros usuarios/dispositivos sin esperar a un refresh manual.
          fusionarBitacoraFirebase(datos.bitacora);

          if (hayFormularioActivo()) return; // Form abierto: datos listos en memoria, UI se actualiza al cerrar
          if (enConfiguracion) return; // Edición de config en progreso: no sobreescribir UI

          renderCompleto();
        }
      } catch (err) {
        if (primeraCargaFB) {
          primeraCargaFB = false;
          console.error("[CRM] Error en carga inicial Firebase:", err);
          mostrarEstado("⚠️ Error de conexión a Firebase. Reintentando en la próxima carga.", 4000);
          cargarDesdeLocalStorage();
        }
      }
    }, (error) => {
      // Antes esto solo se veía en la consola del navegador — quien entrara con una sesión sin
      // permiso (ej. anónima, después de apretar las reglas de Firestore) se quedaba viendo la
      // app rota o vacía sin ninguna explicación. Ahora se le manda directo al login seguro.
      if (error?.code === "permission-denied") {
        primeraCargaFB = false;
        clearTimeout(timeoutInicial);
        ocultarEstado();
        document.getElementById("login-overlay")?.classList.remove("hidden");
        const stepUser = document.getElementById("login-step-user");
        const stepPass = document.getElementById("login-step-pass");
        const stepSeguro = document.getElementById("login-step-securo");
        if (stepUser) stepUser.style.display = "none";
        if (stepPass) stepPass.style.display = "none";
        if (stepSeguro) stepSeguro.style.display = "block";
        const errEl = document.getElementById("login-securo-error");
        if (errEl) errEl.textContent = "Tu sesión no tiene permiso para ver los datos del CRM — inicia sesión con tu cuenta segura.";
      }
    });
  }

  async function guardarLocal(key, data) {
    try { localStorage.setItem(key, JSON.stringify(data)); } catch(e) {}
  }

  // ============================================================
  // PERMISOS DE NAVEGACIÓN
  // ============================================================
  // true si el usuario en sesión puede ver `sectionId`. Los admins siempre ven todo (para que
  // nunca se puedan bloquear ellos mismos por accidente). Un usuario "normal" sin
  // seccionesPermitidas configurado también ve todo — es el default de compatibilidad para no
  // quitarle acceso a nadie el día que esta función se activó. Secciones fuera de
  // SECCIONES_CONFIGURABLES (dashboard, bitácora, knowledge) no se filtran aquí — tienen su
  // propia regla aparte.
  function tieneAccesoSeccion(sectionId) {
    if (!SECCIONES_CONFIGURABLES.some(s => s.id === sectionId)) return true;
    const u = getUsuarioActual();
    if (!u) return false;
    if (u.rol === "admin") return true;
    const permitidas = getUsuarios().find(x => x.nombre === u.nombre)?.seccionesPermitidas;
    if (!permitidas || !Array.isArray(permitidas)) return true;
    return permitidas.includes(sectionId);
  }

  function aplicarPermisosNavegacion() {
    const u = getUsuarioActual();
    const esAdmin = u?.rol === "admin";
    const navBitacora = document.getElementById("nav-item-bitacora");
    if (navBitacora) navBitacora.style.display = esAdmin ? "" : "none";
    // Importar JSON solo para admins — puede sobreescribir datos
    const btnImport = document.getElementById("btnImportarJSON") as HTMLButtonElement | null;
    if (btnImport) btnImport.style.display = esAdmin ? "" : "none";
    // Oculta del sidebar las secciones que el admin restringió para este usuario (Configuración
    // → Usuarios). Solo aplica a "normal" — tieneAccesoSeccion ya deja pasar todo a los admins.
    SECCIONES_CONFIGURABLES.forEach(s => {
      const nav = document.querySelector(`.nav-item[data-section="${s.id}"]`) as HTMLElement | null;
      if (nav) nav.style.display = tieneAccesoSeccion(s.id) ? "" : "none";
    });
    // Solicitar permiso de notificaciones del navegador
    if (esAdmin && "Notification" in window && Notification.permission === "default") {
      Notification.requestPermission();
    }
  }

  // ============================================================
  // BITÁCORA
  // ============================================================
  // Fusiona el array de bitácora de Firestore con entradas locales aún no confirmadas por el
  // servidor (mismo criterio que usa logBitacora: 60 días de retención). Se usa tanto en la
  // carga inicial de la app como en el botón "🔄 Actualizar" del panel de Bitácora — la vista ya
  // abierta nunca vuelve a sincronizar esto sola (ver nota en el listener de suscribirCRM), así
  // que sin un refresco manual un admin con la pestaña abierta no ve lo que otros usuarios
  // registran después.
  function fusionarBitacoraFirebase(bitacoraFB) {
    if (!bitacoraFB || !bitacoraFB.length) return;
    const fechasFB = new Set(bitacoraFB.map(e => e.fecha));
    const localExtras = bitacoraLog.filter(e => !fechasFB.has(e.fecha));
    const limite60Carga = new Date();
    limite60Carga.setDate(limite60Carga.getDate() - 60);
    const fusionSinFiltrar = [...localExtras, ...bitacoraFB];
    bitacoraLog = fusionSinFiltrar
      .filter(e => new Date(e.fecha) >= limite60Carga)
      .sort((a, b) => new Date(b.fecha).getTime() - new Date(a.fecha).getTime());
    guardarLocal("crm_bitacora", bitacoraLog);
    // Si el filtro recortó algo (documento viejo con entradas de +60 días), reflejarlo
    // también en Firestore para que el documento compartido no siga creciendo de más.
    if (bitacoraLog.length < fusionSinFiltrar.length && firebaseEnabled && !crmLocalOnly) {
      guardarBitacora(bitacoraLog).catch(err => console.error("[Bitácora] Error al recortar en Firebase:", err));
    }
  }

  function logBitacora(msg, icon = "📌") {
    const u = getUsuarioActual();
    const entry = { fecha: new Date().toISOString(), msg, icon, usuario: u?.nombre || "Sistema" };
    bitacoraLog.unshift(entry);
    const limite60 = new Date();
    limite60.setDate(limite60.getDate() - 60);
    bitacoraLog = bitacoraLog.filter(e => new Date(e.fecha) >= limite60);
    guardarLocal("crm_bitacora", bitacoraLog);
    // agregarEntradaBitacora() agrega solo esta entrada (arrayUnion, atómico en el servidor) en
    // vez de mandar bitacoraLog completo: como la vista de Bitácora de una pestaña ya abierta no
    // se resincroniza sola con Firestore (ver fusionarBitacoraFirebase), dos usuarios activos al
    // mismo tiempo tenían cada uno una copia desactualizada del arreglo — quien guardaba al
    // final borraba silenciosamente la entrada que el otro acababa de registrar.
    if (firebaseEnabled) agregarEntradaBitacora(entry).catch(err => console.error("[Bitácora] Error al guardar en Firebase:", err));
  }

  // Listener para el evento de login (cruzar scope IIFE ↔ auth)
  document.addEventListener("crm:login", () => {
    aplicarPermisosNavegacion();
    logBitacora("Sesión iniciada", "🔐");
    initKB();
    actualizarBadgeCuentaSegura();
    revisarSesionAnonima();
  }, { once: false });

  // El login viejo (usuario+contraseña local) solo controla la entrada a la UI — no toca la
  // sesión real de Firebase Auth. Cada navegador/dispositivo mantiene su propia sesión de Auth
  // por separado, así que un dispositivo donde nunca se inició sesión con la cuenta segura sigue
  // siendo anónimo ahí aunque el login viejo "funcione". Las reglas de Firestore rechazan
  // escrituras anónimas, así que sin este aviso el usuario solo veía fallar guardados uno por
  // uno (bitácora, tickets, clientes...) sin entender por qué.
  function revisarSesionAnonima() {
    const banner = document.getElementById("banner-sesion-anonima");
    if (!banner) return;
    if (!firebaseEnabled || !sesionEsAnonima()) { banner.style.display = "none"; return; }
    const u = getUsuarioActual();
    if (!u) { banner.style.display = "none"; return; }
    const registro = getUsuarios().find((x: any) => x.nombre === u.nombre);
    const msgEl = document.getElementById("banner-sesion-anonima-msg")!;
    const btnAccion = document.getElementById("btn-banner-sesion-anonima-accion") as HTMLButtonElement;
    if (registro?.authEmail) {
      msgEl.textContent = "Este dispositivo no tiene tu sesión segura activa — por seguridad se inicia por separado en cada equipo. Mientras tanto, lo que hagas aquí no se guardará.";
      btnAccion.textContent = "Iniciar sesión segura →";
      btnAccion.onclick = () => {
        document.getElementById("login-overlay")?.classList.remove("hidden");
        document.getElementById("login-step-user")!.style.display = "none";
        document.getElementById("login-step-pass")!.style.display = "none";
        document.getElementById("login-step-securo")!.style.display = "block";
        const correoInp = document.getElementById("login-securo-correo") as HTMLInputElement;
        if (correoInp) correoInp.value = registro.authEmail;
        const passInp = document.getElementById("login-securo-pass") as HTMLInputElement;
        if (passInp) { passInp.value = ""; passInp.focus(); }
      };
    } else {
      msgEl.textContent = "Este dispositivo necesita activar tu cuenta segura (correo+contraseña) para poder guardar cambios — por seguridad se activa por separado en cada equipo.";
      btnAccion.textContent = "🔒 Activar ahora";
      btnAccion.onclick = () => abrirModalCuentaSegura();
    }
    banner.style.display = "flex";
  }
  // Sin botón de cerrar a propósito: mientras la sesión siga siendo anónima en este dispositivo,
  // nada de lo que se haga se guarda de verdad — el banner solo desaparece solo cuando
  // revisarSesionAnonima() detecta que ya hay una sesión segura real (tras iniciarSesionSegura()).

  // ============================================================
  // CUENTA SEGURA (paso 1 de migración a autenticación real — ver plan)
  // Cada usuario activa su propia cuenta de correo/contraseña real de Firebase sin necesitar
  // confirmar por correo (ya demostró quién es al entrar con el login de siempre). El login
  // viejo sigue funcionando igual mientras el equipo migra a su propio ritmo.
  // ============================================================
  function actualizarBadgeCuentaSegura() {
    const u = getUsuarioActual();
    const badge = document.getElementById("badge-cuenta-segura");
    if (!badge || !u) return;
    const registro = getUsuarios().find((x: any) => x.nombre === u.nombre);
    badge.style.display = registro?.authEmail ? "none" : "inline-flex";
  }

  // Si se abre desde el sidebar (self-service), el objetivo es quien está logueado.
  // Si se abre desde Configuración → Usuarios para otra persona, cuentaSeguraObjetivo trae su nombre.
  let cuentaSeguraObjetivo: string | null = null;

  function abrirModalCuentaSegura(nombreObjetivo?: string) {
    const modal = document.getElementById("modal-cuenta-segura");
    const u = getUsuarioActual();
    cuentaSeguraObjetivo = nombreObjetivo || u?.nombre || null;
    const esParaOtro = cuentaSeguraObjetivo !== u?.nombre;
    const registro = getUsuarios().find((x: any) => x.nombre === cuentaSeguraObjetivo);
    const yaActiva = document.getElementById("cuenta-segura-ya-activa");
    const formWrap = document.getElementById("cuenta-segura-form-wrap");
    const errEl = document.getElementById("cuenta-segura-error");
    const titulo = document.querySelector("#modal-cuenta-segura .modal-header h2");
    if (titulo) titulo.textContent = esParaOtro ? `🔒 Activar cuenta segura — ${cuentaSeguraObjetivo}` : "🔒 Activar inicio de sesión seguro";
    if (errEl) { errEl.style.display = "none"; errEl.textContent = ""; }
    if (registro?.authEmail) {
      if (yaActiva) yaActiva.style.display = "block";
      const spanCorreo = document.getElementById("cuenta-segura-correo-activo");
      if (spanCorreo) spanCorreo.textContent = registro.authEmail;
      if (formWrap) formWrap.style.display = "none";
    } else {
      if (yaActiva) yaActiva.style.display = "none";
      if (formWrap) formWrap.style.display = "block";
      (document.getElementById("cs-correo") as HTMLInputElement).value = "";
      (document.getElementById("cs-pass1") as HTMLInputElement).value = "";
      (document.getElementById("cs-pass2") as HTMLInputElement).value = "";
    }
    if (modal) modal.style.display = "flex";
  }

  document.getElementById("btnCuentaSegura")?.addEventListener("click", () => abrirModalCuentaSegura());
  document.getElementById("btnCerrarCuentaSegura")?.addEventListener("click", () => {
    const m = document.getElementById("modal-cuenta-segura"); if (m) m.style.display = "none";
  });
  document.getElementById("btnCancelarCuentaSegura")?.addEventListener("click", () => {
    const m = document.getElementById("modal-cuenta-segura"); if (m) m.style.display = "none";
  });

  document.getElementById("btnActivarCuentaSegura")?.addEventListener("click", async () => {
    const errEl = document.getElementById("cuenta-segura-error") as HTMLElement;
    const correo = (document.getElementById("cs-correo") as HTMLInputElement).value.trim().toLowerCase();
    const pass1 = (document.getElementById("cs-pass1") as HTMLInputElement).value;
    const pass2 = (document.getElementById("cs-pass2") as HTMLInputElement).value;
    errEl.style.display = "none"; errEl.textContent = "";

    if (!correo || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(correo)) {
      errEl.textContent = "Ingresa un correo válido."; errEl.style.display = "block"; return;
    }
    if (pass1.length < 6) {
      errEl.textContent = "La contraseña debe tener al menos 6 caracteres."; errEl.style.display = "block"; return;
    }
    if (pass1 !== pass2) {
      errEl.textContent = "Las contraseñas no coinciden."; errEl.style.display = "block"; return;
    }

    const uSesion = getUsuarioActual();
    const esParaOtro = cuentaSeguraObjetivo !== uSesion?.nombre;

    const btn = document.getElementById("btnActivarCuentaSegura") as HTMLButtonElement;
    btn.disabled = true; btn.textContent = "Activando...";
    // permanecer=false cuando un admin la activa para otra persona: restaura la sesión anónima
    // después de crearla, para no dejar al admin "metido" con la identidad de otra persona.
    const res = await activarCuentaSegura(correo, pass1, !esParaOtro);
    btn.disabled = false; btn.textContent = "🔒 Activar";

    if (!res.ok) {
      errEl.textContent = res.mensaje || "No se pudo activar."; errEl.style.display = "block";
      return;
    }

    const usuariosAct = getUsuarios();
    const idx = usuariosAct.findIndex((x: any) => x.nombre === cuentaSeguraObjetivo);
    if (idx !== -1) {
      usuariosAct[idx].authEmail = correo;
      saveUsuariosLocal(usuariosAct);
      guardarUsuarios(usuariosAct).catch(() => {});
    }
    actualizarBadgeCuentaSegura();
    if (typeof renderUsuariosPanel === "function") renderUsuariosPanel();
    const m = document.getElementById("modal-cuenta-segura"); if (m) m.style.display = "none";
    toast(esParaOtro ? `🔒 Cuenta segura activada para ${cuentaSeguraObjetivo}` : "🔒 Cuenta segura activada correctamente");
    logBitacora(`Cuenta segura activada${esParaOtro ? ` para ${cuentaSeguraObjetivo}` : ""} (${correo})`, "🔒");
  });

  // Aviso centralizado cuando un guardado a Firestore falla — varias funciones guardarX()
  // devuelven solo `false`/`undefined` y no todos los call sites revisan el resultado, así que
  // sin esto el usuario podía ver "guardado" en pantalla aunque el escrito real fallara.
  document.addEventListener("crm:write-error", (e: Event) => {
    const { operacion, mensaje } = (e as CustomEvent).detail || {};
    toast(`⚠️ No se pudo guardar "${operacion}" en Firebase — ${mensaje || "sin conexión"}`, "error");
  });

  function renderBitacora() {
    const cont = document.getElementById("bitacora-list");
    if (!cont) return;
    const u = getUsuarioActual();
    if (!u || u.rol !== "admin") {
      cont.innerHTML = '<div style="text-align:center; color:var(--text-muted); padding:24px; font-size:0.85rem;">🔒 Acceso restringido a administradores.</div>';
      return;
    }
    if (!bitacoraLog.length) {
      cont.innerHTML = '<div style="text-align:center; color:var(--text-muted); padding:24px; font-size:0.85rem;">Sin actividad registrada.</div>';
      return;
    }
    const desde = (document.getElementById("bit-filtro-desde") as HTMLInputElement)?.value || "";
    const hasta = (document.getElementById("bit-filtro-hasta") as HTMLInputElement)?.value || "";
    let entradas = bitacoraLog;
    if (desde) entradas = entradas.filter(e => e.fecha && e.fecha.slice(0, 10) >= desde);
    if (hasta) entradas = entradas.filter(e => e.fecha && e.fecha.slice(0, 10) <= hasta);
    if (!entradas.length) {
      cont.innerHTML = '<div style="text-align:center; color:var(--text-muted); padding:24px; font-size:0.85rem;">Sin resultados en ese rango de fechas.</div>';
      return;
    }
    const hoy = new Date().getFullYear();
    cont.innerHTML = entradas.map(e => {
      const d = new Date(e.fecha);
      const opts = d.getFullYear() !== hoy
        ? { day:'2-digit', month:'2-digit', year:'2-digit', hour:'2-digit', minute:'2-digit' }
        : { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' };
      return `
      <div class="bitacora-entry">
        <span class="bitacora-time">${d.toLocaleString('es-MX', opts)}</span>
        ${e.usuario ? `<span style="font-size:0.68rem; color:#818cf8; font-weight:700; background:rgba(99,102,241,0.12); padding:1px 6px; border-radius:3px; white-space:nowrap; flex-shrink:0;">${e.usuario}</span>` : ""}
        <span class="bitacora-msg">${e.icon} ${e.msg}</span>
      </div>`;
    }).join("");
  }

  document.getElementById("btnActualizarBitacora")?.addEventListener("click", async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    if (crmLocalOnly || !firebaseEnabled) { toast("⚠️ No aplica en Modo Local", "warning"); return; }
    btn.disabled = true;
    const textoOriginal = btn.textContent;
    btn.textContent = "Actualizando...";
    try {
      const datos = await cargarDatosCRM();
      fusionarBitacoraFirebase(datos?.bitacora);
      renderBitacora();
      toast("🔄 Bitácora actualizada");
    } catch {
      toast("⚠️ No se pudo actualizar — revisa tu conexión", "error");
    } finally {
      btn.disabled = false;
      btn.textContent = textoOriginal;
    }
  });

  document.getElementById("btnLimpiarBitacora")?.addEventListener("click", async () => {
    if (!await confirmar("¿Limpiar toda la bitácora?", "🗑️")) return;
    bitacoraLog = [];
    guardarLocal("crm_bitacora", []);
    if (firebaseEnabled) guardarBitacora(bitacoraLog).catch(() => {});
    renderBitacora();
  });

  document.getElementById("bit-filtro-desde")?.addEventListener("change", renderBitacora);
  document.getElementById("bit-filtro-hasta")?.addEventListener("change", renderBitacora);
  document.getElementById("btnLimpiarFiltroBitacora")?.addEventListener("click", () => {
    (document.getElementById("bit-filtro-desde") as HTMLInputElement).value = "";
    (document.getElementById("bit-filtro-hasta") as HTMLInputElement).value = "";
    renderBitacora();
  });

  // ============================================================
  // MODO OSCURO / CLARO
  // ============================================================
  function aplicarTema() {
    const isLight = localStorage.getItem("crm_tema") === "light";
    document.body.classList.toggle("light-mode", isLight);
    const btnToggle = document.getElementById("btnToggleDarkMode");
    const btnTema = document.getElementById("btnToggleTema");
    if (btnToggle) btnToggle.textContent = isLight ? "☀️" : "🌙";
    if (btnTema) btnTema.textContent = isLight ? "☀️ Modo Claro (activo)" : "🌙 Modo Oscuro (activo)";
  }

  function toggleTema() {
    const isLight = localStorage.getItem("crm_tema") === "light";
    localStorage.setItem("crm_tema", isLight ? "dark" : "light");
    aplicarTema();
    logBitacora(`Tema cambiado a ${isLight ? "oscuro" : "claro"}`, "🎨");
  }

  document.getElementById("btnToggleDarkMode")?.addEventListener("click", toggleTema);
  document.getElementById("btnToggleTema")?.addEventListener("click", toggleTema);
  aplicarTema();

  // ============================================================
  // MODAL ACERCA DE
  // ============================================================
  function cargarDatosAcercaDe() {
    const version = acercaDe.version || "v3.0.0";
    const fecha = acercaDe.fecha || "Junio 2026";
    const notas = acercaDe.notas || "";
    const vTxt = document.getElementById("acerca-version-txt");
