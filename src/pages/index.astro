  document.getElementById("btnGuardarTicket")?.addEventListener("click", async () => {
    const idx = editTkIdx.value;
    const contacto = document.getElementById("form-tk-contacto").value.trim();
    const contactoCorreo = document.getElementById("form-tk-correo-contacto").value.trim();
    const empresa = document.getElementById("form-tk-empresa").value.trim();
    const asunto = document.getElementById("form-tk-asunto").value.trim();
    const tipo = document.getElementById("form-tk-tipo").value;
    const estado = document.getElementById("form-tk-estado").value;
    const prioridad = document.getElementById("form-tk-prioridad").value;
    const grupo = document.getElementById("form-tk-grupo").value;
    const agente = document.getElementById("form-tk-agente").value;
    const descripcion = document.getElementById("form-tk-descripcion").innerHTML.trim();
    const cc = document.getElementById("form-tk-cc").value.trim();
    const cco = document.getElementById("form-tk-cco").value.trim();
    const referido = document.getElementById("form-tk-referido")?.value.trim() || "";
    const solicitado = document.getElementById("form-tk-solicitado")?.value.trim() || "";
    const canalizado = document.getElementById("form-tk-canalizado")?.value.trim() || "";
    const realizado = document.getElementById("form-tk-realizado")?.value.trim() || "";
    const notasInternas = document.getElementById("form-tk-notas-internas")?.value.trim() || "";

    if (!contacto || !asunto || !descripcion) {
      alert("Por favor rellena los campos obligatorios: Contacto, Asunto, Descripción.");
      return;
    }

    if (idx === "") {
      const num = tickets.length > 0 ? Math.max(...tickets.map(t => t.numero)) + 1 : 1001;
      tickets.push({
        numero: num, asunto, empresa, contacto, contactoCorreo, tipo, estado, prioridad, grupo, agente,
        descripcion, notasInternas, cc, cco, referido, solicitado, canalizado, realizado,
        adjuntos: [...adjuntosTicketActual],
        fechaCreacion: new Date().toISOString(),
        fechaActualizacion: new Date().toISOString(),
        notas: []
      });
      logBitacora(`Ticket #${num} creado: "${asunto}" — ${empresa || contacto}`, "🎫");

      const enviarCorreo = document.getElementById("chk-enviar-correo")?.checked;
      const mailTo = contactoCorreo || contactos.find(c => c.nombre === contacto)?.correo || "";
      if (enviarCorreo && mailTo) {
        const mailCC = [configTickets.correoSoporte || "", cc].filter(Boolean).join(",");
        const mailSubject = `[Ticket #${num}] ${asunto}`;
        const htmlTicket = `
          <h2 style="color:#4f46e5; font-family:sans-serif;">[Ticket #${num}] ${asunto}</h2>
          <table style="border-collapse:collapse; width:100%; font-family:sans-serif; font-size:14px;">
            <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6; width:130px;">Empresa</td><td style="padding:6px 12px;">${empresa}</td></tr>
            <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6;">Contacto</td><td style="padding:6px 12px;">${contacto}</td></tr>
            <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6;">Tipo</td><td style="padding:6px 12px;">${tipo}</td></tr>
            <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6;">Prioridad</td><td style="padding:6px 12px;">${prioridad}</td></tr>
            <tr><td style="padding:6px 12px; font-weight:bold; background:#f3f4f6;">Estado</td><td style="padding:6px 12px;">${estado}</td></tr>
          </table>
          <h3 style="margin-top:16px; font-family:sans-serif;">Descripción</h3>
          <div style="background:#f9fafb; padding:12px; border-radius:6px; font-family:sans-serif; white-space:pre-wrap;">${descripcion.replace(/<[^>]*>/g, "")}</div>
          <hr style="margin-top:24px; border:none; border-top:1px solid #e5e7eb;">
          <p style="font-size:12px; color:#6b7280; font-family:sans-serif;">DATTASOFT BY INFOXPERT — Sistema de Tickets</p>
        `;
        const sent = await enviarEmailConProveedor({ to: mailTo, subject: mailSubject, html: htmlTicket, replyTo: mailCC || "" });
        if (sent?.ok) { toast(`✉️ Notificación enviada a ${mailTo}`); logBitacora(`✉️ Correo enviado a ${mailTo} — Ticket #${num}`, "📧"); }
        else toast(`⚠️ No se pudo enviar: ${sent?.error || "error desconocido"}`, 5000);
      } else if (enviarCorreo && !mailTo) {
        toast("⚠️ El contacto no tiene correo registrado", 4000);
      }
    } else {
      const t = tickets[parseInt(idx)];
      const adjuntosExistentes = t.adjuntos || [];
      Object.assign(t, { asunto, empresa, contacto, contactoCorreo, tipo, estado, prioridad, grupo, agente,
        descripcion, notasInternas, cc, cco, referido, solicitado, canalizado, realizado,
        adjuntos: [...adjuntosExistentes, ...adjuntosTicketActual],
        fechaActualizacion: new Date().toISOString() });
      logBitacora(`Ticket #${t.numero} "${t.asunto}" actualizado a ${estado}${prioridad ? ` · ${prioridad}` : ""}`, "✏️");
    }

    guardarLocal("crm_tickets", tickets);
    if (crmLocalOnly) {
      toast("💾 Ticket guardado (Local)");
      cerrarFormTicket();
      renderTickets();
      renderDashboard();
      return;
    }
    mostrarEstado("💾 Guardando ticket...");
    const ok = await guardarTickets(tickets);
    if (ok) { toast("💾 Ticket guardado"); ocultarEstado(); }
    else { mostrarEstado("⚠️ Guardado localmente (sin conexión)", 3000); }
    cerrarFormTicket();
    renderTickets();
    renderDashboard();
  });

  function prepararEdicionTicket(e) {
    const idx = parseInt(e.target.closest("button").dataset.idx);
    const t = tickets[idx];
    cerrarFormTicket();
    document.getElementById("form-tk-titulo").textContent = "✏️ Editar Ticket";
    editTkIdx.value = idx;
    document.getElementById("form-tk-contacto").value = t.contacto || "";
    document.getElementById("form-tk-correo-contacto").value = t.contactoCorreo || "";
    document.getElementById("form-tk-empresa").value = t.empresa || "";
    document.getElementById("form-tk-asunto").value = t.asunto;
    document.getElementById("form-tk-descripcion").innerHTML = t.descripcion || "";
    document.getElementById("form-tk-cc").value = t.cc || "";
    document.getElementById("form-tk-cco").value = t.cco || "";
    const fRef = document.getElementById("form-tk-referido"); if (fRef) fRef.value = t.referido || "";
    const fSol = document.getElementById("form-tk-solicitado"); if (fSol) fSol.value = t.solicitado || "";
    const fCan = document.getElementById("form-tk-canalizado"); if (fCan) fCan.value = t.canalizado || "";
    const fRea = document.getElementById("form-tk-realizado"); if (fRea) fRea.value = t.realizado || "";
    const fNI = document.getElementById("form-tk-notas-internas"); if (fNI) fNI.value = t.notasInternas || "";
    initTicketFormDropdowns(t);
    formTk?.classList.remove("hidden");
    formTk?.scrollIntoView({ behavior: "smooth" });
  }

  async function eliminarTicket(e) {
    const idx = parseInt(e.target.closest("button").dataset.idx);
    if (!confirm("¿Mover este ticket a la papelera?")) return;
    const [t] = tickets.splice(idx, 1);
    t.fechaEliminado = new Date().toISOString();
    papelera.unshift(t);
    logBitacora(`Ticket #${t.numero} "${t.asunto}" movido a papelera`, "🗑️");
    actualizarBadgePapelera();
    if (firebaseEnabled) { guardarPapelera(papelera).catch(() => {}); }
    if (crmLocalOnly) {
      toast("🗑️ Ticket en papelera (Local)");
      renderTickets();
      renderDashboard();
      return;
    }
    await guardarTickets(tickets);
    toast("🗑️ Ticket movido a papelera");
    renderTickets();
    renderDashboard();
  }

  // Ticket Detail Modal
  let ticketDetalleIdx = null;
  const modalDetalle = document.getElementById("modal-detalle-ticket");

  function abrirDetalleTicket(e) {
    const idx = parseInt(e.target.closest("button").dataset.idx);
    ticketDetalleIdx = idx;
    const t = tickets[idx];

    document.getElementById("det-tk-num").textContent = `Folio #${t.numero}`;
    document.getElementById("det-tk-asunto").textContent = t.asunto;
    document.getElementById("det-tk-empresa").textContent = t.empresa || "—";
    document.getElementById("det-tk-contacto").textContent = t.contacto || "—";
    document.getElementById("det-tk-grupo").textContent = t.grupo || "—";
    document.getElementById("det-tk-agente").textContent = t.agente || "—";
    document.getElementById("det-tk-descripcion").innerHTML = t.descripcion || "";
    const detNI = document.getElementById("det-tk-notas-internas");
    const detNISec = document.getElementById("det-tk-notas-internas-section");
    if (detNI && detNISec) {
      if (t.notasInternas) { detNI.textContent = t.notasInternas; detNISec.style.display = "block"; }
      else { detNI.textContent = ""; detNISec.style.display = "none"; }
    }
    renderAdjuntosDetalle(t);

    const bPrior = document.getElementById("det-tk-prioridad-badge");
    bPrior.textContent = t.prioridad;
    bPrior.className = `badge badge-${(t.prioridad || "media").toLowerCase()}`;

    const bEst = document.getElementById("det-tk-estado-badge");
    bEst.textContent = t.estado;
    bEst.className = `badge badge-${(t.estado || "abierto").toLowerCase()}`;

    const bTipo = document.getElementById("det-tk-tipo-badge");
    bTipo.textContent = t.tipo || "General";

    populateSelectOptions("selectCambiarEstadoDetalle", configTickets.estados, t.estado);
    renderNotasTicket(t);

    if (modalDetalle) modalDetalle.style.display = "flex";
  }

  function renderNotasTicket(t) {
    const cont = document.getElementById("det-tk-notas");
    if (!cont) return;
    cont.innerHTML = "";
    const notas = t.notas || [];
    if (notas.length === 0) {
      cont.innerHTML = '<div style="text-align:center; color:var(--text-light); font-size:0.8rem; padding:14px;">Sin notas de seguimiento.</div>';
      return;
    }
    notas.forEach(n => {
      const div = document.createElement("div");
      div.className = "note-item";
      div.innerHTML = `
        <div class="note-meta">
          <strong>👤 ${n.autor || "Soporte"}</strong>
          <span>📅 ${new Date(n.fecha).toLocaleString()}</span>
        </div>
        <div style="line-height:1.5; white-space:pre-wrap;">${n.texto}</div>
      `;
      cont.appendChild(div);
    });
    cont.scrollTop = cont.scrollHeight;
  }

  document.getElementById("btnCerrarDetalle")?.addEventListener("click", () => {
    if (modalDetalle) modalDetalle.style.display = "none";
    ticketDetalleIdx = null;
    document.getElementById("txtNuevaNotaTicket").value = "";
  });

  document.getElementById("btnAgregarNotaTicket")?.addEventListener("click", async () => {
    if (ticketDetalleIdx === null) return;
    const txt = document.getElementById("txtNuevaNotaTicket").value.trim();
    const nuevoEstado = document.getElementById("selectCambiarEstadoDetalle")?.value;
    const t = tickets[ticketDetalleIdx];

    if (!txt && nuevoEstado === t.estado) {
      alert("Escribe una nota o cambia el estado.");
      return;
    }

    if (txt) {
      if (!t.notas) t.notas = [];
      t.notas.push({ autor: "Soporte", fecha: new Date().toISOString(), texto: txt });
      document.getElementById("txtNuevaNotaTicket").value = "";
    }

    if (nuevoEstado && nuevoEstado !== t.estado) {
      if (!t.notas) t.notas = [];
      t.notas.push({ autor: "Sistema", fecha: new Date().toISOString(), texto: `Estado cambiado: "${t.estado}" → "${nuevoEstado}"` });
      t.estado = nuevoEstado;
      document.getElementById("det-tk-estado-badge").textContent = nuevoEstado;
      document.getElementById("det-tk-estado-badge").className = `badge badge-${nuevoEstado.toLowerCase()}`;
    }

    t.fechaActualizacion = new Date().toISOString();
    guardarLocal("crm_tickets", tickets);
    if (crmLocalOnly) {
      toast("💬 Nota agregada (Local)");
      renderNotasTicket(t);
      renderTickets();
      renderDashboard();
      return;
    }
    mostrarEstado("💬 Posteando...");
    const ok = await guardarTickets(tickets);
    if (ok) { toast("💬 Nota agregada"); ocultarEstado(); }
    else { mostrarEstado("⚠️ Guardado localmente (sin conexión)", 2000); }
    renderNotasTicket(t);
    renderTickets();
    renderDashboard();
  });

