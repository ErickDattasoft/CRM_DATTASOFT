    sistEl.textContent = ev.sistema ? `📦 ${ev.sistema}` : "";
    const fechaEl = document.getElementById("ev-fecha-display");
    fechaEl.textContent = ev.fecha ? `📅 ${new Date(ev.fecha + "T00:00:00").toLocaleDateString("es-MX", { weekday:"long", day:"2-digit", month:"long", year:"numeric" })}${ev.hora ? " · " + ev.hora : ""}` : "";
