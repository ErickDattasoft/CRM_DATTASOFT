    <div class="form-group" style="margin-bottom:14px;">
      <label>Nombre del punto</label>
      <input id="gh-punto-nombre" type="text" placeholder="v2025.06.25-kb-completo" style="font-size:0.85rem;">
      <span style="font-size:0.7rem; color:var(--text-muted); margin-top:3px; display:block;">Sin espacios. Ejemplo: v1.2-fix-login</span>
    </div>
    <div class="form-group" style="margin-bottom:20px;">
      <label>Descripción (opcional)</label>
      <input id="gh-punto-desc" type="text" placeholder="Base de Conocimiento completa + pizarra" style="font-size:0.85rem;">
    </div>
    <div style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
      <button id="btn-gh-punto-crear" class="btn btn-primary btn-sm">🔖 Crear</button>
      <button id="btn-gh-punto-cancelar" class="btn btn-ghost btn-sm">Cancelar</button>
      <span id="gh-punto-status2" style="font-size:0.78rem; display:none;"></span>
    </div>
  </div>
</div>
