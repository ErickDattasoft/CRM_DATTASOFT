        <td style="text-align:center;"><input type="checkbox" class="ev-ext-invitado" data-idx="${i}" ${ext.invitado ? "checked" : ""} style="width:16px;height:16px;accent-color:#6366f1;cursor:pointer;" title="Marcar si se le contactó"></td>
        <td><select class="ev-ext-respuesta" data-idx="${i}" style="font-size:0.75rem; padding:4px 6px; width:100%;">${selOpts}</select></td>
        <td><input class="ev-ext-notas" data-idx="${i}" value="${(ext.notas || "").replace(/"/g, "&quot;")}" placeholder="Notas..." style="font-size:0.75rem; padding:4px 8px; width:100%;"></td>
