    ["form-tk-contacto-buscar", "form-tk-contacto", "form-tk-correo-contacto", "form-tk-empresa",
     "form-tk-asunto", "form-tk-cc", "form-tk-cco",
     "form-tk-referido", "form-tk-solicitado", "form-tk-canalizado", "form-tk-realizado",
     "form-tk-notas-internas"].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.value = "";
    });
