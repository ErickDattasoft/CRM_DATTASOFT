  function renderDrawerHistorial() {
    const tl = document.getElementById("drawer-historial-timeline");
    if (!tl || drawerEmpresaActual === null) return;
    const empresa = clientes[drawerEmpresaActual]?.EMPRESA || "";
    const ints = interacciones.filter(i => i.empresa === empresa).sort((a, b) => new Date(b.fecha).getTime() - new Date(a.fecha).getTime());
    // Agregar tickets como interacciones automáticas
    const ticketsEmp = tickets.filter(t => t.empresa === empresa).map(t => ({
      id: "tk_" + t.numero, tipo: "Ticket", texto: `Ticket #${t.numero}: ${t.asunto} (${t.estado})`,
      fecha: t.fechaCreacion, usuario: t.agente || "Sistema", _auto: true
    }));
    const todos = [...ints, ...ticketsEmp].sort((a, b) => new Date(b.fecha).getTime() - new Date(a.fecha).getTime());
    if (!todos.length) { tl.innerHTML = '<div class="timeline-empty">Sin interacciones registradas.<br><span style="font-size:0.75rem;">Usa el formulario de arriba para agregar una nota, llamada o reunión.</span></div>'; return; }
    const iconos = { Nota: "📝", Llamada: "📞", Correo: "✉️", Reunión: "🤝", Ticket: "🎫" };
    tl.innerHTML = todos.map(it => {
      const tipoCssMap: Record<string,string> = { Nota:"nota", Llamada:"llamada", Correo:"correo", "Reunión":"reunion", Ticket:"ticket" };
      const tipoCls = tipoCssMap[it.tipo] || "nota";
      const fecha = it.fecha ? new Date(it.fecha).toLocaleDateString("es-MX", { day:"2-digit", month:"short", year:"numeric" }) : "";
      return `<div class="timeline-item">
        <div class="timeline-dot timeline-dot-${tipoCls}"></div>
        <div class="timeline-content">
          <div class="timeline-meta">
            <span class="timeline-tipo timeline-tipo-${tipoCls}">${iconos[it.tipo] || "📌"} ${it.tipo}</span>
            <span>${fecha}</span>
            ${it.usuario ? `<span>· ${it.usuario}</span>` : ""}
            ${!it._auto ? `<button class="btn btn-danger btn-xs" data-int-id="${it.id}" style="margin-left:auto;padding:1px 5px;">✕</button>` : ""}
          </div>
          <div class="timeline-text">${it.texto || ""}</div>
        </div>
      </div>`;
    }).join("");
    tl.querySelectorAll("[data-int-id]").forEach(b => b.addEventListener("click", async function() {
      const id = this.dataset.intId;
      interacciones = interacciones.filter(i => i.id !== id);
      await guardarInteracciones(interacciones);
      renderDrawerHistorial();
    }));
  }

  function renderDrawerTareas() {
