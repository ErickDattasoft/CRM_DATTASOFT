  function renderDrawerHistorial() {
    const tl = document.getElementById("drawer-historial-timeline");
    const resumenBox = document.getElementById("hist-tickets-resumen");
    if (!tl || drawerEmpresaActual === null) return;
    const empresa = clientes[drawerEmpresaActual]?.EMPRESA || "";
    const ints = interacciones.filter(i => i.empresa === empresa);
    // Una línea por ticket (no por cada evento de actividad) — fechada a su creación, con
    // el estado ACTUAL. El detalle evento por evento (quién cambió qué y cuándo) vive en la
    // sección "Actividad del ticket" dentro del detalle de cada ticket; aquí se busca poder
    // contestar "cuántos tickets se hicieron en este rango y cómo están".
    const ticketsEmp = tickets.filter(t => t.empresa === empresa).map(t => ({
      id: "tk_" + t.numero, numero: t.numero, tipo: "Ticket",
      texto: `#${t.numero} ${t.asunto} — Estado: ${t.estado}`,
      fecha: t.fechaCreacion, usuario: t.agente || "Sistema", _auto: true
    }));
    let todos = [...ints, ...ticketsEmp].sort((a, b) => new Date(b.fecha).getTime() - new Date(a.fecha).getTime());
    const desde = (document.getElementById("hist-filtro-desde") as HTMLInputElement)?.value || "";
    const hasta = (document.getElementById("hist-filtro-hasta") as HTMLInputElement)?.value || "";
    const filtroTipo = (document.getElementById("hist-filtro-tipo") as HTMLSelectElement)?.value || "";
    if (desde) todos = todos.filter(it => it.fecha && it.fecha.slice(0, 10) >= desde);
    if (hasta) todos = todos.filter(it => it.fecha && it.fecha.slice(0, 10) <= hasta);
    if (filtroTipo) todos = todos.filter(it => it.tipo === filtroTipo);

    if (resumenBox) {
      if (filtroTipo === "Ticket" && todos.length) {
        const conteo: Record<string, number> = {};
        todos.forEach(it => {
          const tk = tickets.find(x => x.numero === it.numero);
          const est = tk?.estado || "—";
          conteo[est] = (conteo[est] || 0) + 1;
        });
        const partes = Object.entries(conteo).map(([est, n]) => `<strong>${n}</strong> ${escapeHtml(est)}`).join(" · ");
        resumenBox.innerHTML = `🎫 <strong>${todos.length}</strong> ticket${todos.length === 1 ? "" : "s"} en este rango — ${partes}`;
        resumenBox.style.display = "block";
      } else {
        resumenBox.style.display = "none";
      }
    }

    if (!todos.length) {
      const sinResultados = desde || hasta || filtroTipo;
      tl.innerHTML = sinResultados
        ? '<div class="timeline-empty">Sin resultados con ese filtro.</div>'
        : '<div class="timeline-empty">Sin interacciones registradas.<br><span style="font-size:0.75rem;">Usa el formulario de arriba para agregar una nota, llamada o reunión.</span></div>';
      return;
    }
    const iconos = { Nota: "📝", Llamada: "📞", Correo: "✉️", Reunión: "🤝", Ticket: "🎫" };
    tl.innerHTML = todos.map(it => {
      const tipoCssMap: Record<string,string> = { Nota:"nota", Llamada:"llamada", Correo:"correo", "Reunión":"reunion", Ticket:"ticket" };
      const tipoCls = tipoCssMap[it.tipo] || "nota";
      const fecha = it.fecha ? parseFechaLocal(it.fecha).toLocaleDateString("es-MX", { day:"2-digit", month:"short", year:"numeric" }) : "";
      return `<div class="timeline-item">
        <div class="timeline-dot timeline-dot-${tipoCls}"></div>
        <div class="timeline-content">
          <div class="timeline-meta">
            <span class="timeline-tipo timeline-tipo-${tipoCls}">${iconos[it.tipo] || "📌"} ${it.tipo}</span>
            <span>${fecha}</span>
            ${it.usuario ? `<span>· ${it.usuario}</span>` : ""}
            ${it.tipo === "Ticket" ? `<button class="btn btn-ghost btn-xs btn-ver-ticket-historial" data-ticket-numero="${it.numero}" style="margin-left:auto;">Ver ticket →</button>` : ""}
            ${!it._auto ? `<button class="btn btn-danger btn-xs" data-int-id="${it.id}" style="margin-left:auto;padding:1px 5px;">✕</button>` : ""}
          </div>
          <div class="timeline-text">${it.texto || ""}</div>
        </div>
      </div>`;
    }).join("");
    tl.querySelectorAll("[data-int-id]").forEach(b => b.addEventListener("click", async function() {
      const id = this.dataset.intId;
      interacciones = interacciones.filter(i => i.id !== id);
      await guardarInteracciones(interacciones);
      renderDrawerHistorial();
    }));
    tl.querySelectorAll("[data-ticket-numero]").forEach(b => b.addEventListener("click", function() {
      const numero = this.dataset.ticketNumero;
      const idx = tickets.findIndex(t => String(t.numero) === numero);
      if (idx === -1) return;
      cerrarDrawer();
      mostrarDetalleTicket(idx);
    }));
  }

