  // ============================================================
  // PAPELERA DE RECICLAJE
  // ============================================================
  function renderPapelera() {
    const tbody = document.getElementById("tabla-papelera-body");
    if (!tbody) return;
    tbody.innerHTML = "";
    if (!papelera.length) {
      tbody.innerHTML = '<tr><td colspan="6" style="text-align:center; color:var(--text-muted); padding:20px; font-style:italic;">Papelera vacía.</td></tr>';
      return;
    }
    papelera.forEach((t, i) => {
      const tr = document.createElement("tr");
      tr.innerHTML = `
        <td style="text-align:center; font-weight:700; color:var(--text-muted);">#${t.numero}</td>
        <td><strong>${t.asunto || "—"}</strong></td>
        <td>${t.empresa || "—"}</td>
        <td style="text-align:center;"><span class="badge badge-${(t.estado||"abierto").toLowerCase()}">${t.estado||"—"}</span></td>
        <td style="font-size:0.78rem; color:var(--text-light);">${t.fechaEliminado ? new Date(t.fechaEliminado).toLocaleDateString('es-MX') : "—"}</td>
        <td style="text-align:center;">
          <div style="display:inline-flex; gap:4px;">
            <button class="btn btn-success btn-xs btn-restaurar-tk" data-idx="${i}" title="Restaurar">↩️</button>
            <button class="btn btn-danger btn-xs btn-eliminar-def-tk" data-idx="${i}" title="Eliminar definitivamente">🔥</button>
          </div>
        </td>`;
      tbody.appendChild(tr);
    });
    tbody.querySelectorAll(".btn-restaurar-tk").forEach(b => b.addEventListener("click", async (e) => {
      const i = parseInt(e.target.closest("button").dataset.idx);
      const t = papelera.splice(i, 1)[0];
      delete t.fechaEliminado;
      tickets.push(t);
      if (firebaseEnabled) { guardarPapelera(papelera).catch(() => {}); await guardarTickets(tickets); }
      logBitacora(`Ticket #${t.numero} restaurado de papelera`, "↩️");
      toast(`↩️ Ticket #${t.numero} restaurado`);
      actualizarBadgePapelera();
      renderPapelera();
      renderTickets();
      renderDashboard();
    }));
    tbody.querySelectorAll(".btn-eliminar-def-tk").forEach(b => b.addEventListener("click", (e) => {
      const i = parseInt(e.target.closest("button").dataset.idx);
      if (!confirm("¿Eliminar definitivamente? Esta acción no se puede deshacer.")) return;
      const t = papelera.splice(i, 1)[0];
      if (firebaseEnabled) guardarPapelera(papelera).catch(() => {});
      logBitacora(`Ticket #${t.numero} eliminado definitivamente`, "🔥");
      toast(`🔥 Ticket eliminado definitivamente`);
      actualizarBadgePapelera();
      renderPapelera();
    }));
  }

  function actualizarBadgePapelera() {
    const badge = document.getElementById("badge-papelera");
    if (!badge) return;
    if (papelera.length > 0) { badge.style.display = "inline-flex"; badge.textContent = papelera.length; }
    else { badge.style.display = "none"; }
  }

