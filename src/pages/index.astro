            <button class="btn btn-ghost btn-sm" id="btnVerInscripciones" style="display:none; background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.3);color:#a5b4fc;">👥 Inscritos <span id="badge-inscritos" style="background:#6366f1;color:white;border-radius:10px;padding:1px 7px;font-size:0.75rem;margin-left:4px;">0</span></button>
