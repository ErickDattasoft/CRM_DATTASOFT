      toast("📊 Resumen enviado a " + correos.join(", "));
    } catch(e) {
      console.warn("[ResumenSemanal] Error al enviar:", e);
      toast("❌ No se pudo enviar el resumen — revisa la consola", "error");
    }
  }

  document.getElementById("btn-enviar-resumen-semanal")?.addEventListener("click", async (e) => {
