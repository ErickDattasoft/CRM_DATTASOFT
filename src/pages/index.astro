  function compararVersiones(vC, vO) {
    const normalize = v => String(v || "").toLowerCase().trim();
    vC = normalize(vC);
    vO = normalize(vO);
    if (!vO) return 0; // no official version to compare
    if (!vC || vC === "no aplica") return -1; // company missing version while official exists
    if (vC === vO) return 0;

    const parse = v => {
      const spMatch = v.match(/sp\s*(\d+)/);
      const sp = spMatch ? parseInt(spMatch[1]) : 0;
      const base = v.split(/sp/)[0].replace(/[^0-9.]/g, "").split(".").map(n => parseInt(n) || 0);
      return { base, sp };
    };

    const pC = parse(vC);
    const pO = parse(vO);
    const maxLen = Math.max(pC.base.length, pO.base.length);
    while (pC.base.length < maxLen) pC.base.push(0);
    while (pO.base.length < maxLen) pO.base.push(0);

    for (let i = 0; i < maxLen; i++) {
      if (pC.base[i] < pO.base[i]) return -1;
      if (pC.base[i] > pO.base[i]) return 1;
    }
    if (pC.sp < pO.sp) return -1;
    if (pC.sp > pO.sp) return 1;
    return 0;
  }

  function esVersionMenor(vC, vO) {
    return compararVersiones(vC, vO) < 0;
  }

