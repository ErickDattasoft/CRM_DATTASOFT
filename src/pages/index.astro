  tkBuscarInput?.addEventListener("input", function() {
    const val = this.value.toLowerCase().trim();
    if (val.length < 1) { tkAutoList?.classList.add("hidden"); return; }

    // Deduplicar contactos por nombre+empresa (case-insensitive) antes de buscar
    const contactosUnicos = [];
    const seenKeys = new Set();
    contactos.forEach(c => {
      const k = `${(c.nombre||"").toLowerCase().trim()}||${(c.empresa||"").toLowerCase().trim()}`;
      if (!seenKeys.has(k)) { seenKeys.add(k); contactosUnicos.push(c); }
    });

    const fromContactos = contactosUnicos.filter(c =>
      (c.nombre || "").toLowerCase().includes(val) ||
      (c.correo || "").toLowerCase().includes(val) ||
      (c.empresa || "").toLowerCase().includes(val)
    );

    // Buscar también en clientes como fallback
    const fromClientes = clientes
      .filter(c =>
        (c.CONTACTO || "").toLowerCase().includes(val) ||
        (c.EMPRESA || "").toLowerCase().includes(val) ||
        (c.CORREO || "").toLowerCase().includes(val)
      )
      .map(c => ({ nombre: c.CONTACTO, correo: c.CORREO, empresa: c.EMPRESA, telefono1: c.TELEFONO_1 }));

    // Unir evitando duplicados (case-insensitive)
    const seenFinal = new Set(fromContactos.map(c => `${(c.nombre||"").toLowerCase()}||${(c.empresa||"").toLowerCase()}`));
    const extra = fromClientes.filter(c => !seenFinal.has(`${(c.nombre||"").toLowerCase()}||${(c.empresa||"").toLowerCase()}`));
    const matches = [...fromContactos, ...extra];

    if (matches.length === 0) {
      tkAutoList.innerHTML = `<div class="autocomplete-item" style="color:var(--text-muted); font-style:italic;">Sin resultados para "${this.value}"</div>`;
      tkAutoList?.classList.remove("hidden");
      return;
    }

    tkAutoList.innerHTML = "";
    matches.slice(0, 15).forEach(c => {
      const div = document.createElement("div");
      div.className = "autocomplete-item";
      div.innerHTML = `
        <div style="font-weight:600; color:var(--text-bright); font-size:0.84rem;">👤 ${c.nombre || "Sin nombre"}</div>
        <div style="font-size:0.72rem; color:var(--text-light); margin-top:2px;">🏢 ${c.empresa || "Sin empresa"} ${c.correo ? `· ✉️ ${c.correo}` : ""}</div>
      `;
      div.addEventListener("click", () => seleccionarContacto(c));
      tkAutoList.appendChild(div);
    });

    tkAutoList?.classList.remove("hidden");
  });

  // Close autocomplete on outside click
  document.addEventListener("click", e => {
    if (!e.target.closest(".autocomplete-wrap")) tkAutoList?.classList.add("hidden");
  });

  function populateTipoAgenteFilters() {
    const tipos = [...new Set(tickets.map(t => t.tipo).filter(Boolean))].sort();
    const agentes = [...new Set(tickets.map(t => t.agente).filter(Boolean))].sort();
    const selTipo = document.getElementById("selectFiltroTipo");
    const selAgente = document.getElementById("selectFiltroAgente");
    if (selTipo) {
      const cur = selTipo.value;
      selTipo.innerHTML = '<option value="">📋 Tipo</option>' + tipos.map(t => `<option value="${t}"${t===cur?' selected':''}>${t}</option>`).join("");
    }
    if (selAgente) {
      const cur = selAgente.value;
      selAgente.innerHTML = '<option value="">🧑‍💼 Agente</option>' + agentes.map(a => `<option value="${a}"${a===cur?' selected':''}>${a}</option>`).join("");
    }
  }

  function renderTickets() {
    const tbody = document.getElementById("tabla-tickets-body");
    if (!tbody) return;
    tbody.innerHTML = "";

    populateTipoAgenteFilters();

    const busq = document.getElementById("txtBuscarTicket")?.value.toLowerCase().trim() || "";
    const fEstado = document.getElementById("selectFiltroEstado")?.value || "";
    const fPrior = document.getElementById("selectFiltroPrioridad")?.value || "";
    const fTipo = document.getElementById("selectFiltroTipo")?.value || "";
    const fAgente = document.getElementById("selectFiltroAgente")?.value || "";

    const filtrados = tickets.map((t, i) => ({ ...t, _idx: i })).filter(t => {
      if (fEstado && t.estado !== fEstado) return false;
      if (fPrior && t.prioridad !== fPrior) return false;
      if (fTipo && t.tipo !== fTipo) return false;
      if (fAgente && t.agente !== fAgente) return false;
      if (busq) {
        return (t.asunto || "").toLowerCase().includes(busq) ||
               (t.empresa || "").toLowerCase().includes(busq) ||
               (t.contacto || "").toLowerCase().includes(busq) ||
               (t.agente || "").toLowerCase().includes(busq) ||
               String(t.numero).includes(busq);
      }
      return true;
    }).sort((a, b) => b.numero - a.numero);

    filtrados.forEach(t => {
      const tr = document.createElement("tr");
      tr.dataset.idx = t._idx;
      tr.innerHTML = `
        <td style="text-align:center; font-weight:700; color:var(--text-muted);">#${t.numero}</td>
        <td><strong style="color:var(--text-bright);">${t.asunto}</strong></td>
        <td>
          <span style="display:block; font-weight:600;">👤 ${t.contacto || "—"}</span>
          <span style="display:block; font-size:0.72rem; color:var(--text-light);">🏢 ${t.empresa || "—"}</span>
        </td>
        <td style="text-align:center;"><span class="badge" style="background:rgba(99,102,241,0.12); color:#a5b4fc;">${t.tipo || "General"}</span></td>
        <td style="text-align:center;"><span class="badge badge-${(t.prioridad || "media").toLowerCase()}">${t.prioridad}</span></td>
        <td style="text-align:center;"><span class="badge badge-${(t.estado || "abierto").toLowerCase()}">${t.estado}</span></td>
        <td style="font-size:0.8rem; color:var(--text-muted);">${t.agente || "—"}</td>
        <td style="font-size:0.78rem; color:var(--text-light);">${t.fechaCreacion ? new Date(t.fechaCreacion).toLocaleDateString() : "—"}</td>
        <td style="text-align:center;">
          <div style="display:inline-flex; gap:4px;">
            <button class="btn btn-secondary btn-xs btn-ver-tk" data-idx="${t._idx}">👁️</button>
            <button class="btn btn-primary btn-xs btn-edit-tk" data-idx="${t._idx}">✏️</button>
            <button class="btn btn-danger btn-xs btn-del-tk" data-idx="${t._idx}">🗑️</button>
          </div>
        </td>
      `;
      tbody.appendChild(tr);
    });

    tbody.querySelectorAll(".btn-ver-tk").forEach(b => b.addEventListener("click", abrirDetalleTicket));
    tbody.querySelectorAll(".btn-edit-tk").forEach(b => b.addEventListener("click", prepararEdicionTicket));
    tbody.querySelectorAll(".btn-del-tk").forEach(b => b.addEventListener("click", eliminarTicket));

    // Click selecciona fila (morado), doble click abre edición
    tbody.addEventListener("click", (e) => {
      if (e.target.closest("button")) return;
      const row = e.target.closest("tr");
      if (!row) return;
      tbody.querySelectorAll("tr td").forEach(td => { td.style.background = ""; td.style.borderLeft = ""; td.style.paddingLeft = ""; });
      row.querySelectorAll("td").forEach((td, i) => {
        td.style.background = "rgba(99,102,241,0.18)";
        if (i === 0) { td.style.borderLeft = "4px solid #6366f1"; td.style.paddingLeft = "14px"; }
      });
    });
    tbody.addEventListener("dblclick", (e) => {
      e.preventDefault();
      if (e.target.closest("button")) return;
      const row = e.target.closest("tr");
      if (!row) return;
      row.querySelector(".btn-edit-tk")?.click();
    });

    updateBrowserTabTitle();

    // Update counters
    const el = id => document.getElementById(id);
    el("tk-count-total").textContent = tickets.length;
    el("tk-count-abiertos").textContent = tickets.filter(t => t.estado === "Abierto").length;
    el("tk-count-pendientes").textContent = tickets.filter(t => t.estado === "Pendiente").length;
    el("tk-count-resueltos").textContent = tickets.filter(t => t.estado === "Resuelto").length;
    el("tk-count-cerrados").textContent = tickets.filter(t => t.estado === "Cerrado").length;
  }

