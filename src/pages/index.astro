  function exportarExcel(tipo) {
    const wb = XLSX.utils.book_new();
    const fnClose = () => { const m = document.getElementById("modal-exportar-excel"); if(m) m.style.display = "none"; };

    if (tipo === "empresas" || tipo === "todo") {
      const rows = clientes.map(c => {
        const row = { Empresa: c.EMPRESA, Contacto: c.CONTACTO, Correo: c.CORREO, RFC: c.RFC || "", Teléfono1: c.TELEFONO_1, Teléfono2: c.TELEFONO_2 };
        listaSistemas.forEach(s => { row[s] = c.SISTEMAS?.[s.toUpperCase().trim()] || ""; });
        return row;
      });
      const ws = XLSX.utils.json_to_sheet(rows);
      XLSX.utils.book_append_sheet(wb, ws, "Empresas");
    }

    if (tipo === "contactos" || tipo === "todo") {
      const rows = contactos.map(c => ({ Nombre: c.nombre, Correo: c.correo, Teléfono1: c.telefono1, Teléfono2: c.telefono2, Empresa: c.empresa }));
      const ws = XLSX.utils.json_to_sheet(rows);
      XLSX.utils.book_append_sheet(wb, ws, "Contactos");
    }

    if (tipo === "tickets" || tipo === "todo") {
      const rows = tickets.map(t => ({
        Folio: t.numero, Asunto: t.asunto, Empresa: t.empresa, Contacto: t.contacto,
        Tipo: t.tipo, Estado: t.estado, Prioridad: t.prioridad, Grupo: t.grupo,
        Agente: t.agente, Referido: t.referido, Solicitado: t.solicitado,
        Canalizado: t.canalizado, Realizado: t.realizado,
        Descripción: (t.descripcion || "").replace(/<[^>]+>/g, ""),
        Creado: t.fechaCreacion ? new Date(t.fechaCreacion).toLocaleString('es-MX') : "",
        Actualizado: t.fechaActualizacion ? new Date(t.fechaActualizacion).toLocaleString('es-MX') : ""
      }));
      const ws = XLSX.utils.json_to_sheet(rows);
      XLSX.utils.book_append_sheet(wb, ws, "Tickets");
    }

    const nombre = tipo === "todo" ? "CRM_DATTASOFT_completo" : `CRM_DATTASOFT_${tipo}`;
    XLSX.writeFile(wb, `${nombre}_${new Date().toISOString().slice(0,10)}.xlsx`);
    logBitacora(`Exportación Excel: ${tipo}`, "📊");
    toast(`📊 Excel exportado: ${nombre}`);
    fnClose();
  }

