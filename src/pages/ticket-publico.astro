---
// Página pública para que clientes levanten tickets
// NO tiene acceso a datos internos del CRM
---

<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Soporte Técnico — DATTASOFT</title>
  <meta name="description" content="Levanta un ticket de soporte técnico con DATTASOFT BY INFOXPERT.">
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 14px;
      background: #0f1117;
      color: #e2e8f0;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 24px 16px 48px;
    }
    .header {
      text-align: center;
      margin-bottom: 32px;
      margin-top: 16px;
    }
    .header-logo { font-size: 2.8rem; margin-bottom: 8px; line-height: 1; }
    #portal-logo-img { width: 72px; height: 72px; object-fit: contain; border-radius: 12px; margin: 0 auto 10px; display: none; }
    .header h1 { font-size: 1.5rem; font-weight: 800; color: #fff; margin-bottom: 4px; }
    .header p { font-size: 0.85rem; color: #8b95a8; }

    .form-card {
      background: rgba(26,30,41,0.95);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 16px;
      padding: 32px;
      width: 100%;
      max-width: 580px;
      box-shadow: 0 8px 25px rgba(0,0,0,0.3);
    }
    .form-title {
      font-size: 1rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 16px;
    }
    label {
      font-size: 0.78rem;
      font-weight: 700;
      color: #8b95a8;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .required { color: #ef4444; }
    input, select, textarea {
      background: #1e2231;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 10px;
      padding: 10px 14px;
      color: #e2e8f0;
      font-family: inherit;
      font-size: 0.9rem;
      transition: border-color 0.2s;
      outline: none;
      width: 100%;
    }
    input:focus, select:focus, textarea:focus {
      border-color: #6366f1;
      background: #252a3a;
    }
    select option { background: #1e2231; }
    textarea { resize: vertical; min-height: 100px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    @media (max-width: 500px) { .form-row { grid-template-columns: 1fr; } }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 12px 24px;
      border: none;
      border-radius: 10px;
      font-family: inherit;
      font-size: 0.9rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-primary { background: #6366f1; color: #fff; width: 100%; margin-top: 8px; }
    .btn-primary:hover { background: #4f46e5; transform: translateY(-1px); }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    .alert {
      padding: 14px 16px;
      border-radius: 10px;
      font-size: 0.85rem;
      margin-bottom: 16px;
      display: none;
    }
    .alert-success { background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.25); color: #34d399; }
    .alert-error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); color: #f87171; }

    .footer-note {
      margin-top: 24px;
      text-align: center;
      font-size: 0.75rem;
      color: #4a5568;
    }

    .spinner { display: none; width: 18px; height: 18px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; animation: spin 0.7s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    .img-drop-zone {
      position: relative;
      border: 2px dashed rgba(99,102,241,0.35);
      border-radius: 10px;
      padding: 18px;
      text-align: center;
      color: #8b95a8;
      font-size: 0.83rem;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
      background: rgba(99,102,241,0.04);
    }
    .img-drop-zone:hover, .img-drop-zone.drag-over {
      border-color: #6366f1;
      background: rgba(99,102,241,0.1);
    }
    .img-drop-zone input[type="file"] {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
      width: 100%;
      height: 100%;
      padding: 0;
      border: none;
      background: none;
    }
    .img-preview-wrap {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }
    .img-thumb {
      position: relative;
      width: 72px;
      height: 72px;
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.1);
      background: #1e2231;
      flex-shrink: 0;
    }
    .img-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .img-thumb-del {
      position: absolute;
      top: 2px;
      right: 2px;
      background: rgba(239,68,68,0.85);
      color: #fff;
      border: none;
      border-radius: 50%;
      width: 18px;
      height: 18px;
      font-size: 11px;
      line-height: 1;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
    }

    #success-view {
      display: none;
      text-align: center;
      padding: 40px 20px;
    }
    #success-view .big-icon { font-size: 4rem; margin-bottom: 16px; }
    #success-view h2 { font-size: 1.3rem; color: #fff; margin-bottom: 8px; }
    #success-view p { font-size: 0.88rem; color: #8b95a8; line-height: 1.6; }
    #success-view .folio-display {
      display: inline-block;
      background: rgba(99,102,241,0.15);
      border: 1px solid rgba(99,102,241,0.3);
      border-radius: 8px;
      padding: 8px 20px;
      font-size: 1.1rem;
      font-weight: 800;
      color: #818cf8;
      margin: 12px 0;
    }
  </style>
</head>
<body>
  <div class="header">
    <div class="header-logo" id="portal-logo-emoji">📊</div>
    <img id="portal-logo-img" alt="Logo empresa">
    <h1>DATTASOFT BY INFOXPERT</h1>
    <p>Soporte Técnico — Levanta tu ticket de asistencia</p>
  </div>

  <div class="form-card">
    <!-- Alert messages -->
    <div class="alert alert-error" id="alert-error"></div>

    <!-- Success view -->
    <div id="success-view">
      <div class="big-icon">✅</div>
      <h2>¡Ticket enviado!</h2>
      <div class="folio-display" id="folio-generado">Folio #—</div>
      <p>Tu solicitud fue recibida correctamente. Nuestro equipo se pondrá en contacto contigo a la brevedad.<br><br>Guarda tu número de folio para dar seguimiento.</p>
    </div>

    <!-- Form -->
    <div id="form-view">
      <div class="form-title">📋 Nueva Solicitud de Soporte</div>

      <div class="form-row">
        <div class="form-group">
          <label>Tu Nombre <span class="required">*</span></label>
          <input type="text" id="pub-nombre" placeholder="Ej: Juan Pérez" required>
        </div>
        <div class="form-group">
          <label>Empresa / Organización <span class="required">*</span></label>
          <input type="text" id="pub-empresa" placeholder="Nombre de tu empresa" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Correo electrónico <span class="required">*</span></label>
          <input type="email" id="pub-correo" placeholder="correo@empresa.com" required>
        </div>
        <div class="form-group">
          <label>Teléfono / WhatsApp</label>
          <input type="tel" id="pub-telefono" placeholder="Ej: 55 1234 5678">
        </div>
      </div>

      <div class="form-group">
        <label>Asunto / Título del problema <span class="required">*</span></label>
        <input type="text" id="pub-asunto" placeholder="Ej: Error al timbrar facturas" required>
      </div>

      <div class="form-group">
        <label>Sistema CONTPAQi afectado</label>
        <select id="pub-sistema">
          <option value="">— Seleccionar sistema (opcional) —</option>
          <option>CONTABILIDAD</option>
          <option>BANCOS</option>
          <option>NÓMINAS</option>
          <option>COMERCIAL PRO</option>
          <option>COMERCIAL PREMIUM</option>
          <option>FACTURA ELECTRÓNICA</option>
          <option>XML EN LÍNEA</option>
          <option>COMPONENTES</option>
          <option>RESPALDOS</option>
          <option>SERVIDOR DE LICENCIAS</option>
          <option>Otro / No aplica</option>
        </select>
      </div>

      <div class="form-group">
        <label>Prioridad</label>
        <select id="pub-prioridad">
          <option value="Media">Media — Puedo trabajar con inconvenientes</option>
          <option value="Alta">Alta — El sistema falla pero puedo hacer algo</option>
          <option value="Urgente">Urgente — Sistema completamente detenido</option>
          <option value="Baja">Baja — Duda o consulta general</option>
        </select>
      </div>

      <div class="form-group">
        <label>Descripción del problema <span class="required">*</span></label>
        <textarea id="pub-descripcion" placeholder="Describe con el mayor detalle posible: ¿qué estabas haciendo cuando ocurrió el error?, ¿qué mensaje de error apareció?, ¿cuándo inició el problema?" required></textarea>
      </div>

      <div class="form-group">
        <label>Imágenes adjuntas <span style="color:#8b95a8; text-transform:none; font-weight:400; letter-spacing:0;">(opcional · máx. 3 fotos o capturas)</span></label>
        <div class="img-drop-zone" id="img-drop-zone">
          <span style="font-size:1.4rem; display:block; margin-bottom:4px;">🖼️</span>
          <span id="img-drop-text">Haz clic aquí o arrastra imágenes</span>
          <input type="file" id="pub-imagenes" accept="image/*" multiple>
        </div>
        <div class="img-preview-wrap" id="img-previews"></div>
      </div>

      <button class="btn btn-primary" id="btnEnviarTicket">
        <div class="spinner" id="spinner"></div>
        <span id="btn-text">Enviar solicitud de soporte</span>
      </button>
    </div>
  </div>

  <div class="footer-note">
    DATTASOFT BY INFOXPERT — Soporte Técnico CONTPAQi
  </div>

  <script>
  (() => {
    const FIREBASE_PROJECT = "agenda-crm-netlify";
    const FIREBASE_API_KEY = import.meta.env.PUBLIC_FIREBASE_API_KEY || "AIzaSyDT6EkBk0pMA9t_APJlLPku_EWco_OMM3Q";

    // ── Auth anónima + Logo ───────────────────────────────────────
    let anonToken: string | null = null;

    async function getAnonToken(): Promise<string | null> {
      if (anonToken) return anonToken;
      try {
        const resp = await fetch(
          `https://identitytoolkit.googleapis.com/v1/accounts:signUp?key=${FIREBASE_API_KEY}`,
          { method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ returnSecureToken: true }) }
        );
        const data = await resp.json();
        anonToken = data.idToken ?? null;
        return anonToken;
      } catch { return null; }
    }

    let correoSoporteAdmin = "";

    async function cargarLogoPortal() {
      try {
        const token = await getAnonToken();
        if (!token) return;
        const resp = await fetch(
          `https://firestore.googleapis.com/v1/projects/${FIREBASE_PROJECT}/databases/(default)/documents/agenda/datos`,
          { headers: { Authorization: `Bearer ${token}` } }
        );
        if (!resp.ok) return;
        const data = await resp.json();
        correoSoporteAdmin = data?.fields?.configTickets?.mapValue?.fields?.correoSoporte?.stringValue || "";
        const logo = data?.fields?.logoEmpresa?.stringValue;
        if (!logo) return;
        const emoji = document.getElementById("portal-logo-emoji") as HTMLElement | null;
        const img   = document.getElementById("portal-logo-img")   as HTMLImageElement | null;
        if (emoji) emoji.style.display = "none";
        if (img)   { img.src = logo; img.style.display = "block"; }
        document.querySelectorAll<HTMLLinkElement>("link[rel='icon']").forEach(el => { el.href = logo; });
      } catch { /* sin logo, se queda el emoji */ }
    }

    cargarLogoPortal();

    const btn = document.getElementById("btnEnviarTicket");
    const spinner = document.getElementById("spinner");
    const btnText = document.getElementById("btn-text");
    const alertError = document.getElementById("alert-error");

    // ── Imágenes adjuntas ─────────────────────────────────────
    const MAX_IMG = 3;
    const MAX_PX = 900;
    const QUALITY = 0.70;
    type ImgData = { nombre: string; tipo: string; data: string };
    let imagenesAdjuntas: ImgData[] = [];

    function comprimirImagen(file: File): Promise<ImgData> {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onerror = reject;
        reader.onload = e => {
          const result = (e.target as FileReader).result as string;
          const img = new Image();
          img.onerror = reject;
          img.onload = () => {
            let w = img.naturalWidth, h = img.naturalHeight;
            if (w > MAX_PX || h > MAX_PX) {
              const r = Math.min(MAX_PX / w, MAX_PX / h);
              w = Math.round(w * r);
              h = Math.round(h * r);
            }
            const canvas = document.createElement("canvas");
            canvas.width = w; canvas.height = h;
            canvas.getContext("2d")!.drawImage(img, 0, 0, w, h);
            resolve({ nombre: file.name, tipo: "image/jpeg", data: canvas.toDataURL("image/jpeg", QUALITY) });
          };
          img.src = result;
        };
        reader.readAsDataURL(file);
      });
    }

    function renderPreviews() {
      const wrap = document.getElementById("img-previews");
      const txt = document.getElementById("img-drop-text");
      if (!wrap || !txt) return;
      wrap.innerHTML = "";
      txt.textContent = imagenesAdjuntas.length >= MAX_IMG
        ? `Máximo ${MAX_IMG} imágenes alcanzado`
        : `Haz clic aquí o arrastra imágenes (${imagenesAdjuntas.length}/${MAX_IMG})`;
      imagenesAdjuntas.forEach((img, i) => {
        const div = document.createElement("div");
        div.className = "img-thumb";
        div.innerHTML = `<img src="${img.data}" alt="${img.nombre}"><button class="img-thumb-del" data-i="${i}" title="Quitar">×</button>`;
        div.querySelector(".img-thumb-del")!.addEventListener("click", () => {
          imagenesAdjuntas.splice(i, 1);
          renderPreviews();
        });
        wrap.appendChild(div);
      });
    }

    async function procesarArchivos(files: FileList | null) {
      if (!files) return;
      const libres = MAX_IMG - imagenesAdjuntas.length;
      if (libres <= 0) return;
      const seleccionados = Array.from(files).filter((f: File) => f.type.startsWith("image/")).slice(0, libres);
      for (const f of seleccionados) {
        try {
          imagenesAdjuntas.push(await comprimirImagen(f));
        } catch { /* ignorar imagen inválida */ }
      }
      renderPreviews();
    }

    const dropZone = document.getElementById("img-drop-zone");
    const fileInput = document.getElementById("pub-imagenes") as HTMLInputElement | null;

    fileInput?.addEventListener("change", e => {
      const inp = e.target as HTMLInputElement;
      procesarArchivos(inp.files);
      inp.value = "";
    });
    dropZone?.addEventListener("dragover", e => { e.preventDefault(); dropZone.classList.add("drag-over"); });
    dropZone?.addEventListener("dragleave", () => dropZone.classList.remove("drag-over"));
    dropZone?.addEventListener("drop", e => {
      e.preventDefault();
      dropZone.classList.remove("drag-over");
      procesarArchivos((e as DragEvent).dataTransfer?.files ?? null);
    });

    // ── Envío del formulario ──────────────────────────────────
    function showError(msg) {
      alertError.textContent = msg;
      alertError.style.display = "block";
      setTimeout(() => { alertError.style.display = "none"; }, 5000);
    }

    function setLoading(v) {
      spinner.style.display = v ? "block" : "none";
      btnText.textContent = v ? "Enviando..." : "Enviar solicitud de soporte";
      btn.disabled = v;
    }

    btn?.addEventListener("click", async () => {
      const nombre = document.getElementById("pub-nombre")?.value.trim();
      const empresa = document.getElementById("pub-empresa")?.value.trim();
      const correo = document.getElementById("pub-correo")?.value.trim();
      const telefono = document.getElementById("pub-telefono")?.value.trim();
      const asunto = document.getElementById("pub-asunto")?.value.trim();
      const sistema = document.getElementById("pub-sistema")?.value;
      const prioridad = document.getElementById("pub-prioridad")?.value || "Media";
      const descripcion = document.getElementById("pub-descripcion")?.value.trim();

      if (!nombre || !empresa || !correo || !asunto || !descripcion) {
        showError("Por favor completa todos los campos obligatorios (marcados con *).");
        return;
      }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(correo)) {
        showError("Por favor ingresa un correo electrónico válido.");
        return;
      }

      setLoading(true);

      const folio = `PUB-${Date.now()}`;

      // Construir campo adjuntos en formato REST de Firestore
      const adjuntosField = imagenesAdjuntas.length > 0
        ? {
            arrayValue: {
              values: imagenesAdjuntas.map(img => ({
                mapValue: {
                  fields: {
                    nombre: { stringValue: img.nombre },
                    tipo: { stringValue: img.tipo },
                    data: { stringValue: img.data }
                  }
                }
              }))
            }
          }
        : { arrayValue: {} };

      try {
        const token = await getAnonToken();
        const url = `https://firestore.googleapis.com/v1/projects/${FIREBASE_PROJECT}/databases/(default)/documents/tickets_publicos`;
        const resp = await fetch(url, {
          method: "POST",
          headers: { "Content-Type": "application/json", ...(token ? { Authorization: `Bearer ${token}` } : {}) },
          body: JSON.stringify({
            fields: {
              folioPub: { stringValue: folio },
              fuente: { stringValue: "publico" },
              estado: { stringValue: "Pendiente" },
              prioridad: { stringValue: prioridad },
              asunto: { stringValue: asunto },
              contacto: { stringValue: nombre },
              contactoCorreo: { stringValue: correo },
              empresa: { stringValue: empresa },
              telefono: { stringValue: telefono || "" },
              sistema: { stringValue: sistema || "" },
              descripcion: { stringValue: descripcion },
              fechaCreacion: { stringValue: new Date().toISOString() },
              revisado: { booleanValue: false },
              adjuntos: adjuntosField
            }
          })
        });

        if (!resp.ok) {
          const errBody = await resp.json().catch(() => ({}));
          throw new Error(`Error ${resp.status}: ${JSON.stringify(errBody)}`);
        }

        document.getElementById("form-view").style.display = "none";
        document.getElementById("folio-generado").textContent = `Folio ${folio}`;
        document.getElementById("success-view").style.display = "block";

        // ── Correo al admin (acepta varios correos separados por coma) ──
        const adminDest = (correoSoporteAdmin || "erick.casas@dattasoft.mx")
          .split(/[,;]/)
          .map(e => e.trim())
          .filter(e => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e));
        const sistemaRow = sistema ? `<tr><td style="padding:6px 0;font-weight:600;color:#64748b;width:120px;">Sistema</td><td style="padding:6px 0;">${sistema}</td></tr>` : "";
        const telefonoRow = telefono ? `<tr><td style="padding:6px 0;font-weight:600;color:#64748b;">Teléfono</td><td style="padding:6px 0;">${telefono}</td></tr>` : "";
        fetch("/send-email", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            to: adminDest,
            subject: `🎫 Nuevo ticket ${folio} — ${empresa}`,
            html: `<div style="font-family:sans-serif;max-width:600px;margin:0 auto;color:#1e293b;">
              <div style="background:#6366f1;padding:16px 20px;border-radius:8px 8px 0 0;">
                <h2 style="color:#fff;margin:0;font-size:1rem;">🎫 Nuevo ticket desde el portal público</h2>
              </div>
              <div style="background:#f8fafc;border:1px solid #e2e8f0;border-top:none;padding:20px;border-radius:0 0 8px 8px;">
                <table style="width:100%;border-collapse:collapse;">
                  <tr><td style="padding:6px 0;font-weight:600;color:#64748b;width:120px;">Folio</td><td style="padding:6px 0;font-weight:800;color:#6366f1;">${folio}</td></tr>
                  <tr><td style="padding:6px 0;font-weight:600;color:#64748b;">Empresa</td><td style="padding:6px 0;">${empresa}</td></tr>
                  <tr><td style="padding:6px 0;font-weight:600;color:#64748b;">Contacto</td><td style="padding:6px 0;">${nombre}</td></tr>
                  <tr><td style="padding:6px 0;font-weight:600;color:#64748b;">Correo</td><td style="padding:6px 0;">${correo}</td></tr>
                  ${telefonoRow}${sistemaRow}
                  <tr><td style="padding:6px 0;font-weight:600;color:#64748b;">Prioridad</td><td style="padding:6px 0;">${prioridad}</td></tr>
                  <tr><td style="padding:6px 0;font-weight:600;color:#64748b;">Asunto</td><td style="padding:6px 0;">${asunto}</td></tr>
                </table>
                <div style="margin-top:14px;padding:12px;background:#fff;border:1px solid #e2e8f0;border-radius:6px;">
                  <div style="font-size:0.75rem;font-weight:700;color:#64748b;margin-bottom:6px;">DESCRIPCIÓN</div>
                  <div style="white-space:pre-wrap;color:#1e293b;font-size:0.9rem;">${descripcion}</div>
                </div>
              </div>
            </div>`
          })
        }).catch(() => {});

        // ── Confirmación al cliente ──────────────────────────────
        fetch("/send-email", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            to: correo,
            subject: `✅ Solicitud recibida — Folio ${folio}`,
            html: `<div style="font-family:sans-serif;max-width:600px;margin:0 auto;color:#1e293b;">
              <div style="background:#6366f1;padding:16px 20px;border-radius:8px 8px 0 0;">
