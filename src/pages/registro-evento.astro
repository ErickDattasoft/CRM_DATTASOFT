---
// Página pública de registro a eventos — DATTASOFT CRM
// URL: /registro-evento?id=ev_XXXXX
const firebaseApiKey = import.meta.env.PUBLIC_FIREBASE_API_KEY || "AIzaSyDT6EkBk0pMA9t_APJlLPku_EWco_OMM3Q";
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registro de Evento</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Outfit', sans-serif;
      background: #0a0c14;
      color: #e2e8f0;
      min-height: 100vh;
    }

    /* Hero superior */
    .hero {
      background: linear-gradient(135deg, #1a1e2e 0%, #0f1117 50%, #1a1228 100%);
      border-bottom: 1px solid rgba(99,102,241,0.2);
      padding: 48px 24px 56px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: "";
      position: absolute;
      top: -60px; left: 50%; transform: translateX(-50%);
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(99,102,241,0.12) 0%, transparent 70%);
      pointer-events: none;
    }
    .empresa-logo-wrap {
      margin-bottom: 20px;
      display: flex;
      justify-content: center;
    }
    .empresa-logo-wrap img {
      width: 80px; height: 80px;
      border-radius: 18px;
      object-fit: contain;
      box-shadow: 0 8px 32px rgba(99,102,241,0.3);
      border: 2px solid rgba(99,102,241,0.3);
    }
    .empresa-logo-fallback {
      width: 80px; height: 80px;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      border-radius: 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      margin-bottom: 0;
      box-shadow: 0 8px 32px rgba(99,102,241,0.3);
    }
    .empresa-nombre-txt {
      font-size: 0.85rem;
      font-weight: 600;
      color: #6366f1;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-top: 12px;
      margin-bottom: 28px;
    }
    .evento-titulo-hero {
      font-size: clamp(1.6rem, 5vw, 2.4rem);
      font-weight: 900;
      color: #f1f5f9;
      line-height: 1.2;
      margin-bottom: 12px;
    }
    .evento-meta-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: center;
      margin-top: 16px;
    }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 24px;
      padding: 6px 16px;
      font-size: 0.85rem;
      color: #cbd5e1;
      font-weight: 500;
    }
    .chip-icon { font-size: 1rem; }

    /* Descripción del evento */
    .evento-desc {
      max-width: 640px;
      margin: 0 auto;
      padding: 32px 24px 0;
      text-align: center;
    }
    .evento-desc p {
      font-size: 1rem;
      color: #94a3b8;
      line-height: 1.7;
    }

    /* Formulario */
    .form-wrapper {
      max-width: 560px;
      margin: 0 auto;
      padding: 32px 24px 60px;
    }
    .form-card {
      background: #141827;
      border: 1px solid rgba(99,102,241,0.2);
      border-radius: 20px;
      padding: 36px 32px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    }
    .form-card-title {
      font-size: 1.1rem;
      font-weight: 800;
      color: #f1f5f9;
      margin-bottom: 6px;
    }
    .form-card-subtitle {
      font-size: 0.82rem;
      color: #64748b;
      margin-bottom: 28px;
    }
    .form-group {
      margin-bottom: 18px;
    }
    label {
      display: block;
      font-size: 0.75rem;
      font-weight: 700;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 7px;
    }
    .required { color: #6366f1; }
    input, select, textarea {
      width: 100%;
      background: rgba(255,255,255,0.04);
      border: 1.5px solid rgba(255,255,255,0.09);
      border-radius: 10px;
      padding: 12px 14px;
      color: #e2e8f0;
      font-size: 0.95rem;
      font-family: inherit;
      transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
      outline: none;
    }
    input::placeholder, textarea::placeholder { color: #475569; }
    input:focus, select:focus, textarea:focus {
      border-color: #6366f1;
      background: rgba(99,102,241,0.06);
      box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
    }
    select option { background: #141827; }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }
    @media(max-width: 500px) { .form-row { grid-template-columns: 1fr; } .form-card { padding: 24px 20px; } }

    .btn-submit {
      width: 100%;
      padding: 16px;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      color: white;
      border: none;
      border-radius: 12px;
      font-size: 1.05rem;
      font-weight: 700;
      font-family: inherit;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.1s, box-shadow 0.2s;
      margin-top: 10px;
      box-shadow: 0 4px 20px rgba(99,102,241,0.4);
      letter-spacing: 0.01em;
    }
    .btn-submit:hover { opacity: 0.9; box-shadow: 0 6px 28px rgba(99,102,241,0.5); }
    .btn-submit:active { transform: scale(0.98); }
    .btn-submit:disabled { background: #1e2535; color: #475569; box-shadow: none; cursor: not-allowed; }

    /* Estados: éxito / error */
    .state-box {
      text-align: center;
      padding: 48px 24px;
    }
    .state-icon { font-size: 4rem; margin-bottom: 16px; display: block; }
    .state-title { font-size: 1.5rem; font-weight: 800; margin-bottom: 10px; }
    .state-subtitle { font-size: 0.9rem; color: #64748b; line-height: 1.6; }
    .state-success .state-title { color: #34d399; }
    .state-error .state-title { color: #f87171; }

    /* Loading inicial */
    #loading-screen {
      position: fixed; inset: 0;
      background: #0a0c14;
      display: flex; align-items: center; justify-content: center;
      z-index: 100; flex-direction: column; gap: 16px;
    }
    .spinner {
      width: 44px; height: 44px;
      border: 3px solid rgba(99,102,241,0.2);
      border-top-color: #6366f1;
      border-radius: 50%;
      animation: spin 0.75s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    #app { display: none; }
  </style>
</head>
<body>

  <div id="loading-screen">
    <div class="spinner"></div>
    <div style="color:#475569;font-size:0.85rem;font-weight:500;">Cargando evento...</div>
  </div>

  <div id="app">

    <!-- HERO -->
    <div class="hero" id="hero-section">
      <div class="empresa-logo-wrap">
        <img id="empresa-logo" alt="Logo" style="display:none;">
        <div class="empresa-logo-fallback" id="logo-fallback">🏢</div>
      </div>
      <div class="empresa-nombre-txt" id="empresa-nombre">DATTASOFT</div>
      <div class="evento-titulo-hero" id="evento-titulo">Cargando...</div>
      <div class="evento-meta-chips" id="evento-chips"></div>
    </div>

    <!-- DESCRIPCIÓN -->
    <div class="evento-desc" id="evento-desc-wrap" style="display:none;">
      <p id="evento-desc"></p>
    </div>

    <!-- FORMULARIO -->
    <div class="form-wrapper">
      <div class="form-card" id="form-card">
        <!-- Contenido inyectado por JS -->
      </div>
    </div>

  </div>

  <script type="module" is:inline define:vars={{ firebaseApiKey }}>
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
    import { getFirestore, doc, getDoc, collection, addDoc, query, where, getDocs, serverTimestamp }
      from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";
    import { getAuth, signInAnonymously } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";

    const firebaseConfig = {
      apiKey: firebaseApiKey,
      authDomain: "agenda-crm-netlify.firebaseapp.com",
      projectId: "agenda-crm-netlify",
    };

    const app = initializeApp(firebaseConfig);
    const db  = getFirestore(app);
    const auth = getAuth(app);
    const params  = new URLSearchParams(location.search);
    const eventoId = params.get("id");

    async function main() {
      try { await signInAnonymously(auth); } catch(e) { console.warn("Auth:", e); }

      const loadingScreen = document.getElementById("loading-screen");
      const appDiv = document.getElementById("app");
      const formCard = document.getElementById("form-card");

      // Cargar datos de empresa (logo, nombre, correo admin)
      let correoAdmin = "erick.casas@dattasoft.mx"; // fallback si aún no se guardó Configuración → Correo de soporte
      let nombreEmpresaCRM = "DATTASOFT";
      try {
        const snap = await getDoc(doc(db, "agenda", "datos"));
        if (snap.exists()) {
          const d = snap.data();
          if (d.logoEmpresa) {
            const img = document.getElementById("empresa-logo");
            img.src = d.logoEmpresa;
            img.style.display = "block";
            document.getElementById("logo-fallback").style.display = "none";
          }
          if (d.acercaDe?.nombre) {
            nombreEmpresaCRM = d.acercaDe.nombre;
            document.getElementById("empresa-nombre").textContent = nombreEmpresaCRM;
            document.title = `Registro — ${nombreEmpresaCRM}`;
          }
          correoAdmin = d.configTickets?.correoSoporte || "erick.casas@dattasoft.mx";
        }
      } catch(e) {}

      loadingScreen.style.display = "none";
      appDiv.style.display = "block";

      if (!eventoId) {
        showNotFound("Link inválido", "No se especificó el evento. Verifica el link que te compartieron.");
        return;
      }

      // Buscar evento
      let evento = null;
      try {
        const snap = await getDoc(doc(db, "agenda", "datos"));
        if (snap.exists()) {
          const evts = snap.data().eventos || [];
          evento = evts.find(e => e.id === eventoId);
        }
      } catch(e) { console.error(e); }

      if (!evento) {
        showNotFound("Evento no encontrado", "El evento que buscas ya no está disponible o el link es incorrecto.");
        return;
      }

      // Llenar hero
      document.getElementById("evento-titulo").textContent = evento.nombre || "Evento";

      const chips = [];
      if (evento.fecha) {
        const fd = new Date(evento.fecha + "T12:00:00").toLocaleDateString("es-MX", { weekday:"long", day:"numeric", month:"long", year:"numeric" });
        chips.push(`<span class="chip"><span class="chip-icon">📅</span>${fd}</span>`);
      }
      if (evento.hora) chips.push(`<span class="chip"><span class="chip-icon">🕐</span>${evento.hora}</span>`);
      if (evento.sistema) chips.push(`<span class="chip"><span class="chip-icon">💼</span>${evento.sistema}</span>`);
      document.getElementById("evento-chips").innerHTML = chips.join("");

      if (evento.notas) {
        document.getElementById("evento-desc").textContent = evento.notas;
        document.getElementById("evento-desc-wrap").style.display = "block";
      }

      // Formulario
      formCard.innerHTML = `
        <div class="form-card-title">📝 Completa tu registro</div>
        <div class="form-card-subtitle">Llena el formulario y te esperamos en el evento.</div>
        <form id="form-registro">
          <div class="form-row">
            <div class="form-group">
              <label>Nombre completo <span class="required">*</span></label>
              <input id="r-nombre" type="text" placeholder="Tu nombre y apellido" required autocomplete="name">
            </div>
            <div class="form-group">
              <label>Empresa / Organización</label>
              <input id="r-empresa" type="text" placeholder="Nombre de tu empresa" autocomplete="organization">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Correo electrónico <span class="required">*</span></label>
              <input id="r-correo" type="email" placeholder="tu@correo.com" required autocomplete="email">
            </div>
            <div class="form-group">
              <label>Teléfono</label>
              <input id="r-telefono" type="tel" placeholder="55 1234 5678" autocomplete="tel">
            </div>
          </div>
          <div class="form-group">
            <label>¿Cómo te enteraste del evento?</label>
            <select id="r-fuente">
              <option value="">— Selecciona una opción —</option>
              <option>📘 Facebook</option>
              <option>📸 Instagram</option>
              <option>💼 LinkedIn</option>
              <option>💬 WhatsApp</option>
              <option>👥 Recomendación de un amigo</option>
              <option>✉️ Correo electrónico</option>
              <option>🌐 Página web</option>
              <option>Otro</option>
            </select>
          </div>
          <button type="submit" class="btn-submit" id="btn-submit">✅ Confirmar mi Registro</button>
        </form>
      `;

      document.getElementById("form-registro").addEventListener("submit", async (e) => {
        e.preventDefault();
        const nombre = document.getElementById("r-nombre").value.trim();
        const correo = document.getElementById("r-correo").value.trim();
        if (!nombre || !correo) return;

        const btn = document.getElementById("btn-submit");
        btn.disabled = true;
        btn.textContent = "⏳ Registrando...";

        try {
          // Verificar si ya existe ese correo
          const q = query(
            collection(db, "inscripciones_evento"),
            where("eventoId", "==", eventoId),
            where("correo", "==", correo)
          );
          const existing = await getDocs(q);
          if (!existing.empty) {
            formCard.innerHTML = `
              <div class="state-box state-success">
                <span class="state-icon">ℹ️</span>
                <div class="state-title">Ya estás registrado</div>
                <div class="state-subtitle">Tu correo <strong>${correo}</strong> ya fue registrado para este evento. ¡Te esperamos!</div>
              </div>`;
            return;
          }

          // Guardar
          const empresaReg = document.getElementById("r-empresa").value.trim();
          const telefono   = document.getElementById("r-telefono").value.trim();
          const fuente     = document.getElementById("r-fuente").value.replace(/^[^\w]+/, "").trim();
          await addDoc(collection(db, "inscripciones_evento"), {
            eventoId,
            eventoNombre: evento.nombre || "",
            nombre,
            empresa: empresaReg,
            correo,
            telefono,
            fuente,
            fechaRegistro: serverTimestamp(),
          });

          // Fecha formateada para los correos
          const fechaLarga = evento.fecha
            ? new Date(evento.fecha + "T12:00:00").toLocaleDateString("es-MX", { weekday:"long", day:"numeric", month:"long", year:"numeric" })
            : "";
          const horaStr = evento.hora ? ` a las ${evento.hora}` : "";

          // ── Correo de confirmación al cliente ──────────────────────────
          const htmlCliente = `
<div style="font-family:'Segoe UI',sans-serif;max-width:580px;margin:0 auto;background:#0f1117;border-radius:16px;overflow:hidden;">
  <div style="background:linear-gradient(135deg,#6366f1,#8b5cf6);padding:32px 32px 24px;text-align:center;">
    <div style="font-size:2.5rem;margin-bottom:8px;">🎉</div>
    <h1 style="color:#fff;font-size:1.4rem;font-weight:800;margin:0;">¡Registro confirmado!</h1>
  </div>
  <div style="padding:28px 32px;background:#141827;color:#cbd5e1;">
    <p style="font-size:1rem;margin-bottom:20px;">Hola <strong style="color:#a5b4fc;">${nombre}</strong>, quedaste registrado para:</p>
    <div style="background:rgba(99,102,241,0.1);border:1px solid rgba(99,102,241,0.3);border-radius:12px;padding:20px 24px;margin-bottom:24px;">
      <div style="font-size:1.15rem;font-weight:800;color:#e2e8f0;margin-bottom:10px;">${evento.nombre || ""}</div>
      ${fechaLarga ? `<div style="color:#94a3b8;font-size:0.9rem;">📅 ${fechaLarga}${horaStr}</div>` : ""}
      ${evento.sistema ? `<div style="color:#94a3b8;font-size:0.9rem;margin-top:6px;">💼 ${evento.sistema}</div>` : ""}
    </div>
    <p style="font-size:0.85rem;color:#64748b;line-height:1.6;">
      Pronto nos pondremos en contacto contigo con más detalles.<br>
      Si tienes alguna duda, responde a este correo.
    </p>
  </div>
  <div style="padding:16px 32px;background:#0f1117;text-align:center;">
    <p style="font-size:0.75rem;color:#334155;margin:0;">${nombreEmpresaCRM}</p>
  </div>
</div>`;

          // ── Notificación al admin ──────────────────────────────────────
          const htmlAdmin = `
<div style="font-family:'Segoe UI',sans-serif;max-width:560px;margin:0 auto;">
  <h2 style="color:#1e293b;border-bottom:2px solid #6366f1;padding-bottom:8px;">🔔 Nuevo registro en evento</h2>
  <p style="color:#475569;margin-bottom:16px;"><strong>${evento.nombre || eventoId}</strong>${fechaLarga ? " — " + fechaLarga : ""}</p>
  <table style="width:100%;border-collapse:collapse;font-size:0.9rem;">
    <tr style="background:#f8fafc;"><td style="padding:10px 14px;font-weight:600;border-bottom:1px solid #e2e8f0;color:#334155;width:36%;">Nombre</td><td style="padding:10px 14px;border-bottom:1px solid #e2e8f0;">${nombre}</td></tr>
    ${empresaReg ? `<tr><td style="padding:10px 14px;font-weight:600;border-bottom:1px solid #e2e8f0;color:#334155;">Empresa</td><td style="padding:10px 14px;border-bottom:1px solid #e2e8f0;">${empresaReg}</td></tr>` : ""}
    <tr style="background:#f8fafc;"><td style="padding:10px 14px;font-weight:600;border-bottom:1px solid #e2e8f0;color:#334155;">Correo</td><td style="padding:10px 14px;border-bottom:1px solid #e2e8f0;"><a href="mailto:${correo}" style="color:#6366f1;">${correo}</a></td></tr>
    ${telefono ? `<tr><td style="padding:10px 14px;font-weight:600;border-bottom:1px solid #e2e8f0;color:#334155;">Teléfono</td><td style="padding:10px 14px;border-bottom:1px solid #e2e8f0;">${telefono}</td></tr>` : ""}
    ${fuente ? `<tr style="background:#f8fafc;"><td style="padding:10px 14px;font-weight:600;color:#334155;">Fuente</td><td style="padding:10px 14px;">${fuente}</td></tr>` : ""}
  </table>
  <p style="margin-top:20px;font-size:0.78rem;color:#94a3b8;">Puedes ver todos los inscritos en CRM → Eventos → 👥 Inscritos.</p>
</div>`;

          // Enviar ambos correos en paralelo (fallos silenciosos — no bloquean el registro)
          await Promise.allSettled([
            correoAdmin
              ? fetch("/send-email", { method:"POST", headers:{"Content-Type":"application/json"},
                  body: JSON.stringify({ to: correoAdmin, subject: `🔔 Nuevo registro: ${nombre} — ${evento.nombre || eventoId}`, html: htmlAdmin }) })
              : Promise.resolve(),
            fetch("/send-email", { method:"POST", headers:{"Content-Type":"application/json"},
              body: JSON.stringify({ to: correo, subject: `✅ Confirmación de registro — ${evento.nombre || "Evento"}`, html: htmlCliente }) }),
          ]);

          // Éxito
          formCard.innerHTML = `
            <div class="state-box state-success">
              <span class="state-icon">🎉</span>
              <div class="state-title">¡Registro exitoso!</div>
              <div class="state-subtitle">
                ¡Hola <strong>${nombre}</strong>! Quedaste registrado para<br>
                <strong>${evento.nombre}</strong>.<br><br>
                Te esperamos el ${evento.fecha ? new Date(evento.fecha + "T12:00:00").toLocaleDateString("es-MX",{weekday:"long",day:"numeric",month:"long"}) : ""}${evento.hora ? " a las " + evento.hora : ""}. 😊
              </div>
            </div>`;
        } catch(err) {
          btn.disabled = false;
          btn.textContent = "✅ Confirmar mi Registro";
          const errDiv = document.createElement("div");
          errDiv.style.cssText = "margin-top:12px;padding:12px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:10px;color:#f87171;font-size:0.85rem;text-align:center;";
          errDiv.textContent = "❌ Ocurrió un error. Por favor intenta de nuevo.";
          document.getElementById("form-registro").appendChild(errDiv);
          setTimeout(() => errDiv.remove(), 4000);
        }
      });
    }

    function showNotFound(titulo, msg) {
      document.getElementById("hero-section").style.display = "none";
      document.getElementById("form-card").innerHTML = `
        <div class="state-box state-error">
          <span class="state-icon">🔍</span>
          <div class="state-title">${titulo}</div>
          <div class="state-subtitle">${msg}</div>
        </div>`;
    }

    main();
  </script>
</body>
</html>
