---
// Página pública de registro a eventos — DATTASOFT CRM
// URL: /registro-evento?id=ev_XXXXX
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registro de Evento</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Outfit', sans-serif; background: #0f1117; color: #e2e8f0; min-height: 100vh; display: flex; align-items: flex-start; justify-content: center; padding: 24px 16px 60px; }
    .container { width: 100%; max-width: 520px; margin: 0 auto; }
    .logo-wrap { text-align: center; margin-bottom: 24px; }
    .logo-wrap img { width: 72px; height: 72px; border-radius: 14px; object-fit: contain; }
    .empresa-nombre { font-size: 1rem; font-weight: 600; color: #94a3b8; margin-top: 8px; }
    .card { background: #1a1e2e; border: 1px solid rgba(99,102,241,0.25); border-radius: 16px; padding: 28px 28px; box-shadow: 0 8px 40px rgba(0,0,0,0.4); }
    .evento-titulo { font-size: 1.4rem; font-weight: 800; color: #f1f5f9; margin-bottom: 6px; line-height: 1.3; }
    .evento-meta { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 20px; font-size: 0.83rem; color: #94a3b8; }
    .meta-item { display: flex; align-items: center; gap: 5px; background: rgba(255,255,255,0.04); padding: 4px 10px; border-radius: 20px; }
    .divider { border: none; border-top: 1px solid rgba(255,255,255,0.07); margin: 20px 0; }
    .form-title { font-size: 0.82rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #6366f1; margin-bottom: 16px; }
    .form-group { margin-bottom: 14px; }
    label { display: block; font-size: 0.78rem; font-weight: 600; color: #94a3b8; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.04em; }
    input, select, textarea { width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.12); border-radius: 8px; padding: 10px 12px; color: #e2e8f0; font-size: 0.9rem; font-family: inherit; transition: border-color 0.2s; outline: none; }
    input:focus, select:focus, textarea:focus { border-color: #6366f1; background: rgba(99,102,241,0.08); }
    select option { background: #1a1e2e; }
    .required { color: #f87171; }
    .btn-submit { width: 100%; padding: 14px; background: #6366f1; color: white; border: none; border-radius: 10px; font-size: 1rem; font-weight: 700; font-family: inherit; cursor: pointer; transition: background 0.2s, transform 0.1s; margin-top: 8px; }
    .btn-submit:hover { background: #4f46e5; }
    .btn-submit:active { transform: scale(0.98); }
    .btn-submit:disabled { background: #374151; cursor: not-allowed; }
    .msg { text-align: center; padding: 20px; border-radius: 10px; margin-top: 16px; }
    .msg-success { background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.3); color: #34d399; }
    .msg-error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #f87171; }
    .msg-icon { font-size: 2.5rem; margin-bottom: 10px; }
    .msg h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 6px; }
    .msg p { font-size: 0.85rem; opacity: 0.85; }
    .loading-overlay { position: fixed; inset: 0; background: rgba(15,17,23,0.8); display: flex; align-items: center; justify-content: center; z-index: 999; }
    .spinner { width: 40px; height: 40px; border: 3px solid rgba(99,102,241,0.2); border-top-color: #6366f1; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    #loading-screen { position: fixed; inset: 0; background: #0f1117; display: flex; align-items: center; justify-content: center; z-index: 100; flex-direction: column; gap: 16px; }
    .not-found { text-align: center; padding: 40px 0; }
    .not-found-icon { font-size: 3rem; margin-bottom: 12px; }
    .not-found h2 { font-size: 1.2rem; color: #f87171; margin-bottom: 8px; }
    .not-found p { color: #64748b; font-size: 0.85rem; }
  </style>
</head>
<body>
  <div id="loading-screen">
    <div class="spinner"></div>
    <div style="color:#64748b;font-size:0.85rem;">Cargando evento...</div>
  </div>

  <div class="container" id="app" style="display:none;">
    <div class="logo-wrap">
      <img id="empresa-logo" alt="Logo" style="display:none;">
      <div style="font-size:2rem;" id="logo-fallback">🏢</div>
      <div class="empresa-nombre" id="empresa-nombre">DATTASOFT</div>
    </div>

    <div class="card" id="card-main">
      <!-- Contenido cargado por JS -->
    </div>
  </div>

  <script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
    import { getFirestore, doc, getDoc, collection, addDoc, query, where, getDocs, serverTimestamp }
      from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";
    import { getAuth, signInAnonymously } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";

    const firebaseConfig = {
      apiKey: "AIzaSyDT6EkBk0pMA9t_APJlLPku_EWco_OMM3Q",
      authDomain: "agenda-crm-netlify.firebaseapp.com",
      projectId: "agenda-crm-netlify",
    };

    const app = initializeApp(firebaseConfig);
    const db = getFirestore(app);
    const auth = getAuth(app);

    const params = new URLSearchParams(location.search);
    const eventoId = params.get("id");

    async function main() {
      try {
        await signInAnonymously(auth);
      } catch (e) {
        console.error("Auth error:", e);
      }

      const loadingScreen = document.getElementById("loading-screen");
      const appDiv = document.getElementById("app");
      const card = document.getElementById("card-main");

      // Cargar logo y nombre de empresa
      try {
        const datosSnap = await getDoc(doc(db, "agenda", "datos"));
        if (datosSnap.exists()) {
          const d = datosSnap.data();
          if (d.logoEmpresa) {
            const img = document.getElementById("empresa-logo");
            img.src = d.logoEmpresa;
            img.style.display = "block";
            document.getElementById("logo-fallback").style.display = "none";
          }
          if (d.acercaDe?.nombre) {
            document.getElementById("empresa-nombre").textContent = d.acercaDe.nombre;
            document.title = `Registro — ${d.acercaDe.nombre}`;
          }
        }
      } catch(e) { console.warn("No se pudo cargar datos de empresa"); }

      loadingScreen.style.display = "none";
      appDiv.style.display = "block";

      if (!eventoId) {
        card.innerHTML = `<div class="not-found"><div class="not-found-icon">🔍</div><h2>Link inválido</h2><p>No se especificó el evento. Verifica el link que te compartieron.</p></div>`;
        return;
      }

      // Buscar el evento en la colección datos
      let evento = null;
      try {
        const datosSnap = await getDoc(doc(db, "agenda", "datos"));
        if (datosSnap.exists()) {
          const d = datosSnap.data();
          const evts = d.eventos || [];
          evento = evts.find(e => e.id === eventoId);
        }
      } catch(e) { console.error("Error buscando evento:", e); }

      if (!evento) {
        card.innerHTML = `<div class="not-found"><div class="not-found-icon">📅</div><h2>Evento no encontrado</h2><p>El evento que buscas ya no está disponible o el link es incorrecto.</p></div>`;
        return;
      }

      const fechaDisplay = evento.fecha ? new Date(evento.fecha + "T12:00:00").toLocaleDateString("es-MX", { weekday:"long", day:"numeric", month:"long", year:"numeric" }) : "";
      const horaDisplay = evento.hora || "";

      card.innerHTML = `
        <div class="evento-titulo">${evento.nombre || "Evento"}</div>
        <div class="evento-meta">
          ${fechaDisplay ? `<span class="meta-item">📅 ${fechaDisplay}</span>` : ""}
          ${horaDisplay ? `<span class="meta-item">🕐 ${horaDisplay}</span>` : ""}
          ${evento.sistema ? `<span class="meta-item">💼 ${evento.sistema}</span>` : ""}
        </div>
        ${evento.notas ? `<div style="font-size:0.85rem;color:#94a3b8;line-height:1.6;margin-bottom:16px;">${evento.notas}</div>` : ""}
        <hr class="divider">
        <div class="form-title">📝 Formulario de Registro</div>
        <form id="form-registro">
          <div class="form-group">
            <label>Nombre completo <span class="required">*</span></label>
            <input id="r-nombre" type="text" placeholder="Tu nombre y apellido" required>
          </div>
          <div class="form-group">
            <label>Empresa / Organización</label>
            <input id="r-empresa" type="text" placeholder="Nombre de tu empresa">
          </div>
          <div class="form-group">
            <label>Correo electrónico <span class="required">*</span></label>
            <input id="r-correo" type="email" placeholder="tu@correo.com" required>
          </div>
          <div class="form-group">
            <label>Teléfono</label>
            <input id="r-telefono" type="tel" placeholder="55 1234 5678">
          </div>
          <div class="form-group">
            <label>¿Cómo te enteraste del evento?</label>
            <select id="r-fuente">
              <option value="">— Selecciona —</option>
              <option>Facebook</option>
              <option>Instagram</option>
              <option>LinkedIn</option>
              <option>WhatsApp</option>
              <option>Recomendación</option>
              <option>Correo electrónico</option>
              <option>Otro</option>
            </select>
          </div>
          <button type="submit" class="btn-submit" id="btn-submit">✅ Confirmar mi Registro</button>
        </form>
        <div id="form-msg" style="display:none;"></div>
      `;

      document.getElementById("form-registro").addEventListener("submit", async (e) => {
        e.preventDefault();
        const nombre = document.getElementById("r-nombre").value.trim();
        const correo = document.getElementById("r-correo").value.trim();
        if (!nombre || !correo) return;

        const btn = document.getElementById("btn-submit");
        btn.disabled = true;
        btn.textContent = "⏳ Enviando...";

        try {
          // Verificar si ya se registró con ese correo
          const q = query(collection(db, "inscripciones_evento"), where("eventoId", "==", eventoId), where("correo", "==", correo));
          const existing = await getDocs(q);
          if (!existing.empty) {
            document.getElementById("form-registro").style.display = "none";
            document.getElementById("form-msg").style.display = "block";
            document.getElementById("form-msg").innerHTML = `<div class="msg msg-success"><div class="msg-icon">ℹ️</div><h3>Ya estás registrado</h3><p>Tu correo <strong>${correo}</strong> ya fue registrado para este evento.</p></div>`;
            return;
          }

          await addDoc(collection(db, "inscripciones_evento"), {
            eventoId,
            eventoNombre: evento.nombre || "",
            nombre,
            empresa: document.getElementById("r-empresa").value.trim(),
            correo,
            telefono: document.getElementById("r-telefono").value.trim(),
            fuente: document.getElementById("r-fuente").value,
            fechaRegistro: serverTimestamp(),
          });

          document.getElementById("form-registro").style.display = "none";
          document.getElementById("form-msg").style.display = "block";
          document.getElementById("form-msg").innerHTML = `<div class="msg msg-success"><div class="msg-icon">🎉</div><h3>¡Registro exitoso!</h3><p>Hola <strong>${nombre}</strong>, quedaste registrado para <strong>${evento.nombre}</strong>. ¡Te esperamos!</p></div>`;
        } catch(err) {
          btn.disabled = false;
          btn.textContent = "✅ Confirmar mi Registro";
          document.getElementById("form-msg").style.display = "block";
          document.getElementById("form-msg").innerHTML = `<div class="msg msg-error"><div class="msg-icon">❌</div><h3>Error al registrarse</h3><p>Ocurrió un problema. Por favor intenta de nuevo o contacta a la empresa.</p></div>`;
        }
      });
    }

    main();
  </script>
</body>
</html>
